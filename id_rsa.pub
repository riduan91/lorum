python -c "from airflow.settings import Session; from airflow.models import TaskInstance; from sqlalchemy import update; from datetime import datetime; dag_id='your_dag_id'; task_id='your_task_id'; execution_date=datetime(2025,8,12,0,0,0); s=Session(); s.execute(update(TaskInstance).where(TaskInstance.dag_id==dag_id, TaskInstance.task_id==task_id, TaskInstance.execution_date==execution_date).values(try_number=1)); s.commit(); s.close(); print('✅ try_number reset to 1')"
