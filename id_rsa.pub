# ----------  ports_exposure_parallel_vec.py  ----------
import numpy as np
import pandas as pd
from concurrent.futures import ProcessPoolExecutor, as_completed

from sqlalchemy import func
from dags.common.dmir_connections import get_session
from dags.common.models import DMIRBRSInstAnalytic
from dags.common.utils import chunker, get_all_as_df, get_hardware_info, normalize_type


# ------------------------------------------------------------------
# 1.  PARALLEL FETCH of analytics (no pd.read_sql)
# ------------------------------------------------------------------
_ANALYTIC_COLS = [
    DMIRBRSInstAnalytic.strInstAladdin,
    DMIRBRSInstAnalytic.datInstQuotationDate,
    DMIRBRSInstAnalytic.numInstYieldToMaturity,
    DMIRBRSInstAnalytic.numInstConvexity,
    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
    DMIRBRSInstAnalytic.numInstSpreadDuration,
]

def _fetch_analytic_chunk(idx: int, inst_ids: list[str], dates: list[pd.Timestamp]):
    """
    Worker: fetch analytics for this instrument chunk and *all*
    required quotation dates in one go.
    """
    print(f"[ANA] chunk {idx:>3} – instruments={len(inst_ids)}")
    session = get_session()
    try:
        q = (
            session.query(*_ANALYTIC_COLS)
            .filter(
                DMIRBRSInstAnalytic.strInstAladdin.in_(inst_ids),
                DMIRBRSInstAnalytic.datInstQuotationDate.in_(dates),
            )
        )
        df_part = get_all_as_df(q)
        return df_part
    finally:
        session.close()


def fetch_analytics_parallel(df_instr: pd.DataFrame, max_workers: int = 24) -> pd.DataFrame:
    """
    Parallel version of the analytics pull: splits unique instruments
    into 1 000‑sized chunks, fires them in a pool, concatenates.
    """
    if df_instr.empty:
        return pd.DataFrame(columns=[c.key for c in _ANALYTIC_COLS])

    inst_ids = df_instr["strInstAladdin"].dropna().unique().tolist()
    dates    = df_instr["datPeriodLastDay"].dropna().unique().tolist()

    dfs = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futs = {
            exe.submit(_fetch_analytic_chunk, idx, chunk, dates): idx
            for idx, chunk in enumerate(chunker(inst_ids, 1_000))
        }
        for fut in as_completed(futs):
            dfs.append(fut.result())
            get_hardware_info()

    if dfs:
        return pd.concat(dfs, ignore_index=True)
    return pd.DataFrame(columns=[c.key for c in _ANALYTIC_COLS])


# ------------------------------------------------------------------
# 2.  VECTORISED AGGREGATION  (no ProcessPoolExecutor)
# ------------------------------------------------------------------
def aggregate_exposure_duration(
    df_instr: pd.DataFrame,
    df_tmp: pd.DataFrame,
    *,
    analytic_workers: int = 24,
) -> pd.DataFrame:
    """
    * Fetches instrument analytics in parallel (see above).
    * Performs portfolio aggregation with pure Pandas/NumPy.
    * Overwrites the RG02/RG03/RG.. fields inside **df_tmp**.
    """
    if df_instr.empty:
        return df_tmp.copy()

    # 2‑A  merge analytics ---------------------------------------------------------
    df_ana = fetch_analytics_parallel(df_instr, max_workers=analytic_workers)

    joined = df_instr.merge(
        df_ana,
        left_on=["strInstAladdin", "datPeriodLastDay"],
        right_on=["strInstAladdin", "datInstQuotationDate"],
        how="left",
        suffixes=("", "_ana"),
    )

    # 2‑B  vector helpers ----------------------------------------------------------
    dur_w   = joined["numDurExposureWeight"].astype(float).fillna(0.0)
    mod_w   = joined["numModifDurationContribWeight"].astype(float).fillna(0.0)
    ytm     = joined["numInstYieldToMaturity"].astype(float).fillna(0.0)
    cnvx    = joined["numInstConvexity"].astype(float).fillna(0.0)
    oas     = joined["numInstOptionAdjSpread"].astype(float).fillna(0.0)
    spr_dur = joined["numInstSpreadDuration"].astype(float).fillna(0.0)

    joined["w_YTM"]       = ytm  * dur_w
    joined["w_Convexity"] = cnvx * dur_w
    joined["w_YTM_Dur"]   = ytm  * mod_w
    joined["w_OAS"]       = oas  * dur_w
    joined["w_DTS"]       = oas  * spr_dur * dur_w

    # 2‑C  group‑by aggregation ----------------------------------------------------
    gcols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    agg = (
        joined.groupby(gcols, sort=False, observed=True)
        .agg(
            numCurExposurePortf       = ("numCurExposureInPortfCur", "sum"),
            numDurExposurePortf       = ("numDurExposureInPortfCur", "sum"),
            numEffectDurationPortf    = ("numEffectDurationContrib", "sum"),
            numModifDurationPortf     = ("numModifDurationContrib", "sum"),
            numMCDurationPortf        = ("numMCDurationContrib", "sum"),
            numSpreadDurationPortf    = ("numSpreadDurationContrib", "sum"),
            numPtfAvgYTM              = ("w_YTM", "sum"),
            numPtfAvgConvexity        = ("w_Convexity", "sum"),
            numPtfAvgYTMDurWeighted   = ("w_YTM_Dur", "sum"),
            numPtfAvgOas              = ("w_OAS", "sum"),
            numPtfAvgDts              = ("w_DTS", "sum"),
        )
        .reset_index()
    )

    # 2‑D  merge back into staging --------------------------------------------------
    df = df_tmp.merge(
        agg,
        on=gcols,
        how="left",
        suffixes=("", "_new"),
    )

    repl_cols = [
        "numCurExposurePortf",
        "numDurExposurePortf",
        "numEffectDurationPortf",
        "numModifDurationPortf",
        "numMCDurationPortf",
        "numSpreadDurationPortf",
        "numPtfAvgYTM",
        "numPtfAvgConvexity",
        "numPtfAvgYTMDurWeighted",
        "numPtfAvgOas",
        "numPtfAvgDts",
    ]
    for c in repl_cols:
        if f"{c}_new" in df.columns:
            df[c] = df.pop(f"{c}_new")

    return df


__all__ = ["aggregate_exposure_duration"]
# --------------------------------------------------------  eof  -------
