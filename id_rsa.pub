import numpy as np
import pandas as pd


def compute_instr_indicators_bkgn_3(chunk_idx: int, df_chunk: pd.DataFrame) -> pd.DataFrame:
    """
    Reproduce the SQL aggregation that fills #tblDMIRBKGN3.

    Parameters
    ----------
    chunk_idx : int
        Index of the chunk being processed (only used for logging).
    df_chunk : pd.DataFrame
        One slice of #tblDMIRBKGN2.

    Returns
    -------
    pd.DataFrame
        Aggregated indicators – the Python equivalent of the SQL SELECT-INTO block.
    """
    print(f"Processing chunk {chunk_idx}")

    # ------------------------------------------------------------------
    # 1. Make sure all numeric columns are numeric (coerce bad values → NaN)
    # ------------------------------------------------------------------
    num_cols = [
        "numinsqty",
        "numInstUndrlygQty",
        "numinslclcurpri",
        "numccyqRate",
        "numPFCurrencyRate",
        "numeurmktcap",
    ]
    df_chunk[num_cols] = df_chunk[num_cols].apply(pd.to_numeric, errors="coerce")

    # ------------------------------------------------------------------
    # 2. Build the row-level expressions used later in the aggregates
    # ------------------------------------------------------------------
    base_futures = (
        df_chunk["numinsqty"]
        * df_chunk["numInstUndrlygQty"]
        * df_chunk["numinslclcurpri"]
        / df_chunk["numccyqRate"]
        * df_chunk["numPFCurrencyRate"]
    )
    # If pricing type == 'PERCENTAGE' divide by 100 **before** aggregating
    is_percentage = df_chunk["strInstPriceType"].str.upper() == "PERCENTAGE"
    df_chunk["expr_futures"] = np.where(is_percentage, base_futures / 100.0, base_futures)

    df_chunk["expr_others"] = df_chunk["numeurmktcap"] * df_chunk["numPFCurrencyRate"]

    df_chunk["expr_options"] = (
        df_chunk["numinsqty"]
        * df_chunk["numInstUndrlygQty"]
        * df_chunk["numeurmktcap"]
        * df_chunk["numPFCurrencyRate"]
    )

    df_chunk["expr_forex"] = (
        df_chunk["numinsqty"] / df_chunk["numccyqRate"] * df_chunk["numPFCurrencyRate"]
    )

    # ------------------------------------------------------------------
    # 3. Aggregate – same GROUP BY list as in SQL (includes the two aux cols)
    # ------------------------------------------------------------------
    group_cols = [
        "numBenchFBAId",
        "strCompositionCd",
        "strPFCurrencyISOCode",
        "datReportingDay",
        "strInstAladdin",
        "numInstId",
        "strPeriodTypeFlag",
        "strInstPriceType",
        "strInstrumentTypeIRName",
    ]

    agg_map = {
        "expr_futures":  "sum",   # CASE → sum() on pre-adjusted rows
        "expr_others":   "sum",
        "expr_options":  "sum",   # <-- matches SQL (was max() before)
        "expr_forex":    "max",
    }

    res = df_chunk.groupby(group_cols, dropna=False).agg(agg_map).reset_index()

    # ------------------------------------------------------------------
    # 4. Rename to final column names
    # ------------------------------------------------------------------
    res.rename(
        columns={
            "expr_futures":  "numExposureBenchFutures",
            "expr_others":   "numExposureBenchOthers",
            "expr_options":  "numCurExposureInBenchCurOptions",
            "expr_forex":    "numExposureBenchForex",
        },
        inplace=True,
    )

    # ------------------------------------------------------------------
    # 5. Conditional columns that depend on strInstrumentTypeIRName
    # ------------------------------------------------------------------
    inst_type = res["strInstrumentTypeIRName"].fillna(" ").str.upper()

    res["numCurExposureInBenchCur"] = np.where(
        inst_type == "FOREX",
        res["numExposureBenchForex"],
        res["numExposureBenchOthers"],
    )

    res["numDurExposureInBenchCur"] = np.where(
        inst_type == "FOREX",
        0.0,
        res["numExposureBenchOthers"],
    )

    res["numMarketValue"] = res["numExposureBenchOthers"]

    # ------------------------------------------------------------------
    # 6. Drop the two extra GROUP BY columns (SQL didn't write them out)
    # ------------------------------------------------------------------
    res.drop(columns=["strInstPriceType", "strInstrumentTypeIRName"], inplace=True)

    return res
