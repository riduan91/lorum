from datetime import date, timedelta
import pandas as pd
from sqlalchemy import func, and_

# ------------------------------------------------------------------
# helpers ----------------------------------------------------------
# ------------------------------------------------------------------
def _eom_prev_month(d: date) -> date:
    """Last calendar day of the previous month."""
    first = d.replace(day=1)
    return first - timedelta(days=1)


def _yyyymm(d: date) -> str:
    return d.strftime("%Y%m")


# ------------------------------------------------------------------
# main -------------------------------------------------------------
# ------------------------------------------------------------------
def _build_df_to_remove_alp(current_date: date | None = None) -> pd.DataFrame:
    """
    Return the list of ALP Scope‑LT rows (numReportPortfGroupID, period)
    that should be deleted, reproducing the full logic of the `#to_remove2`
    temp‑table block in the SQL procedure.

    Parameters
    ----------
    current_date : date, optional
        The `@varCurrentDate` value from the SQL.  Defaults to today.

    Returns
    -------
    pd.DataFrame  with columns  [num_transp, num_scope, grp, period]
    """
    current_date = current_date or date.today()
    eom_prev = _eom_prev_month(current_date)
    prev_period = _yyyymm(eom_prev)

    session = get_session()
    try:
        # ----------------------------------------------------------
        # 1) total Scope AUM per (period, group) -------------------
        # ----------------------------------------------------------
        scope_sum = (
            session.query(
                DMIRScopeLT.strReportPeriod.label("period"),
                DMIRScopeLT.numReportPortfGroupID.label("grp"),
                func.sum(DMIRScopeLT.numPortfAUM).label("num_scope"),
            )
            .filter(DMIRScopeLT.strReportPortfHoldSrc == "ALP")
            .group_by(DMIRScopeLT.strReportPeriod, DMIRScopeLT.numReportPortfGroupID)
            .subquery()
        )

        # ----------------------------------------------------------
        # 2) transparized AUM for same (period, group) -------------
        # ----------------------------------------------------------
        agg_q = (
            session.query(
                func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
                scope_sum.c.num_scope,
                scope_sum.c.grp,
                scope_sum.c.period,
            )
            .join(
                scope_sum,
                and_(
                    DMIRTransparizLT.strReportPeriod == scope_sum.c.period,
                    DMIRTransparizLT.numReportPortfGroupID == scope_sum.c.grp,
                ),
            )
            .filter(
                DMIRTransparizLT.numLowestInventoryflag == 1,
                DMIRTransparizLT.numInstID > 1,
            )
            .group_by(scope_sum.c.num_scope, scope_sum.c.grp, scope_sum.c.period)
        )

        df = pd.DataFrame(session.execute(agg_q).mappings().all())
        normalize_type(df)

        if df.empty:
            return pd.DataFrame(columns=["num_transp", "num_scope", "grp", "period"])

        # AUM‑difference tolerance
        df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

        # ----------------------------------------------------------
        # 3) EXTERNAL / SPECIAL underlying‑holdings safeguard ------
        # ----------------------------------------------------------
        ext_pairs_q = (
            session.query(
                DMIRMonitoringLT.numReportPortfGroupID.label("grp"),
                DMIRMonitoringLT.strReportPeriod.label("period"),
            )
            .filter(
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_(["EXTERNAL", "SPECIAL"]),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .join(
                DMIRExternalSpecialHolding,
                and_(
                    DMIRExternalSpecialHolding.strPortfISINCode
                    == DMIRMonitoringLT.strInstISINCode,
                    DMIRExternalSpecialHolding.datHoldDate
                    >= func.coalesce(DMIRMonitoringLT.datLastNAVDate, date(2000, 1, 1)),
                    DMIRExternalSpecialHolding.datHoldDate <= DMIRMonitoringLT.datHoldDate,
                    DMIRExternalSpecialHolding.numAuditId > DMIRMonitoringLT.numAuditId,
                ),
            )
            .distinct()
        )
        ext_pairs = set(get_all_as_df(ext_pairs_q).apply(tuple, axis=1))
        df = df[~df.apply(lambda r: (r.grp, r.period) in ext_pairs, axis=1)]

        # ----------------------------------------------------------
        # 4) groups with fresher DMC holdings  → do‑not‑delete -----
        #    (SQL CTE portfGroupDoNotDelete) -----------------------
        # ----------------------------------------------------------
        # 4a)  holdings‑audit id per GPS code (same logic as DMC part)
        audit_subq = (
            session.query(
                DMIRDMCHolding.strPortfGPSCode.label("gps"),
                func.max(DMIRDMCHolding.numAuditId).label("holdings_audit_id"),
            )
            .join(
                DMIRBRSDMCPortfIndicators,
                and_(
                    DMIRBRSDMCPortfIndicators.strPortfGPSCode
                    == DMIRDMCHolding.strPortfGPSCode,
                    DMIRBRSDMCPortfIndicators.datPeriodLastNav
                    == DMIRDMCHolding.datACCDATE,
                ),
            )
            .filter(DMIRBRSDMCPortfIndicators.datPeriodLastDay == eom_prev)
            .group_by(DMIRDMCHolding.strPortfGPSCode)
            .subquery()
        )

        # 4b)  exempt group IDs
        gps_exempt = get_all_as_df(
            session.query(DMIRMonitoringLT.numReportPortfGroupID)
            .join(
                audit_subq,
                audit_subq.c.gps == DMIRMonitoringLT.strInvestedInPortfID,
            )
            .filter(
                DMIRMonitoringLT.datPeriodLastDay == eom_prev,
                DMIRMonitoringLT.strSrcUndrlygHoldData == "INTERNAL",
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.numPortfLevel >= 1,
                audit_subq.c.holdings_audit_id > DMIRMonitoringLT.numAuditId,
            )
            .distinct()
        )["numReportPortfGroupID"].tolist()

        df = df[
            ~((df.period == prev_period) & (df.grp.isin(gps_exempt)))
        ]

        # ----------------------------------------------------------
        # 5) groups with newer MACC‑NAV audit‑id -------------------
        # ----------------------------------------------------------
        nav_pairs_q = (
            session.query(DMIRMaccNav.numPortfGroupFKey.label("grp"))
            .outerjoin(
                DMIRBRSLTPortfIndicators,
                and_(
                    DMIRBRSLTPortfIndicators.datPeriodLastDay == DMIRMaccNav.datNavDate,
                    DMIRBRSLTPortfIndicators.numPortfGroupFkey
                    == DMIRMaccNav.numPortfGroupFKey,
                ),
            )
            .filter(
                DMIRMaccNav.datNavDate == eom_prev,
                DMIRMaccNav.numAuditId
                > func.coalesce(DMIRBRSLTPortfIndicators.numAuditId, 0),
                DMIRMaccNav.numTotalAUM != 0,
                DMIRMaccNav.strPerformanceStatus.in_(["Validated Data", "Preliminary Data"]),
            )
            .distinct()
        )
        nav_exclude = {t[0] for t in session.execute(nav_pairs_q).all()}
        df = df[~df.grp.isin(nav_exclude)]

        # ----------------------------------------------------------
        # 6) done --------------------------------------------------
        # ----------------------------------------------------------
        return (
            df[["num_transp", "num_scope", "grp", "period"]]
            if not df.empty
            else pd.DataFrame(columns=["num_transp", "num_scope", "grp", "period"])
        )

    finally:
        session.close()
