# === Impacted functions only: instruments cache + vectorized data_monitoring_previous_step_internal_2 ===

import threading
import pandas as pd
import numpy as np
from sqlalchemy import and_, func, cast, String
from sqlalchemy.exc import SQLAlchemyError

# Global (module-level) cache
_INSTRUMENTS_DF = None           # pandas.DataFrame
_INSTRUMENTS_MAP = None          # dict: strInstAladdin -> {instrument fields}
_INSTRUMENTS_LOCK = threading.Lock()

def _ensure_instruments_cache(Session):
    """
    Build the instruments lookup once into a pandas DataFrame and a dict map.
    Pure ORM (no raw SQL); safe for repeated calls.
    Populates:
      _INSTRUMENTS_DF with columns:
        ['strInstAladdin','numInstID','strInvestedInPortfID','strInvestedInPortfName',
         'strInstrumentTypeIRName','strPortfGPSCode','strInstISINCode']
      _INSTRUMENTS_MAP for optional row-wise lookups (not used by the vectorized path).
    """
    global _INSTRUMENTS_DF, _INSTRUMENTS_MAP
    if _INSTRUMENTS_DF is not None and _INSTRUMENTS_MAP is not None:
        return

    with _INSTRUMENTS_LOCK:
        if _INSTRUMENTS_DF is not None and _INSTRUMENTS_MAP is not None:
            return

        session = Session()
        try:
            q = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin.label("strInstAladdin"),
                    cast(DMIRBRSInstrument.numInstID, String(255)).label("numInstID"),
                    func.coalesce(
                        DMIRPortfolio.strPortfGPSCode, DMIRBRSInstrument.strInstISINCode
                    ).label("strInvestedInPortfID"),
                    func.coalesce(
                        DMIRPortfolio.strPtfName, DMIRBRSInstrument.strInstName
                    ).label("strInvestedInPortfName"),
                    DMIRInstrumentIRType.strInstrumentTypeIRName.label("strInstrumentTypeIRName"),
                    DMIRPortfolio.strPortfGPSCode.label("strPortfGPSCode"),
                    DMIRBRSInstrument.strInstISINCode.label("strInstISINCode"),
                )
                .outerjoin(
                    DMIRShare,
                    and_(
                        DMIRBRSInstrument.strInstISINCode == DMIRShare.strShISINCode,
                        DMIRShare.strShStatusLabel == "Launched",
                    ),
                )
                .outerjoin(DMIRPortfolio, DMIRPortfolio.strPortfGPSCode == DMIRShare.strPortfGpsCode)
                .join(
                    DMIRInstrumentIRType,
                    and_(
                        DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                        DMIRInstrumentIRType.strReportingType == "class2",
                        func.lower(DMIRInstrumentIRType.strInstrumentTypeIRName).in_(
                            ("mutual funds", "index", "monetary funds")
                        ),
                    ),
                )
                .distinct()
                .yield_per(10000)
                .execution_options(stream_results=True)
            )
            data = [dict(r._mapping) for r in q]
            _INSTRUMENTS_DF = pd.DataFrame.from_records(data)
            if _INSTRUMENTS_DF.empty:
                # ensure expected columns exist even if empty
                _INSTRUMENTS_DF = pd.DataFrame(
                    columns=[
                        "strInstAladdin","numInstID","strInvestedInPortfID","strInvestedInPortfName",
                        "strInstrumentTypeIRName","strPortfGPSCode","strInstISINCode"
                    ]
                )
            _INSTRUMENTS_MAP = _INSTRUMENTS_DF.set_index("strInstAladdin").to_dict(orient="index")
            logger.log.info(f"Instruments cache loaded: {len(_INSTRUMENTS_DF)} rows.")
        finally:
            session.close()


def data_monitoring_previous_step_internal_2(
    Session: sqlalchemy.orm.Session, path_monitoring_previous_step_internal: str
):
    """
    Vectorized (pandas) version using a shared instruments DataFrame cache:
      - Merges each input batch with instruments cache (vectorized).
      - Prefetches DMIRSpecialFunds per-batch and marks SPECIAL in a vectorized way.
      - Computes strSrcUndrlygHoldData via numpy where cascade.
      - Saves once at the end.
    """
    logger.log.info("Get data monitoring previous step internal 2 (pandas vectorized).")

    # Ensure instruments cache is ready
    _ensure_instruments_cache(Session)
    instr_df = _INSTRUMENTS_DF

    session = Session()
    try:
        all_batches = []

        for idx, monitoring_internal in enumerate(
            cte_data_monitoring_previous_step_internal(
                path_monitoring_previous_step_internal=path_monitoring_previous_step_internal
            )
        ):
            logger.log.info(f"cte_data_monitoring_previous_step_internal idx = {idx}")

            # Load the batch into a DataFrame
            q = (
                session.query(
                    monitoring_internal.c.datReportDate,
                    monitoring_internal.c.strReportPeriod,
                    monitoring_internal.c.strReportPortfHoldSrc,
                    monitoring_internal.c.numReportPortfGroupID,
                    monitoring_internal.c.strReportPortfGPSCode,
                    monitoring_internal.c.strPortfID,
                    monitoring_internal.c.strPortfName,
                    monitoring_internal.c.numPortfAUM,
                    monitoring_internal.c.strPortfISOCur,
                    monitoring_internal.c.strInvestedInInstrID,   # join key to instruments
                    monitoring_internal.c.numHoldCrossCur,
                    monitoring_internal.c.numHoldValueInPortfCur,
                    monitoring_internal.c.numHoldQuantity,
                    monitoring_internal.c.datHoldDate,
                    monitoring_internal.c.numHoldPrice,
                    monitoring_internal.c.numHoldAccruedIntInstr,
                    monitoring_internal.c.numHoldAccruedIntPortf,
                    monitoring_internal.c.numWeightInReportPortfAUM,
                    monitoring_internal.c.strPortfLevelID,
                    monitoring_internal.c.datPeriodLastDay,
                    monitoring_internal.c.strInstAladdin,
                    monitoring_internal.c.numInstID,
                    monitoring_internal.c.numHoldAvrgCostInPortfCur,
                    monitoring_internal.c.strLevel1IsinCode,
                    monitoring_internal.c.strReportPortfISOCur,
                )
                .yield_per(5000)
                .execution_options(stream_results=True)
            )
            rows = [dict(r._mapping) for r in q]
            if not rows:
                continue

            df = pd.DataFrame.from_records(rows)

            # Normalize datatypes for vector ops
            if "datHoldDate" in df.columns:
                df["datHoldDate"] = pd.to_datetime(df["datHoldDate"], errors="coerce")

            # Vectorized merge with instruments cache
            merged = df.merge(
                instr_df,
                how="left",
                left_on="strInvestedInInstrID",
                right_on="strInstAladdin",
                suffixes=("", "_inst"),
            )

            # Prefetch SPECIAL rows for this batch
            isin_vals = merged["strInstISINCode"].dropna().unique().tolist() if "strInstISINCode" in merged else []
            lvl_vals = merged["strPortfLevelID"].dropna().unique().tolist() if "strPortfLevelID" in merged else []

            specials_df = pd.DataFrame(columns=["strSPISINCode", "strPortfLevelID", "datValidBegin", "datValidEnd"])
            if isin_vals and lvl_vals:
                specials = (
                    session.query(
                        DMIRSpecialFunds.strSPISINCode,
                        DMIRSpecialFunds.strPortfLevelID,
                        DMIRSpecialFunds.datValidBegin,
                        DMIRSpecialFunds.datValidEnd,
                    )
                    .filter(
                        DMIRSpecialFunds.strSPISINCode.in_(isin_vals),
                        DMIRSpecialFunds.strPortfLevelID.in_(lvl_vals),
                    )
                    .all()
                )
                if specials:
                    specials_df = pd.DataFrame.from_records(
                        [
                            {
                                "strSPISINCode": s.strSPISINCode,
                                "strPortfLevelID": s.strPortfLevelID,
                                "datValidBegin": s.datValidBegin,
                                "datValidEnd": s.datValidEnd,
                            }
                            for s in specials
                        ]
                    )
                    specials_df["datValidBegin"] = pd.to_datetime(specials_df["datValidBegin"], errors="coerce")
                    specials_df["datValidEnd"] = pd.to_datetime(specials_df["datValidEnd"], errors="coerce")

            # Vectorized SPECIAL determination
            if not specials_df.empty:
                merged = merged.reset_index().rename(columns={"index": "_row_idx"})
                sp_merge = merged[["_row_idx", "strInstISINCode", "strPortfLevelID", "datHoldDate"]].merge(
                    specials_df,
                    left_on=["strInstISINCode", "strPortfLevelID"],
                    right_on=["strSPISINCode", "strPortfLevelID"],
                    how="left",
                )
                cond = (
                    (sp_merge["datValidBegin"].isna() | (sp_merge["datValidBegin"] <= sp_merge["datHoldDate"]))
                    & (sp_merge["datValidEnd"].isna() | (sp_merge["datValidEnd"] <= sp_merge["datHoldDate"]))
                )
                special_any = cond.groupby(sp_merge["_row_idx"]).any()
                merged = merged.merge(
                    special_any.rename("is_special"),
                    left_on="_row_idx",
                    right_index=True,
                    how="left",
                )
                merged["is_special"] = merged["is_special"].fillna(False)
            else:
                merged["is_special"] = False

            # Compute strSrcUndrlygHoldData vectorized
            has_internal = merged["strPortfGPSCode"].notna() if "strPortfGPSCode" in merged else False
            merged["strSrcUndrlygHoldData"] = np.where(
                merged["is_special"],
                "SPECIAL",
                np.where(has_internal, "INTERNAL", "EXTERNAL"),
            )

            # Final projection
            out_cols = [
                "datReportDate",
                "strReportPeriod",
                "strReportPortfHoldSrc",
                "numReportPortfGroupID",
                "strReportPortfGPSCode",
                "strPortfID",
                "strPortfName",
                "numPortfAUM",
                "strPortfISOCur",
                "strInvestedInInstrID",
                "numHoldCrossCur",
                "numHoldValueInPortfCur",
                "numHoldQuantity",
                "datHoldDate",
                "numHoldPrice",
                "numHoldAccruedIntInstr",
                "numHoldAccruedIntPortf",
                "numWeightInReportPortfAUM",
                "strPortfLevelID",
                "datPeriodLastDay",
                "strSrcUndrlygHoldData",
                "strInstAladdin",
                "numInstID",
                "numHoldAvrgCostInPortfCur",
                # enriched fields from instruments cache:
                "strInvestedInPortfID",
                "strInvestedInPortfName",
                "strInstISINCode",
                "strInstrumentTypeIRName",
                "strLevel1IsinCode",
                "strReportPortfISOCur",
            ]
            for c in out_cols:
                if c not in merged.columns:
                    merged[c] = pd.Series([None] * len(merged))

            all_batches.append(merged[out_cols])

        # Save once
        if all_batches:
            final_df = pd.concat(all_batches, ignore_index=True)
            monitoring_data = final_df.to_dict(orient="records")
        else:
            monitoring_data = []

        path_out = dataprocess.save_json(
            data=monitoring_data,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_previous_step_internal_2",
        )

        logger.log.info(
            f"Get data monitoring previous step internal 2 (vectorized) done. Scope size = {len(monitoring_data)}"
        )
        return path_out

    except SQLAlchemyError as e:
        session.rollback()
        logger.log.error(
            f"Error occurred when data_monitoring_previous_step_internal_2 (vectorized): {str(e)}."
        )
        raise
    finally:
        session.close()
