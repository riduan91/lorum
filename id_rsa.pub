from __future__ import annotations

"""
DMIR – Look-through scope-shrinking for SQL Server 2019
======================================================

Re-implements the tail of the legacy stored-procedure
`DMIR.stpDMIRLTScopeAG_sourcePython`.

Blocks
------
1. MA purge                          → _delete_scope_ma
2. DMC   (#to_remove)                → _build_df_to_remove_dmc  / _apply_delete_dmc
3. ALP   (#to_remove2)               → _build_df_to_remove_alp  / _apply_delete_alp
4. auditIdDMCHoldings / gpsDoNot…    → _recent_dmc_holdings_audit / _gps_do_not_delete
5. ESG   (#to_remove3)               → _build_df_to_remove_esg  / _apply_delete_esg
6. Threshold harmonisation           → harmonise_thresholds
7. Refresh newer DMC holdings        → refresh_scope_for_updated_holdings
"""

import logging
from datetime import datetime, timedelta, date
from typing import Set

import pandas as pd
from dateutil.relativedelta import relativedelta
from sqlalchemy import and_, func
from sqlalchemy.orm import Session

from dags.common.dmir_connections import get_session
from dags.common.models import (
    DMIRBRSDMCPortfIndicators,
    DMIRDMCHolding,
    DMIRMonitoringLT_Legacy as DMIRMonitoringLT,
    DMIRMaccNav,
    DMIRReportParam,
    DMIRScopeLT,
    DMIRTransparizLT_Legacy as DMIRTransparizLT,
    DMIRPortfolio,
)
from dags.common.utils import get_all_as_df
from dags.lookthrough_transpariz.config import MONTHS_TO_LOOK_PAST_FULL
from dags.lookthrough_transpariz.lt_utils import update_dmc_data_with_holdings

# ---------------------------------------------------------------------------
# Generic helpers
# ---------------------------------------------------------------------------


def _within_eu_window(ts: datetime) -> bool:
    """True if  (hour>1 & BD>5)  OR  (hour>10 & BD<=5)."""
    d, h = ts.day, ts.hour
    return (h > 1 and d > 5) or (h > 10 and d <= 5)


def _delete_scope_ma(session: Session) -> int:
    return (
        session.query(DMIRScopeLT)
        .filter(DMIRScopeLT.strReportPortfHoldSrc == "MA")
        .delete(synchronize_session=False)
    )


def _delete_pairs_scope_lt(
    session: Session, src: str, keycol: str, pairs: list[tuple]
) -> int:
    total = 0
    for key, period in pairs:
        total += (
            session.query(DMIRScopeLT)
            .filter(
                DMIRScopeLT.strReportPortfHoldSrc == src,
                getattr(DMIRScopeLT, keycol) == key,
                DMIRScopeLT.strReportPeriod == period,
            )
            .delete(synchronize_session=False)
        )
    return total


# ---------------------------------------------------------------------------
# Block 2 – DMC  (#to_remove)
# ---------------------------------------------------------------------------


def _build_df_to_remove_dmc(session: Session) -> pd.DataFrame:
    agg = (
        session.query(
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
            DMIRScopeLT.numReportPortfAUM.label("num_scope"),
            DMIRScopeLT.strReportPortfGPSCode.label("gps"),
            DMIRScopeLT.strReportPeriod.label("period"),
        )
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
            DMIRTransparizLT.strReportPortfGPSCode == DMIRScopeLT.strReportPortfGPSCode,
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.numInstID > 1,
        )
        .group_by(
            DMIRScopeLT.numReportPortfAUM,
            DMIRScopeLT.strReportPortfGPSCode,
            DMIRScopeLT.strReportPeriod,
        )
    )
    df = get_all_as_df(agg)
    if df.empty:
        return df
    df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

    bad = get_all_as_df(
        session.query(
            DMIRTransparizLT.strReportPortfGPSCode, DMIRTransparizLT.strReportPeriod
        )
        .filter(
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.numInstID == -1,
        )
        .distinct()
    )
    exclude = set(bad.apply(tuple, axis=1))
    return df[~df.apply(lambda r: (r.gps, r.period) in exclude, axis=1)]


def _apply_delete_dmc(df: pd.DataFrame, session: Session) -> int:
    return _delete_pairs_scope_lt(
        session, "DMC", "strReportPortfGPSCode", df[["gps", "period"]].values.tolist()
    )


# ---------------------------------------------------------------------------
# Block 3 – ALP  (#to_remove2)
# ---------------------------------------------------------------------------


def _build_df_to_remove_alp(session: Session, gps_exempt: Set[str]) -> pd.DataFrame:
    agg = (
        session.query(
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
            DMIRScopeLT.numReportPortfAUM.label("num_scope"),
            DMIRScopeLT.numReportPortfGroupID.label("grp"),
            DMIRScopeLT.strReportPeriod.label("period"),
        )
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "ALP",
            DMIRTransparizLT.strReportPortfHoldSrc == "ALP",
            DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
            DMIRTransparizLT.numReportPortfGroupID == DMIRScopeLT.numReportPortfGroupID,
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.numInstID > 1,
        )
        .group_by(
            DMIRScopeLT.numReportPortfAUM,
            DMIRScopeLT.numReportPortfGroupID,
            DMIRScopeLT.strReportPeriod,
        )
    )
    df = get_all_as_df(agg)
    if df.empty:
        return df
    df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

    ext_idx = set(
        get_all_as_df(
            session.query(
                DMIRMonitoringLT.numReportPortfGroupID,
                DMIRMonitoringLT.strReportPeriod,
            )
            .filter(
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_("EXTERNAL", "SPECIAL"),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .distinct()
        ).apply(tuple, axis=1)
    )
    df = df[~df.apply(lambda r: (r.grp, r.period) in ext_idx, axis=1)]
    df = df[~df.grp.isin(gps_exempt)]
    return df


def _apply_delete_alp(df: pd.DataFrame, session: Session) -> int:
    return _delete_pairs_scope_lt(
        session, "ALP", "numReportPortfGroupID", df[["grp", "period"]].values.tolist()
    )


# ---------------------------------------------------------------------------
# Block 4 – auditIdDMCHoldings / gpsDoNotDelete
# ---------------------------------------------------------------------------


def _recent_dmc_holdings_audit(session: Session, month_end: date) -> pd.DataFrame:
    q = (
        session.query(
            DMIRDMCHolding.strPortfGPSCode,
            func.max(DMIRDMCHolding.numAuditId).label("aud_hold"),
        )
        .join(
            DMIRBRSDMCPortfIndicators,
            and_(
                DMIRBRSDMCPortfIndicators.strPortfGPSCode
                == DMIRDMCHolding.strPortfGPSCode,
                DMIRBRSDMCPortfIndicators.datPeriodLastNav == DMIRDMCHolding.datACCDATE,
                DMIRBRSDMCPortfIndicators.datPeriodLastDay == month_end,
            ),
        )
        .group_by(DMIRDMCHolding.strPortfGPSCode)
    )
    return get_all_as_df(q)


def _gps_do_not_delete(
    session: Session, month_end: date, df_audit: pd.DataFrame
) -> Set[str]:
    if df_audit.empty:
        return set()
    max_audit = df_audit.set_index("strPortfGPSCode").aud_hold.to_dict()

    lt_audit = get_all_as_df(
        session.query(
            DMIRTransparizLT.strReportPortfGPSCode,
            func.max(DMIRTransparizLT.numAuditId).label("aud_lt"),
        )
        .filter(
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.datPeriodLastDay == month_end,
        )
        .group_by(DMIRTransparizLT.strReportPortfGPSCode)
    ).set_index("strReportPortfGPSCode").aud_lt.to_dict()

    return {gps for gps, a in max_audit.items() if a > lt_audit.get(gps, 0)}


# ---------------------------------------------------------------------------
# Block 5 – ESG  (#to_remove3)
# ---------------------------------------------------------------------------


def _build_df_to_remove_esg(session: Session, gps_exempt: Set[str]) -> pd.DataFrame:
    agg = (
        session.query(
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
            DMIRScopeLT.numReportPortfAUM.label("num_scope"),
            DMIRScopeLT.strReportPortfGPSCode.label("gps"),
            DMIRScopeLT.strReportPeriod.label("period"),
        )
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "DMC",
            DMIRScopeLT.strReportPortfName == "DMC NAME ESG SCORES",
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPortfGPSCode == DMIRScopeLT.strReportPortfGPSCode,
            DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.numInstID > 1,
        )
        .group_by(
            DMIRScopeLT.numReportPortfAUM,
            DMIRScopeLT.strReportPortfGPSCode,
            DMIRScopeLT.strReportPeriod,
        )
    )
    df = get_all_as_df(agg)
    if df.empty:
        return df
    df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

    recent_prefix = (datetime.now() - relativedelta(months=1)).strftime("%Y%m")
    mask_exempt = df.period.str.startswith(recent_prefix) & df.gps.isin(gps_exempt)
    return df[~mask_exempt]


def _apply_delete_esg(df: pd.DataFrame, session: Session) -> int:
    return _delete_pairs_scope_lt(
        session,
        "DMC",
        "strReportPortfGPSCode",
        df[["gps", "period"]].values.tolist(),
    )


# ---------------------------------------------------------------------------
# Block 6 – Threshold harmonisation
# ---------------------------------------------------------------------------


def harmonise_thresholds(session: Session) -> None:
    subq = (
        session.query(
            func.min(DMIRReportParam.numLTThreshold).label("thr"),
            DMIRReportParam.strAccSrc,
            DMIRReportParam.numPortfGroupfKey,
            DMIRReportParam.strPortfGPSCode,
        )
        .filter(DMIRReportParam.numLTflag == 1)
        .group_by(
            DMIRReportParam.strAccSrc,
            DMIRReportParam.numPortfGroupfKey,
            DMIRReportParam.strPortfGPSCode,
        )
    ).subquery()

    # ALP
    (
        session.query(DMIRScopeLT)
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "ALP",
            DMIRScopeLT.numReportPortfGroupID == subq.c.numPortfGroupfKey,
        )
        .update({DMIRScopeLT.numLTThreshold: subq.c.thr}, synchronize_session=False)
    )
    # DMC
    (
        session.query(DMIRScopeLT)
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "DMC",
            DMIRScopeLT.strReportPortfGPSCode == subq.c.strPortfGPSCode,
        )
        .update({DMIRScopeLT.numLTThreshold: subq.c.thr}, synchronize_session=False)
    )

    # floors / caps
    (
        session.query(DMIRScopeLT)
        .filter(DMIRScopeLT.numLTThreshold == 0)
        .update({DMIRScopeLT.numLTThreshold: 1e-8}, synchronize_session=False)
    )
    (
        session.query(DMIRScopeLT)
        .filter(DMIRScopeLT.numLTThreshold > 0.0001)
        .update({DMIRScopeLT.numLTThreshold: 0.0001}, synchronize_session=False)
    )


# ---------------------------------------------------------------------------
# Extra – refresh_scope_for_updated_holdings
# ---------------------------------------------------------------------------


def refresh_scope_for_updated_holdings(now: datetime, audit_id: int = 0) -> None:
    """
    Re-insert scope rows when DMC holdings have a newer audit-id than the
    corresponding TransparizLT records (condensed version of the final T-SQL).
    """
    session = get_session()
    try:
        last_month_end = (now.replace(day=1) - timedelta(days=1)).date()
        look_back = now - relativedelta(months=4)

        # 1) candidates
        q = (
            session.query(
                DMIRMonitoringLT.strReportPortfGPSCode.label("gps"),
                DMIRMonitoringLT.strReportPeriod.label("period"),
                DMIRMonitoringLT.datHoldDate.label("datHoldDate"),
                DMIRMonitoringLT.strPortfName.label("name"),
            )
            .filter(
                DMIRMonitoringLT.numPortfLevel == 1,
                DMIRMonitoringLT.strReportPortfHoldSrc == "DMC",
                DMIRMonitoringLT.datPeriodLastDay == last_month_end,
                DMIRMonitoringLT.datLastNAVDate >= look_back.date(),
            )
            .distinct()
        )
        df = get_all_as_df(q)
        if df.empty:
            return

        # 2) enrich with holdings (get AUM, currency, etc.)
        df = update_dmc_data_with_holdings(df, load_dmc_holdings(now))

        # 3) drop duplicates already present
        existing = set(
            get_all_as_df(
                session.query(
                    DMIRScopeLT.strReportPortfGPSCode, DMIRScopeLT.strReportPeriod
                )
                .filter(DMIRScopeLT.strReportPortfHoldSrc == "DMC")
                .distinct()
            ).apply(tuple, axis=1)
        )
        df = df[~df.apply(lambda r: (r.gps, r.period) in existing, axis=1)]
        if df.empty:
            return

        # 4) insert
        rows = []
        for _, r in df.iterrows():
            rows.append(
                DMIRScopeLT(
                    datReportDate=last_month_end,
                    strReportPeriod=r.period,
                    strReportPortfHoldSrc="DMC",
                    numReportPortfGroupID=-1,
                    strReportPortfGPSCode=r.gps,
                    strReportPortfName=r.name,
                    numReportPortfAUM=r.numPortfAUM,
                    strReportPortfISOCur=r.strPortfISOCur,
                    numLTThreshold=0.0001,
                    str1LevelPortfID=r.gps,
                    strPortfName=r.name,
                    strPortfISOCur=r.strPortfISOCur,
                    numPortfAUM=r.numPortfAUM,
                    datHoldDate=r.datHoldDate,
                    numPortfExRateInRptPtfCur=1,
                    numPortfAUMInRptPtfCur=r.numPortfAUM,
                    strPortfLevelID=f"DMC_{r.gps}_{r.gps}",
                    strStatusHoldData="Validated Data",
                    datLastModifDate=now,
                    datPeriodLastDay=r.datHoldDate,
                    numAuditId=audit_id,
                )
            )
        session.bulk_save_objects(rows)
        session.commit()
        logging.info("Inserted %s refreshed DMC scope rows", len(rows))
    finally:
        session.close()


def load_dmc_holdings(now: datetime) -> pd.DataFrame:
    """Mirror of #tmpHoldingsData block – returns the best VALO row per month."""
    session = get_session()
    rownum = (
        func.row_number()
        .over(
            partition_by=[
                DMIRDMCHolding.strPortfGPSCode,
                func.format(DMIRDMCHolding.datACCDATE, "yyyyMM"),
            ],
            order_by=[
                DMIRDMCHolding.strPortfGPSCode.desc(),
                DMIRDMCHolding.datACCDATE.desc(),
                DMIRDMCHolding.numHoldValuInPortfCur.desc(),
            ],
        )
        .label("rn")
    )
    q = (
        session.query(
            DMIRDMCHolding.strPortfGPSCode,
            DMIRDMCHolding.datACCDATE.label("datDateVL"),
            func.format(DMIRDMCHolding.datACCDATE, "yyyyMM").label("period"),
            DMIRDMCHolding.strPortfISOCur,
            DMIRDMCHolding.numHoldValuInPortfCur.label("numPortfAUM"),
            rownum,
        )
        .filter(DMIRDMCHolding.datACCDATE >= now - relativedelta(months=MONTHS_TO_LOOK_PAST_FULL))
    )
    sub = q.subquery()
    df = get_all_as_df(
        session.query(
            sub.c.strPortfGPSCode,
            sub.c.datDateVL,
            sub.c.period,
            sub.c.strPortfISOCur,
            sub.c.numPortfAUM,
        ).filter(sub.c.rn == 1)
    )
    session.close()
    return df


# ---------------------------------------------------------------------------
# Orchestrator – run blocks 1-6 in order
# ---------------------------------------------------------------------------


def reduce_scope_and_cleanup() -> None:
    now = datetime.now()
    if not _within_eu_window(now):
        logging.info("Skip scope-cleanup – outside EU window.")
        return

    month_end = (now.replace(day=1) - timedelta(days=1)).date()

    session = get_session()
    try:
        with session.begin():
            # MA purge
            _delete_scope_ma(session)

            # safeguard lists
            df_audit = _recent_dmc_holdings_audit(session, month_end)
            gps_exempt = _gps_do_not_delete(session, month_end, df_audit)

            # DMC
            _apply_delete_dmc(_build_df_to_remove_dmc(session), session)

            # ALP
            _apply_delete_alp(_build_df_to_remove_alp(session, gps_exempt), session)

            # ESG
            _apply_delete_esg(_build_df_to_remove_esg(session, gps_exempt), session)

            # thresholds
            harmonise_thresholds(session)
    finally:
        session.close()


# ---------------------------------------------------------------------------
# Airflow TaskFlow wrappers
# ---------------------------------------------------------------------------

from airflow.decorators import task


@task
def task__reduce_scope_and_cleanup(**_):
    reduce_scope_and_cleanup()
    return "scope_cleaned"


@task
def task__harmonise_thresholds(**_):
    with get_session() as ss:
        harmonise_thresholds(ss)
        ss.commit()
    return "thresholds_fixed"


@task
def task__refresh_scope_updated_holdings(**context):
    audit_id = context["params"].get("audit_id", 0)
    refresh_scope_for_updated_holdings(datetime.now(), audit_id)
    return "scope_refreshed"
