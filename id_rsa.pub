import gc
import math
import numpy as np
import pandas as pd
import os

# -------- Hardware info (drop-in) ------------------------------------
def get_hardware_info():
    """
    Returns a short one-line string with current process RSS, system RAM usage, and CPU cores.
    Example:
      'procRSS=3.42GB | RAM used=28.7/63.9GB (45.0%) | CPU cores=32'
    """
    def _fmt_bytes(n):
        if n is None:
            return "n/a"
        units = ["B","KB","MB","GB","TB","PB"]
        i = int(math.floor(math.log(max(n,1), 1024)))
        i = min(i, len(units)-1)
        return f"{n / (1024**i):.2f}{units[i]}"

    rss = None; total = None; used = None; percent = None
    cores = os.cpu_count() or 1
    try:
        import psutil
        p = psutil.Process(os.getpid())
        rss = p.memory_info().rss
        vm = psutil.virtual_memory()
        total = vm.total
        used = total - vm.available
        percent = vm.percent
    except Exception:
        try:
            import resource
            ru = resource.getrusage(resource.RUSAGE_SELF).ru_maxrss
            rss = ru * 1024 if ru < 10**7 else ru
        except Exception:
            try:
                with open(f"/proc/{os.getpid()}/smaps_rollup","r") as f:
                    for line in f:
                        if line.startswith("Rss:"):
                            rss = int(line.split()[1]) * 1024
                            break
            except Exception:
                pass
        try:
            meminfo = {}
            with open("/proc/meminfo") as f:
                for line in f:
                    key, val = line.split(":")
                    meminfo[key.strip()] = int(val.strip().split()[0]) * 1024
            total = meminfo.get("MemTotal")
            avail = meminfo.get("MemAvailable")
            if total and avail:
                used = total - avail
                percent = (used / total) * 100
        except Exception:
            pass

    parts = [
        f"procRSS={_fmt_bytes(rss)}",
        f"RAM used={_fmt_bytes(used)}/{_fmt_bytes(total)}" + (f" ({percent:.1f}%)" if percent is not None else ""),
        f"CPU cores={cores}",
    ]
    return " | ".join(parts)

# -------- LIKE-join helper (no explosion) ----------------------------
def _prefix_min_like_join_no_merge(df_part2, df_lkp):
    """
    Implements SQL:
      l.strPortfLevelID LIKE h.strPortfLevelID + '.' + h.strInvestedInPortfID + '%'
    Per strReportPeriod, via binary search over sorted keys (no cross-join).
    """
    print("[PART2] start", (df_part2.shape, df_lkp.shape), get_hardware_info())

    # Build concatenated keys
    p2 = df_part2.copy()
    p2["period_prefix"] = (
        p2["strReportPeriod"].astype(str) + "|" +
        p2["strPortfLevelID"].astype(str) + "." +
        p2["strInvestedInPortfID"].astype(str)
    )
    print("[PART2] built period_prefix", p2.shape, get_hardware_info())

    lkp = df_lkp.copy()
    lkp["period_level"] = (
        lkp["strReportPeriod"].astype(str) + "|" +
        lkp["strPortfLevelID"].astype(str)
    )
    print("[PART2] built period_level", lkp.shape, get_hardware_info())

    out = []
    hi_char = chr(0x10FFFF)

    # Process by period (avoids explosion)
    for idx, (period, g_h) in enumerate(p2.groupby("strReportPeriod", sort=False), 1):
        g_l = lkp.loc[lkp["strReportPeriod"] == period, ["period_level", "numReportLevelID"]]
        if g_l.empty:
            out.append(g_h.assign(numReportLevelID_lkp=np.nan))
            if idx % 10 == 0:
                print(f"[PART2] period {idx} (empty lkp)", g_h.shape, get_hardware_info())
            continue

        L = g_l["period_level"].to_numpy()
        V = g_l["numReportLevelID"].to_numpy()
        order = np.argsort(L, kind="mergesort")
        Ls, Vs = L[order], V[order]

        pref = g_h["period_prefix"].to_numpy()
        upref, inv = np.unique(pref, return_inverse=True)

        lo = np.searchsorted(Ls, upref, side="left")
        hi = np.searchsorted(Ls, upref + hi_char, side="left")

        mins = np.full(upref.shape[0], np.nan)
        for i in range(upref.shape[0]):
            if hi[i] > lo[i]:
                mins[i] = np.min(Vs[lo[i]:hi[i]])

        g_res = g_h.copy()
        g_res["numReportLevelID_lkp"] = mins[inv]
        out.append(g_res)

        if idx % 10 == 0:
            # report every 10 periods to avoid excessive logging
            print(f"[PART2] period {idx} done", g_res.shape, get_hardware_info())

    part2_final = pd.concat(out, ignore_index=True).drop(columns=["period_prefix"])
    print("[PART2] concatenated result", part2_final.shape, get_hardware_info())
    gc.collect(); print("[PART2] gc after concat", get_hardware_info())
    return part2_final

# -------- Main function ----------------------------------------------
def process_final_step_3(
    df_DMIRTransparizLTWrk: pd.DataFrame,
    df_instrument: pd.DataFrame,
    df_instrument_irtype: pd.DataFrame,
):
    print("[START]", (df_DMIRTransparizLTWrk.shape, df_instrument.shape, df_instrument_irtype.shape), get_hardware_info())

    # --- Lookup from lowest-level rows (SQL: #lkp) --------------------
    lkp_cols = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID",
        "strInvestedInPortfISOCur","numReportLevelID",
    ]
    df_lkp = (
        df_DMIRTransparizLTWrk.loc[df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 1, lkp_cols]
        .drop_duplicates()
    )
    print("[lkp] built", df_lkp.shape, get_hardware_info())

    # ---------- PART 1: exact 4-key join (SQL LEFT JOIN to #lkp) ------
    cond_master = (
        (df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 0) &
        (
            df_DMIRTransparizLTWrk["strInvestedInPortfID"].isna() |
            (df_DMIRTransparizLTWrk["numUndrlygIRLTflag"] == 0) |
            (df_DMIRTransparizLTWrk["numPresUndrlygHoldData"] == 0)
        )
    )
    df_master = df_DMIRTransparizLTWrk.loc[cond_master, [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID",
        "strInvestedInPortfISOCur","numInventoryLevel"
    ]].copy()
    print("[PART1] master filtered", df_master.shape, get_hardware_info())

    join4 = ["strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur"]
    part1 = df_master.merge(
        df_lkp[join4 + ["numReportLevelID"]].rename(columns={"numReportLevelID":"numReportLevelID_lkp"}),
        on=join4, how="left", copy=False
    )
    print("[PART1] merged", part1.shape, get_hardware_info())
    del df_master; gc.collect(); print("[PART1] gc after del master", get_hardware_info())

    # ---------- PART 2: LIKE-join (no explosion) ----------------------
    cond_part2 = (
        (df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 0) &
        df_DMIRTransparizLTWrk["strInvestedInPortfID"].notna() &
        (df_DMIRTransparizLTWrk["numUndrlygIRLTflag"] == 1) &
        (df_DMIRTransparizLTWrk["numPresUndrlygHoldData"] == 1)
    )
    df_part2 = df_DMIRTransparizLTWrk.loc[cond_part2, [
        "strReportPeriod","strPortfLevelID","strInvestedInPortfID",
        "strInvestedInInstrID","strInvestedInPortfISOCur","numInventoryLevel"
    ]].copy()
    print("[PART2] part2 filtered", df_part2.shape, get_hardware_info())

    df_lkp_like = (
        df_DMIRTransparizLTWrk.loc[df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 1,
                                   ["strReportPeriod","strPortfLevelID","numReportLevelID"]]
        .drop_duplicates()
    )
    print("[PART2] lkp_like built", df_lkp_like.shape, get_hardware_info())

    part2_like = _prefix_min_like_join_no_merge(df_part2, df_lkp_like)
    print("[PART2] like result", part2_like.shape, get_hardware_info())
    del df_part2, df_lkp_like; gc.collect(); print("[PART2] gc after like", get_hardware_info())

    # ---------- UNION branches ----------------------------------------
    keep = ["strReportPeriod","numInventoryLevel","strPortfLevelID",
            "strInvestedInInstrID","strInvestedInPortfISOCur","numReportLevelID_lkp"]
    part1 = part1[keep]; print("[UNION] part1 narrowed", part1.shape, get_hardware_info())
    part2_like = part2_like[keep]; print("[UNION] part2_like narrowed", part2_like.shape, get_hardware_info())

    df_step_final_3 = pd.concat([part1, part2_like], ignore_index=True)
    print("[UNION] concatenated", df_step_final_3.shape, get_hardware_info())
    del part1, part2_like; gc.collect(); print("[UNION] gc after concat", get_hardware_info())

    # ---------- Update main table -------------------------------------
    join_full = ["strReportPeriod","numInventoryLevel","strPortfLevelID",
                 "strInvestedInInstrID","strInvestedInPortfISOCur"]
    df_updated = df_DMIRTransparizLTWrk.merge(
        df_step_final_3[join_full + ["numReportLevelID_lkp"]],
        on=join_full, how="left", copy=False
    )
    print("[UPDATE] merged back", df_updated.shape, get_hardware_info())
    del df_step_final_3; gc.collect(); print("[UPDATE] gc after merge back", get_hardware_info())

    changed = df_updated["numReportLevelID_lkp"].notna()
    df_updated.loc[changed, "numReportLevelID"] = df_updated.loc[changed, "numReportLevelID_lkp"]
    df_updated.loc[changed, "datLastModifDate"] = pd.Timestamp.now()
    print("[UPDATE] applied changes", df_updated.shape, get_hardware_info())
    df_updated.drop(columns="numReportLevelID_lkp", inplace=True)
    print("[UPDATE] dropped temp col", df_updated.shape, get_hardware_info())

    # --- Deletion 1 (unmapped inst with 0 MV) -------------------------
    before = df_updated.shape[0]
    df_updated = df_updated.loc[
        ~(
            (df_updated["numInstID"].fillna(-1) == -1) &
            (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
        )
    ]
    print(f"[DEL1] {before - df_updated.shape[0]} rows removed", df_updated.shape, get_hardware_info())

    # --- Deletion 2 (Forex class7 with 0 qty & MV) --------------------
    if df_instrument_irtype.empty:
        df_instrument_irtype = pd.DataFrame(
            columns=["numInstrTypeID","strReportingType","strInstrumentTypeIRName"]
        )
    print("[DEL2] irtype ready", df_instrument_irtype.shape, get_hardware_info())

    forex_type_ids = df_instrument_irtype.loc[
        (df_instrument_irtype["strReportingType"] == "class7") &
        (df_instrument_irtype["strInstrumentTypeIRName"] == "Forex"),
        "numInstrTypeID"
    ].unique()
    print("[DEL2] forex_type_ids", forex_type_ids.shape, get_hardware_info())

    df_updated = df_updated.merge(
        df_instrument[["numInstID","numInstTypeId"]], on="numInstID", how="left", copy=False
    )
    print("[DEL2] merged instrument types", df_updated.shape, get_hardware_info())

    mask_forex = (
        df_updated["numInstTypeId"].isin(forex_type_ids) &
        (df_updated["numWeightedQtqInReportPortf"].fillna(0) == 0.0) &
        (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
    )
    before2 = df_updated.shape[0]
    df_updated = df_updated.loc[~mask_forex].drop(columns="numInstTypeId")
    print(f"[DEL2] {before2 - df_updated.shape[0]} forex rows removed", df_updated.shape, get_hardware_info())

    print("[END]", df_updated.shape, get_hardware_info())
    return df_updated
