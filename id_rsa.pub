/* ============================================================================
   Row-by-row comparison (NULL = NULL) – DMIR.tblDMIRBRSBenchIndicators
   ============================================================================*/
DECLARE @fba_id      INT  = 265853;          -- benchmark to check
DECLARE @market_date DATE = '2025-06-20';    -- market date to check

/* sentinel literals used everywhere via ISNULL(..,@dflt_*) */
DECLARE @dflt_date    DATE        = '19000101';
DECLARE @dflt_float   FLOAT       = -999999999.0;
DECLARE @dflt_int     INT         = -999999999;
DECLARE @dflt_string  VARCHAR(1)  = '';

/* ========================================================================== */
SELECT
        a.datMarketDate     AS datMarketDate
      , a.strPeriodTypeFlag AS strPeriodTypeFlag
      , a.datPeriodLastDay  AS datPeriodLastDay
      , a.numBenchFBAId     AS numBenchFBAId

/* ─────────────────────────────── 0 / 1 mismatch flags ─────────────────────────────── */
      , CASE WHEN ISNULL(a.strPeriodTypeFlag       ,@dflt_string)=ISNULL(b.strPeriodTypeFlag       ,@dflt_string) THEN 0 ELSE 1 END AS valid_strPeriodTypeFlag
      , CASE WHEN ISNULL(a.datPeriodLastDay        ,@dflt_date  )=ISNULL(b.datPeriodLastDay        ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datPeriodLastDay
      , CASE WHEN ISNULL(a.datMarketDate           ,@dflt_date  )=ISNULL(b.datMarketDate           ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datMarketDate
      , CASE WHEN ISNULL(a.numBenchFBAId           ,@dflt_int   )=ISNULL(b.numBenchFBAId           ,@dflt_int   ) THEN 0 ELSE 1 END AS valid_numBenchFBAId
      , CASE WHEN ISNULL(a.strPFCurrencyISOCode    ,@dflt_string)=ISNULL(b.strPFCurrencyISOCode    ,@dflt_string) THEN 0 ELSE 1 END AS valid_strPFCurrencyISOCode
      , CASE WHEN ISNULL(a.numDurExposureBench     ,@dflt_float )=ISNULL(b.numDurExposureBench     ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numDurExposureBench
      , CASE WHEN ISNULL(a.numCurExposureBench     ,@dflt_float )=ISNULL(b.numCurExposureBench     ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numCurExposureBench
      , CASE WHEN ISNULL(a.datBenchAvgMaturityLife ,@dflt_date  )=ISNULL(b.datBenchAvgMaturityLife ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datBenchAvgMaturityLife
      , CASE WHEN ISNULL(a.numEffectDurationBench  ,@dflt_float )=ISNULL(b.numEffectDurationBench  ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numEffectDurationBench
      , CASE WHEN ISNULL(a.numModifDurationBench   ,@dflt_float )=ISNULL(b.numModifDurationBench   ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numModifDurationBench
      , CASE WHEN ISNULL(a.numMCDurationBench      ,@dflt_float )=ISNULL(b.numMCDurationBench      ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numMCDurationBench
      , CASE WHEN ISNULL(a.numSpreadDurationBench  ,@dflt_float )=ISNULL(b.numSpreadDurationBench  ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numSpreadDurationBench
      , CASE WHEN ISNULL(a.numBenchAvgCoupon       ,@dflt_float )=ISNULL(b.numBenchAvgCoupon       ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchAvgCoupon
      , CASE WHEN ISNULL(a.numBenchAvgYTM          ,@dflt_float )=ISNULL(b.numBenchAvgYTM          ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchAvgYTM
      , CASE WHEN ISNULL(a.numBenchAvgConvexity    ,@dflt_float )=ISNULL(b.numBenchAvgConvexity    ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchAvgConvexity
      , CASE WHEN ISNULL(a.numHoldingsNumber       ,@dflt_float )=ISNULL(b.numHoldingsNumber       ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numHoldingsNumber
      , CASE WHEN ISNULL(a.numBenchPriceEarnRatio  ,@dflt_float )=ISNULL(b.numBenchPriceEarnRatio  ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchPriceEarnRatio
      , CASE WHEN ISNULL(a.numBenchPriceToBook     ,@dflt_float )=ISNULL(b.numBenchPriceToBook     ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchPriceToBook
      , CASE WHEN ISNULL(a.numBenchDivYld          ,@dflt_float )=ISNULL(b.numBenchDivYld          ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchDivYld
      , CASE WHEN ISNULL(a.numBenchPriceCash       ,@dflt_float )=ISNULL(b.numBenchPriceCash       ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchPriceCash
      , CASE WHEN ISNULL(a.numBench35YrForecastEarnGrowth,@dflt_float)=ISNULL(b.numBench35YrForecastEarnGrowth,@dflt_float) THEN 0 ELSE 1 END AS valid_numBench35YrForecastEarnGrowth
      , CASE WHEN ISNULL(a.numBenchROE             ,@dflt_float )=ISNULL(b.numBenchROE             ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchROE
      , CASE WHEN ISNULL(a.numBenchEvEbit          ,@dflt_float )=ISNULL(b.numBenchEvEbit          ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchEvEbit
      , CASE WHEN ISNULL(a.numBenchEvSales         ,@dflt_float )=ISNULL(b.numBenchEvSales         ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchEvSales
      , CASE WHEN ISNULL(a.numBenchEvEbitda        ,@dflt_float )=ISNULL(b.numBenchEvEbitda        ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchEvEbitda
      , CASE WHEN ISNULL(a.numBenchTotalExpenseRatio,@dflt_float)=ISNULL(b.numBenchTotalExpenseRatio,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchTotalExpenseRatio
      , CASE WHEN ISNULL(a.datModificationDate     ,@dflt_date  )=ISNULL(b.datModificationDate     ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datModificationDate
      , CASE WHEN ISNULL(a.numAuditId              ,@dflt_int   )=ISNULL(b.numAuditId              ,@dflt_int   ) THEN 0 ELSE 1 END AS valid_numAuditId
      , CASE WHEN ISNULL(a.strBenchAvgRtgSP        ,@dflt_string)=ISNULL(b.strBenchAvgRtgSP        ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgSP
      , CASE WHEN ISNULL(a.strBenchAvgRtgMD        ,@dflt_string)=ISNULL(b.strBenchAvgRtgMD        ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgMD
      , CASE WHEN ISNULL(a.strBenchAvgRtgFH        ,@dflt_string)=ISNULL(b.strBenchAvgRtgFH        ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgFH
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom1   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom1   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom1
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom2   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom2   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom2
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom3   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom3   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom3
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom4   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom4   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom4
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom5   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom5   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom5
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom6   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom6   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom6
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom7   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom7   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom7
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom8   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom8   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom8
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom9   ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom9   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom9
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom10  ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom10  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom10
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom11  ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom11  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom11
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom12  ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom12  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom12
      , CASE WHEN ISNULL(a.strBenchAvgRtgCustom13  ,@dflt_string)=ISNULL(b.strBenchAvgRtgCustom13  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom13
      , CASE WHEN ISNULL(a.numBenchWAL             ,@dflt_float )=ISNULL(b.numBenchWAL             ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchWAL
      , CASE WHEN ISNULL(a.numBenchWAM             ,@dflt_float )=ISNULL(b.numBenchWAM             ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchWAM
      , CASE WHEN ISNULL(a.numBenchInflSens        ,@dflt_float )=ISNULL(b.numBenchInflSens        ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchInflSens
      , CASE WHEN ISNULL(a.numBenchDebtEq          ,@dflt_float )=ISNULL(b.numBenchDebtEq          ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchDebtEq
      , CASE WHEN ISNULL(a.numBenchWAMarketCap     ,@dflt_float )=ISNULL(b.numBenchWAMarketCap     ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchWAMarketCap
      , CASE WHEN ISNULL(a.numEffectDurationBenchFI,@dflt_float )=ISNULL(b.numEffectDurationBenchFI,@dflt_float ) THEN 0 ELSE 1 END AS valid_numEffectDurationBenchFI
      , CASE WHEN ISNULL(a.numModifDurationBenchFI ,@dflt_float )=ISNULL(b.numModifDurationBenchFI ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numModifDurationBenchFI
      , CASE WHEN ISNULL(a.numMCDurationBenchFI    ,@dflt_float )=ISNULL(b.numMCDurationBenchFI    ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numMCDurationBenchFI
      , CASE WHEN ISNULL(a.numBenchAvgCouponFI     ,@dflt_float )=ISNULL(b.numBenchAvgCouponFI     ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchAvgCouponFI
      , CASE WHEN ISNULL(a.numBenchAvgYTMFI        ,@dflt_float )=ISNULL(b.numBenchAvgYTMFI        ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numBenchAvgYTMFI
      , CASE WHEN ISNULL(a.datBenchAvgMaturityLifeFI,@dflt_date)=ISNULL(b.datBenchAvgMaturityLifeFI,@dflt_date) THEN 0 ELSE 1 END AS valid_datBenchAvgMaturityLifeFI
      , CASE WHEN ISNULL(a.numSpreadDurationBenchFI,@dflt_float)=ISNULL(b.numSpreadDurationBenchFI,@dflt_float) THEN 0 ELSE 1 END AS valid_numSpreadDurationBenchFI
      , CASE WHEN ISNULL(a.numBenchAvgMarketCap    ,@dflt_float)=ISNULL(b.numBenchAvgMarketCap    ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgMarketCap
      , CASE WHEN ISNULL(a.numBenchMedMarketCap    ,@dflt_float)=ISNULL(b.numBenchMedMarketCap    ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchMedMarketCap
      , CASE WHEN ISNULL(a.numBenchAvgYTMDurWeighted,@dflt_float)=ISNULL(b.numBenchAvgYTMDurWeighted,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgYTMDurWeighted
      , CASE WHEN ISNULL(a.numBenchAvgYTMDurWeightedFI,@dflt_float)=ISNULL(b.numBenchAvgYTMDurWeightedFI,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgYTMDurWeightedFI
      , CASE WHEN ISNULL(a.numBenchAvgYieldWorst   ,@dflt_float)=ISNULL(b.numBenchAvgYieldWorst   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgYieldWorst
      , CASE WHEN ISNULL(a.numBenchAvgYieldWorstFI ,@dflt_float)=ISNULL(b.numBenchAvgYieldWorstFI ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgYieldWorstFI
      , CASE WHEN ISNULL(a.numBenchAvgOas          ,@dflt_float)=ISNULL(b.numBenchAvgOas          ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgOas
      , CASE WHEN ISNULL(a.numBenchAvgOasFI        ,@dflt_float)=ISNULL(b.numBenchAvgOasFI        ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgOasFI
      , CASE WHEN ISNULL(a.numNumberOfIssuers      ,@dflt_float)=ISNULL(b.numNumberOfIssuers      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numNumberOfIssuers
      , CASE WHEN ISNULL(a.numNumberOfIssuersFI    ,@dflt_float)=ISNULL(b.numNumberOfIssuersFI    ,@dflt_float) THEN 0 ELSE 1 END AS valid_numNumberOfIssuersFI
      , CASE WHEN ISNULL(a.numBenchAvgDtsFI        ,@dflt_float)=ISNULL(b.numBenchAvgDtsFI        ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgDtsFI
      , CASE WHEN ISNULL(a.numBenchAvgPrice        ,@dflt_float)=ISNULL(b.numBenchAvgPrice        ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgPrice
      , CASE WHEN ISNULL(a.numESGGlbScore          ,@dflt_float)=ISNULL(b.numESGGlbScore          ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGlbScore
      , CASE WHEN ISNULL(a.numESGGlbCovWeight      ,@dflt_float)=ISNULL(b.numESGGlbCovWeight      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGlbCovWeight
      , CASE WHEN ISNULL(a.numESGGlbScoreCov       ,@dflt_float)=ISNULL(b.numESGGlbScoreCov       ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGlbScoreCov
      , CASE WHEN ISNULL(a.numESGEnvScore          ,@dflt_float)=ISNULL(b.numESGEnvScore          ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGEnvScore
      , CASE WHEN ISNULL(a.numESGEnvCovWeight      ,@dflt_float)=ISNULL(b.numESGEnvCovWeight      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGEnvCovWeight
      , CASE WHEN ISNULL(a.numESGEnvScoreCov       ,@dflt_float)=ISNULL(b.numESGEnvScoreCov       ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGEnvScoreCov
      , CASE WHEN ISNULL(a.numESGSocialScore       ,@dflt_float)=ISNULL(b.numESGSocialScore       ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGSocialScore
      , CASE WHEN ISNULL(a.numESGSocialCovWeight   ,@dflt_float)=ISNULL(b.numESGSocialCovWeight   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGSocialCovWeight
      , CASE WHEN ISNULL(a.numESGSocialScoreCov    ,@dflt_float)=ISNULL(b.numESGSocialScoreCov    ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGSocialScoreCov
      , CASE WHEN ISNULL(a.numESGGovernanceScore   ,@dflt_float)=ISNULL(b.numESGGovernanceScore   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGovernanceScore
      , CASE WHEN ISNULL(a.numESGGovCovWeight      ,@dflt_float)=ISNULL(b.numESGGovCovWeight      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGovCovWeight
      , CASE WHEN ISNULL(a.numESGGovernanceScoreCov,@dflt_float)=ISNULL(b.numESGGovernanceScoreCov,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGovernanceScoreCov
      , CASE WHEN ISNULL(a.numESGDecile            ,@dflt_float)=ISNULL(b.numESGDecile            ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGDecile
      , CASE WHEN ISNULL(a.numESGDecileCovWeight   ,@dflt_float)=ISNULL(b.numESGDecileCovWeight   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGDecileCovWeight
      , CASE WHEN ISNULL(a.numESGDecileCov         ,@dflt_float)=ISNULL(b.numESGDecileCov         ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGDecileCov
      , CASE WHEN ISNULL(a.numESGGlbPotentialScoreCov,@dflt_float)=ISNULL(b.numESGGlbPotentialScoreCov,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGlbPotentialScoreCov
      , CASE WHEN ISNULL(a.numCO2IntensRevEval     ,@dflt_float)=ISNULL(b.numCO2IntensRevEval     ,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensRevEval
      , CASE WHEN ISNULL(a.numCO2IntensRevEvalCovWeight,@dflt_float)=ISNULL(b.numCO2IntensRevEvalCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensRevEvalCovWeight
      , CASE WHEN ISNULL(a.numCO2IntensRevEvalCov  ,@dflt_float)=ISNULL(b.numCO2IntensRevEvalCov  ,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensRevEvalCov
      , CASE WHEN ISNULL(a.numCO2IntensEVEval      ,@dflt_float)=ISNULL(b.numCO2IntensEVEval      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensEVEval
      , CASE WHEN ISNULL(a.numCO2IntensEVEvalCovWeight,@dflt_float)=ISNULL(b.numCO2IntensEVEvalCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensEVEvalCovWeight
      , CASE WHEN ISNULL(a.numCO2IntensEVEvalCov   ,@dflt_float)=ISNULL(b.numCO2IntensEVEvalCov   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensEVEvalCov
      , CASE WHEN ISNULL(a.numCO2EmmisionsScope12  ,@dflt_float)=ISNULL(b.numCO2EmmisionsScope12  ,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2EmmisionsScope12
      , CASE WHEN ISNULL(a.numCO2EmmissionCovWeight,@dflt_float)=ISNULL(b.numCO2EmmissionCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2EmmissionCovWeight
      , CASE WHEN ISNULL(a.numCO2EmmisionsCov      ,@dflt_float)=ISNULL(b.numCO2EmmisionsCov      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2EmmisionsCov
      , CASE WHEN ISNULL(a.numESGKPIGenderDiversityValu,@dflt_float)=ISNULL(b.numESGKPIGenderDiversityValu,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIGenderDiversityValu
      , CASE WHEN ISNULL(a.numESGKPIGenderDivCovWeight,@dflt_float)=ISNULL(b.numESGKPIGenderDivCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIGenderDivCovWeight
      , CASE WHEN ISNULL(a.numESGKPIGenderDivValuCov,@dflt_float)=ISNULL(b.numESGKPIGenderDivValuCov,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIGenderDivValuCov
      , CASE WHEN ISNULL(a.numESGKPIHumanRightsValu,@dflt_float)=ISNULL(b.numESGKPIHumanRightsValu,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsValu
      , CASE WHEN ISNULL(a.numESGKPIHumanRightsCovWeight,@dflt_float)=ISNULL(b.numESGKPIHumanRightsCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsCovWeight
      , CASE WHEN ISNULL(a.numESGKPIHumanRightsValuCov,@dflt_float)=ISNULL(b.numESGKPIHumanRightsValuCov,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsValuCov
      , CASE WHEN ISNULL(a.numESGKPIExposureControvESG,@dflt_float)=ISNULL(b.numESGKPIExposureControvESG,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExposureControvESG
      , CASE WHEN ISNULL(a.numESGKPIExpControvESGCovWeight,@dflt_float)=ISNULL(b.numESGKPIExpControvESGCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExpControvESGCovWeight
      , CASE WHEN ISNULL(a.numESGKPIExpControvESGCov,@dflt_float)=ISNULL(b.numESGKPIExpControvESGCov,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExpControvESGCov
      , CASE WHEN ISNULL(a.numESGKPIExposureControvSocial,@dflt_float)=ISNULL(b.numESGKPIExposureControvSocial,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExposureControvSocial
      , CASE WHEN ISNULL(a.numESGKPIExpControvSocCovWeight,@dflt_float)=ISNULL(b.numESGKPIExpControvSocCovWeight,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExpControvSocCovWeight
      , CASE WHEN ISNULL(a.numESGKPIExpControvSocCov,@dflt_float)=ISNULL(b.numESGKPIExpControvSocCov,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExpControvSocCov
      , CASE WHEN ISNULL(a.numESGKPIEngmtEnv      ,@dflt_float)=ISNULL(b.numESGKPIEngmtEnv      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIEngmtEnv
      , CASE WHEN ISNULL(a.numESGKPIEngmtSocial   ,@dflt_float)=ISNULL(b.numESGKPIEngmtSocial   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIEngmtSocial
      , CASE WHEN ISNULL(a.numESGKPIEngmtGov      ,@dflt_float)=ISNULL(b.numESGKPIEngmtGov      ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIEngmtGov
      , CASE WHEN ISNULL(a.numESGKPIEngmtNumMeetings,@dflt_float)=ISNULL(b.numESGKPIEngmtNumMeetings,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIEngmtNumMeetings
      , CASE WHEN ISNULL(a.numESGKPIAllTypEngmt   ,@dflt_float)=ISNULL(b.numESGKPIAllTypEngmt   ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIAllTypEngmt
      , CASE WHEN ISNULL(a.numGrpPolicyRcoWeight ,@dflt_float)=ISNULL(b.numGrpPolicyRcoWeight ,@dflt_float) THEN 0 ELSE 1 END AS valid_numGrpPolicyRcoWeight
      , CASE WHEN ISNULL(a.numESGGlbCovWeightG    ,@dflt_float)=ISNULL(b.numESGGlbCovWeightG    ,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGGlbCovWeightG
      , CASE WHEN ISNULL(a.numCO2IntensEVEvalCovWeightG,@dflt_float)=ISNULL(b.numCO2IntensEVEvalCovWeightG,@dflt_float) THEN 0 ELSE 1 END AS valid_numCO2IntensEVEvalCovWeightG
      , CASE WHEN ISNULL(a.numESGKPIGenderDivCovWeightG,@dflt_float)=ISNULL(b.numESGKPIGenderDivCovWeightG,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIGenderDivCovWeightG
      , CASE WHEN ISNULL(a.numESGKPIHumanRightsCovWeightG,@dflt_float)=ISNULL(b.numESGKPIHumanRightsCovWeightG,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsCovWeightG
      , CASE WHEN ISNULL(a.numESGKPIExpControvESGCovWeightG,@dflt_float)=ISNULL(b.numESGKPIExpControvESGCovWeightG,@dflt_float) THEN 0 ELSE 1 END AS valid_numESGKPIExpControvESGCovWeightG
      , CASE WHEN ISNULL(a.numBenchAvgDts         ,@dflt_float)=ISNULL(b.numBenchAvgDts         ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgDts
      , CASE WHEN ISNULL(a.numBenchAvgConvexityFI ,@dflt_float)=ISNULL(b.numBenchAvgConvexityFI ,@dflt_float) THEN 0 ELSE 1 END AS valid_numBenchAvgConvexityFI
/* ───────────────────────────── end of flag list ───────────────────────────── */

FROM   DMIR.tblDMIRBRSBenchIndicators a
JOIN   DMIR.tblDMIRBRSBenchIndicators b
       ON  ISNULL(a.strPeriodTypeFlag ,@dflt_string)=ISNULL(b.strPeriodTypeFlag ,@dflt_string)
       AND ISNULL(a.datPeriodLastDay  ,@dflt_date  )=ISNULL(b.datPeriodLastDay  ,@dflt_date  )
       AND ISNULL(a.numBenchFBAId     ,@dflt_int   )=ISNULL(b.numBenchFBAId     ,@dflt_int   )
       AND ISNULL(a.datMarketDate     ,@dflt_date  )=ISNULL(b.datMarketDate     ,@dflt_date  )

WHERE  a.datMarketDate = @market_date
  AND  a.numBenchFBAId = @fba_id;
