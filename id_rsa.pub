from dags.common.dmir_connections import get_session
from dags.common.models import (
    DMIRAPILTHolding,
    DMIRBRSALPHAPortfGroupIndicators,
    DMIRBRSCurrencyQuote,
    DMIRBRSDMCPortfIndicators,
    DMIRBRSInstAnalytic,
