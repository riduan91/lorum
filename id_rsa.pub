python -c "from airflow.settings import Session; from airflow.models import TaskInstance; from airflow.utils import timezone as tz; dag_id='my_dag'; task_id='my_task'; execution_date=tz.parse('2025-08-12T00:00:00+00:00'); queued=tz.parse('2025-08-12T08:00:00+00:00'); started=tz.parse('2025-08-12T08:05:00+00:00'); s=Session(); n=s.query(TaskInstance).filter(TaskInstance.dag_id==dag_id, TaskInstance.task_id==task_id, TaskInstance.execution_date==execution_date).update({'queued_dttm': queued, 'start_date': started}); s.commit(); s.close(); print(f'✅ Updated {n} TaskInstance row(s)')"
