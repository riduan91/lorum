from sqlalchemy import func, select
from sqlalchemy.orm import Session

with Session(engine) as session:
    max_audit_subq = (
        select(func.max(DMIRTransparizLT.numAuditId)).scalar_subquery()
    )

    latest_rows = (
        session.query(
            DMIRTransparizLT.datReportDate,
            DMIRTransparizLT.strReportPeriod,
            DMIRTransparizLT.numPortfLevel,
            DMIRTransparizLT.numInventoryLevel,
            DMIRTransparizLT.strReportPortfHoldSrc,
            DMIRTransparizLT.numReportPortfGroupID,
            DMIRTransparizLT.strReportPortfGPSCode,
            DMIRTransparizLT.strPortfID,
            DMIRTransparizLT.strPortfName,
            DMIRTransparizLT.strPortfLevelID,
            DMIRTransparizLT.numPortfAUM,
            DMIRTransparizLT.strPortfISOCur,
            DMIRTransparizLT.numPortfExRateInRptPtfCur,
            DMIRTransparizLT.numPortfAUMInRptPtfCur,
            DMIRTransparizLT.strInvestedInPortfID,
            DMIRTransparizLT.strInvestedInInstrID,
            DMIRTransparizLT.strInvestedInPortfName,
            DMIRTransparizLT.strInstISINCode,
            DMIRTransparizLT.strInstCatName,
            DMIRTransparizLT.strInvestedInPortfISOCur,
            DMIRTransparizLT.numHoldCrossCur,
            DMIRTransparizLT.numHoldValueInPortfCur,
            DMIRTransparizLT.numHoldQuantity,
            DMIRTransparizLT.datHoldDate,
            DMIRTransparizLT.datLastNAVDate,
            DMIRTransparizLT.numUndrlygIRLTflag,
            DMIRTransparizLT.numHoldValueInReportPortfCur,
            DMIRTransparizLT.numPctReportPortfInUndrlyg,
            DMIRTransparizLT.numWeightedAmtInReportPortf,
            DMIRTransparizLT.numWeightedQtqInReportPortf,
            DMIRTransparizLT.numLowestInventoryflag,
            DMIRTransparizLT.numReportLevelID,
            DMIRTransparizLT.datLastModifDate,
            DMIRTransparizLT.datPeriodLastDay,
            DMIRTransparizLT.numInstID,
            DMIRTransparizLT.numHoldAvrgCostInReportPortf,
            DMIRTransparizLT.numPresUndrlygHoldData,
            DMIRTransparizLT.numAuditId,
            DMIRTransparizLT.numHoldPrice,
            DMIRTransparizLT.numHoldAccruedIntInstr,
            DMIRTransparizLT.numHoldAccruedIntPortf,
            DMIRTransparizLT.strLevel1IsinCode,
            DMIRTransparizLT.strReportPortfISOCur,
            DMIRTransparizLT.strInstAladdin
        )
        .filter(DMIRTransparizLT.numAuditId == max_audit_subq)
        .all()
    )
