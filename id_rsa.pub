def compute_bench_indicators_bkgn_8(df_tblDMIRBKGN7):
    """
    Vectorized, low-copy version:
    - Build rating maps once
    - Map instead of merging
    - Single-pass compute of weights
    - Return (BKGN8, IRRatingsBetween)
    """
    if df_tblDMIRBKGN7 is None or df_tblDMIRBKGN7.empty:
        return pd.DataFrame(), pd.DataFrame()

    # --- 1) Keep only needed columns & dtypes ---
    group_keys = ["numBenchFBAId","strCompositionCd","datReportingDay","strPeriodTypeFlag","strPFCurrencyISOCode"]
    base_cols = group_keys + ["numweight",
        "strInstRtgSPStandardized","strInstRtgMDStandardized","strInstRtgFHStandardized"
    ] + [f"strInstRtgCustom{i}" for i in range(1, 14)]
    df = df_tblDMIRBKGN7[base_cols].copy()

    # memory-friendly dtypes
    df["numweight"] = df["numweight"].astype("float32", copy=False)

    # --- 2) Build rating maps ONCE ---
    # (One short query, small table in memory)
    session = get_session()
    try:
        rows = session.query(
            DMIRRatingIREvaluation.strRatingAgency,
            DMIRRatingIREvaluation.strRatingValue,
            DMIRRatingIREvaluation.numRatingValue
        ).all()
    finally:
        safe_close(session)

    df_rat = pd.DataFrame(
        [(r.strRatingAgency, r.strRatingValue, r.numRatingValue) for r in rows],
        columns=["agency","strRating","numRating"]
    )
    map_sp     = df_rat[df_rat.agency=="SP"].set_index("strRating")["numRating"].to_dict()
    map_moody  = df_rat[df_rat.agency=="MOODY"].set_index("strRating")["numRating"].to_dict()
    map_fitch  = df_rat[df_rat.agency=="FITCH"].set_index("strRating")["numRating"].to_dict()

    # --- 3) Map ratings → numeric (no merges) ---
    df["numRatingSP"] = df["strInstRtgSPStandardized"].map(map_sp).astype("float32")
    df["numRatingMD"] = df["strInstRtgMDStandardized"].map(map_moody).astype("float32")
    df["numRatingFT"] = df["strInstRtgFHStandardized"].map(map_fitch).astype("float32")

    for i in range(1, 14):
        col = f"strInstRtgCustom{i}"
        df[f"numRatingC{i}"] = df[col].map(map_sp).astype("float32")

    # --- 4) Compute weights (vectorized) ---
    # Base agency weights
    nz = lambda s: s.fillna(0)
    w  = df["numweight"]

    df["numWeightSP"]        = np.where(nz(df["numRatingSP"])!=0, w, 0).astype("float32")
    df["numRatingWeightSP"]  = (w * nz(df["numRatingSP"])).astype("float32")

    df["numWeightMD"]        = np.where(nz(df["numRatingMD"])!=0, w, 0).astype("float32")
    df["numRatingWeightMD"]  = (w * nz(df["numRatingMD"])).astype("float32")

    df["numWeightFT"]        = np.where(nz(df["numRatingFT"])!=0, w, 0).astype("float32")
    df["numRatingWeightFT"]  = (w * nz(df["numRatingFT"])).astype("float32")

    for i in range(1, 14):
        nr = nz(df[f"numRatingC{i}"])
        df[f"numWeightC{i}"]       = np.where(nr!=0, w, 0).astype("float32")
        df[f"numRatingWeightC{i}"] = (w * nr).astype("float32")

    # --- 5) Keep rows that have at least one rating present ---
    rating_text_cols = [
        "strInstRtgSPStandardized","strInstRtgMDStandardized","strInstRtgFHStandardized",
        *[f"strInstRtgCustom{i}" for i in range(1,14)]
    ]
    has_any_rating = df[rating_text_cols].notna().any(axis=1)
    df = df.loc[has_any_rating]

    # --- 6) Select output columns only (drop intermediates early) ---
    keep = group_keys + ["numweight",
        "numRatingSP","numWeightSP","numRatingWeightSP",
        "numRatingMD","numWeightMD","numRatingWeightMD",
        "numRatingFT","numWeightFT","numRatingWeightFT",
        *rating_text_cols
    ]
    for i in range(1,14):
        keep += [f"numRatingC{i}", f"numWeightC{i}", f"numRatingWeightC{i}"]

    df_tblDMIRBKGN8 = df[keep].reset_index(drop=True)

    # --- 7) Prepare IRRatingsBetween once (unchanged logic, small table) ---
    df_IR = df_rat.rename(columns={"agency":"strRatingAgency"})
    df_IR = df_IR.sort_values(["strRatingAgency","numRating"], ascending=[True, False]).copy()
    df_IR["nbr"] = df_IR.groupby("strRatingAgency").cumcount() + 1
    df_IRB = df_IR.copy()
    df_IRB["strPrevRating"] = df_IRB.groupby("strRatingAgency")["strRating"].shift(1)
    df_IRB["numPrevRating"] = df_IRB.groupby("strRatingAgency")["numRating"].shift(1)
    df_IRB["numPrevRating"] = df_IRB["numPrevRating"].fillna(0.00000000009)

    return df_tblDMIRBKGN8, df_IRB


def compute_bench_indicators_bkgn_9(df_tblDMIRBKGN8: pd.DataFrame,
                                    df_IRRatingsBetween: pd.DataFrame) -> pd.DataFrame:
    """
    Memory-lean BKGN9:
    - single groupby+sum
    - vectorized averages
    - merge_asof-based nearest rating mapping (no per-group loops, no multiprocessing)
    """
    if df_tblDMIRBKGN8 is None or df_tblDMIRBKGN8.empty:
        return pd.DataFrame()

    # 1) Grouping keys
    group_keys = [
        "numBenchFBAId",
        "strCompositionCd",
        "datReportingDay",
        "strPeriodTypeFlag",
        "strPFCurrencyISOCode",
    ]

    # 2) Columns to sum
    weight_cols = ["numWeightSP","numWeightMD","numWeightFT"] + [f"numWeightC{i}" for i in range(1,14)]
    wgt_rt_cols = ["numRatingWeightSP","numRatingWeightMD","numRatingWeightFT"] + [f"numRatingWeightC{i}" for i in range(1,14)]
    sum_cols = weight_cols + wgt_rt_cols

    # Keep only what we need to aggregate
    df = df_tblDMIRBKGN8[group_keys + sum_cols].copy()

    # 3) One-pass aggregation (sums)
    agg = df.groupby(group_keys, as_index=False)[sum_cols].sum()

    # 4) Compute numeric averages (safe division)
    def safe_div(num, den):
        out = num / den.replace(0, np.nan)
        return out.fillna(0.0)

    agg["numBenchAvgRtgSP"] = safe_div(agg["numRatingWeightSP"], agg["numWeightSP"])
    agg["numBenchAvgRtgMD"] = safe_div(agg["numRatingWeightMD"], agg["numWeightMD"])
    agg["numBenchAvgRtgFT"] = safe_div(agg["numRatingWeightFT"], agg["numWeightFT"])
    for i in range(1, 14):
        agg[f"numBenchAvgRtgC{i}"] = safe_div(agg[f"numRatingWeightC{i}"], agg[f"numWeightC{i}"])

    # 5) Vectorized mapping: numeric avg -> nearest string rating per agency
    def nearest_label(avg_series: pd.Series, agency: str) -> pd.Series:
        # Prepare agency ladder
        ref = df_IRRatingsBetween[df_IRRatingsBetween["strRatingAgency"] == agency][
            ["strRating", "numRating"]
        ].drop_duplicates().sort_values("numRating", ascending=True)  # ascending for merge_asof
        if ref.empty:
            return pd.Series(["NR"] * len(avg_series), index=avg_series.index)

        # Two as-of merges: lower (<=) and upper (>=)
        left = pd.merge_asof(
            avg_series.sort_values().to_frame("numAvg"),
            ref.rename(columns={"numRating": "numLower", "strRating": "strLower"}),
            left_on="numAvg",
            right_on="numLower",
            direction="backward",
        )
        right = pd.merge_asof(
            avg_series.sort_values().to_frame("numAvg"),
            ref.rename(columns={"numRating": "numUpper", "strRating": "strUpper"}),
            left_on="numAvg",
            right_on="numUpper",
            direction="forward",
        )

        merged = left.join(right.set_index("numAvg"), on="numAvg")
        # Compute distances
        d_low = (merged["numAvg"] - merged["numLower"]).abs()
        d_up  = (merged["numUpper"] - merged["numAvg"]).abs()

        # Choose closer; ties go to lower (matches your original)
        choice = np.where((merged["strLower"].notna()) & ((d_low <= d_up) | merged["strUpper"].isna()),
                          merged["strLower"], merged["strUpper"])

        # Fill missing with NR
        out = pd.Series(choice, index=avg_series.sort_values().index).reindex(avg_series.index)
        return out.fillna("NR")

    agg["strBenchAvgRtgSP"] = nearest_label(agg["numBenchAvgRtgSP"], "SP")
    agg["strBenchAvgRtgMD"] = nearest_label(agg["numBenchAvgRtgMD"], "MOODY")
    agg["strBenchAvgRtgFT"] = nearest_label(agg["numBenchAvgRtgFT"], "FITCH")
    agg["strBenchAvgRtgFH"] = agg["strBenchAvgRtgFT"]  # keep your aliasing

    for i in range(1, 14):
        agg[f"strBenchAvgRtgC{i}"] = nearest_label(agg[f"numBenchAvgRtgC{i}"], "SP")

    # 6) Final column order (existing columns only)
    final_cols = group_keys + [
        "numBenchAvgRtgSP","strBenchAvgRtgSP",
        "numBenchAvgRtgMD","strBenchAvgRtgMD",
        "numBenchAvgRtgFT","strBenchAvgRtgFT",
    ]
    for i in range(1, 14):
        final_cols += [f"numBenchAvgRtgC{i}", f"strBenchAvgRtgC{i}"]

    final = [c for c in final_cols if c in agg.columns]
    return agg[final].reset_index(drop=True)
