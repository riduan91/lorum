    DMIRInstrumentIRType,
    DMIRPortfolio,
    DMIRPortfolioLnk,
)
from dags.common.utils import chunker, get_hardware_info

IT1 = aliased(DMIRInstrumentIRType)
IT3 = aliased(DMIRInstrumentIRType)
IT8 = aliased(DMIRInstrumentIRType)
IT9 = aliased(DMIRInstrumentIRType)
SB_BB = aliased(DMIRBRSInstSector)
SB_LH = aliased(DMIRBRSInstSector)
SB_MSCI = aliased(DMIRBRSInstSector)
SB_ICB = aliased(DMIRBRSInstSector)


def extract_dmc_scopes(df_transpariz_lt: pd.DataFrame, audit_id: int):
    # filter on audit id and non-'NA' portfolios
    df = df_transpariz_lt.loc[
        (df_transpariz_lt["numAuditId"] >= audit_id)
        & (df_transpariz_lt["strReportPortfGPSCode"] != "NA"),
        ["strReportPortfGPSCode", "datPeriodLastDay"],
    ]
    # deduplicate
    df_scopes_dmc = (
        df.drop_duplicates()
        .rename(
            columns={
                "strReportPortfGPSCode": "ReportPortfGPSCode",
                "datPeriodLastDay": "datPeriodLastDay",
            }
        )
        .reset_index(drop=True)
    )
    return df_scopes_dmc


def extract_alpha_scopes(df_transpariz_lt: pd.DataFrame, audit_id: int):
    # filter on audit id and valid portfolio group IDs
    df = df_transpariz_lt.loc[
        (df_transpariz_lt["numAuditId"] >= audit_id)
        & df_transpariz_lt["numReportPortfGroupID"].notna()
        & (df_transpariz_lt["numReportPortfGroupID"] != -1),
        ["numReportPortfGroupID", "datPeriodLastDay"],
    ]
    # deduplicate and rename
    df_scopes_alpha = (
        df.drop_duplicates()
        .rename(columns={"numReportPortfGroupID": "numPortfGroupFkey"})
        .reset_index(drop=True)
    )
    return df_scopes_alpha


def get_sign_leg_and_nr_leg(subchunk):
    if (subchunk["numHoldQuantity"] >= 0).all():
        sign_leg = 1
    elif (subchunk["numHoldQuantity"] < 0).all():
        sign_leg = -1
    else:
        sign_leg = 0
    nr_legs = len(subchunk)
    if nr_legs == 1:
        sign_leg = 0
    return {"signOfLeg": sign_leg, "nrLegs": nr_legs}


def _fetch_instruments_worker(chunk_inst_alds):
    print(f"[worker] instruments: fetching {len(chunk_inst_alds)} keys")
    session = get_session()
    try:
        rows = (
            session.query(
                DMIRBRSInstrument.strInstAladdin,
                DMIRBRSInstrument.strInstCurrCode,
                DMIRBRSInstrument.strInstName,
                DMIRBRSInstrument.strBloombergCode,
                DMIRBRSInstrument.strInstISINCode,
                DMIRBRSInstrument.strInstSedolCode,
                DMIRBRSInstrument.strInstCUSIPCode,
                DMIRBRSInstrument.strInstIssuerName,
                DMIRBRSInstrument.strInstExchLocName,
                DMIRBRSInstrument.strInstListingCountryLabel,
                DMIRBRSInstrument.strInstIssueCountryLabel,
                DMIRBRSInstrument.strInstIssuerCountryLabel,
                DMIRBRSInstrument.strInstRiskCountryLabel,
                DMIRBRSInstrument.numInstCouponRate,
                DMIRBRSInstrument.numInstForwardRate,
                DMIRBRSInstrument.datInstMaturityDate,
                DMIRBRSInstrument.datInstCallDate,
                DMIRBRSInstrument.datInstNextCouponDate,
                DMIRBRSInstrument.strInstPriceType,
                DMIRBRSInstrument.strInstRateType,
                DMIRBRSInstrument.numInstSpotRate,
                DMIRBRSInstrument.datInstStartDate,
                DMIRBRSInstrument.numInstUndrlygQty,
                DMIRBRSInstrument.strInstUndrlygISINCode,
                DMIRBRSInstrument.datInstIssueDate,
                DMIRBRSInstrument.numInstNominalMt,
                DMIRBRSInstrument.datInstContractEnd,
                DMIRBRSInstrument.strInstContractName,
                DMIRBRSInstrument.strInstLegTyp1,
                DMIRBRSInstrument.strInstLegTyp2,
                DMIRBRSInstrument.strInstLegType,
                DMIRBRSInstrument.strCpnRateTypPaid,
                DMIRBRSInstrument.strCpnRateTypeRecv,
                DMIRBRSInstrument.numCpnFixedRatePaid,
                DMIRBRSInstrument.numCpnFixedRateRecv,
                DMIRBRSInstrument.strCpnIndexPaid,
                DMIRBRSInstrument.strCpnIndexRecv,
                DMIRBRSInstrument.strSwapFreqPaid,
                DMIRBRSInstrument.strSwapFreqRecv,
                DMIRBRSInstrument.strinstrmttypcd,
                DMIRBRSInstrument.numInstTypeId,
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(chunk_inst_alds))
            .all()
        )
        # Return plain dicts (avoid pickling ORM objects)
        out = []
        for i in rows:
            out.append(
                dict(
                    strInstAladdin=i.strInstAladdin,
                    strInstCurrCode=i.strInstCurrCode,
                    strInstName=i.strInstName,
                    strBloombergCode=i.strBloombergCode,
                    strInstISINCode=i.strInstISINCode,
                    strInstSedolCode=i.strInstSedolCode,
                    strInstCUSIPCode=i.strInstCUSIPCode,
                    strInstIssuerName=i.strInstIssuerName,
                    strInstExchLocName=i.strInstExchLocName,
                    strInstListingCountryLabel=i.strInstListingCountryLabel,
                    strInstIssueCountryLabel=i.strInstIssueCountryLabel,
                    strInstIssuerCountryLabel=i.strInstIssuerCountryLabel,
                    strInstRiskCountryLabel=i.strInstRiskCountryLabel,
                    numInstCouponRate=i.numInstCouponRate,
                    numInstForwardRate=i.numInstForwardRate,
                    datInstMaturityDate=i.datInstMaturityDate,
                    datInstCallDate=i.datInstCallDate,
                    datInstNextCouponDate=i.datInstNextCouponDate,
                    strInstPriceType=i.strInstPriceType,
                    strInstRateType=i.strInstRateType,
                    numInstSpotRate=i.numInstSpotRate,
                    datInstStartDate=i.datInstStartDate,
                    numInstUndrlygQty=i.numInstUndrlygQty,
                    strInstUndrlygISINCode=i.strInstUndrlygISINCode,
                    datInstIssueDate=i.datInstIssueDate,
                    numInstNominalMt=i.numInstNominalMt,
                    datInstContractEnd=i.datInstContractEnd,
                    strInstContractName=i.strInstContractName,
                    strInstLegTyp1=i.strInstLegTyp1,
                    strInstLegTyp2=i.strInstLegTyp2,
                    strInstLegType=i.strInstLegType,
                    strCpnRateTypPaid=i.strCpnRateTypPaid,
                    strCpnRateTypeRecv=i.strCpnRateTypeRecv,
                    numCpnFixedRatePaid=i.numCpnFixedRatePaid,
                    numCpnFixedRateRecv=i.numCpnFixedRateRecv,
                    strCpnIndexPaid=i.strCpnIndexPaid,
                    strCpnIndexRecv=i.strCpnIndexRecv,
                    strSwapFreqPaid=i.strSwapFreqPaid,
                    strSwapFreqRecv=i.strSwapFreqRecv,
                    strinstrmttypcd=i.strinstrmttypcd,
                    numInstTypeId=i.numInstTypeId,
                )
            )
        print(f"[worker] instruments: done {len(out)} rows")
        return out
    finally:
        session.close()


def fetch_instruments_parallel(inst_alds, chunk_size=2000, max_workers=24):
    print(
        f"Fetching instruments in parallel: {len(inst_alds)} keys, chunk={chunk_size}, workers={max_workers}"
    )
    get_hardware_info()

    results = []
    with ProcessPoolExecutor(max_workers=max_workers) as ex:
        futures = []
        for chunk_inst_alds in chunker(list(inst_alds), chunk_size):
            futures.append(ex.submit(_fetch_instruments_worker, chunk_inst_alds))

        for fut in as_completed(futures):
            rows = fut.result()  # will raise if worker failed
            results.extend(rows)
            print(f"instruments fetched total: {len(results)}")
            get_hardware_info()

    print("Instruments parallel fetch complete")
    get_hardware_info()
    return results  # list of dicts


# --- Worker must be at top-level (picklable) ---
def _fetch_analytics_worker(args):
    chunk_inst_alds, period_ends_list = args
    print(f"[worker] analytics: {len(chunk_inst_alds)} keys x {len(period_ends_list)} dates")
    session = get_session()
    try:
        rows = (
            session.query(DMIRBRSInstAnalytic)
            .filter(
                DMIRBRSInstAnalytic.strInstAladdin.in_(chunk_inst_alds),
                DMIRBRSInstAnalytic.datInstQuotationDate.in_(period_ends_list),
            )
            .all()
        )
        out = []
        for a in rows:
            out.append(
                dict(
                    strInstAladdin=a.strInstAladdin,
                    datInstQuotationDate=a.datInstQuotationDate,
                    nummktcap=a.nummktcap,
                    numInstYieldToMaturity=a.numInstYieldToMaturity,
                    numInstEffDuration=a.numInstEffDuration,
                    numInstModifDuration=a.numInstModifDuration,
                    numInstSpreadDuration=a.numInstSpreadDuration,
                    numInstMCDuration=a.numInstMCDuration,
                    numInstYield=a.numInstYield,
                    numInstYieldToCall=a.numInstYieldToCall,
                    numInstYieldToMaturityPaid=a.numInstYieldToMaturityPaid,
                    numInstYieldToMaturityRecv=a.numInstYieldToMaturityRecv,
                    numInstOptionAdjSpread=a.numInstOptionAdjSpread,
                )
            )
        print(f"[worker] analytics: done {len(out)} rows")
        return out
    finally:
        session.close()


def fetch_analytics_parallel(inst_alds, period_ends, chunk_size=2000, max_workers=24):
    print(
        f"Fetching analytics in parallel: {len(inst_alds)} keys, {len(period_ends)} dates, chunk={chunk_size}, workers={max_workers}"
    )
    get_hardware_info()

    period_ends_list = list(period_ends)  # make picklable, stable order not required
    results = []
    with ProcessPoolExecutor(max_workers=max_workers) as ex:
        futures = []
        for chunk_inst_alds in chunker(list(inst_alds), chunk_size):
            futures.append(ex.submit(_fetch_analytics_worker, (chunk_inst_alds, period_ends_list)))

        for fut in as_completed(futures):
            rows = fut.result()
            results.extend(rows)
            print(f"analytics fetched total: {len(results)}")
            get_hardware_info()

    print("Analytics parallel fetch complete")
    get_hardware_info()
    return results  # list of dicts


MODEL_MAP = {
    "SB_BB": SB_BB,
    "SB_LH": SB_LH,
    "SB_MSCI": SB_MSCI,
    "SB_ICB": SB_ICB,
}


# ---- worker (top-level) ----
def _fetch_sector_worker(model_label: str, key_prefix: str, inst_alds_chunk):
    # model_label: "SB_BB" | "SB_LH" | "SB_MSCI" | "SB_ICB"
    # key_prefix:  e.g. "InstrSectorBBLevel" (will produce ...1, ...2, ...3)
    print(f"[worker] {model_label}: fetching {len(inst_alds_chunk)} instruments")
    session = get_session()
    try:
        Model = MODEL_MAP[model_label]
        agency = {"SB_BB": "BNPP_BICS", "SB_LH": "LH", "SB_MSCI": "MSCI", "SB_ICB": "ICB"}[
            model_label
        ]
        rows = (
            session.query(Model)
            .filter(
                Model.strInstAladdin.in_(list(inst_alds_chunk)),
                Model.strInstSectorAgy == agency,
            )
            .all()
        )
        out = []
        for r in rows:
            out.append(
                {
                    "strInstAladdin": r.strInstAladdin,
                    f"{key_prefix}1": getattr(r, "strInstSectorL1", None)
                    or getattr(r, "strIssSector1Label", None),
                    f"{key_prefix}2": getattr(r, "strInstSectorL2", None)
                    or getattr(r, "strIssSector2Label", None),
                    f"{key_prefix}3": getattr(r, "strInstSectorL3", None)
                    or getattr(r, "strIssSector3Label", None),
                }
            )
        print(f"[worker] {model_label}: done {len(out)} rows")
        return model_label, out
    finally:
        session.close()


# ---- launcher ----
def fetch_sectors_parallel(inst_alds, chunk_size=2000, max_workers=8):
    """
    Parallel fetch for sector tables (BB/LH/MSCI/ICB).
    Returns four DataFrames: df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb
    """
    model_jobs = [
        ("SB_BB", "InstrSectorBBLevel"),
        ("SB_LH", "InstrSectorBarclaysLevel"),
        ("SB_MSCI", "InstrSectorMSCILevel"),
        ("SB_ICB", "InstrSectorICBLevel"),
    ]

    print(f"Launching sector fetch in parallel for {len(inst_alds)} instruments")
    get_hardware_info()

    # submit all (model x chunk) jobs
    futures = []
    with ProcessPoolExecutor(max_workers=max_workers) as ex:
        for model_label, key_prefix in model_jobs:
            for inst_alds_chunk in chunker(list(inst_alds), chunk_size):
                futures.append(
                    ex.submit(_fetch_sector_worker, model_label, key_prefix, inst_alds_chunk)
                )

        # collect
        buckets = {m[0]: [] for m in model_jobs}
        for fut in as_completed(futures):
            model_label, rows = fut.result()  # raise on error
            buckets[model_label].extend(rows)
            total = sum(len(v) for v in buckets.values())
            print(f"Sectors fetched so far: {total}")
            get_hardware_info()

    # build DataFrames
    df_sb_bb = (
        pd.DataFrame(buckets["SB_BB"])
        if buckets["SB_BB"]
        else pd.DataFrame(
            columns=[
                "strInstAladdin",
                "InstrSectorBBLevel1",
                "InstrSectorBBLevel2",
                "InstrSectorBBLevel3",
            ]
        )
    )
    df_sb_lh = (
        pd.DataFrame(buckets["SB_LH"])
        if buckets["SB_LH"]
        else pd.DataFrame(
            columns=[
                "strInstAladdin",
                "InstrSectorBarclaysLevel1",
                "InstrSectorBarclaysLevel2",
                "InstrSectorBarclaysLevel3",
            ]
        )
    )
    df_sb_msci = (
        pd.DataFrame(buckets["SB_MSCI"])
        if buckets["SB_MSCI"]
        else pd.DataFrame(
            columns=[
                "strInstAladdin",
                "InstrSectorMSCILevel1",
                "InstrSectorMSCILevel2",
                "InstrSectorMSCILevel3",
            ]
        )
    )
    df_sb_icb = (
        pd.DataFrame(buckets["SB_ICB"])
        if buckets["SB_ICB"]
        else pd.DataFrame(
            columns=[
                "strInstAladdin",
                "InstrSectorICBLevel1",
                "InstrSectorICBLevel2",
                "InstrSectorICBLevel3",
            ]
        )
    )

    print("Sector parallel fetch complete")
    get_hardware_info()
    return df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb


def _build_df_inst(session, inst_alds, period_ends, rpt_codes, grp_ids):
    print(f"Build df_inst: {len(inst_alds)} instruments, {len(period_ends)} dates")
    get_hardware_info()

    # --- Instruments ---
    instruments_dicts = fetch_instruments_parallel(inst_alds, chunk_size=2000, max_workers=24)
    df_i = pd.DataFrame(instruments_dicts)
    print("df_i", df_i.shape, get_hardware_info())

    # --- Analytics (per inst/date) ---
    analytics_dicts = fetch_analytics_parallel(
        inst_alds, period_ends, chunk_size=2000, max_workers=24
    )
    df_a = pd.DataFrame(analytics_dicts)
    print("df_a", df_a.shape, get_hardware_info())

    # --- Currency quotes (per currency/date) ---
    curr_codes = set(df_i["strInstCurrCode"].dropna().tolist())
    quotes_rows = []
    for chunk_curr in chunker(list(curr_codes), 2000):
        quotes_rows.extend(
            session.query(DMIRBRSCurrencyQuote)
            .filter(
                DMIRBRSCurrencyQuote.strCurrCode.in_(chunk_curr),
                DMIRBRSCurrencyQuote.datccyqDate.in_(list(period_ends)),
            )
            .all()
        )
    df_q = pd.DataFrame(
        [
            dict(
                strCurrCode=q.strCurrCode,
                datccyqDate=q.datccyqDate,
                numccyqrateInv=q.numccyqrateInv,
            )
            for q in quotes_rows
        ]
    )
    print("df_q", df_q.shape, get_hardware_info())

    # --- IT classes (by type id) ---
    type_ids = set(df_i["numInstTypeId"].dropna().tolist())

    def _it_df(model, cls_label):
        rows = (
            session.query(model)
            .filter(
                model.numInstrTypeID.in_(list(type_ids)),
                model.strReportingType == f"class{cls_label}",
            )
            .all()
        )
        return pd.DataFrame(
            [
                dict(
                    numInstrTypeID=r.numInstrTypeID,
                    **{
                        f"InstrumentTypeNameClass{cls_label}": r.strInstrumentTypeName,
                        f"InstrumentTypeIRNameClass{cls_label}": r.strInstrumentTypeIRName,
                    },
                )
                for r in rows
            ]
        )

    df_it1 = _it_df(IT1, "1")
    df_it3 = _it_df(IT3, "3")
    df_it8 = _it_df(IT8, "8")
    df_it9 = _it_df(IT9, "9")
    print("df_it1", df_it1.shape, get_hardware_info())

    df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb = fetch_sectors_parallel(
        inst_alds, chunk_size=2000, max_workers=24
    )

    # --- Portfolio / Link / AUM ---
    ports = (
        session.query(
            DMIRPortfolio.strPortfGPSCode,
            DMIRPortfolio.strPtfName,
            DMIRPortfolio.strPtfCurrCode,
        )
        .filter(DMIRPortfolio.strPortfGPSCode.in_(list(rpt_codes)))
        .all()
    )
    df_p = pd.DataFrame(
        [
            dict(
                strPortfGPSCode=p.strPortfGPSCode,
                strPtfName=p.strPtfName,
                strPtfCurrCode=p.strPtfCurrCode,
            )
            for p in ports
        ]
    )
    print("df_p", df_p.shape, get_hardware_info())

    lnks = (
        session.query(
            DMIRPortfolioLnk.strPortfGroupDECALOGCode,
            DMIRPortfolioLnk.numPortfGroupSkey,
            DMIRPortfolioLnk.strPortfGroupType,
        )
        .filter(
            DMIRPortfolioLnk.numPortfGroupSkey.in_(list(map(int, grp_ids))),
            DMIRPortfolioLnk.strPortfGroupType.in_(["A", "G"]),
        )
        .all()
    )
    df_lnk = pd.DataFrame(
        [
            dict(
                numReportPortfGroupID=l.numPortfGroupSkey,
                strPortfGroupDECALOGCode=l.strPortfGroupDECALOGCode,
            )
            for l in lnks
        ]
    ).drop_duplicates("numReportPortfGroupID")
    print("df_lnk", df_lnk.shape, get_hardware_info())

    aums = (
        session.query(
            DMIRBRSDMCPortfIndicators.strPortfGPSCode,
            DMIRBRSDMCPortfIndicators.datPeriodLastDay,
            DMIRBRSDMCPortfIndicators.numFundAUM,
        )
        .filter(
            DMIRBRSDMCPortfIndicators.strPortfGPSCode.in_(list(rpt_codes)),
            DMIRBRSDMCPortfIndicators.datPeriodLastDay.in_(list(period_ends)),
        )
        .all()
    )
    df_aum = (
        pd.DataFrame(
            [
                dict(
                    strPortfGPSCode=r.strPortfGPSCode,
                    datPeriodLastDay=r.datPeriodLastDay,
                    numFundAUM=r.numFundAUM,
                )
                for r in aums
            ]
        )
        .sort_values("numFundAUM", ascending=False)
        .drop_duplicates(["strPortfGPSCode", "datPeriodLastDay"])
    )
    print("df_aum", df_aum.shape, get_hardware_info())

    # --- Compose df_inst (wide, per instrument) ---
    df_inst = df_i.copy()
    for dfit in (df_it1, df_it3, df_it8, df_it9):
        if not dfit.empty:
            df_inst = df_inst.merge(
                dfit, left_on="numInstTypeId", right_on="numInstrTypeID", how="left"
            ).drop(columns=["numInstrTypeID"], errors="ignore")
    for dfsb in (df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb):
        if not dfsb.empty:
            df_inst = df_inst.merge(dfsb, on="strInstAladdin", how="left")

    print("df_inst", df_inst.shape, get_hardware_info())

    print("df_inst built")
    get_hardware_info()
    return df_inst, df_a, df_q, df_p, df_lnk, df_aum


# ---------------------------------------------------
# Vectorized serial processing (no parallelization)
# ---------------------------------------------------
def process_dmc_records(
    df_lt: pd.DataFrame,
    df_scope_dmc: pd.DataFrame,  # (strReportPortfGPSCode, datPeriodLastDay)
    df_lt_ind: pd.DataFrame,  # tblDMIRBRSLTPortfInstrIndicators
    num_audit_id: int,
) -> pd.DataFrame:
    """
    Serial + vectorized version that keeps the original business logic.
    """

    # 0) Scope-filter & audit flag
    df_lt = df_lt.assign(numAuditId=num_audit_id).merge(
        df_scope_dmc,
        left_on=["strReportPortfGPSCode", "datPeriodLastDay"],
        right_on=["ReportPortfGPSCode", "datPeriodLastDay"],
        how="inner",
    )
    # Enforce lowest-inventory flag like SQL
    df_lt = df_lt.query("numLowestInventoryflag == 1")

    # 1) Keys for bulk fetch
    get_hardware_info()
    print("Preparing unique keys for bulk fetch")
    inst_alds = set(df_lt["strInstAladdin"].dropna().unique().tolist())
    period_ends = set(df_lt["datPeriodLastDay"].dropna().unique().tolist())
    rpt_codes = set(df_lt["strReportPortfGPSCode"].dropna().unique().tolist())
    grp_ids = set(df_lt["numReportPortfGroupID"].dropna().unique().tolist())

    session = get_session()
    try:
        df_inst, df_a, df_q, df_p, df_lnk, df_aum = _build_df_inst(
            session, inst_alds, period_ends, rpt_codes, grp_ids
        )
    finally:
        session.close()

    # 2) Aggregations on df_lt (per key + instrument)
    print("Aggregating df_lt")
    get_hardware_info()

    group_cols = [
        "strReportPortfGPSCode",
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "numAuditId",
        "strInstAladdin",
        "numInstID",
    ]
    agg_spec = {
        "numHoldPrice": "mean",
        "numHoldAccruedIntPortf": "sum",
        "numWeightedAmtInReportPortf": "sum",
        "numHoldCrossCur": "mean",
        "numWeightedQtqInReportPortf": "sum",
        "numHoldAvrgCostInReportPortf": "sum",
        "strInvestedInPortfISOCur": "first",
    }
    df_lt_agg = df_lt.groupby(group_cols, as_index=False).agg(agg_spec)

    print("Applying signOfLeg")
    get_hardware_info()

    sign_stats = (
        df_lt.groupby(group_cols)
        .agg(
            nrLegs=("numHoldQuantity", "size"),
            q_min=("numHoldQuantity", "min"),
            q_max=("numHoldQuantity", "max"),
        )
        .reset_index()
    )

    # 2) vectorized sign:
    #    - if all >= 0  -> q_min >= 0  -> +1
    #    - if all <  0  -> q_max <  0  -> -1
    #    - else -> 0
    #    - and if nrLegs == 1 -> force 0
    sign = np.select(
        [sign_stats["q_min"] >= 0, sign_stats["q_max"] < 0],
        [1, -1],
        default=0,
    )
    sign = np.where(sign_stats["nrLegs"] == 1, 0, sign)

    sign_stats = sign_stats.assign(signOfLeg=sign).drop(columns=["q_min", "q_max"])
    df_lt_agg = df_lt_agg.merge(sign_stats, on=group_cols, how="left")

    # 3) Merges
    print("Merging instrument")
    get_hardware_info()

    # instrument details
    df_m = df_lt_agg.merge(df_inst, on="strInstAladdin", how="left")

    # limit signOfLeg to FX derivatives only (class9 == 'Derivatives - Forex')
    df_m["signOfLeg"] = np.where(
        df_m["InstrumentTypeIRNameClass9"].eq("Derivatives - Forex"), df_m["signOfLeg"], 0
    )
    df_m.loc[df_m["nrLegs"] == 1, "signOfLeg"] = 0

    # analytics per (inst, date)
    print("Merging analytics")
    get_hardware_info()

    if not df_a.empty:
        df_a["datInstQuotationDate"] = pd.to_datetime(df_a["datInstQuotationDate"])
        df_m = df_m.merge(
            df_a,
            left_on=["strInstAladdin", "datPeriodLastDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            how="left",
        ).drop(columns=["datInstQuotationDate"], errors="ignore")
        # map analytics to holding fields
        for src, dst in [
            ("numInstYieldToMaturity", "InstrYieldToMaturity"),
            ("numInstEffDuration", "InstrEffectiveDuration"),
            ("numInstModifDuration", "InstrModifiedDuration"),
            ("numInstSpreadDuration", "InstrSpreadDuration"),
            ("numInstMCDuration", "InstrMCDuration"),
            ("numInstYield", "InstrYield"),
            ("numInstYieldToCall", "InstrYieldCalculatedToMaturity"),
            ("numInstYieldToMaturityPaid", "InstrYieldToMaturityPaid"),
            ("numInstYieldToMaturityRecv", "InstrYieldToMaturityReceived"),
            ("numInstOptionAdjSpread", "InstrOAS"),
        ]:
            df_m[dst] = df_m[src]

    print("Merging quotes")
    get_hardware_info()

    # quotes per (currency, date)
    if not df_q.empty:
        df_q["datccyqDate"] = pd.to_datetime(df_q["datccyqDate"])
        df_m = df_m.merge(
            df_q,
            left_on=["strInstCurrCode", "datPeriodLastDay"],
            right_on=["strCurrCode", "datccyqDate"],
            how="left",
        ).drop(columns=["strCurrCode", "datccyqDate"], errors="ignore")

    print("Merging portfolio")
    get_hardware_info()
    # portfolio info
    if not df_p.empty:
        df_m = df_m.merge(
            df_p, left_on="strReportPortfGPSCode", right_on="strPortfGPSCode", how="left"
        ).drop(columns=["strPortfGPSCode"], errors="ignore")

    print("Merging link")
    get_hardware_info()
    # link by group
    if not df_lnk.empty:
        df_m = df_m.merge(df_lnk, on="numReportPortfGroupID", how="left")

    # AUM by (portfolio, date)
    print("Merging aum")
    get_hardware_info()
    if not df_aum.empty:
        df_aum["datPeriodLastDay"] = pd.to_datetime(df_aum["datPeriodLastDay"])
        df_m = df_m.merge(
            df_aum,
            left_on=["strReportPortfGPSCode", "datPeriodLastDay"],
            right_on=["strPortfGPSCode", "datPeriodLastDay"],
            how="left",
        )

    print("Merging instr indicators")
    get_hardware_info()
    # indicators per (portfolio, date, inst)
    df_m = df_m.merge(
        df_lt_ind,
        left_on=["strReportPortfGPSCode", "datPeriodLastDay", "strInstAladdin"],
        right_on=["strPortfGPSCode", "datPeriodLastDay", "strInstAladdin"],
        how="left",
        suffixes=("", "_ind"),
    ).drop(columns=["strPortfGPSCode_ind"], errors="ignore")

    # map indicator-driven ratings and ESG/CO2
    rating_map = {
        "InstRtgSPStandardized": "strInstRtgSPStandardized",
        "InstRtgMDStandardized": "strInstRtgMDStandardized",
        "InstRtgFHStandardized": "strInstRtgFHStandardized",
        "InstrESGGlbScore": "numESGGlbScore",
        "InstrESGGlbScoreCov": "numESGGlbScoreCov",
        "InstrCO2IntensEVEval": "numCO2IntensEVEval",
        "InstrCO2IntensEVEvalCov": "numCO2IntensEVEvalCov",
    }
    for k, v in rating_map.items():
        if v in df_m.columns:
            df_m[k] = df_m[v]
    for i in range(1, 14):
        src = f"strInstRtgCustom{i}"
        if src in df_m.columns:
            df_m[f"InstrCustomRating{i}"] = df_m[src]

    # 4) Vectorized enrichment

    # Constants
    df_m["strSource"] = "DMC-LT"
    df_m["AccountingDate"] = pd.to_datetime(df_m["datPeriodLastDay"]).dt.normalize()
    df_m["InstrumentDWHID"] = df_m["numInstID"]
    df_m["PortfolioDWHID"] = df_m["strReportPortfGPSCode"]
    df_m["PortfolioDWHGroupID"] = None
    df_m["PortfolioName"] = df_m.get("strPtfName")
    df_m["PortfolioCurrency"] = df_m.get("strPtfCurrCode")
    df_m["InstrUnitCostInstrCur"] = None
    df_m["InstrAvrgCostPortfCur"] = None
    df_m["InstrLastPriceDate"] = df_m["numHoldPrice"]
    df_m["InstrProfitLossPortfCur"] = None
    df_m["InstrQuantity"] = df_m["numWeightedQtqInReportPortf"]
    df_m["InstrLastPrice"] = df_m["numHoldPrice"]
    df_m["HoldingTypeName"] = None

    print("Coupon...")

    # DMC: keep full coupon indices (no truncation)
    df_m["InstrCouponIndexPaid"] = df_m["strCpnIndexPaid"]
    df_m["InstrCouponIndexReceived"] = df_m["strCpnIndexRecv"]

    print("Exchange rate...")
    # Exchange rate (SQL uses numHoldCrossCur)
    df_m["InstrExchangeRate"] = df_m["numHoldCrossCur"]

    # Instrument currency (invested in portfolio currency)
    df_m["InstrCurISOCode"] = df_m["strInvestedInPortfISOCur"]

    # Market Cap EUR
    df_m["InstrMktCapEur"] = np.where(
        df_m["nummktcap"].notna() & df_m["numccyqrateInv"].notna(),
        df_m["nummktcap"] * df_m["numccyqrateInv"],
        np.nan,
    )

    # Zero contributions when (nrLegs == 2) & (signOfLeg < 0)
    neg_leg_mask = (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0)
    for c in [
        "numEffectDurationContrib",
        "numMCDurationContrib",
        "numModifDurationContrib",
        "numSpreadDurationContrib",
    ]:
        out_col = {
            "numEffectDurationContrib": "InstrEffectiveDurationContribution",
            "numMCDurationContrib": "InstrMCDurationContribution",
            "numModifDurationContrib": "InstrModifiedDurationContribution",
            "numSpreadDurationContrib": "InstrSpreadDurationContribution",
        }[c]
        df_m[out_col] = np.where(neg_leg_mask, 0, df_m[c])

    print("InstrDurExposureInPortfCur & InstrDurExposureWeight rate...")
    # Duration exposure (cur & weight)
    qty_zero_mask = (df_m["nrLegs"] == 2) & (df_m["InstrQuantity"] == 0)
    df_m["InstrDurExposureInPortfCur"] = np.select(
        [qty_zero_mask, (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0)],
        [df_m["numWeightedAmtInReportPortf"], 0],
        default=df_m["numDurExposureInPortfCur"],
    )
    df_m["InstrDurExposureWeight"] = np.select(
        [
            qty_zero_mask & df_m["numFundAUM"].notna(),
            (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0),
        ],
        [df_m["numWeightedAmtInReportPortf"] / df_m["numFundAUM"], 0],
        default=df_m["numDurExposureWeight"],
    )

    print("FX family...")
    get_hardware_info()
    # FX family flag from IT class 3 IR name
    fx_family = (
        df_m["InstrumentTypeIRNameClass3"]
        .astype("string")
        .str.upper()
        .isin(["CURRENCY SPOT", "CURRENCY FORWARD", "CURRENCY SWAP", "FOREX POSITIONS"])
    )

    # Currency exposure (cur & weight)
    zero_qty_forward_mask = (df_m["InstrQuantity"] == 0) & (
        df_m["numHoldAvrgCostInReportPortf"] > 0
    )
    fx_flip_mask = fx_family & ((df_m["signOfLeg"] < 0) | zero_qty_forward_mask)

    # Cur exposure
    df_m["InstrCurExposureInPortfCur"] = np.select(
        [
            fx_flip_mask,  # flip + add PL portion
            (~fx_family) & (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0),  # zero out
        ],
        [
            (-df_m["numCurExposureInPortfCur"]).where(
                df_m["numCurExposureInPortfCur"].notna(), np.nan
            )
            + np.where(
                df_m["numFundAUM"].notna() & df_m["numInstrWeight"].notna(),
                df_m["numInstrWeight"] * df_m["numFundAUM"],
                0,
            ),
            0,
        ],
        default=df_m["numCurExposureInPortfCur"],
    )
    # DMC: for non-FX, ELSE branch is holding amount (not indicator)
    non_fx = ~fx_family
    df_m.loc[non_fx & ~neg_leg_mask, "InstrCurExposureInPortfCur"] = df_m[
        "numWeightedAmtInReportPortf"
    ]

    # Weight exposure
    print("Weight exposure...")
    df_m["InstrCurExposureWeight"] = np.select(
        [
            fx_flip_mask,  # flip + add weight
            (~fx_family) & (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0),  # zero out
        ],
        [
            (-df_m["numCurExposureWeight"]).where(df_m["numCurExposureWeight"].notna(), np.nan)
            + df_m["numInstrWeight"],
            0,
        ],
        default=df_m["numCurExposureWeight"],
    )
    # DMC: for non-FX, ELSE branch is amount/AUM
    df_m.loc[
        non_fx & ~neg_leg_mask & df_m["numFundAUM"].notna(), "InstrCurExposureWeight"
    ] = df_m["numWeightedAmtInReportPortf"] / df_m["numFundAUM"]

    # Instrument weight
    print("Instrument weight...")
    df_m["InstrWeight"] = np.where(
        df_m["numFundAUM"].notna() & (df_m["numFundAUM"] != 0),
        df_m["numWeightedAmtInReportPortf"] / df_m["numFundAUM"],
        np.nan,
    )

    # Market-cap tier (positive-only buckets)
    df_m["InstrMktCapEurTr1"] = np.select(
        [
            df_m["InstrMktCapEur"].gt(0) & df_m["InstrMktCapEur"].le(3e8),
            df_m["InstrMktCapEur"].gt(3e8) & df_m["InstrMktCapEur"].le(2.5e9),
            df_m["InstrMktCapEur"].gt(2.5e9) & df_m["InstrMktCapEur"].le(1e10),
            df_m["InstrMktCapEur"].gt(1e10),
        ],
        [
            "CR_DATA_MKTCAP1_4_0-300M",
            "CR_DATA_MKTCAP1_3_300M-2.5B",
            "CR_DATA_MKTCAP1_2_2.5B-10B",
            "CR_DATA_MKTCAP1_1_10B-MAX",
        ],
        default="CR_DATA_MKTCAP1_OTHER",
    ).astype("object")

    # dateEOM (exact end-of-month)
    df_m["dateEOM"] = pd.to_datetime(df_m["datPeriodLastDay"]) + pd.offsets.MonthEnd(0)

    # DMC: unconditional sector override for Cash/Derivatives when not bond/stock/...
    not_bond_stock_like = ~df_m["InstrumentTypeIRNameClass3"].astype("string").str.upper().str.contains(
        "BOND|STOCK|WARRANT|CDS|CORPORATE", na=False
    )
    is_cash = (
        df_m["InstrumentTypeIRNameClass9"].astype("string").str.upper().eq("CASH") & not_bond_stock_like
    )
    is_deriv = (
        df_m["InstrumentTypeIRNameClass9"]
        .astype("string")
        .str.upper()
        .str.contains("DERIVATIVES", na=False)
        & not_bond_stock_like
    )
    for pref in ["BB", "Barclays", "MSCI", "ICB"]:
        for lvl in ["1", "2", "3"]:
            c = f"InstrSector{pref}Level{lvl}"
            df_m.loc[is_cash, c] = "Cash"
            df_m.loc[is_deriv, c] = "Derivatives"

    # Map/rename instrument details to final names (already aligned above)
    # Sectors are already attached with names: InstrSectorBBLevel1..3, etc.

    # Core instrument fields
    df_m["InstrumentName"] = df_m["strInstName"]
    df_m["BloombergCode"] = df_m["strBloombergCode"]
    df_m["InstrISINCode"] = df_m["strInstISINCode"]
    df_m["InstSedolCode"] = df_m["strInstSedolCode"]
    df_m["InstCusipCode"] = df_m["strInstCUSIPCode"]
    df_m["InstrIssuerName"] = df_m["strInstIssuerName"]
    df_m["InstrExchangeLocationName"] = df_m["strInstExchLocName"]
    df_m["InstrListingCotationCountryLabel"] = df_m["strInstListingCountryLabel"]
    df_m["InstrIssueCountryLabel"] = df_m["strInstIssueCountryLabel"]
    df_m["InstrIssuerCountryLabel"] = df_m["strInstIssuerCountryLabel"]
    df_m["InstrRiskCountryLabel"] = df_m["strInstRiskCountryLabel"]
    df_m["InstrCouponRate"] = df_m["numInstCouponRate"]
    df_m["InstrForwardRate"] = df_m["numInstForwardRate"]
    df_m["InstrMaturityDate"] = df_m["datInstMaturityDate"]
    df_m["InstrCallDate"] = df_m["datInstCallDate"]
    df_m["InstrNextCouponDate"] = df_m["datInstNextCouponDate"]
    df_m["InstrRateType"] = df_m["strInstRateType"]
    df_m["InstrSpotRate"] = df_m["numInstSpotRate"]
    df_m["InstrStartDate"] = df_m["datInstStartDate"]
    df_m["InstrUnderlyingQuantity"] = df_m["numInstUndrlygQty"]
    df_m["InstrUnderlyingISINCode"] = df_m["strInstUndrlygISINCode"]
    df_m["InstrIssueDate"] = df_m["datInstIssueDate"]
    df_m["InstrNominalAmount"] = df_m["numInstNominalMt"]
    df_m["InstrRiskCurrency"] = df_m["strInstCurrCode"]
    df_m["InstrContractEndDate"] = df_m["datInstContractEnd"]
    df_m["InstrContractName"] = df_m["strInstContractName"]
    df_m["InstrLegType1"] = df_m["strInstLegTyp1"]
    df_m["InstrLegType2"] = df_m["strInstLegTyp2"]
    df_m["InstrLegType"] = df_m["strInstLegType"]
    df_m["InstrCouponTypePaid"] = df_m["strCpnRateTypPaid"]
    df_m["InstrCouponTypeReceived"] = df_m["strCpnRateTypeRecv"]
    df_m["InstrCouponFixedInterestRatePaid"] = df_m["numCpnFixedRatePaid"]
    df_m["InstrCouponFixedInterestRateReceived"] = df_m["numCpnFixedRateRecv"]
    df_m["SwapPaidFrequency"] = df_m["strSwapFreqPaid"]
    df_m["SwapReceivedFrequency"] = df_m["strSwapFreqRecv"]
    df_m["instrTypCd"] = df_m["strinstrmttypcd"]

    print(f"Vectorized build complete, rows: {len(df_m)}")
    get_hardware_info()

    columns = list(DMIRAPILTHolding.__table__.columns.keys())
    if df_m.empty:
        return pd.DataFrame(columns=columns)

    holding_key = [
        "strReportPortfGPSCode",  # or Portfolio-group for Alpha
        "datPeriodLastDay",
        "numReportPortfGroupID",  # Alpha uses this; DMC keeps it too (may be NULL)
        "numAuditId",
        "strInstAladdin",
        "numInstID",
    ]

    dup_mask = df_m.duplicated(subset=holding_key, keep="first")
    if dup_mask.any():
        n = dup_mask.sum()
        print(f"[dedup] WARNING: dropping {n} duplicate holdings before insert")
        df_m = df_m.loc[~dup_mask].copy()
    else:
        print("[dedup] Remove no duplication.")
    get_hardware_info()

    df_m = df_m[[c for c in columns if c in df_m.columns]]
    return df_m


def process_alpha_records(
    df_lt: pd.DataFrame,
    df_scope_alpha: pd.DataFrame,
    df_lt_ind: pd.DataFrame,
    num_audit_id: int,
) -> pd.DataFrame:
    # ────────────────────────────────────────────────────────────────────
    # 1)  scope filter  + audit flag
    # ────────────────────────────────────────────────────────────────────
    df_lt = (
        df_lt.assign(numAuditId=num_audit_id)
        .merge(
            df_scope_alpha,
            left_on=["numReportPortfGroupID", "datPeriodLastDay"],
            right_on=["numPortfGroupFkey", "datPeriodLastDay"],
            how="inner",
        )
        .query(
            "numLowestInventoryflag == 1 "
            "and strReportPortfGPSCode == 'NA' "
            "and numReportPortfGroupID != -1"
        )
    )

    if df_lt.empty:
        print("Alpha-LT: nothing to process after scope filter.")
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

    print(f"Alpha-LT rows after filter: {len(df_lt):,}")
    get_hardware_info()

    # ────────────────────────────────────────────────────────────────────
    # 2)  pandas aggregation (means / sums + nrLegs & signOfLeg)
    # ────────────────────────────────────────────────────────────────────
    group_cols = [
        "strReportPortfGPSCode",
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "numAuditId",
        "strInstAladdin",
        "numInstID",
    ]

    agg_spec = {
        "numHoldPrice": "mean",
        "numHoldAccruedIntPortf": "sum",
        "numWeightedAmtInReportPortf": "sum",
        "numHoldCrossCur": "mean",
        "numWeightedQtqInReportPortf": "sum",
        "numHoldAvrgCostInReportPortf": "sum",
        "numHoldQuantity": ["size", "min", "max"],
        "strInvestedInPortfISOCur": "first",
    }

    print("pandas groupby/agg …")
    get_hardware_info()

    # pandas ≥2.1 supports engine="pyarrow" for faster multi-threaded group-by;
    # if you have it, uncomment the next line.
    # df_agg = df_lt.groupby(group_cols, as_index=False, engine="pyarrow").agg(agg_spec)
    df_agg = df_lt.groupby(group_cols, as_index=False).agg(agg_spec)

    # flatten MultiIndex columns created by the last entry
    df_agg.columns = [
        "_".join(filter(None, col)).rstrip("_") if isinstance(col, tuple) else col
        for col in df_agg.columns
    ]
    df_agg = df_agg.rename(
        columns={
            "numHoldQuantity_size": "nrLegs",
            "numHoldQuantity_min": "q_min",
            "numHoldQuantity_max": "q_max",
            "numHoldPrice_mean": "numHoldPrice",
            "numHoldAccruedIntPortf_sum": "numHoldAccruedIntPortf",
            "numWeightedAmtInReportPortf_sum": "numWeightedAmtInReportPortf",
            "numHoldCrossCur_mean": "numHoldCrossCur",
            "numWeightedQtqInReportPortf_sum": "numWeightedQtqInReportPortf",
            "numHoldAvrgCostInReportPortf_sum": "numHoldAvrgCostInReportPortf",
        }
    )

    # vectorised signOfLeg
    df_agg["signOfLeg"] = np.select(
        [df_agg["q_min"] >= 0, df_agg["q_max"] < 0],
        [1, -1],
        default=0,
    )
    df_agg.loc[df_agg["nrLegs"] == 1, "signOfLeg"] = 0
    df_agg = df_agg.drop(columns=["q_min", "q_max"])

    print("Aggregation complete")
    get_hardware_info()

    # ────────────────────────────────────────────────────────────────────
    # 3)  parallel metadata fetches (helpers already defined)
    # ────────────────────────────────────────────────────────────────────
    inst_alds = set(df_agg["strInstAladdin"])
    period_ends = set(df_agg["datPeriodLastDay"])
    grp_ids = set(df_agg["numReportPortfGroupID"])

    df_i = pd.DataFrame(fetch_instruments_parallel(inst_alds, 2_000, max_workers=8))
    df_a = pd.DataFrame(fetch_analytics_parallel(inst_alds, period_ends, 2_000, max_workers=8))
    df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb = fetch_sectors_parallel(
        inst_alds, chunk_size=2_000, max_workers=8
    )

    # ────────────────────────────────────────────────────────────────────
    # 4)  serial pulls (quotes, AUM, link)
    # ────────────────────────────────────────────────────────────────────
    curr_codes = set(df_i["strInstCurrCode"].dropna())
    session = get_session()
    try:
        quotes_rows = (
            session.query(
                DMIRBRSCurrencyQuote.strCurrCode,
                DMIRBRSCurrencyQuote.datccyqDate,
                DMIRBRSCurrencyQuote.numccyqrateInv,
            )
            .filter(
                DMIRBRSCurrencyQuote.strCurrCode.in_(list(curr_codes)),
                DMIRBRSCurrencyQuote.datccyqDate.in_(list(period_ends)),
            )
            .all()
        )
        df_q = pd.DataFrame(
            [
                {
                    "strCurrCode": q.strCurrCode,
                    "datccyqDate": q.datccyqDate,
                    "numccyqrateInv": q.numccyqrateInv,
                }
                for q in quotes_rows
            ]
        )

        aum_rows = (
            session.query(
                DMIRBRSALPHAPortfGroupIndicators.numPortfGroupFkey,
                DMIRBRSALPHAPortfGroupIndicators.numAUM,
                DMIRBRSALPHAPortfGroupIndicators.datPeriodLastDay,
            )
            .filter(
                DMIRBRSALPHAPortfGroupIndicators.numPortfGroupFkey.in_(list(grp_ids)),
                DMIRBRSALPHAPortfGroupIndicators.datPeriodLastDay.in_(list(period_ends)),
                DMIRBRSALPHAPortfGroupIndicators.strPeriodTypeFlag == "M",
            )
            .all()
        )
        df_aum = pd.DataFrame(
            [
                {
                    "numReportPortfGroupID": r.numPortfGroupFkey,
                    "datPeriodLastDay": r.datPeriodLastDay,
                    "numAUM": r.numAUM,
                }
                for r in aum_rows
            ]
        )

        link_rows = (
            session.query(
                DMIRPortfolioLnk.numPortfGroupSkey, DMIRPortfolioLnk.strPortfGroupDECALOGCode
            )
            .filter(
                DMIRPortfolioLnk.numPortfGroupSkey.in_(list(map(int, grp_ids))),
                DMIRPortfolioLnk.strPortfGroupType.in_(["A", "G"]),
            )
            .all()
        )
        df_link = pd.DataFrame(
            [
                {
                    "numReportPortfGroupID": r.numPortfGroupSkey,
                    "strPortfGroupDECALOGCode": r.strPortfGroupDECALOGCode,
                }
                for r in link_rows
            ]
        )
    finally:
        session.close()

    # ────────────────────────────────────────────────────────────────────
    # 5)  merge all metadata
    # ────────────────────────────────────────────────────────────────────
    print("Merging metadata …")
    get_hardware_info()

    df = df_agg.merge(df_i, on="strInstAladdin", how="left")

    # limit signOfLeg to FX derivatives only (class9 == 'Derivatives - Forex')
    df["signOfLeg"] = np.where(
        df["InstrumentTypeIRNameClass9"].eq("Derivatives - Forex"), df["signOfLeg"], 0
    )
    df.loc[df["nrLegs"] == 1, "signOfLeg"] = 0

    if not df_a.empty:
        df_a["datInstQuotationDate"] = pd.to_datetime(df_a["datInstQuotationDate"])
        df = df.merge(
            df_a,
            left_on=["strInstAladdin", "datPeriodLastDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            how="left",
        ).drop(columns=["datInstQuotationDate"], errors="ignore")
        for src, dst in [
            ("numInstYieldToMaturity", "InstrYieldToMaturity"),
            ("numInstEffDuration", "InstrEffectiveDuration"),
            ("numInstModifDuration", "InstrModifiedDuration"),
            ("numInstSpreadDuration", "InstrSpreadDuration"),
            ("numInstMCDuration", "InstrMCDuration"),
            ("numInstYield", "InstrYield"),
            ("numInstYieldToCall", "InstrYieldCalculatedToMaturity"),
            ("numInstYieldToMaturityPaid", "InstrYieldToMaturityPaid"),
            ("numInstYieldToMaturityRecv", "InstrYieldToMaturityReceived"),
            ("numInstOptionAdjSpread", "InstrOAS"),
        ]:
            df[dst] = df[src]

    if not df_q.empty:
        df_q["datccyqDate"] = pd.to_datetime(df_q["datccyqDate"])
        df = df.merge(
            df_q,
            left_on=["strInstCurrCode", "datPeriodLastDay"],
            right_on=["strCurrCode", "datccyqDate"],
            how="left",
        ).drop(columns=["strCurrCode", "datccyqDate"], errors="ignore")

    for dfsb in (df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb):
        if not dfsb.empty:
            df = df.merge(dfsb, on="strInstAladdin", how="left")

    df_aum["datPeriodLastDay"] = pd.to_datetime(df_aum["datPeriodLastDay"])
    df = df.merge(df_link, on="numReportPortfGroupID", how="left").merge(
        df_aum, on=["numReportPortfGroupID", "datPeriodLastDay"], how="left"
    )

    # ────────────────────────────────────────────────────────────────────
    # 6)  merge ratings/exposures (df_lt_ind)
    # ────────────────────────────────────────────────────────────────────
    def _norm_date(s):
        s = pd.to_datetime(s, errors="coerce")
        try:
            s = s.dt.tz_localize(None)
        except Exception:
            pass
        return s.dt.normalize()

    def _nstr(s):
        return s.astype("string").str.strip()

    df["datPeriodLastDay"] = _norm_date(df["datPeriodLastDay"])
    df["strInstAladdin"] = _nstr(df["strInstAladdin"])
    df_lt_ind["datPeriodLastDay"] = _norm_date(df_lt_ind["datPeriodLastDay"])
    df_lt_ind["strInstAladdin"] = _nstr(df_lt_ind["strInstAladdin"])

    df = df.merge(
        df_lt_ind,
        left_on=["numReportPortfGroupID", "datPeriodLastDay", "strInstAladdin"],
        right_on=["numPortfGroupFKey", "datPeriodLastDay", "strInstAladdin"],
        how="left",
        suffixes=("", "_ind"),
    ).drop(columns=["numPortfGroupFKey"], errors="ignore")

    # overwrite/complete indicator columns from _ind
    overwrite_map = {
        "InstrEffectiveDurationContribution": "numEffectDurationContrib",
        "InstrMCDurationContribution": "numMCDurationContrib",
        "InstrModifiedDurationContribution": "numModifDurationContrib",
        "InstrSpreadDurationContribution": "numSpreadDurationContrib",
        "InstrDurExposureInPortfCur": "numDurExposureInPortfCur",
        "InstrCurExposureInPortfCur": "numCurExposureInPortfCur",
        "InstrCurExposureWeight": "numCurExposureWeight",
        "InstrDurExposureWeight": "numDurExposureWeight",
        "InstRtgSPStandardized": "strInstRtgSPStandardized",
        "InstRtgMDStandardized": "strInstRtgMDStandardized",
        "InstRtgFHStandardized": "strInstRtgFHStandardized",
        "InstrESGGlbScore": "numESGGlbScore",
        "InstrESGGlbScoreCov": "numESGGlbScoreCov",
        "InstrCO2IntensEVEval": "numCO2IntensEVEval",
        "InstrCO2IntensEVEvalCov": "numCO2IntensEVEvalCov",
    }

    print("df.columns", list(df.columns))
    for out_col, src in overwrite_map.items():
        if src in df.columns:
            if out_col in df.columns:
                df[out_col] = df[src].combine_first(df[out_col])
            else:
                df[out_col] = df[src]

    for k in range(1, 14):
        base = f"InstrCustomRating{k}"
        src = f"strInstRtgCustom{k}"
        if src in df.columns:
            if base in df.columns:
                df[base] = df[src].combine_first(df[base])
            else:
                df[base] = df[src]

    # ────────────────────────────────────────────────────────────────────
    # 7)  derived fields (weight, mkt-cap tier, etc.)
    # ────────────────────────────────────────────────────────────────────
    df["strSource"] = "ALP-LT"
    df["AccountingDate"] = pd.to_datetime(df["datPeriodLastDay"]).dt.normalize()
    df["PortfolioDWHID"] = None
    df["PortfolioDWHGroupID"] = df["numReportPortfGroupID"]
    df["InstrumentDWHID"] = df["numInstID"]
    df["InstrLastPriceDate"] = df["numHoldPrice"]
    df["InstrQuantity"] = df["numWeightedQtqInReportPortf"]
    df["InstrLastPrice"] = df["numHoldPrice"]
    # SQL uses numHoldCrossCur
    df["InstrExchangeRate"] = df["numHoldCrossCur"]
    # currency code invested
    df["InstrCurISOCode"] = df["strInvestedInPortfISOCur"]
    df["InstrMktCapEur"] = df["nummktcap"] * df["numccyqrateInv"]
    df["InstrWeight"] = df["numWeightedAmtInReportPortf"] / df["numAUM"]

    df["InstrMktCapEurTr1"] = np.select(
        [
            df["InstrMktCapEur"].gt(0) & df["InstrMktCapEur"].le(3e8),
            df["InstrMktCapEur"].gt(3e8) & df["InstrMktCapEur"].le(2.5e9),
            df["InstrMktCapEur"].gt(2.5e9) & df["InstrMktCapEur"].le(1e10),
            df["InstrMktCapEur"].gt(1e10),
        ],
        [
            "CR_DATA_MKTCAP1_4_0-300M",
            "CR_DATA_MKTCAP1_3_300M-2.5B",
            "CR_DATA_MKTCAP1_2_2.5B-10B",
            "CR_DATA_MKTCAP1_1_10B-MAX",
        ],
        default="CR_DATA_MKTCAP1_OTHER",
    ).astype("object")

    df["dateEOM"] = pd.to_datetime(df["datPeriodLastDay"]) + pd.offsets.MonthEnd(0)

    # Alpha: fallback only when empty
    not_bond_stock_like = ~df["InstrumentTypeIRNameClass3"].astype("string").str.upper().str.contains(
        "BOND|STOCK|WARRANT|CDS|CORPORATE", na=False
    )
    is_cash = df["InstrumentTypeIRNameClass9"].astype("string").str.upper().eq("CASH") & not_bond_stock_like
    is_deriv = (
        df["InstrumentTypeIRNameClass9"].astype("string").str.upper().str.contains("DERIVATIVES", na=False)
        & not_bond_stock_like
    )
    for pref in ["BB", "Barclays", "MSCI", "ICB"]:
        for lvl in ["1", "2", "3"]:
            c = f"InstrSector{pref}Level{lvl}"
            empty = df[c].isna() | (df[c].astype("string").str.strip() == "")
            df.loc[empty & is_cash, c] = "Cash"
            df.loc[empty & is_deriv, c] = "Derivatives"

    # Aladdin group code
    df["AladdinGroupCode"] = df["strPortfGroupDECALOGCode"]

    # Core instrument fields (mirror DMC block where relevant)
    df["InstrumentName"] = df["strInstName"]
    df["BloombergCode"] = df["strBloombergCode"]
    df["InstrISINCode"] = df["strInstISINCode"]
    df["InstSedolCode"] = df["strInstSedolCode"]
    df["InstCusipCode"] = df["strInstCUSIPCode"]
    df["InstrIssuerName"] = df["strInstIssuerName"]
    df["InstrExchangeLocationName"] = df["strInstExchLocName"]
    df["InstrListingCotationCountryLabel"] = df["strInstListingCountryLabel"]
    df["InstrIssueCountryLabel"] = df["strInstIssueCountryLabel"]
    df["InstrIssuerCountryLabel"] = df["strInstIssuerCountryLabel"]
    df["InstrRiskCountryLabel"] = df["strInstRiskCountryLabel"]
    df["InstrCouponRate"] = df["numInstCouponRate"]
    df["InstrForwardRate"] = df["numInstForwardRate"]
    df["InstrMaturityDate"] = df["datInstMaturityDate"]
    df["InstrCallDate"] = df["datInstCallDate"]
    df["InstrNextCouponDate"] = df["datInstNextCouponDate"]
    df["InstrRateType"] = df["strInstRateType"]
    df["InstrSpotRate"] = df["numInstSpotRate"]
    df["InstrStartDate"] = df["datInstStartDate"]
    df["InstrUnderlyingQuantity"] = df["numInstUndrlygQty"]
    df["InstrUnderlyingISINCode"] = df["strInstUndrlygISINCode"]
    df["InstrIssueDate"] = df["datInstIssueDate"]
    df["InstrNominalAmount"] = df["numInstNominalMt"]
    df["InstrRiskCurrency"] = df["strInstCurrCode"]
    df["InstrContractEndDate"] = df["datInstContractEnd"]
    df["InstrContractName"] = df["strInstContractName"]
    df["InstrLegType1"] = df["strInstLegTyp1"]
    df["InstrLegType2"] = df["strInstLegTyp2"]
    df["InstrLegType"] = df["strInstLegType"]
    df["InstrCouponTypePaid"] = df["strCpnRateTypPaid"]
    df["InstrCouponTypeReceived"] = df["strCpnRateTypeRecv"]
    df["InstrCouponFixedInterestRatePaid"] = df["numCpnFixedRatePaid"]
    df["InstrCouponFixedInterestRateReceived"] = df["numCpnFixedRateRecv"]
    df["SwapPaidFrequency"] = df["strSwapFreqPaid"]
    df["SwapReceivedFrequency"] = df["strSwapFreqRecv"]
    df["instrTypCd"] = df["strinstrmttypcd"]

    # Alpha coupon index truncation to 10 chars
    df["InstrCouponIndexPaid"] = (
        df["strCpnIndexPaid"].where(df["strCpnIndexPaid"].notna(), None).astype("object").str.slice(0, 10)
    )
    df["InstrCouponIndexReceived"] = (
        df["strCpnIndexRecv"].where(df["strCpnIndexRecv"].notna(), None).astype("object").str.slice(0, 10)
    )

    print(f"Alpha-LT build complete - rows: {len(df):,}")
    get_hardware_info()

    columns = list(DMIRAPILTHolding.__table__.columns.keys())
    if df.empty:
        return pd.DataFrame(columns=columns)

    holding_key = [
        "strReportPortfGPSCode",  # or Portfolio-group for Alpha
        "datPeriodLastDay",
        "numReportPortfGroupID",  # Alpha uses this; DMC keeps it too (may be NULL)
        "numAuditId",
        "strInstAladdin",
        "numInstID",
    ]

    dup_mask = df.duplicated(subset=holding_key, keep="first")
    if dup_mask.any():
        n = dup_mask.sum()
        print(f"[dedup] WARNING: dropping {n} duplicate holdings before insert")
        get_hardware_info()
        df = df.loc[~dup_mask].copy()
    else:
        print("[dedup] Remove no duplication.")

    df = df[[c for c in columns if c in df.columns]]

    return df


def _update_chunk_country_of_risk(chunk: pd.DataFrame, cutoff) -> pd.DataFrame:
    # mask recent rows in this chunk
    recent = pd.to_datetime(chunk["AccountingDate"]) >= cutoff
    if not recent.any():
        return chunk

    # collect unique aladdin codes in this chunk
    codes = chunk.loc[recent, "strInstAladdin"].unique().tolist()
    if not codes:
        return chunk

    # fetch mapping for these codes only
    session = get_session()
    chunk_size = 2000

    rows = []
    try:
        for i in range(0, len(codes), chunk_size):
            batch_ids = codes[i : i + chunk_size]
            res = (
                session.query(
                    DMIRFundCountryOfRisk.strInstAladdin,
                    DMIRFundCountryOfRisk.strRiskCountryLabel,
                )
                .filter(DMIRFundCountryOfRisk.strInstAladdin.in_(batch_ids))
                .all()
            )
            rows.extend(res)
    finally:
        session.close()

    mapping = {ald: label for ald, label in rows}

    # apply mapping
    new_labels = chunk.loc[recent, "strInstAladdin"].map(mapping)
    mask_map = new_labels.notna()
    chunk.loc[recent & mask_map, "InstrRiskCountryLabel"] = new_labels[mask_map]
    get_hardware_info()
    return chunk


def update_country_of_risk(df_api_lt_holding: pd.DataFrame, max_workers: int = 8):
    # compute cutoff date
    cutoff = pd.Timestamp.now().normalize() - pd.DateOffset(months=3)

    # split into chunks
    chunks = np.array_split(df_api_lt_holding, max_workers)

    # process in parallel
    updated = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = [executor.submit(_update_chunk_country_of_risk, ch, cutoff) for ch in chunks]
        for fut in as_completed(futures):
            updated.append(fut.result())

    # reassemble
    df_updated = pd.concat(updated, ignore_index=True)

    # if no rows at all, preserve columns
    if df_updated.empty:
        return pd.DataFrame(columns=df_api_lt_holding.columns)

    return df_updated


def _update_chunk_underlying_characteristics(chunk: pd.DataFrame, cutoff) -> pd.DataFrame:
    recent = pd.to_datetime(chunk["AccountingDate"]) >= cutoff

    # identify which rows need first- and second-level underlying
    mask_fb = recent & chunk["InstrumentTypeIRNameClass3"].eq("Future on bond")
    mask_lo = recent & chunk["InstrumentTypeIRNameClass3"].eq("Listed Option On Future On Bond")

    # collect all aladdin codes we need to look up
    codes = set(chunk.loc[mask_fb | mask_lo, "strInstAladdin"])
    if not codes:
        return chunk

    # fetch only those instrument rows
    session = get_session()
    inst_rows = []
    chunk_size = 2000
    try:
        codes = list(codes)
        for i in range(0, len(codes), chunk_size):
            batch_ids = codes[i : i + chunk_size]
            res = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin,
                    DMIRBRSInstrument.strInstUnderlygAladdin,
                    DMIRBRSInstrument.datInstMaturityDate,
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(batch_ids))
                .all()
            )
            inst_rows.extend(res)
    finally:
        session.close()

    # build maps
    underl_map = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst_rows}
    maturity_map = {r.strInstAladdin: r.datInstMaturityDate for r in inst_rows}

    # 8.2a: Future on bond → first-level
    if mask_fb.any():
        fb_al = chunk.loc[mask_fb, "strInstAladdin"].map(underl_map)
        fb_mat = fb_al.map(maturity_map)
        chunk.loc[mask_fb, "InstrMaturityDate"] = fb_mat.values

    # 8.2b: Listed Option On Future On Bond → second-level
    if mask_lo.any():
        lo_al1 = chunk.loc[mask_lo, "strInstAladdin"].map(underl_map)
        # fetch second-level underlyings if any new codes
        sec_codes = set(lo_al1.dropna())
        inst2 = []

        if sec_codes:
            session = get_session()
            try:
                for i in range(0, len(sec_codes), chunk_size):
                    batch_ids = sec_codes[i : i + chunk_size]
                    res = (
                        session.query(
                            DMIRBRSInstrument.strInstAladdin,
                            DMIRBRSInstrument.strInstUnderlygAladdin,
                            DMIRBRSInstrument.datInstMaturityDate,
                        )
                        .filter(DMIRBRSInstrument.strInstAladdin.in_(batch_ids))
                        .all()
                    )
                    inst2.extend(res)
            finally:
                session.close()
            underl_map2 = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst2}
            maturity_map2 = {r.strInstAladdin: r.datInstMaturityDate for r in inst2}
        else:
            underl_map2 = {}
            maturity_map2 = {}

        lo_al2 = lo_al1.map(underl_map2)
        lo_mat = lo_al2.map(maturity_map2)
        chunk.loc[mask_lo, "InstrMaturityDate"] = lo_mat.values

    get_hardware_info()
    return chunk


def update_underlying_characteristics(df_api_lt_holding: pd.DataFrame, max_workers: int = 8):
    cutoff = pd.Timestamp.now().normalize() - pd.DateOffset(months=3)

    # split DataFrame into chunks
    chunks = np.array_split(df_api_lt_holding, max_workers)

    # process in parallel
    updated = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = [
            executor.submit(_update_chunk_underlying_characteristics, ch, cutoff) for ch in chunks
        ]
        for fut in as_completed(futures):
            updated.append(fut.result())

    df_updated = pd.concat(updated, ignore_index=True)

    # if empty, preserve columns
    if df_updated.empty:
        return pd.DataFrame(columns=df_api_lt_holding.columns)

    return df_updated


def _update_chunk_underlying_sectors(
    chunk: pd.DataFrame, cutoff, relevant_types, agencies
) -> pd.DataFrame:
    # mask recent and relevant derivatives
    recent = pd.to_datetime(chunk["AccountingDate"]) >= cutoff
    deriv = chunk["InstrumentTypeIRNameClass9"].str.upper().str.contains("DERIVATIVES", na=False)
    mask = recent & deriv & chunk["InstrumentTypeIRNameClass3"].isin(relevant_types)
    if not mask.any():
        return chunk

    codes = chunk.loc[mask, "strInstAladdin"].unique().tolist()
    session = get_session()
    inst_rows = []
    chunk_size = 2000
    try:
        # fetch instrument → underlying mapping
        for i in range(0, len(codes), chunk_size):
            batch_ids = codes[i : i + chunk_size]
            res = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin, DMIRBRSInstrument.strInstUnderlygAladdin
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(batch_ids))
                .all()
            )
            inst_rows.extend(res)

        instr_map = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst_rows}
        underl_codes = [v for v in instr_map.values() if v]

        if underl_codes:
            # fetch underlying instrument country fields
            ul_rows = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin,
                    DMIRBRSInstrument.strInstIssueCountryLabel,
                    DMIRBRSInstrument.strInstIssuerCountryLabel,
                    DMIRBRSInstrument.strInstRiskCountryLabel,
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(underl_codes))
                .all()
            )
            country_map = {
                r.strInstAladdin: (
                    r.strInstIssueCountryLabel,
                    r.strInstIssuerCountryLabel,
                    r.strInstRiskCountryLabel,
                )
                for r in ul_rows
            }

            # fetch sectors for underlyings
            sect_rows = (
                session.query(
                    DMIRBRSInstSector.strInstAladdin,
                    DMIRBRSInstSector.strInstSectorAgy,
                    DMIRBRSInstSector.strInstSectorL1,
                    DMIRBRSInstSector.strInstSectorL2,
                    DMIRBRSInstSector.strInstSectorL3,
                    DMIRBRSInstSector.strIssSector1Label,
                    DMIRBRSInstSector.strIssSector2Label,
                    DMIRBRSInstSector.strIssSector3Label,
                )
                .filter(
                    DMIRBRSInstSector.strInstAladdin.in_(underl_codes),
                    DMIRBRSInstSector.strInstSectorAgy.in_(agencies.keys()),
                )
                .all()
            )
            sector_map = {(r.strInstSectorAgy, r.strInstAladdin): r for r in sect_rows}
        else:
            country_map = {}
            sector_map = {}
    finally:
        session.close()

    for idx in chunk.index[mask]:
        orig = chunk.at[idx, "strInstAladdin"]
        underl = instr_map.get(orig)
        # update sectors
        for ag, prefix in agencies.items():
            # determine column names
            col1 = f"InstrSector{prefix}Level1"
            col2 = f"InstrSector{prefix}Level2"
            col3 = f"InstrSector{prefix}Level3"
            row = sector_map.get((ag, underl))
            if row:
                val1 = row.strInstSectorL1 or row.strIssSector1Label
                val2 = row.strInstSectorL2 or row.strIssSector2Label
                val3 = row.strInstSectorL3 or row.strIssSector3Label
                if val1 is not None:
                    chunk.at[idx, col1] = val1
                if val2 is not None:
                    chunk.at[idx, col2] = val2
                if val3 is not None:
                    chunk.at[idx, col3] = val3
        # update country labels
        issue, issuer, risk = country_map.get(underl, (None, None, None))
        if issue:
            chunk.at[idx, "InstrIssueCountryLabel"] = issue
        if issuer:
            chunk.at[idx, "InstrIssuerCountryLabel"] = issuer
        if risk:
            chunk.at[idx, "InstrRiskCountryLabel"] = risk

    get_hardware_info()
    return chunk


def update_underlying_sectors(df_api_lt_holding: pd.DataFrame, max_workers: int = 8):
    cutoff = pd.Timestamp.now().normalize() - pd.DateOffset(months=3)
    relevant_types = {
        "Future on OPC",
        "CDS on Corporate",
        "CDS on Index",
        "CDS Tranche",
        "Forward Contracts",
        "Future on bond",
        "Future on bond index",
        "Future on stock",
        "Future on stock index",
        "Listed Option on Bond",
        "Listed Option On Index",
        "Listed Option on Stock",
        "Option on Stock derivatives",
        "OTC Option On Index",
        "OTC Option On Stock",
        "Warrant",
    }
    agencies = {"BNPP_BICS": "BB", "LH": "Barclays", "MSCI": "MSCI", "ICB": "ICB"}

    chunks = np.array_split(df_api_lt_holding, max_workers)
    updated = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = [
            executor.submit(_update_chunk_underlying_sectors, ch, cutoff, relevant_types, agencies)
            for ch in chunks
        ]
        for fut in as_completed(futures):
            updated.append(fut.result())

    df_updated = pd.concat(updated, ignore_index=True)
    if df_updated.empty:
        return pd.DataFrame(columns=df_api_lt_holding.columns)
    return df_updated


def _update_chunk_underlying_sectors_second_level(
    chunk: pd.DataFrame, cutoff, deriv2_types, agencies
) -> pd.DataFrame:
    recent = pd.to_datetime(chunk["AccountingDate"]) >= cutoff
    mask = (
        recent
        & chunk["InstrumentTypeIRNameClass9"].str.upper().str.contains("DERIVATIVES", na=False)
        & chunk["InstrumentTypeIRNameClass3"].isin(deriv2_types)
    )
    if not mask.any():
        return chunk

    # first-level underlying codes
    orig_codes = chunk.loc[mask, "strInstAladdin"].unique().tolist()

    session = get_session()
    chunk_size = 2000
    try:
        inst1 = []
        for i in range(0, len(orig_codes), chunk_size):
            batch_ids = orig_codes[i : i + chunk_size]
            res = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin, DMIRBRSInstrument.strInstUnderlygAladdin
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(batch_ids))
                .all()
            )
            inst1.extend(res)

        underl1_map = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst1}
        # collect second-level codes
        underl2_codes = [underl1_map.get(o) for o in orig_codes if underl1_map.get(o)]
        underl2_codes = list({c for c in underl2_codes if c})
        if not underl2_codes:
            return chunk

        # fetch second-level instrument countries
        inst2 = (
            session.query(
                DMIRBRSInstrument.strInstAladdin,
                DMIRBRSInstrument.strInstIssueCountryLabel,
                DMIRBRSInstrument.strInstIssuerCountryLabel,
                DMIRBRSInstrument.strInstRiskCountryLabel,
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(underl2_codes))
            .all()
        )
        country_map = {
            r.strInstAladdin: (
                r.strInstIssueCountryLabel,
                r.strInstIssuerCountryLabel,
                r.strInstRiskCountryLabel,
            )
            for r in inst2
        }

        # fetch sectors for second-level underlyings
        sect = (
            session.query(
                DMIRBRSInstSector.strInstAladdin,
                DMIRBRSInstSector.strInstSectorAgy,
                DMIRBRSInstSector.strInstSectorL1,
                DMIRBRSInstSector.strInstSectorL2,
                DMIRBRSInstSector.strInstSectorL3,
                DMIRBRSInstSector.strIssSector1Label,
                DMIRBRSInstSector.strIssSector2Label,
                DMIRBRSInstSector.strIssSector3Label,
            )
            .filter(
                DMIRBRSInstSector.strInstAladdin.in_(underl2_codes),
                DMIRBRSInstSector.strInstSectorAgy.in_(agencies),
            )
            .all()
        )
        sector_map = {(r.strInstSectorAgy, r.strInstAladdin): r for r in sect}

        # second-level issuer codes
        inst2_iss = (
            session.query(
                DMIRBRSInstrument.strInstAladdin, DMIRBRSInstrument.strInstIssuerCode
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(underl2_codes))
            .all()
        )
        issuer_map2 = {r.strInstAladdin: r.strInstIssuerCode for r in inst2_iss}
        issuer2_codes = [issuer_map2.get(u) for u in underl2_codes if issuer_map2.get(u)]

        issuer_rats2 = (
            session.query(DMIRBRSIssuerRating)
            .filter(
                DMIRBRSIssuerRating.strInstIssuerCode.in_(issuer2_codes),
                DMIRBRSIssuerRating.datIssuerRtgDate.in_(chunk.loc[mask, "dateEOM"].dropna().unique().tolist()),
                DMIRBRSIssuerRating.strIssuerRtgVision == "M",
            )
            .all()
        )
        issuer_rat2_map = {(r.strInstIssuerCode, r.datIssuerRtgDate): r for r in issuer_rats2}

        inst_rats2 = (
            session.query(DMIRBRSInstRating)
            .filter(
                DMIRBRSInstRating.strInstAladdin.in_(underl2_codes),
                DMIRBRSInstRating.datInstRtgDate.in_(chunk.loc[mask, "dateEOM"].dropna().unique().tolist()),
                DMIRBRSInstRating.strInstRtgVision == "M",
            )
            .all()
        )
        inst_rat2_map = {(r.strInstAladdin, r.datInstRtgDate): r for r in inst_rats2}

    finally:
        session.close()

    for idx in chunk.index[mask]:
        orig = chunk.at[idx, "strInstAladdin"]
        date_eom = chunk.at[idx, "dateEOM"]
        u1 = underl1_map.get(orig)
        u2 = u1  # second-level instrument key
        # update sectors
        for ag in agencies:
            pref = {"BNPP_BICS": "BB", "LH": "Barclays", "MSCI": "MSCI", "ICB": "ICB"}[ag]
            col1 = f"InstrSector{pref}Level1"
            col2 = f"InstrSector{pref}Level2"
            col3 = f"InstrSector{pref}Level3"
            r = sector_map.get((ag, u2))
            if r:
                v1 = r.strInstSectorL1 or r.strIssSector1Label
                v2 = r.strInstSectorL2 or r.strIssSector2Label
                v3 = r.strInstSectorL3 or r.strIssSector3Label
                if v1 is not None:
                    chunk.at[idx, col1] = v1
                if v2 is not None:
                    chunk.at[idx, col2] = v2
                if v3 is not None:
                    chunk.at[idx, col3] = v3
        # update countries
        issue, issuer, risk = country_map.get(u2, (None, None, None))
        if issue:
            chunk.at[idx, "InstrIssueCountryLabel"] = issue
        if issuer:
            chunk.at[idx, "InstrIssuerCountryLabel"] = issuer
        if risk:
            chunk.at[idx, "InstrRiskCountryLabel"] = risk

        # ratings coalesce (level-2 issuer preferred for this function)
        inst2 = inst_rat2_map.get((u2, date_eom))
        issr2 = issuer_rat2_map.get((issuer_map2.get(u2), date_eom))

        def coalesce(*vals):
            for v in vals:
                if pd.notna(v):
                    return v
            return None

        for fld in ["InstRtgSPStandardized", "InstRtgMDStandardized", "InstRtgFHStandardized"]:
            orig_val = chunk.at[idx, fld]
            inst2_val = getattr(inst2, f"strInstRtg{fld[4:]}", None) if inst2 else None
            issr2_val = getattr(issr2, f"strIssuerRtg{fld[4:]}", None) if issr2 else None
            chunk.at[idx, fld] = coalesce(orig_val, inst2_val, issr2_val)

        for i in range(1, 14):
            col = f"InstrCustomRating{i}"
            orig_val = chunk.at[idx, col]
            inst2_val = getattr(inst2, f"strInstRtgCustom{i}", None) if inst2 else None
            issr2_val = getattr(issr2, f"strIssuerRtgCustom{i}", None) if issr2 else None
            chunk.at[idx, col] = coalesce(orig_val, inst2_val, issr2_val)

    get_hardware_info()
    return chunk


def update_underlying_sectors_second_level(df_api_lt_holding: pd.DataFrame, max_workers: int = 8):
    cutoff = pd.Timestamp.now().normalize() - pd.DateOffset(months=3)
    deriv2_types = {
        "Listed Option On Future On Bond",
        "OTC Option On Future On Bond",
    }
    agencies = ["BNPP_BICS", "LH", "MSCI", "ICB"]

    # split and parallelize
    chunks = np.array_split(df_api_lt_holding, max_workers)
    updated = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = [
            executor.submit(
                _update_chunk_underlying_sectors_second_level, ch, cutoff, deriv2_types, agencies
            )
            for ch in chunks
        ]
        for fut in as_completed(futures):
            updated.append(fut.result())

    df_updated = pd.concat(updated, ignore_index=True)
    if df_updated.empty:
        return pd.DataFrame(columns=df_api_lt_holding.columns)
    return df_updated


def _process_chunk_ratings(chunk: pd.DataFrame, recent, types) -> pd.DataFrame:
    mask = recent[chunk.index] & chunk["InstrumentTypeIRNameClass3"].isin(types)
    if not mask.any():
        return chunk

    # collect unique aladdin codes and dateEOM
    codes = chunk.loc[mask, "strInstAladdin"].unique().tolist()
    dates = chunk.loc[mask, "dateEOM"].dropna().unique().tolist()
    if not codes or not dates:
        return chunk

    # 2) fetch underlying instrument → get underlying aladdin and issuer code
    session = get_session()
    inst_rows = []
    chunk_size = 2000
    try:
        for i in range(0, len(codes), chunk_size):
            batch_ids = codes[i : i + chunk_size]
            res = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin,
                    DMIRBRSInstrument.strInstUnderlygAladdin,
                    DMIRBRSInstrument.strInstIssuerCode,
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(batch_ids))
                .all()
            )
            inst_rows.extend(res)
    finally:
        session.close()

    underl_map = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst_rows}
    issuer_map = {r.strInstUnderlygAladdin: r.strInstIssuerCode for r in inst_rows}

    # 3) fetch InstRating for those underlying codes and dates
    underl_codes = list({underl_map[c] for c in codes if underl_map.get(c)})
    session = get_session()
    try:
        inst_ratings = (
            session.query(
                DMIRBRSInstRating.strInstAladdin,
                DMIRBRSInstRating.datInstRtgDate,
                DMIRBRSInstRating.strInstRtgSPStandardized,
                DMIRBRSInstRating.strInstRtgMDStandardized,
                DMIRBRSInstRating.strInstRtgFHStandardized,
                DMIRBRSInstRating.strInstRtgCustom1,
                DMIRBRSInstRating.strInstRtgCustom2,
                DMIRBRSInstRating.strInstRtgCustom3,
                DMIRBRSInstRating.strInstRtgCustom4,
                DMIRBRSInstRating.strInstRtgCustom5,
                DMIRBRSInstRating.strInstRtgCustom6,
                DMIRBRSInstRating.strInstRtgCustom7,
                DMIRBRSInstRating.strInstRtgCustom8,
                DMIRBRSInstRating.strInstRtgCustom9,
                DMIRBRSInstRating.strInstRtgCustom10,
                DMIRBRSInstRating.strInstRtgCustom11,
                DMIRBRSInstRating.strInstRtgCustom12,
                DMIRBRSInstRating.strInstRtgCustom13,
            )
            .filter(
                DMIRBRSInstRating.strInstAladdin.in_(underl_codes),
                DMIRBRSInstRating.datInstRtgDate.in_(dates),
                DMIRBRSInstRating.strInstRtgVision == "M",
            )
            .all()
        )

        issuer_codes = list({issuer_map.get(u) for u in underl_codes if issuer_map.get(u)})
        issuer_ratings = (
            session.query(
                DMIRBRSIssuerRating.strInstIssuerCode,
                DMIRBRSIssuerRating.datIssuerRtgDate,
                DMIRBRSIssuerRating.strIssuerRtgSPStandardized,
                DMIRBRSIssuerRating.strIssuerRtgMDStandardized,
                DMIRBRSIssuerRating.strIssuerRtgFHStandardized,
                DMIRBRSIssuerRating.strIssuerRtgCustom1,
                DMIRBRSIssuerRating.strIssuerRtgCustom2,
                DMIRBRSIssuerRating.strIssuerRtgCustom3,
                DMIRBRSIssuerRating.strIssuerRtgCustom4,
                DMIRBRSIssuerRating.strIssuerRtgCustom5,
                DMIRBRSIssuerRating.strIssuerRtgCustom6,
                DMIRBRSIssuerRating.strIssuerRtgCustom7,
                DMIRBRSIssuerRating.strIssuerRtgCustom8,
                DMIRBRSIssuerRating.strIssuerRtgCustom9,
                DMIRBRSIssuerRating.strIssuerRtgCustom10,
                DMIRBRSIssuerRating.strIssuerRtgCustom11,
                DMIRBRSIssuerRating.strIssuerRtgCustom12,
                DMIRBRSIssuerRating.strIssuerRtgCustom13,
            )
            .filter(
                DMIRBRSIssuerRating.strInstIssuerCode.in_(issuer_codes),
                DMIRBRSIssuerRating.datIssuerRtgDate.in_(dates),
                DMIRBRSIssuerRating.strIssuerRtgVision == "M",
            )
            .all()
        )
    finally:
        session.close()

    inst_dict = {(r.strInstAladdin, r.datInstRtgDate): r for r in inst_ratings}
    issuer_dict = {(r.strInstIssuerCode, r.datIssuerRtgDate): r for r in issuer_ratings}

    # 4) apply updates
    for idx in chunk.index[mask]:
        orig = chunk.at[idx, "strInstAladdin"]
        dat = chunk.at[idx, "dateEOM"]
        underl = underl_map.get(orig)
        inst_rat = inst_dict.get((underl, dat))
        issuer = issuer_map.get(underl)
        iss_rat = issuer_dict.get((issuer, dat))

        # helper to choose
        def choose(orig_val, inst_val, iss_val):
            return orig_val if pd.notna(orig_val) else (inst_val or iss_val)

        chunk.at[idx, "InstRtgSPStandardized"] = choose(
            chunk.at[idx, "InstRtgSPStandardized"],
            getattr(inst_rat, "strInstRtgSPStandardized", None),
            getattr(iss_rat, "strIssuerRtgSPStandardized", None),
        )
        chunk.at[idx, "InstRtgMDStandardized"] = choose(
            chunk.at[idx, "InstRtgMDStandardized"],
            getattr(inst_rat, "strInstRtgMDStandardized", None),
            getattr(iss_rat, "strIssuerRtgMDStandardized", None),
        )
        chunk.at[idx, "InstRtgFHStandardized"] = choose(
            chunk.at[idx, "InstRtgFHStandardized"],
            getattr(inst_rat, "strInstRtgFHStandardized", None),
            getattr(iss_rat, "strIssuerRtgFHStandardized", None),
        )
        for i in range(1, 14):
            orig_cr = chunk.at[idx, f"InstrCustomRating{i}"]
            inst_cr = getattr(inst_rat, f"strInstRtgCustom{i}", None)
            iss_cr = getattr(iss_rat, f"strIssuerRtgCustom{i}", None)
            chunk.at[idx, f"InstrCustomRating{i}"] = choose(orig_cr, inst_cr, iss_cr)

    get_hardware_info()
    return chunk


def update_ratings(df_api_lt_holding: pd.DataFrame, max_workers: int = 8):
    # 1) compute cutoff and mask
    cutoff = pd.Timestamp.now().normalize() - pd.DateOffset(months=3)
    recent = pd.to_datetime(df_api_lt_holding["AccountingDate"]) >= cutoff
    types = {"CDS on Corporate", "Future on bond", "Listed Option on Bond", "CDS on Index"}

    # split into chunks
    chunks = np.array_split(df_api_lt_holding, max_workers)
    updated = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = [executor.submit(_process_chunk_ratings, ch, recent, types) for ch in chunks]
        for fut in as_completed(futures):
            updated.append(fut.result())

    df_updated = pd.concat(updated, ignore_index=True)
    if df_updated.empty:
        return pd.DataFrame(columns=df_api_lt_holding.columns)
    return df_updated


def _process_chunk_deriv2(chunk: pd.DataFrame, cutoff, valid_types) -> pd.DataFrame:
    # mask recent & relevant derivatives
    recent = pd.to_datetime(chunk["AccountingDate"]) >= cutoff
    deriv2 = chunk["InstrumentTypeIRNameClass3"].isin(valid_types)
    mask = recent & deriv2
    if not mask.any():
        return chunk

    # gather keys
    codes = chunk.loc[mask, "strInstAladdin"].unique().tolist()
    dates = chunk.loc[mask, "dateEOM"].dropna().unique().tolist()
    if not codes or not dates:
        return chunk

    session = get_session()
    try:
        # fetch underlying1 and issuer codes
        inst1 = (
            session.query(
                DMIRBRSInstrument.strInstAladdin,
                DMIRBRSInstrument.strInstUnderlygAladdin,
                DMIRBRSInstrument.strInstIssuerCode,
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(codes))
            .all()
        )
        underl1_map = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst1}
        issuer_map = {r.strInstUnderlygAladdin: r.strInstIssuerCode for r in inst1}

        # prepare lists for ratings queries
        underl1_codes = [underl1_map[c] for c in codes if underl1_map.get(c)]
        # fetch instRat (level 1)

        inst_rats = []
        chunk_size = 2000
        for i in range(0, len(underl1_codes), chunk_size):
            batch_ids = underl1_codes[i : i + chunk_size]
            res = (
                session.query(DMIRBRSInstRating)
                .filter(
                    DMIRBRSInstRating.strInstAladdin.in_(batch_ids),
                    DMIRBRSInstRating.datInstRtgDate.in_(dates),
                    DMIRBRSInstRating.strInstRtgVision == "M",
                )
                .all()
            )
            inst_rats.extend(res)
        inst_rat_map = {(r.strInstAladdin, r.datInstRtgDate): r for r in inst_rats}

        # fetch issuerRat (level 1)
        issuer_codes = list({issuer_map.get(u) for u in underl1_codes if issuer_map.get(u)})
        issuer_rats = (
            session.query(DMIRBRSIssuerRating)
            .filter(
                DMIRBRSIssuerRating.strInstIssuerCode.in_(issuer_codes),
                DMIRBRSIssuerRating.datIssuerRtgDate.in_(dates),
                DMIRBRSIssuerRating.strIssuerRtgVision == "M",
            )
            .all()
        )
        issuer_rat_map = {(r.strInstIssuerCode, r.datIssuerRtgDate): r for r in issuer_rats}

        # fetch level-2 underlyings
        inst2 = []
        for i in range(0, len(underl1_codes), chunk_size):
            batch_ids = underl1_codes[i : i + chunk_size]
            res = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin, DMIRBRSInstrument.strInstUnderlygAladdin
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(underl1_codes))
                .all()
            )
            inst2.extend(res)
        underl2_map = {r.strInstAladdin: r.strInstUnderlygAladdin for r in inst2}
        underl2_codes = list({underl2_map[u] for u in underl1_codes if underl2_map.get(u)})

        # fetch instRat2 (level 2)
        inst_rats2 = (
            session.query(DMIRBRSInstRating)
            .filter(
                DMIRBRSInstRating.strInstAladdin.in_(underl2_codes),
                DMIRBRSInstRating.datInstRtgDate.in_(dates),
                DMIRBRSInstRating.strInstRtgVision == "M",
            )
            .all()
        )
        inst_rat2_map = {(r.strInstAladdin, r.datInstRtgDate): r for r in inst_rats2}

        # fetch issuerRat2 (level 2) using issuer of level-2
        inst2_iss = (
            session.query(
                DMIRBRSInstrument.strInstAladdin, DMIRBRSInstrument.strInstIssuerCode
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(underl2_codes))
            .all()
        )
        issuer_map2 = {r.strInstAladdin: r.strInstIssuerCode for r in inst2_iss}
        issuer2_codes = [issuer_map2.get(u) for u in underl2_codes if issuer_map2.get(u)]
        issuer_rats2 = (
            session.query(DMIRBRSIssuerRating)
            .filter(
                DMIRBRSIssuerRating.strInstIssuerCode.in_(issuer2_codes),
                DMIRBRSIssuerRating.datIssuerRtgDate.in_(dates),
                DMIRBRSIssuerRating.strIssuerRtgVision == "M",
            )
            .all()
        )
        issuer_rat2_map = {(r.strInstIssuerCode, r.datIssuerRtgDate): r for r in issuer_rats2}

    finally:
        session.close()

    # coalesce helper
    def coalesce(*vals):
        for v in vals:
            if pd.notna(v):
                return v
        return None

    # apply updates
    for idx in chunk.index[mask]:
        orig = chunk.at[idx, "strInstAladdin"]
        date_eom = chunk.at[idx, "dateEOM"]
        u1 = underl1_map.get(orig)
        u2 = underl2_map.get(u1, None)
        iss1 = issuer_map.get(u1)
        iss2 = issuer_map2.get(u2)

        inst1 = inst_rat_map.get((u1, date_eom))
        issr1 = issuer_rat_map.get((iss1, date_eom))
        inst2 = inst_rat2_map.get((u2, date_eom))
        issr2 = issuer_rat2_map.get((iss2, date_eom))

        # update SP,MD,FH
        for fld in ["InstRtgSPStandardized", "InstRtgMDStandardized", "InstRtgFHStandardized"]:
            orig_val = chunk.at[idx, fld]
            inst_val = getattr(inst1, f"strInstRtg{fld[4:]}", None) if inst1 else None
            issr_val = getattr(issr1, f"strIssuerRtg{fld[4:]}", None) if issr1 else None
            inst2_val = getattr(inst2, f"strInstRtg{fld[4:]}", None) if inst2 else None
            issr2_val = getattr(issr2, f"strIssuerRtg{fld[4:]}", None) if issr2 else None
            chunk.at[idx, fld] = coalesce(orig_val, inst_val, issr_val, inst2_val, issr2_val)

        # custom ratings 1-13
        for i in range(1, 14):
            col = f"InstrCustomRating{i}"
            orig_val = chunk.at[idx, col]
            inst_val = getattr(inst1, f"strInstRtgCustom{i}", None) if inst1 else None
            issr_val = getattr(issr1, f"strIssuerRtgCustom{i}", None) if issr1 else None
            inst2_val = getattr(inst2, f"strInstRtgCustom{i}", None) if inst2 else None
            issr2_val = getattr(issr2, f"strIssuerRtgCustom{i}", None) if issr2 else None
            chunk.at[idx, col] = coalesce(orig_val, inst_val, issr_val, inst2_val, issr2_val)

    get_hardware_info()
    return chunk


def update_derivatives_on_derivatives_ratings(
    df_api_lt_holding: pd.DataFrame, max_workers: int = 8
):
    # cutoff date
    cutoff = pd.Timestamp.now().normalize() - pd.DateOffset(months=3)
    valid_types = {
        "Listed Option On Future On Bond",
        "OTC Option On Future On Bond",
    }

    # split and parallelize
    chunks = np.array_split(df_api_lt_holding, max_workers)
    updated = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = [executor.submit(_process_chunk_deriv2, ch, cutoff, valid_types) for ch in chunks]
        for fut in as_completed(futures):
            updated.append(fut.result())

    df_updated = pd.concat(updated, ignore_index=True)
    if df_updated.empty:
        return pd.DataFrame(columns=df_api_lt_holding.columns)
    return df_updated


def _clean_record(rec: dict) -> dict:
    """Apply your cleaning rules in-place and return the dict."""
    for k, v in list(rec.items()):
        if isinstance(v, decimal.Decimal):
            rec[k] = float(v)
        elif v == "" or v == " " or (pd.isna(v) if v is not None else False):
            rec[k] = None
        elif k == "InstrIssuerName" and v is not None:
            rec[k] = str(v)[:80]
    return rec


def _delete_insert_single(i, key_tuple, df_group, retry=5, sleep_s=8):
    """
    Parallel worker: delete existing rows for key, then bulk insert df_group.
    key_tuple: (PortfolioDWHID, PortfolioDWHGroupID, AccountingDate)
    """
    session = get_session()
    try:
        portf_id, group_id, acct_date = key_tuple
        print(f"[{i}] Processing key: portfolio={portf_id}, group={group_id}, date={acct_date}")

        # --- DELETE for this key ---
        if portf_id is not None and group_id is None:
            q = session.query(DMIRAPILTHolding).filter(
                and_(
                    DMIRAPILTHolding.PortfolioDWHID == portf_id,
                    DMIRAPILTHolding.PortfolioDWHGroupID.is_(None),
                    DMIRAPILTHolding.AccountingDate == acct_date,
                )
            )
        elif group_id is not None and portf_id is None:
            q = session.query(DMIRAPILTHolding).filter(
                and_(
                    DMIRAPILTHolding.PortfolioDWHGroupID == group_id,
                    DMIRAPILTHolding.PortfolioDWHID.is_(None),
                    DMIRAPILTHolding.AccountingDate == acct_date,
                )
            )
        else:
            # invalid key for this table's rules; skip
            print(f"[{i}] Skipping invalid key (both IDs null or both set): {key_tuple}")
            session.close()
            return 0

        deleted = q.delete(synchronize_session=False)
        session.commit()
        print(f"[{i}] Deleted {deleted} rows")

        # --- INSERT all rows for this key ---
        mappings = []
        for rec in df_group.to_dict("records"):
            mappings.append(_clean_record(rec))

        if mappings:
            session.bulk_insert_mappings(DMIRAPILTHolding, mappings)
        get_hardware_info()
        session.commit()
        print(f"[{i}] Inserted {len(mappings)} rows")
        return len(mappings)

    except Exception as e:
        session.rollback()
        if retry > 0:
            print(f"[{i}] Error: {e}. Retrying in {sleep_s}s (left: {retry})")
            time.sleep(sleep_s)
            return _delete_insert_single(
                i, key_tuple, df_group, retry=retry - 1, sleep_s=min(30, sleep_s * 2)
            )
        raise
    finally:
        session.close()


def final_upsert_holdings(df_final: pd.DataFrame, max_workers: int = 32):
    """
    Strategy 1 (parallel delete then insert) for dbo.DMIRAPILTHolding.
    Groups by (PortfolioDWHID, PortfolioDWHGroupID, AccountingDate) and processes each group in parallel.
    Only valid key shapes are processed:
      - (PortfolioID, None, Date)
      - (None, GroupID, Date)
    """

    # Ensure AccountingDate is a date (not string)
    if "AccountingDate" in df_final.columns:
        df_final = df_final.copy()
        df_final["AccountingDate"] = pd.to_datetime(df_final["AccountingDate"]).dt.date

    # Build groups
    key_cols = ["PortfolioDWHID", "PortfolioDWHGroupID", "AccountingDate"]
    groups_it = df_final.groupby(key_cols, dropna=False)
    del df_final

    # Optionally filter invalid keys up-front (both IDs non-null or both null)
    valid_groups = []
    for (portf_id, group_id, acct_date), gdf in groups_it:
        has_portf = (portf_id is not None) and (not pd.isna(portf_id))
        has_group = (group_id is not None) and (not pd.isna(group_id))
        if has_portf ^ has_group:  # exactly one of them present
            valid_groups.append(
                (
                    (None if pd.isna(portf_id) else portf_id),
                    (None if pd.isna(group_id) else group_id),
                    acct_date,
                    gdf,
                )
            )
        else:
            print(f"[skip] invalid key: portfolio={portf_id} group={group_id} date={acct_date}")

    # Dispatch parallel workers
    inserted_total = 0
    futures = {}
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        for i, (portf_id, group_id, acct_date, gdf) in enumerate(valid_groups):
            key = (portf_id, group_id, acct_date)
            futures[executor.submit(_delete_insert_single, i, key, gdf)] = key

        for fut in as_completed(futures):
            key = futures[fut]
            try:
                cnt = fut.result() or 0
                inserted_total += cnt
                print(f"[OK] {key} -> inserted {cnt} (total {inserted_total})")
            except Exception as e:
                print(f"[ERROR] {key}: {e}")

    return inserted_total

