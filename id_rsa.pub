import concurrent.futures

# Configuration and utility imports
from datetime import datetime

# Data processing imports
import numpy as np
import pandas as pd
from sqlalchemy import and_, or_

from dags.benchmark_aggregates_holdings.bench_utils import safe_close
from dags.common.dmir_connections import get_session
from dags.common.models import (
    DMIRBRSBenchIndicators,
    DMIRBRSInstAnalytic,
    DMIRBRSInstrument,
    DMIRInstrumentIRType,
    DMIRRatingIREvaluation,
)
from dags.common.utils import chunker, get_all_as_df, get_hardware_info


def calc_maturity_diff(row):
    """Calculate the maturity difference in days between reporting date and maturity/call date."""
    rep_day = pd.to_datetime(row["datReportingDay"])
    mat_date = (
        pd.to_datetime(row["datInstMaturityDate"])
        if pd.notnull(row["datInstMaturityDate"])
        else None
    )
    call_date = (
        pd.to_datetime(row["datInstCallDate"]) if pd.notnull(row["datInstCallDate"]) else None
    )

    if (mat_date is None) or (rep_day is None):
        return 0

    if mat_date <= rep_day:
        return 0
    elif (row.get("blncall", 0) == 1) and (call_date is not None):
        return (call_date - rep_day).days
    else:
        return (mat_date - rep_day).days


def chunk_list(lst, chunk_size):
    """Split a list into chunks of the specified size."""
    for i in range(0, len(lst), chunk_size):
        yield lst[i : i + chunk_size]


def orm_to_df(rows):
    """Convert SQLAlchemy ORM rows to a pandas DataFrame."""
    if not rows:
        return pd.DataFrame()
    return pd.DataFrame(
        [{c.name: getattr(row, c.name) for c in row.__table__.columns} for row in rows]
    )


def divide_numweight(group, col):
    weight = group["numweight"].sum()
    return group[col].sum() / weight if weight != 0 else np.nan


def single_compute_bench_indicators_bkgn_10(
    i,
    numBenchFBAId,
    strCompositionCd,
    datReportingDay,
    strPeriodTypeFlag,
    strPFCurrencyISOCode,
    group_df,
    retry=3,
):
    print(f"Computing bkgn 10 for chunk {i}")
    get_hardware_info()
    final_results = []
    session = None
    try:
        session = get_session()
        instruments = group_df["strInstAladdin"].unique().tolist()
        group_keys = [
            "numBenchFBAId",
            "strCompositionCd",
            "datReportingDay",
            "strPeriodTypeFlag",
            "strPFCurrencyISOCode",
        ]

        inst_dfs = []
        for chunk in chunk_list(instruments, 2000):
            query_a = (
                session.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.numInstEffDuration,
                    DMIRBRSInstAnalytic.numInstModifDuration,
                    DMIRBRSInstAnalytic.numInstMCDuration,
                    DMIRBRSInstAnalytic.numInstYieldToMaturity,
                    DMIRBRSInstAnalytic.numInstConvexity,
                    DMIRBRSInstAnalytic.numInstSpreadDuration,
                    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
                    DMIRBRSInstAnalytic.numyldtoworst,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.strInstIssuerCode,
                    DMIRBRSInstrument.numInstCouponRate,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.datInstCallDate,
                    DMIRBRSInstrument.numInstTypeId,
                    DMIRBRSInstrument.blncall,
                )
                .select_from(DMIRBRSInstAnalytic)
                .outerjoin(
                    DMIRBRSInstrument,
                    DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                )
                .filter(
                    DMIRBRSInstAnalytic.datInstQuotationDate == datReportingDay,
                    DMIRBRSInstAnalytic.strInstAladdin.in_(chunk),
                )
            )
            inst_dfs.append(get_all_as_df(query_a))
        df_inst = pd.concat(inst_dfs, ignore_index=True)
        del inst_dfs

        if df_inst.empty:
            df_inst = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "numInstEffDuration",
                    "numInstModifDuration",
                    "numInstMCDuration",
                    "numInstYieldToMaturity",
                    "numInstConvexity",
                    "numInstSpreadDuration",
                    "numyldtoworst",
                    "numInstOptionAdjSpread",
                    "datInstQuotationDate",
                    "strInstIssuerCode",
                    "numInstCouponRate",
                    "datInstMaturityDate",
                    "datInstCallDate",
                    "numInstTypeId",
                ]
            )

        df_inst["datInstQuotationDate"] = pd.to_datetime(df_inst["datInstQuotationDate"])

        # Merge group CSV data with analytic data.
        df_a = pd.merge(
            group_df,
            df_inst,
            how="left",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            suffixes=("_group", ""),
        )
        del df_inst

        # Compute aggregated columns.
        df_a["curExposureBench"] = df_a["numCurExposureInBenchCur"]
        df_a["durExposureBench"] = df_a["numDurExposureInBenchCur"]
        df_a["effectDurationBench"] = df_a["numInstEffDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["modifDurationBench"] = df_a["numInstModifDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["MCDurationBench"] = df_a["numInstMCDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["benchAvgCoupon"] = df_a["numInstCouponRate"].astype(float) * df_a["numweight"].astype(
            float
        )
        df_a["benchAvgYTM"] = df_a["numInstYieldToMaturity"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["benchAvgConvexity"] = df_a["numInstConvexity"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["spreadDurationBench"] = df_a["numInstSpreadDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["benchAvgOas"] = df_a["numInstOptionAdjSpread"].astype(float).fillna(0) * df_a[
            "numDurExposureWeight"
        ].astype(float).fillna(0)
        df_a["benchAvgDts"] = (
            df_a["numInstOptionAdjSpread"].astype(float).fillna(0)
            * df_a["numInstSpreadDuration"].astype(float).fillna(0)
            * df_a["numDurExposureWeight"].astype(float).fillna(0)
        )
        df_a["benchAvgYTMDurWeighted"] = df_a["numInstYieldToMaturity"].astype(float) * df_a[
            "numModifDurationContribWeight"
        ].astype(float)
        df_a["benchAvgYieldWorst"] = df_a["numyldtoworst"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)

        # Compute weighted maturity difference.
        df_a["maturity_diff"] = df_a.apply(
            lambda row: calc_maturity_diff(row) * row["numweight"], axis=1
        )

        # Group by the keys and aggregate.
        agg_dict_a = {
            "curExposureBench": "sum",
            "durExposureBench": "sum",
            "effectDurationBench": "sum",
            "modifDurationBench": "sum",
            "MCDurationBench": "sum",
            "benchAvgCoupon": "sum",
            "benchAvgYTM": "sum",
            "benchAvgConvexity": "sum",
            "spreadDurationBench": "sum",
            "benchAvgOas": "sum",
            "benchAvgDts": "sum",
            "benchAvgYTMDurWeighted": "sum",
            "benchAvgYieldWorst": "sum",
            "maturity_diff": "sum",
            "strInstIssuerCode": pd.Series.nunique,
        }
        df_a_grouped = df_a.groupby(group_keys).agg(agg_dict_a).reset_index()
        df_a_grouped["datBenchAvgMaturityLife"] = (
            pd.to_datetime(df_a_grouped["datReportingDay"])
            + pd.to_timedelta(df_a_grouped["maturity_diff"], unit="days")
            if df_a_grouped["maturity_diff"].sum() > 0
            else pd.NaT
        )
        df_a_grouped.drop(columns=["maturity_diff"], inplace=True)
        df_a_grouped.rename(columns={"strInstIssuerCode": "numNumberOfIssuers"}, inplace=True)
        group_a = df_a_grouped.iloc[0].to_dict() if not df_a_grouped.empty else {}

        del df_a
        del df_a_grouped

        inst_dfs_B = []
        for chunk in chunk_list(instruments, 2000):
            query_b = (
                session.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.numInstEffDuration,
                    DMIRBRSInstAnalytic.numInstModifDuration,
                    DMIRBRSInstAnalytic.numInstMCDuration,
                    DMIRBRSInstAnalytic.numInstYieldToMaturity,
                    DMIRBRSInstAnalytic.numInstConvexity,
                    DMIRBRSInstAnalytic.numInstSpreadDuration,
                    DMIRBRSInstAnalytic.numyldtoworst,
                    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.strInstIssuerCode,
                )
                .select_from(DMIRBRSInstrument)
                .outerjoin(
                    DMIRBRSInstAnalytic,
                    and_(DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin),
                )
                .join(
                    DMIRInstrumentIRType,
                    and_(
                        DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                    ),
                )
                .filter(
                    DMIRBRSInstAnalytic.strInstAladdin.in_(chunk),
                    DMIRBRSInstAnalytic.datInstQuotationDate == datReportingDay,
                    DMIRInstrumentIRType.strReportingType == "class4",
                    DMIRInstrumentIRType.strInstrumentTypeIRName.in_(
                        ["Derivatives - Fixed Income", "Fixed Income", "MF - Fixed Income"]
                    ),
                )
            )
            inst_dfs_B.append(get_all_as_df(query_b))

        df_inst_B = pd.concat(
            inst_dfs_B,
            ignore_index=True,
        )
        if df_inst_B.empty:
            df_inst_B = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "numInstEffDuration",
                    "numInstModifDuration",
                    "numInstMCDuration",
                    "numInstYieldToMaturity",
                    "numInstConvexity",
                    "numInstSpreadDuration",
                    "numyldtoworst",
                    "numInstOptionAdjSpread",
                    "datInstQuotationDate",
                    "strInstIssuerCode",
                ]
            )

        df_inst_B["datInstQuotationDate"] = pd.to_datetime(df_inst_B["datInstQuotationDate"])
        # Merge group CSV data with analytic and then with the filtered instrument data.
        df_b = pd.merge(
            group_df,
            df_inst_B,
            how="inner",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            suffixes=("_group", ""),
        )
        del inst_dfs_B

        # Compute FI weighted metrics.
        df_b["effDurationBenchFI"] = df_b["numInstEffDuration"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["modifDurationBenchFI"] = df_b["numInstModifDuration"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["MCDurationBenchFI"] = df_b["numInstMCDuration"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["benchAvgYTMFI"] = df_b["numInstYieldToMaturity"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["benchAvgConvexityFI"] = df_b["numInstConvexity"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["spreadDurationBenchFI"] = df_b["numInstSpreadDuration"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["benchAvgYTMDurWeightedFI"] = df_b["numInstYieldToMaturity"].astype(float) * df_b[
            "numModifDurationContribWeight"
        ].astype(float)
        df_b["benchAvgYieldWorstFI"] = df_b["numyldtoworst"].astype(float) * df_b[
            "numDurExposureWeight"
        ].astype(float)
        df_b["benchAvgOasFI"] = df_b["numInstOptionAdjSpread"].astype(float).fillna(0) * df_b[
            "numDurExposureWeight"
        ].astype(float).fillna(0)
        df_b["benchAvgDtsFI"] = (
            df_b["numInstOptionAdjSpread"].astype(float).fillna(0)
            * df_b["numInstSpreadDuration"].astype(float).fillna(0)
            * df_b["numDurExposureWeight"].astype(float).fillna(0)
        )

        # Group and compute weighted averages.
        df_b_grouped = (
            df_b.groupby(group_keys)
            .apply(
                lambda group: pd.Series(
                    {
                        "numEffectDurationBenchFI": divide_numweight(group, "effDurationBenchFI"),
                        "numModifDurationBenchFI": divide_numweight(group, "modifDurationBenchFI"),
                        "numMCDurationBenchFI": divide_numweight(group, "MCDurationBenchFI"),
                        "numBenchAvgYTMFI": divide_numweight(group, "benchAvgYTMFI"),
                        "numBenchAvgConvexityFI": divide_numweight(group, "benchAvgConvexityFI"),
                        "numSpreadDurationBenchFI": divide_numweight(
                            group, "spreadDurationBenchFI"
                        ),
                        "numBenchAvgYTMDurWeightedFI": divide_numweight(
                            group, "benchAvgYTMDurWeightedFI"
                        ),
                        "numBenchAvgYieldWorstFI": divide_numweight(group, "benchAvgYieldWorstFI"),
                        "numBenchAvgOasFI": divide_numweight(group, "benchAvgOasFI"),
                        "numBenchAvgDtsFI": divide_numweight(group, "benchAvgDtsFI"),
                        "numNumberOfIssuersFI": group["strInstIssuerCode"].nunique(),
                    }
                )
            )
            .reset_index(drop=True)
        )
        group_b = df_b_grouped.iloc[0].to_dict() if not df_b_grouped.empty else {}
        del df_b
        del df_b_grouped

        inst_dfs_c = []
        for chunk in chunk_list(instruments, 2000):
            query_c = (
                session.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.numInstID,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.numInstCouponRate,
                    DMIRBRSInstrument.blncall,
                    DMIRBRSInstrument.datInstCallDate,
                )
                .select_from(DMIRBRSInstrument)
                .outerjoin(
                    DMIRBRSInstAnalytic,
                    and_(
                        DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                    ),
                )
                .join(
                    DMIRInstrumentIRType,
                    DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                )
                .filter(
                    DMIRBRSInstAnalytic.datInstQuotationDate == datReportingDay,
                    DMIRBRSInstAnalytic.strInstAladdin.in_(chunk),
                    DMIRInstrumentIRType.strReportingType == "class4",
                    DMIRInstrumentIRType.strInstrumentTypeIRName == "Fixed Income",
                    DMIRBRSInstrument.numInstTypeId != 506,
                )
            )
            inst_dfs_c.append(get_all_as_df(query_c))

        df_inst_c = pd.concat(
            inst_dfs_c,
            ignore_index=True,
        )
        if df_inst_c.empty:
            df_inst_c = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "datInstQuotationDate",
                    "numInstID",
                    "datInstMaturityDate",
                    "numInstCouponRate",
                    "blncall",
                    "datInstCallDate",
                ]
            )

        df_inst_c["datInstQuotationDate"] = pd.to_datetime(df_inst_c["datInstQuotationDate"])

        df_c = pd.merge(
            group_df,
            df_inst_c,
            how="inner",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            suffixes=("_group", ""),
        )
        del inst_dfs_c

        df_c["benchAvgCouponFI_weighted"] = df_c["numInstCouponRate"].astype(float) * df_c[
            "numweight"
        ].astype(float)
        df_c["maturity_diff_c"] = df_c.apply(
            lambda row: calc_maturity_diff(row) * row["numweight"], axis=1
        )

        df_c_grouped = (
            df_c.groupby(group_keys)
            .apply(
                lambda group: pd.Series(
                    {
                        "numBenchAvgCouponFI": (
                            group["benchAvgCouponFI_weighted"].sum() / group["numweight"].sum()
                            if group["numweight"].sum() != 0
                            else np.nan
                        ),
                        "datBenchAvgMaturityLifeFI": (
                            (
                                pd.to_datetime(group["datReportingDay"].iloc[0])
                                + pd.to_timedelta(
                                    group["maturity_diff_c"].sum() / group["numweight"].sum(),
                                    unit="days",
                                )
                            )
                            if group["numweight"].sum() != 0 and group["maturity_diff_c"].sum() > 0
                            else pd.NaT
                        ),
                    }
                )
            )
            .reset_index(drop=True)
        )
        group_c = df_c_grouped.iloc[0].to_dict() if not df_c_grouped.empty else {}
        del df_c
        del df_c_grouped

        # --------------------------  SUBQUERY D  --------------------------
        dfs = []
        for chunk in chunk_list(instruments, 2000):
            query_d = (
                session.query(DMIRBRSInstrument.strInstAladdin)
                .select_from(DMIRBRSInstrument)
                .outerjoin(
                    DMIRInstrumentIRType,
                    DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                )
                .filter(
                    DMIRBRSInstrument.strInstAladdin.in_(chunk),
                    DMIRInstrumentIRType.strReportingType == "class4",
                    DMIRInstrumentIRType.strInstrumentTypeIRName != "Cash",
                )
            )
            dfs.append(get_all_as_df(query_d))

        df_inst_d = pd.concat(dfs, ignore_index=True)

        if df_inst_d.empty:
            df_inst_d = pd.DataFrame(columns=["strInstAladdin"])

        group_d = {"numHoldingsNumber": df_inst_d["strInstAladdin"].nunique()}
        del df_inst_d

        group_result = {}
        group_result.update(group_a)
        group_result.update(group_b)
        group_result.update(group_c)
        group_result.update(group_d)

        # Ensure the group keys are set.
        group_result["numBenchFBAId"] = numBenchFBAId
        group_result["strCompositionCd"] = strCompositionCd
        group_result["datReportingDay"] = datReportingDay
        group_result["strPeriodTypeFlag"] = strPeriodTypeFlag
        group_result["strPFCurrencyISOCode"] = strPFCurrencyISOCode

        final_results.append(group_result)
        return pd.DataFrame(final_results)
    except Exception as e:
        print(e)
        safe_close(session)
        if retry > 0:
            return single_compute_bench_indicators_bkgn_10(
                i,
                numBenchFBAId,
                strCompositionCd,
                datReportingDay,
                strPeriodTypeFlag,
                strPFCurrencyISOCode,
                group_df,
                retry=retry - 1,
            )
    finally:
        safe_close(session)


def compute_bench_indicators_bkgn_10(df_tblDMIRBKGN7):
    """
    Compute DMIR BKGN 10 table with parallel processing.

    Args:
        df_tblDMIRBKGN7: DataFrame with DMIR BKGN 7 data

    Returns:
        DataFrame with DMIR BKGN 10 data
    """
    if df_tblDMIRBKGN7 is None or len(df_tblDMIRBKGN7) == 0:
        return pd.DataFrame()

    # 1. Define the grouping keys.
    group_keys = [
        "numBenchFBAId",
        "strCompositionCd",
        "datReportingDay",
        "strPeriodTypeFlag",
        "strPFCurrencyISOCode",
    ]

    # 2. Compute groupes
    df_all_groups = df_tblDMIRBKGN7.groupby(group_keys)
    get_hardware_info()
    del df_tblDMIRBKGN7

    # 3. Loop over each unique group in the CSV.
    results = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
        # 64 OK
        futures = {
            executor.submit(
                single_compute_bench_indicators_bkgn_10,
                i,
                numBenchFBAId,
                strCompositionCd,
                datReportingDay,
                strPeriodTypeFlag,
                strPFCurrencyISOCode,
                group_df,
            ): i
            for i, (
                (
                    numBenchFBAId,
                    strCompositionCd,
                    datReportingDay,
                    strPeriodTypeFlag,
                    strPFCurrencyISOCode,
                ),
                group_df,
            ) in enumerate(df_all_groups)
        }

        for future in concurrent.futures.as_completed(futures):
            try:
                chunk_result = future.result()
                results.append(chunk_result)
                get_hardware_info()
                print(f"Found {len(chunk_result)} records.")
            except Exception as exc:
                print(f"Rating batch {futures[future]} generated an exception: {exc}")

    # 4. Combine all group results into the final DataFrame.
    df_tblDMIRBKGN10 = pd.concat(results, ignore_index=True)

    # Final columns selection.
    final_columns = [
        "numBenchFBAId",
        "strCompositionCd",
        "datReportingDay",
        "strPeriodTypeFlag",
        "strPFCurrencyISOCode",
        "curExposureBench",  # from subquery a
        "durExposureBench",  # from subquery a
        "effectDurationBench",  # from subquery a
        "modifDurationBench",  # from subquery a
        "MCDurationBench",  # from subquery a
        "benchAvgCoupon",  # from subquery a
        "benchAvgYTM",  # from subquery a
        "benchAvgConvexity",  # from subquery a
        "datBenchAvgMaturityLife",  # from subquery a
        "numHoldingsNumber",  # from subquery d
        "spreadDurationBench",  # from subquery a
        "numEffectDurationBenchFI",  # from subquery b
        "numModifDurationBenchFI",  # from subquery b
        "numMCDurationBenchFI",  # from subquery b
        "numBenchAvgCouponFI",  # from subquery c
        "numBenchAvgYTMFI",  # from subquery b
        "numBenchAvgConvexityFI",  # from subquery b
        "datBenchAvgMaturityLifeFI",  # from subquery c
        "numSpreadDurationBenchFI",  # from subquery b
        "benchAvgYTMDurWeighted",  # from subquery a
        "numBenchAvgYTMDurWeightedFI",  # from subquery b
        "benchAvgYieldWorst",  # from subquery a
        "numBenchAvgYieldWorstFI",  # from subquery b
        "benchAvgOas",  # from subquery a
        "numBenchAvgOasFI",  # from subquery b
        "numNumberOfIssuersFI",  # from subquery b
        "benchAvgDts",  # from subquery a
        "numBenchAvgDtsFI",  # from subquery b
        "numNumberOfIssuers",  # from subquery a (nunique issuer count)
    ]
    df_tblDMIRBKGN10 = df_tblDMIRBKGN10[final_columns].rename(
        columns={
            "curExposureBench": "numCurExposureBench",
            "durExposureBench": "numDurExposureBench",
            "effectDurationBench": "numEffectDurationBench",
            "modifDurationBench": "numModifDurationBench",
            "MCDurationBench": "numMCDurationBench",
            "benchAvgCoupon": "numBenchAvgCoupon",
            "benchAvgYTM": "numBenchAvgYTM",
            "benchAvgConvexity": "numBenchAvgConvexity",
            "spreadDurationBench": "numSpreadDurationBench",
            "benchAvgYTMDurWeighted": "numBenchAvgYTMDurWeighted",
            "benchAvgYieldWorst": "numBenchAvgYieldWorst",
            "benchAvgOas": "numBenchAvgOas",
            "benchAvgDts": "numBenchAvgDts",
        }
    )
    return df_tblDMIRBKGN10


def left_join_rating(df, rating_col, rating_agency, alias_suffix):
    """
    Join a DataFrame with ratings data.

    Args:
        df: DataFrame to join
        rating_col: Column with rating values
        rating_agency: Rating agency code
        alias_suffix: Suffix for column aliases

    Returns:
        DataFrame with joined rating data
    """
    local_session = get_session()
    try:
        ratings = (
            local_session.query(
                DMIRRatingIREvaluation.strRatingValue, DMIRRatingIREvaluation.numRatingValue
            )
            .filter(DMIRRatingIREvaluation.strRatingAgency == rating_agency)
            .all()
        )

        # Convert to DataFrame
        df_ratings = pd.DataFrame(
            [{"strRating": r.strRatingValue, "numRating": r.numRatingValue} for r in ratings]
        )

        # Join with input DataFrame
        result = pd.merge(
            df,
            df_ratings,
            left_on=rating_col,
            right_on="strRating",
            how="left",
            suffixes=("", f"_{alias_suffix}"),
        )

        # Rename columns
        result = result.rename(
            columns={
                "numRating": f"{alias_suffix}_numRating",
                "strRating": f"{alias_suffix}_strRating",
            }
        )

        return result
    finally:
        safe_close(local_session)


def build_ir_ratings():
    """Build a DataFrame with rating information from DMIRRatingIREvaluation."""
    session = get_session()
    try:
        # Get rating objects
        rating_objs = session.query(DMIRRatingIREvaluation).all()

        # Convert to DataFrame
        df_ratings = pd.DataFrame(
            [
                {
                    "strRatingAgency": row.strRatingAgency,
                    "strRating": row.strRatingValue,
                    "numRating": row.numRatingValue,
                }
                for row in rating_objs
            ]
        )

        # Sort and add numbering
        df_ratings = df_ratings.sort_values(
            ["strRatingAgency", "numRating"], ascending=[True, False]
        )
        df_ratings["nbr"] = df_ratings.groupby("strRatingAgency").cumcount() + 1

        return df_ratings
    finally:
        safe_close(session)


def compute_avg(weight, rating_weight):
    """Compute weighted average rating."""
    if weight == 0:
        return 0
    return rating_weight / weight


def final_rating(avg_rating, rating_agency, df_ratings):
    """Determine final rating string based on numeric average rating."""
    if avg_rating == 0:
        return "NR"

    # Get ratings for this agency
    agency_ratings = df_ratings[df_ratings["strRatingAgency"] == rating_agency].copy()

    # Find two ratings with values around the average
    lower = (
        agency_ratings[agency_ratings["numRating"] <= avg_rating]
        .sort_values("numRating", ascending=False)
        .iloc[0]
        if not agency_ratings[agency_ratings["numRating"] <= avg_rating].empty
        else None
    )

    upper = (
        agency_ratings[agency_ratings["numRating"] > avg_rating]
        .sort_values("numRating", ascending=True)
        .iloc[0]
        if not agency_ratings[agency_ratings["numRating"] > avg_rating].empty
        else None
    )

    if lower is None:
        return upper["strRating"] if upper is not None else "NR"

    if upper is None:
        return lower["strRating"]

    # Determine which is closer
    lower_diff = abs(avg_rating - float(lower["numRating"]))
    upper_diff = abs(avg_rating - float(upper["numRating"]))

    return lower["strRating"] if lower_diff <= upper_diff else upper["strRating"]


def single_process_rating_batch(i, rating_batch, retry=3):
    """
    Process a batch of instrument ratings.

    Args:
        rating_batch: List of instrument records to process

    Returns:
        DataFrame with processed rating data for the batch
    """

    print(f"Processing chunk {i}.")
    session = get_session()
    try:
        # Create a working DataFrame for this batch
        df_rtg = rating_batch

        # Join for each rating type
        df_rtg = left_join_rating(df_rtg, "strInstRtgSPStandardized", "SP", "sp")
        df_rtg = left_join_rating(df_rtg, "strInstRtgMDStandardized", "MOODY", "md")
        df_rtg = left_join_rating(df_rtg, "strInstRtgFHStandardized", "FITCH", "ft")

        # Join for custom ratings
        for i in range(1, 14):
            col_name = f"strInstRtgCustom{i}"
            alias_suffix = f"sp{i}"
            df_rtg = left_join_rating(df_rtg, col_name, "SP", alias_suffix)

        # Compute calculated columns for each rating
        df_rtg["numRatingSP"] = df_rtg["sp_numRating"].astype(float).fillna(0)
        df_rtg["numWeightSP"] = np.where(
            df_rtg["sp_numRating"].astype(float).fillna(0) != 0, df_rtg["numweight"], 0
        )
        df_rtg["numRatingWeightSP"] = df_rtg["numweight"].astype(float) * df_rtg[
            "sp_numRating"
        ].astype(float).fillna(0)

        # Calculate for MOODY
        df_rtg["numRatingMD"] = df_rtg["md_numRating"].astype(float).fillna(0)
        df_rtg["numWeightMD"] = np.where(
            df_rtg["md_numRating"].astype(float).fillna(0) != 0, df_rtg["numweight"], 0
        )
        df_rtg["numRatingWeightMD"] = df_rtg["numweight"].astype(float) * df_rtg[
            "md_numRating"
        ].astype(float).fillna(0)

        # Calculate for FITCH
        df_rtg["numRatingFT"] = df_rtg["ft_numRating"].astype(float).fillna(0)
        df_rtg["numWeightFT"] = np.where(
            df_rtg["ft_numRating"].astype(float).fillna(0) != 0, df_rtg["numweight"], 0
        )
        df_rtg["numRatingWeightFT"] = df_rtg["numweight"].astype(float) * df_rtg[
            "ft_numRating"
        ].astype(float).fillna(0)

        # Calculate for custom ratings 1-13
        for i in range(1, 14):
            suffix = f"sp{i}"
            df_rtg[f"numRatingC{i}"] = df_rtg[f"{suffix}_numRating"].astype(float).fillna(0)
            df_rtg[f"numWeightC{i}"] = np.where(
                df_rtg[f"{suffix}_numRating"].astype(float).fillna(0) != 0, df_rtg["numweight"], 0
            )
            df_rtg[f"numRatingWeightC{i}"] = df_rtg["numweight"].astype(float) * df_rtg[
                f"{suffix}_numRating"
            ].astype(float).fillna(0)

        # Apply WHERE condition - only keep rows with non-zero ratings
        rating_cols = [
            "strInstRtgSPStandardized",
            "strInstRtgMDStandardized",
            "strInstRtgFHStandardized",
        ] + [f"strInstRtgCustom{i}" for i in range(1, 14)]

        df_rtg["rating_concat"] = df_rtg[rating_cols].fillna("0").astype(str).agg("".join, axis=1)
        df_rtg = df_rtg[df_rtg["rating_concat"] != "0" * len(rating_cols)]
        df_rtg.drop(columns=["rating_concat"], inplace=True)

        # Select final columns
        keep_columns = [
            "numBenchFBAId",
            "strCompositionCd",
            "datReportingDay",
            "strPeriodTypeFlag",
            "strPFCurrencyISOCode",
            "numweight",
            "numRatingSP",
            "numWeightSP",
            "numRatingWeightSP",
            "numRatingMD",
            "numWeightMD",
            "numRatingWeightMD",
            "numRatingFT",
            "numWeightFT",
            "numRatingWeightFT",
        ] + rating_cols

        for i in range(1, 14):
            keep_columns.extend([f"numRatingC{i}", f"numWeightC{i}", f"numRatingWeightC{i}"])

        return df_rtg[keep_columns]
    except Exception as e:
        print(e)
        if retry >= 0:
            return single_process_rating_batch(i, rating_batch, retry=retry - 1)
    finally:
        safe_close(session)


def compute_bench_indicators_bkgn_8(df_tblDMIRBKGN7):
    """
    Compute DMIR BKGN 8 table (rating data) with parallel processing.

    Args:
        df_tblDMIRBKGN7: DataFrame with DMIR BKGN 7 data

    Returns:
        DataFrame with instrument rating data
    """
    if df_tblDMIRBKGN7 is None or len(df_tblDMIRBKGN7) == 0:
        return pd.DataFrame(), pd.DataFrame()

    # Replace NaN with None for consistent processing
    df_rtg = df_tblDMIRBKGN7.replace({np.nan: None})

    # Split data into chunks for parallel processing
    # num_cpus = os.cpu_count() or 4
    nb_splits = max(min(len(df_rtg) // 50000, 100), 1)
    df_chunks = np.array_split(df_rtg, nb_splits)

    get_hardware_info()
    del df_rtg
    del df_tblDMIRBKGN7
    get_hardware_info()

    print("Length of df_chunks", len(df_chunks))

    # Process chunks in parallel
    results = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=4) as executor:
        futures = {
            executor.submit(single_process_rating_batch, i, chunk): i
            for i, chunk in enumerate(df_chunks)
        }

        for future in concurrent.futures.as_completed(futures):
            try:
                chunk_result = future.result()
                get_hardware_info()
                results.append(chunk_result)
            except Exception as exc:
                print(f"Rating batch {futures[future]} generated an exception: {exc}")

    # Combine results
    if results:
        df_tblDMIRBKGN8 = pd.concat(results, ignore_index=True)

        # Build IR ratings for use in BKGN 9
        df_IRRatings = build_ir_ratings()
        df_IRRatingsBetween = df_IRRatings.copy()
        df_IRRatingsBetween["strPrevRating"] = df_IRRatingsBetween.groupby("strRatingAgency")[
            "strRating"
        ].shift(1)
        df_IRRatingsBetween["numPrevRating"] = df_IRRatingsBetween.groupby("strRatingAgency")[
            "numRating"
        ].shift(1)

        # Replace missing numPrevRating with small value
        df_IRRatingsBetween["numPrevRating"] = df_IRRatingsBetween["numPrevRating"].fillna(
            0.00000000009
        )

        return df_tblDMIRBKGN8, df_IRRatingsBetween
    else:
        # Return empty DataFrames if no results
        return pd.DataFrame(), pd.DataFrame()


def single_process_rating_group_batch(group_batch, df_IRRatingsBetween):
    """
    Process a batch of grouped rating data.

    Args:
        group_batch: List of groups to process
        df_IRRatingsBetween: DataFrame with rating boundaries

    Returns:
        DataFrame with aggregated ratings for the batch
    """
    results = []
    for group_values, group_df in group_batch:
        # Define an aggregation dictionary for weighted rating components
        agg_dict = {
            "numWeightSP": "sum",
            "numRatingWeightSP": "sum",
            "numWeightMD": "sum",
            "numRatingWeightMD": "sum",
            "numWeightFT": "sum",
            "numRatingWeightFT": "sum",
        }

        # Add custom ratings to aggregation
        for i in range(1, 14):
            agg_dict[f"numWeightC{i}"] = "sum"
            agg_dict[f"numRatingWeightC{i}"] = "sum"

        # Aggregate the data
        agg_result = group_df.agg(agg_dict)

        # Calculate weighted average ratings
        agg_result["numBenchAvgRtgSP"] = compute_avg(
            agg_result["numWeightSP"], agg_result["numRatingWeightSP"]
        )
        agg_result["numBenchAvgRtgMD"] = compute_avg(
            agg_result["numWeightMD"], agg_result["numRatingWeightMD"]
        )
        agg_result["numBenchAvgRtgFT"] = compute_avg(
            agg_result["numWeightFT"], agg_result["numRatingWeightFT"]
        )

        # Calculate custom ratings
        for i in range(1, 14):
            agg_result[f"numBenchAvgRtgC{i}"] = compute_avg(
                agg_result[f"numWeightC{i}"], agg_result[f"numRatingWeightC{i}"]
            )

        # Determine final string ratings
        agg_result["strBenchAvgRtgSP"] = final_rating(
            agg_result["numBenchAvgRtgSP"], "SP", df_IRRatingsBetween
        )
        agg_result["strBenchAvgRtgMD"] = final_rating(
            agg_result["numBenchAvgRtgMD"], "MOODY", df_IRRatingsBetween
        )
        agg_result["strBenchAvgRtgFT"] = final_rating(
            agg_result["numBenchAvgRtgFT"], "FITCH", df_IRRatingsBetween
        )

        agg_result["strBenchAvgRtgFH"] = agg_result["strBenchAvgRtgFT"]  # rename

        # Determine final custom ratings
        for i in range(1, 14):
            agg_result[f"strBenchAvgRtgC{i}"] = final_rating(
                agg_result[f"numBenchAvgRtgC{i}"], "SP", df_IRRatingsBetween
            )

        # Add group values
        result_row = {
            "numBenchFBAId": group_values[0],
            "strCompositionCd": group_values[1],
            "datReportingDay": group_values[2],
            "strPeriodTypeFlag": group_values[3],
            "strPFCurrencyISOCode": group_values[4],
        }
        result_row.update(agg_result.to_dict())

        results.append(result_row)

    if results:
        return pd.DataFrame(results)
    else:
        return pd.DataFrame()


def compute_bench_indicators_bkgn_9(df_tblDMIRBKGN8, df_IRRatingsBetween):
    """
    Compute DMIR BKGN 9 table (aggregated ratings) with parallel processing.

    Args:
        df_tblDMIRBKGN8: DataFrame with rating data
        df_IRRatingsBetween: DataFrame with rating boundaries

    Returns:
        DataFrame with aggregated rating data
    """
    if df_tblDMIRBKGN8 is None or len(df_tblDMIRBKGN8) == 0:
        return pd.DataFrame()

    # Define grouping keys
    group_keys = [
        "numBenchFBAId",
        "strCompositionCd",
        "datReportingDay",
        "strPeriodTypeFlag",
        "strPFCurrencyISOCode",
    ]

    df_tblDMIRBKGN8 = df_tblDMIRBKGN8.groupby(group_keys)
    groups_list = [(group_values, group_df) for group_values, group_df in df_tblDMIRBKGN8]
    get_hardware_info()

    results = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=16) as executor:
        futures = {
            executor.submit(
                single_process_rating_group_batch, groups_list[i : i + 1], df_IRRatingsBetween
            ): i
            for i, batch in enumerate(groups_list)
        }

        for future in concurrent.futures.as_completed(futures):
            try:
                batch_result = future.result()
                get_hardware_info()
                results.append(batch_result)
            except Exception as exc:
                print(f"Rating group batch {futures[future]} generated an exception: {exc}")

    if results:
        df_tblDMIRBKGN9 = pd.concat(results, ignore_index=True)

        final_columns = group_keys + [
            "numBenchAvgRtgSP",
            "strBenchAvgRtgSP",
            "numBenchAvgRtgMD",
            "strBenchAvgRtgMD",
            "numBenchAvgRtgFT",
            "strBenchAvgRtgFT",
        ]

        for i in range(1, 14):
            final_columns.extend([f"numBenchAvgRtgC{i}", f"strBenchAvgRtgC{i}"])
        existing_columns = [col for col in final_columns if col in df_tblDMIRBKGN9.columns]

        return df_tblDMIRBKGN9[existing_columns]
    else:
        return pd.DataFrame()


def single_insert_indicators_batch(records_batch):
    session = get_session()
    try:
        session.bulk_insert_mappings(DMIRBRSBenchIndicators, records_batch)
        session.commit()
        return len(records_batch)
    finally:
        safe_close(session)


def final_delete_and_insert_indicators(
    df_benchscope: pd.DataFrame,
    df_tblDMIRBKGN10: pd.DataFrame,
    df_tblDMIRBKGN9: pd.DataFrame,
    df_esg: pd.DataFrame,
    audit_id,
):
    if df_tblDMIRBKGN10.empty:
        return pd.DataFrame()
    session = get_session()

    # Step 1: “INSERT INTO DMIR.tblDMIRBenchIndicatorsWrk ... SELECT from bs JOIN a LEFT JOIN r”
    #
    #  1.1. Inner‐join df_benchscope (“bs”) with df_tblDMIRBKGN10 (“a”)
    print("Step 1")
    merged = df_benchscope.merge(
        df_tblDMIRBKGN10,
        left_on=["numBenchMarkId", "strPeriodTypeFlag", "datReportingDay", "strPFCurrencyISOCode"],
        right_on=["numBenchFBAId", "strPeriodTypeFlag", "datReportingDay", "strPFCurrencyISOCode"],
        how="left",
        suffixes=("", "_gn10"),
    )

    #  1.2. Left‐join the result with df_tblDMIRBKGN9 (“r”)
    merged = merged.merge(
        df_tblDMIRBKGN9,
        left_on=["numBenchFBAId", "strPeriodTypeFlag", "datReportingDay", "strPFCurrencyISOCode"],
        right_on=["numBenchFBAId", "strPeriodTypeFlag", "datReportingDay", "strPFCurrencyISOCode"],
        how="left",
        suffixes=("", "_gn9"),
    )

    #  1.3. Build df_working with exactly the columns listed in the “good” SQL version.
    df_working = pd.DataFrame(
        {
            "strPeriodTypeFlag": merged["strPeriodTypeFlag"],
            "datPeriodLastDay": merged["datReportingDay"],  # bs.datReportingDay
            "datMarketDate": merged["datPeriodLastMarketDay"],  # bs.datPeriodLastMarketDay
            "numBenchFBAId": merged["numBenchMarkId"],  # a.numBenchFBAId
            "strPFCurrencyISOCode": merged["strPFCurrencyISOCode"],  # a.strPFCurrencyISOCode
            "numDurExposureBench": merged["numDurExposureBench"],  # a.numDurExposureBench
            "numCurExposureBench": merged["numCurExposureBench"],  # a.numCurExposureBench
            "datBenchAvgMaturityLife": merged["datBenchAvgMaturityLife"],
            "numEffectDurationBench": merged["numEffectDurationBench"],  # a.numEffectDurationBench
            "numModifDurationBench": merged["numModifDurationBench"],  # a.numModifDurationBench
            "numMCDurationBench": merged["numMCDurationBench"],  # a.numMCDurationBench
            "numSpreadDurationBench": merged["numSpreadDurationBench"],  # a.numSpreadDurationBench
            "numBenchAvgCoupon": merged["numBenchAvgCoupon"],  # a.numBenchAvgCoupon
            "numBenchAvgYTM": merged["numBenchAvgYTM"],  # a.numBenchAvgYTM
            "numBenchAvgConvexity": merged["numBenchAvgConvexity"],  # a.numBenchAvgConvexity
            "numHoldingsNumber": merged["numHoldingsNumber"],  # a.numHoldingsNumber
            # The next block corresponds to all “= NULL” columns in the SQL:
            "numBenchPriceEarnRatio": pd.NA,
            "numBenchPriceToBook": pd.NA,
            "numBenchDivYld": pd.NA,
            "numBenchPriceCash": pd.NA,
            "numBench35YrForecastEarnGrowth": pd.NA,
            "numBenchROE": pd.NA,
            "numBenchEvEbit": pd.NA,
            "numBenchEvSales": pd.NA,
            "numBenchEvEbitda": pd.NA,
            "numBenchTotalExpenseRatio": pd.NA,
            "datModificationDate": datetime.now(),  # = @dateTimeNow
            "numAuditId": audit_id,  # = @numAuditId
            # Columns pulled from the LEFT JOIN on #tblDMIRBKGN9 (“r”):
            "strBenchAvgRtgSP": merged.get("strBenchAvgRtgSP", pd.NA),
            "strBenchAvgRtgMD": merged.get("strBenchAvgRtgMD", pd.NA),
            "strBenchAvgRtgFH": merged.get(
                "strBenchAvgRtgFT", pd.NA
            ),  # It is indeed strBenchAvgRtgFH, not a typo
            "strBenchAvgRtgCustom1": merged.get("strBenchAvgRtgC1", pd.NA),
            "strBenchAvgRtgCustom2": merged.get("strBenchAvgRtgC2", pd.NA),
            "strBenchAvgRtgCustom3": merged.get("strBenchAvgRtgC3", pd.NA),
            "strBenchAvgRtgCustom4": merged.get("strBenchAvgRtgC4", pd.NA),
            "strBenchAvgRtgCustom5": merged.get("strBenchAvgRtgC5", pd.NA),
            "strBenchAvgRtgCustom6": merged.get("strBenchAvgRtgC6", pd.NA),
            "strBenchAvgRtgCustom7": merged.get("strBenchAvgRtgC7", pd.NA),
            "strBenchAvgRtgCustom8": merged.get("strBenchAvgRtgC8", pd.NA),
            "strBenchAvgRtgCustom9": merged.get("strBenchAvgRtgC9", pd.NA),
            "strBenchAvgRtgCustom10": merged.get("strBenchAvgRtgC10", pd.NA),
            "strBenchAvgRtgCustom11": merged.get("strBenchAvgRtgC11", pd.NA),
            "strBenchAvgRtgCustom12": merged.get("strBenchAvgRtgC12", pd.NA),
            "strBenchAvgRtgCustom13": merged.get("strBenchAvgRtgC13", pd.NA),
            # Next block = NULL columns in SQL:
            "numBenchWAL": pd.NA,
            "numBenchWAM": pd.NA,
            "numBenchInflSens": pd.NA,
            "numBenchDebtEq": pd.NA,
            "numBenchWAMarketCap": pd.NA,
            # Columns from “a” (DMIRBKGN10) for the FI fields:
            "numEffectDurationBenchFI": merged["numEffectDurationBenchFI"],
            "numModifDurationBenchFI": merged["numModifDurationBenchFI"],
            "numMCDurationBenchFI": merged["numMCDurationBenchFI"],
            "numBenchAvgCouponFI": merged["numBenchAvgCouponFI"],
            "numBenchAvgYTMFI": merged["numBenchAvgYTMFI"],
            "numBenchAvgConvexityFI": merged["numBenchAvgConvexityFI"],
            "datBenchAvgMaturityLifeFI": merged["datBenchAvgMaturityLifeFI"],
            "numSpreadDurationBenchFI": merged["numSpreadDurationBenchFI"],
            # Next block = NULL columns:
            "numBenchAvgMarketCap": pd.NA,
            "numBenchMedMarketCap": pd.NA,
            # Final block of “a” columns:
            "numBenchAvgYTMDurWeighted": merged["numBenchAvgYTMDurWeighted"],
            "numBenchAvgYTMDurWeightedFI": merged["numBenchAvgYTMDurWeightedFI"],
            "numBenchAvgYieldWorst": merged["numBenchAvgYieldWorst"],
            "numBenchAvgYieldWorstFI": merged["numBenchAvgYieldWorstFI"],
            "numBenchAvgOas": merged["numBenchAvgOas"],
            "numBenchAvgOasFI": merged["numBenchAvgOasFI"],
            "numNumberOfIssuersFI": merged["numNumberOfIssuersFI"],
            "numBenchAvgDts": merged["numBenchAvgDts"],
            "numBenchAvgDtsFI": merged["numBenchAvgDtsFI"],
            "numNumberOfIssuers": merged["numNumberOfIssuers"],
        }
    )

    #
    # Step 2: UPDATE financial indicators from DMIR.tblDMIRBRSBenchInstrIndicators (“bi”)
    #   3.2. Build a list of AND‐conditions, one per tuple, then OR them together:
    print("Step 2")
    key_list = list(
        df_working[["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay"]]
        .drop_duplicates()
        .itertuples(index=False, name=None)
    )

    bi_dfs = []
    for key_chunk in chunker(key_list, 500):
        filters = []
        for flag, bench_id, day in key_chunk:
            print(f"Processing {flag}, {bench_id}, {day}")
            filters.append(
                and_(
                    DMIRBRSBenchIndicators.strPeriodTypeFlag == flag,
                    DMIRBRSBenchIndicators.numBenchFBAId == bench_id,
                    DMIRBRSBenchIndicators.datPeriodLastDay == day,
                )
            )

        if filters:
            query = session.query(
                DMIRBRSBenchIndicators.strPeriodTypeFlag,
                DMIRBRSBenchIndicators.numBenchFBAId,
                DMIRBRSBenchIndicators.datPeriodLastDay,
                DMIRBRSBenchIndicators.numBenchPriceEarnRatio,
                DMIRBRSBenchIndicators.numBenchPriceToBook,
                DMIRBRSBenchIndicators.numBenchDivYld,
                DMIRBRSBenchIndicators.numBenchPriceCash,
                DMIRBRSBenchIndicators.numBench35YrForecastEarnGrowth,
                DMIRBRSBenchIndicators.numBenchROE,
                DMIRBRSBenchIndicators.numBenchEvEbit,
                DMIRBRSBenchIndicators.numBenchEvSales,
                DMIRBRSBenchIndicators.numBenchEvEbitda,
                DMIRBRSBenchIndicators.numBenchTotalExpenseRatio,
                DMIRBRSBenchIndicators.numBenchWAL,
                DMIRBRSBenchIndicators.numBenchWAM,
                DMIRBRSBenchIndicators.numBenchInflSens,
                DMIRBRSBenchIndicators.numBenchDebtEq,
                DMIRBRSBenchIndicators.numBenchWAMarketCap,
                DMIRBRSBenchIndicators.numBenchAvgMarketCap,
                DMIRBRSBenchIndicators.numBenchMedMarketCap,
            ).filter(or_(*filters))

            bi_dfs.append(get_all_as_df(query))
        print("Finished chunk.")

    if bi_dfs:
        bi_df = pd.concat(bi_dfs, ignore_index=True)
    else:
        bi_df = pd.DataFrame(
            columns=[
                "strPeriodTypeFlag",
                "numBenchFBAId",
                "datPeriodLastDay",
                "numBenchPriceEarnRatio",
                "numBenchPriceToBook",
                "numBenchDivYld",
                "numBenchPriceCash",
                "numBench35YrForecastEarnGrowth",
                "numBenchROE",
                "numBenchEvEbit",
                "numBenchEvSales",
                "numBenchEvEbitda",
                "numBenchTotalExpenseRatio",
                "numBenchWAL",
                "numBenchWAM",
                "numBenchInflSens",
                "numBenchDebtEq",
                "numBenchWAMarketCap",
                "numBenchAvgMarketCap",
                "numBenchMedMarketCap",
            ]
        )

    df_working = df_working.merge(
        bi_df,
        on=["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay"],
        how="left",
        suffixes=("", "_bi"),
    )

    for col in [
        "numBenchPriceEarnRatio",
        "numBenchPriceToBook",
        "numBenchDivYld",
        "numBenchPriceCash",
        "numBench35YrForecastEarnGrowth",
        "numBenchROE",
        "numBenchEvEbit",
        "numBenchEvSales",
        "numBenchEvEbitda",
        "numBenchTotalExpenseRatio",
        "numBenchWAL",
        "numBenchWAM",
        "numBenchInflSens",
        "numBenchDebtEq",
        "numBenchWAMarketCap",
        "numBenchAvgMarketCap",
        "numBenchMedMarketCap",
    ]:
        df_working[col] = df_working[f"{col}_bi"].combine_first(df_working[col])
        df_working.drop(columns=[f"{col}_bi"], inplace=True)

    #   3.4. Perform exactly the same GROUP BY / SUM(...) logic as in SQL:
    if not df_esg.empty:
        agg_esg = df_esg.groupby(
            ["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay"], as_index=False
        ).agg(
            {
                "numESGEnvCovWeight": "sum",
                "numESGEnvScoreCov": "sum",
                "numESGSocialCovWeight": "sum",
                "numESGSocialScoreCov": "sum",
                "numESGGovCovWeight": "sum",
                "numESGGovernanceScoreCov": "sum",
                "numESGDecileCovWeight": "sum",
                "numESGDecileCov": "sum",
                "numESGGlbPotentialScoreCov": "sum",
                "numCO2IntensRevEvalCovWeight": "sum",
                "numCO2IntensRevEvalCov": "sum",
                "numCO2IntensEVEvalCovWeight": "sum",
                "numCO2IntensEVEvalCov": "sum",
                "numCO2EmmisionsScope12": "sum",
                "numCO2EmmissionCovWeight": "sum",
                "numCO2EmmisionsCov": "sum",
                "numESGKPIGenderDivCovWeight": "sum",
                "numESGKPIGenderDivValuCov": "sum",
                "numESGKPIHumanRightsCovWeight": "sum",
                "numESGKPIHumanRightsValuCov": "sum",
                "numESGKPIExpControvESGCovWeight": "sum",
                "numESGKPIExpControvESGCov": "sum",
                "numESGKPIExpControvSocCovWeight": "sum",
                "numESGKPIExpControvSocCov": "sum",
                "numGrpPolicyRcoWeight": "sum",
                "numESGGlbCovWeight": "sum",
                "numESGGlbCovWeightG": "sum",
                "numCO2IntensEVEvalCovWeightG": "sum",
                "numESGKPIGenderDivCovWeightG": "sum",
                "numESGKPIHumanRightsCovWeightG": "sum",
                "numESGKPIExpControvESGCovWeightG": "sum",
            }
        )

        # Compute numESGGlbScoreCov = sum(EnvScore) + sum(SocialScore) + sum(GovScore) + 50
        agg_esg["numESGGlbScoreCov"] = (
            agg_esg["numESGEnvScoreCov"]
            + agg_esg["numESGSocialScoreCov"]
            + agg_esg["numESGGovernanceScoreCov"]
            + 50
        )

        #   3.5. Merge aggregated ESG columns back into df_working
        df_working = df_working.merge(
            agg_esg, on=["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay"], how="left"
        )
    else:
        for col in [
            "numESGEnvCovWeight",
            "numESGEnvScoreCov",
            "numESGSocialCovWeight",
            "numESGSocialScoreCov",
            "numESGGovCovWeight",
            "numESGGovernanceScoreCov",
            "numESGDecileCovWeight",
            "numESGDecileCov",
            "numESGGlbPotentialScoreCov",
            "numCO2IntensRevEvalCovWeight",
            "numCO2IntensRevEvalCov",
            "numCO2IntensEVEvalCovWeight",
            "numCO2IntensEVEvalCov",
            "numCO2EmmisionsScope12",
            "numCO2EmmissionCovWeight",
            "numCO2EmmisionsCov",
            "numESGKPIGenderDivCovWeight",
            "numESGKPIGenderDivValuCov",
            "numESGKPIHumanRightsCovWeight",
            "numESGKPIHumanRightsValuCov",
            "numESGKPIExpControvESGCovWeight",
            "numESGKPIExpControvESGCov",
            "numESGKPIExpControvSocCovWeight",
            "numESGKPIExpControvSocCov",
            "numGrpPolicyRcoWeight",
            "numESGGlbCovWeight",
            "numESGGlbCovWeightG",
            "numCO2IntensEVEvalCovWeightG",
            "numESGKPIGenderDivCovWeightG",
            "numESGKPIHumanRightsCovWeightG",
            "numESGKPIExpControvESGCovWeightG",
            "numESGGlbScoreCov",
        ]:
            df_working[col] = pd.NA

    #
    # Step 4: ESG Engagement via OR‐combined filters
    #
    print("Step 5")
    if not df_working.empty and not df_esg.empty:
        df_eng_src = df_esg[
            [
                "strPeriodTypeFlag",
                "numBenchFBAId",
                "datPeriodLastDay",
                "strESGKPIEngmtRcoIssrCd",
                "numESGKPIEngmtEnv",
                "numESGKPIEngmtSocial",
                "numESGKPIEngmtGov",
                "numESGKPIEngmtNumMeetings",
            ]
        ]

        df_eng_src["strESGKPIEngmtRcoIssrCd"] = df_eng_src["strESGKPIEngmtRcoIssrCd"].fillna("")

        eng_group = df_eng_src.groupby(
            ["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay", "strESGKPIEngmtRcoIssrCd"],
            as_index=False,
        ).agg(
            {
                "numESGKPIEngmtEnv": "max",
                "numESGKPIEngmtSocial": "max",
                "numESGKPIEngmtGov": "max",
                "numESGKPIEngmtNumMeetings": "max",
            }
        )

        print("Step 6")
        eng_summary = (
            eng_group.groupby(
                ["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay"], as_index=False
            )
            .agg(
                {
                    "strESGKPIEngmtRcoIssrCd": "count",  # numESGKPIEngmtGlob
                    "numESGKPIEngmtEnv": "sum",
                    "numESGKPIEngmtSocial": "sum",
                    "numESGKPIEngmtGov": "sum",
                    "numESGKPIEngmtNumMeetings": "sum",
                }
            )
            .rename(columns={"strESGKPIEngmtRcoIssrCd": "numESGKPIEngmtGlob"})
        )

        df_working = df_working.merge(
            eng_summary, on=["strPeriodTypeFlag", "numBenchFBAId", "datPeriodLastDay"], how="left"
        )

        def safe_ratio(env, soc, gov, which):
            denom = (env or 0) + (soc or 0) + (gov or 0)
            return 0.0 if denom == 0 else (which or 0.0) / denom

        df_working[["__env", "__soc", "__gov"]] = df_working[
            ["numESGKPIEngmtEnv", "numESGKPIEngmtSocial", "numESGKPIEngmtGov"]
        ]

        df_working["numESGKPIEngmtEnv"] = df_working.apply(
            lambda row: safe_ratio(
                row["__env"],
                row["__soc"],
                row["__gov"],
                row["__env"],
            ),
            axis=1,
        )
        df_working["numESGKPIEngmtSocial"] = df_working.apply(
            lambda row: safe_ratio(
                row["__env"],
                row["__soc"],
                row["__gov"],
                row["__soc"],
            ),
            axis=1,
        )
        df_working["numESGKPIEngmtGov"] = df_working.apply(
            lambda row: safe_ratio(
                row["__env"],
                row["__soc"],
                row["__gov"],
                row["__gov"],
            ),
            axis=1,
        )
        df_working.drop(columns=["__env", "__soc", "__gov"], inplace=True)
        df_working["numESGKPIEngmtNumMeetings"] = df_working["numESGKPIEngmtNumMeetings"].fillna(0)

        df_working["numESGKPIAllTypEngmt"] = df_working.apply(
            lambda row: (
                0.0
                if (
                    (
                        row["numESGKPIEngmtEnv"]
                        + row["numESGKPIEngmtSocial"]
                        + row["numESGKPIEngmtGov"]
                    )
                    == 0
                )
                else row.get("numESGKPIEngmtGlob", 0.0)
            ),
            axis=1,
        )
    else:
        for col in [
            "numESGKPIEngmtGlob",
            "numESGKPIEngmtEnv",
            "numESGKPIEngmtSocial",
            "numESGKPIEngmtGov",
            "numESGKPIEngmtNumMeetings",
            "numESGKPIAllTypEngmt",
        ]:
            df_working[col] = pd.NA

    df_wrk = df_working.replace({np.nan: None, "": None})

    print("Step 7 - Delete")
    records_to_insert = df_wrk.to_dict(orient="records")
    for flag, bench_id, day in key_list:
        print(f"Deleting records for ({flag}, {bench_id}, {day})")
        session.query(DMIRBRSBenchIndicators).filter(
            DMIRBRSBenchIndicators.strPeriodTypeFlag == flag,
            DMIRBRSBenchIndicators.numBenchFBAId == bench_id,
            DMIRBRSBenchIndicators.datPeriodLastDay == day,
        ).delete(synchronize_session=False)
    session.commit()

    records_to_insert = df_wrk.to_dict(orient="records")

    bench_groups = {}
    for rec in records_to_insert:
        bench_id = rec["numBenchFBAId"]
        if bench_id not in bench_groups:
            bench_groups[bench_id] = []
        bench_groups[bench_id].append(rec)

    batches = []
    current_batch = []
    current_batch_size = 0
    target_batch_size = max(100, len(records_to_insert) // (16 * 2))

    for bench_id in sorted(bench_groups.keys()):
        bench_records = bench_groups[bench_id]

        if current_batch_size > 0 and current_batch_size + len(bench_records) > target_batch_size:
            batches.append(current_batch)
            current_batch = []
            current_batch_size = 0

        current_batch.extend(bench_records)
        current_batch_size += len(bench_records)

    if current_batch:
        batches.append(current_batch)

    insert_counts = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=8) as executor:
        futures = {
            executor.submit(single_insert_indicators_batch, batch): i
            for i, batch in enumerate(batches)
        }

        for future in concurrent.futures.as_completed(futures):
            try:
                batch_insert_count = future.result()
                insert_counts.append(batch_insert_count)
                print(f"Batch {futures[future]}: Inserted {batch_insert_count} records")
            except Exception as exc:
                print(f"Insert batch {futures[future]} generated an exception: {exc}")
    total_inserted = sum(insert_counts)
    print(f"Total inserted {total_inserted} records.")
    return df_wrk
