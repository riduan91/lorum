# ---------------------------------------------------------------------
# light utility -------------------------------------------------------
# ---------------------------------------------------------------------
def chunk_list(seq, size):
    """Yield successive *size* chunks from a list or 1‑D array."""
    for i in range(0, len(seq), size):
        yield seq[i : i + size]


# ---------------------------------------------------------------------
# ❶ Fetch instrument metadata for ONE (report‑day, portfolio) slice
#    – runs in parallel workers
# ---------------------------------------------------------------------
def _get_maturity_coupon_single(idx: int,
                                dat,
                                code: str,
                                fkey: int,
                                slice_df: pd.DataFrame) -> dict:
    """
    For the given (datPeriodLastDay, strPortfGPSCode, numPortfGroupFKey) slice:
      • fetch coupon / maturity fields from DMIRBRSInstrument
      • compute Σ(coupon × weight)    -> numPtfAvgCoupon
      • compute Σ(days  × weight)     -> raw_maturity_days
    Returns a *single* dictionary (one row for X in the SQL).
    """
    session = get_session()
    try:
        period_day = pd.to_datetime(dat)

        # ---- fetch instrument rows in chunks (still parallel safe) ----
        inst_codes = slice_df["strInstAladdin"].dropna().unique().tolist()
        frames = []
        for chunk in chunk_list(inst_codes, 2_000):
            q = (
                session.query(
                    DMIRBRSInstrument.strInstAladdin,
                    DMIRBRSInstrument.numInstCouponRate,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.blncall,
                    DMIRBRSInstrument.datInstCallDate,
                )
                .filter(DMIRBRSInstrument.strInstAladdin.in_(chunk))
            )
            frames.append(get_all_as_df(q))

        if frames:
            df_inst = pd.concat(frames, ignore_index=True)
        else:
            df_inst = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "numInstCouponRate",
                    "datInstMaturityDate",
                    "blncall",
                    "datInstCallDate",
                ]
            )

        # ---- vectorised join & maths ---------------------------------
        df_join = slice_df.merge(df_inst, on="strInstAladdin", how="inner")
        w = df_join["numInstrWeight"].astype(float).fillna(0.0)

        # coupon contribution: Σ(coupon × weight)
        numPtfAvgCoupon = (df_join["numInstCouponRate"].astype(float).fillna(0.0) * w).sum()

        # maturity contribution:  CASE logic reproduced vectorially
        mat_dates = np.where(
            (df_join["blncall"]) & df_join["datInstCallDate"].notna(),
            df_join["datInstCallDate"],
            df_join["datInstMaturityDate"],
        )
        mat_days = (
            (pd.to_datetime(mat_dates) - period_day).dt.days.clip(lower=0).astype(float)
        )
        raw_days = (mat_days * w).sum()

        return {
            "datPeriodLastDay": period_day,
            "strPortfGPSCode": code,
            "numPortfGroupFKey": fkey,
            "numPtfAvgCoupon": numPtfAvgCoupon,
            "raw_maturity_days": raw_days,
        }
    finally:
        session.close()


# ---------------------------------------------------------------------
# ❷ Aggregate those per‑portfolio rows back into the staging dataframe
# ---------------------------------------------------------------------
def compute_maturity_coupon(df_instr: pd.DataFrame,
                            df_tmp:   pd.DataFrame,
                            max_workers: int = 48) -> pd.DataFrame:
    """
    Vectorised re‑implementation of the SQL block that updates
    numPtfAvgCoupon   &   datPtfAvgMaturityLife  in #tmpPortfIndicatorsWrk.
    Only the metadata fetch is parallel; the arithmetic is NumPy / pandas.
    """
    # -- step A: build unique key list --------------------------------
    key_cols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    keys = (
        df_instr[key_cols]
        .drop_duplicates()
        .to_records(index=False)
    )

    # -- step B: parallel fetch + coupon / maturity sums --------------
    records = []
    with ProcessPoolExecutor(max_workers=max_workers) as pool:
        futures = {
            pool.submit(
                _get_maturity_coupon_single,
                i,
                dat,
                code,
                fkey,
                df_instr[
                    (df_instr["datPeriodLastDay"] == dat)
                    & (df_instr["strPortfGPSCode"] == code)
                    & (df_instr["numPortfGroupFKey"] == fkey)
                ],
            ): i
            for i, (dat, code, fkey) in enumerate(keys)
        }
        for fut in as_completed(futures):
            records.append(fut.result())

    if not records:
        # nothing to merge; return original tmp unchanged
        return df_tmp

    df_X = pd.DataFrame.from_records(records)

    # -- step C: convert raw weighted‑day sum into calendar date -------
    df_X["datPtfAvgMaturityLife"] = np.where(
        df_X["raw_maturity_days"].between(-100, 36_500),
        df_X["datPeriodLastDay"] + pd.to_timedelta(df_X["raw_maturity_days"], unit="D"),
        pd.NaT,
    )
    df_X.drop(columns="raw_maturity_days", inplace=True)  # helper no longer needed

    # -- step D: merge back into staging dataframe --------------------
    df_out = df_tmp.merge(
        df_X,
        on=key_cols,
        how="left",
        suffixes=("", "_X"),
    )
    for col in ["numPtfAvgCoupon", "datPtfAvgMaturityLife"]:
        rep = f"{col}_X"
        if rep in df_out.columns:
            df_out[col] = df_out[rep]
            df_out.drop(columns=rep, inplace=True)

    return df_out
