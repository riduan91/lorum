DECLARE
    @accounting_date        DATE        = '2025-05-30',  -- date to test
    @bench_code             INT         = 196823,        -- benchmark to test

    /* ─── type‐appropriate sentinels ───────────────────────── */
    @dflt_date      DATE       = '',      -- sentinel for dates
    @dflt_float     FLOAT      = 0.0,     -- sentinel zero for floats
    @dflt_int       INT        = 0,       -- sentinel zero for ints
    @dflt_string    VARCHAR(1) = '',      -- sentinel empty for strings
    @tol            FLOAT      = 1e-6;    -- tolerance = 10e-7

SELECT
    a.Accountingdate           AS Accountingdate,
    a.BKGNCode                 AS BKGNCode,
    a.InstrumentDWHID          AS InstrumentDWHID,

    /* ─── 0 / 1 mismatch flags ────────────────────────────── */
    CASE WHEN ISNULL(a.Accountingdate   , @dflt_date  ) = ISNULL(b.Accountingdate   , @dflt_date  ) THEN 0 ELSE 1 END AS diff_Accountingdate,
    CASE WHEN ISNULL(a.BKGNCode         , @dflt_int   ) = ISNULL(b.BKGNCode         , @dflt_int   ) THEN 0 ELSE 1 END AS diff_BKGNCode,
    CASE WHEN ISNULL(a.BenchCode        , @dflt_string) = ISNULL(b.BenchCode        , @dflt_string) THEN 0 ELSE 1 END AS diff_BenchCode,
    CASE WHEN ISNULL(a.BenchName        , @dflt_string) = ISNULL(b.BenchName        , @dflt_string) THEN 0 ELSE 1 END AS diff_BenchName,
    CASE WHEN ISNULL(a.BenchCurrency    , @dflt_string) = ISNULL(b.BenchCurrency    , @dflt_string) THEN 0 ELSE 1 END AS diff_BenchCurrency,
    CASE WHEN ISNULL(a.InstrumentDWHID  , @dflt_int   ) = ISNULL(b.InstrumentDWHID  , @dflt_int   ) THEN 0 ELSE 1 END AS diff_InstrumentDWHID,

    CASE WHEN ABS(ISNULL(a.LocalCurrencyPrice, @dflt_float) - ISNULL(b.LocalCurrencyPrice, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_LocalCurrencyPrice,
    CASE WHEN ABS(ISNULL(a.Quantity         , @dflt_float) - ISNULL(b.Quantity         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_Quantity,

    CASE WHEN ISNULL(a.ISINCode         , @dflt_string) = ISNULL(b.ISINCode         , @dflt_string) THEN 0 ELSE 1 END AS diff_ISINCode,
    CASE WHEN ISNULL(a.SedolCode        , @dflt_string) = ISNULL(b.SedolCode        , @dflt_string) THEN 0 ELSE 1 END AS diff_SedolCode,
    CASE WHEN ISNULL(a.CUSIPCode        , @dflt_string) = ISNULL(b.CUSIPCode        , @dflt_string) THEN 0 ELSE 1 END AS diff_CUSIPCode,
    CASE WHEN ISNULL(a.InternalCode     , @dflt_string) = ISNULL(b.InternalCode     , @dflt_string) THEN 0 ELSE 1 END AS diff_InternalCode,
    CASE WHEN ISNULL(a.CurrencyID       , @dflt_string) = ISNULL(b.CurrencyID       , @dflt_string) THEN 0 ELSE 1 END AS diff_CurrencyID,

    CASE WHEN ISNULL(a.strInstAladdin   , @dflt_string) = ISNULL(b.strInstAladdin   , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstAladdin,
    CASE WHEN ISNULL(a.strInstName      , @dflt_string) = ISNULL(b.strInstName      , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstName,
    CASE WHEN ISNULL(a.strBloombergCode , @dflt_string) = ISNULL(b.strBloombergCode , @dflt_string) THEN 0 ELSE 1 END AS diff_strBloombergCode,
    CASE WHEN ISNULL(a.strInstISINCode  , @dflt_string) = ISNULL(b.strInstISINCode  , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstISINCode,
    CASE WHEN ISNULL(a.strInstSedolCode , @dflt_string) = ISNULL(b.strInstSedolCode , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstSedolCode,
    CASE WHEN ISNULL(a.strInstCUSIPCode , @dflt_string) = ISNULL(b.strInstCUSIPCode , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstCUSIPCode,
    CASE WHEN ISNULL(a.strInstIssuerName, @dflt_string) = ISNULL(b.strInstIssuerName, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstIssuerName,
    CASE WHEN ISNULL(a.strInstExchLocName, @dflt_string) = ISNULL(b.strInstExchLocName, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstExchLocName,
    CASE WHEN ISNULL(a.strInstListingCountryLabel, @dflt_string)
              = ISNULL(b.strInstListingCountryLabel, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstListingCountryLabel,
    CASE WHEN ISNULL(a.strInstIssueCountryLabel, @dflt_string)
              = ISNULL(b.strInstIssueCountryLabel, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstIssueCountryLabel,
    CASE WHEN ISNULL(a.strInstIssuerCountryLabel, @dflt_string)
              = ISNULL(b.strInstIssuerCountryLabel, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstIssuerCountryLabel,

    CASE WHEN ABS(ISNULL(a.numInstCouponRate , @dflt_float) - ISNULL(b.numInstCouponRate , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstCouponRate,
    CASE WHEN ABS(ISNULL(a.numInstForwardRate, @dflt_float) - ISNULL(b.numInstForwardRate, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstForwardRate,

    CASE WHEN ISNULL(a.datInstMaturityDate , @dflt_date ) = ISNULL(b.datInstMaturityDate , @dflt_date ) THEN 0 ELSE 1 END AS diff_datInstMaturityDate,
    CASE WHEN ABS(ISNULL(a.RemainLife365     , @dflt_float) - ISNULL(b.RemainLife365     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_RemainLife365,
    CASE WHEN ISNULL(a.datInstCallDate     , @dflt_date ) = ISNULL(b.datInstCallDate     , @dflt_date ) THEN 0 ELSE 1 END AS diff_datInstCallDate,
    CASE WHEN ISNULL(a.datInstNextCouponDate, @dflt_date ) = ISNULL(b.datInstNextCouponDate, @dflt_date ) THEN 0 ELSE 1 END AS diff_datInstNextCouponDate,

    CASE WHEN ISNULL(a.strInstPriceType  , @dflt_string) = ISNULL(b.strInstPriceType  , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstPriceType,
    CASE WHEN ISNULL(a.strInstRateType   , @dflt_string) = ISNULL(b.strInstRateType   , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRateType,

    CASE WHEN ABS(ISNULL(a.numInstSpotRate , @dflt_float) - ISNULL(b.numInstSpotRate , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstSpotRate,
    CASE WHEN ISNULL(a.datInstStartDate  , @dflt_date ) = ISNULL(b.datInstStartDate  , @dflt_date ) THEN 0 ELSE 1 END AS diff_datInstStartDate,
    CASE WHEN ABS(ISNULL(a.numInstUndrlygQty, @dflt_float) - ISNULL(b.numInstUndrlygQty, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstUndrlygQty,
    CASE WHEN ISNULL(a.strInstUndrlygISINCode, @dflt_string) = ISNULL(b.strInstUndrlygISINCode, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstUndrlygISINCode,
    CASE WHEN ISNULL(a.datInstIssueDate  , @dflt_date ) = ISNULL(b.datInstIssueDate  , @dflt_date ) THEN 0 ELSE 1 END AS diff_datInstIssueDate,
    CASE WHEN ABS(ISNULL(a.numInstNominalMt , @dflt_float) - ISNULL(b.numInstNominalMt , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstNominalMt,
    CASE WHEN ISNULL(a.strInstCurrCode   , @dflt_string) = ISNULL(b.strInstCurrCode   , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstCurrCode,
    CASE WHEN ISNULL(a.datInstContractEnd, @dflt_date ) = ISNULL(b.datInstContractEnd, @dflt_date ) THEN 0 ELSE 1 END AS diff_datInstContractEnd,
    CASE WHEN ISNULL(a.strInstContractName, @dflt_string) = ISNULL(b.strInstContractName, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstContractName,

    CASE WHEN ISNULL(a.strInstLegTyp1    , @dflt_string) = ISNULL(b.strInstLegTyp1    , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstLegTyp1,
    CASE WHEN ISNULL(a.strInstLegTyp2    , @dflt_string) = ISNULL(b.strInstLegTyp2    , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstLegTyp2,
    CASE WHEN ISNULL(a.strInstLegType    , @dflt_string) = ISNULL(b.strInstLegType    , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstLegType,

    CASE WHEN ISNULL(a.strCpnRateTypPaid , @dflt_string) = ISNULL(b.strCpnRateTypPaid , @dflt_string) THEN 0 ELSE 1 END AS diff_strCpnRateTypPaid,
    CASE WHEN ISNULL(a.strCpnRateTypeRecv, @dflt_string) = ISNULL(b.strCpnRateTypeRecv, @dflt_string) THEN 0 ELSE 1 END AS diff_strCpnRateTypeRecv,

    CASE WHEN ABS(ISNULL(a.numCpnFixedRatePaid, @dflt_float) - ISNULL(b.numCpnFixedRatePaid, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numCpnFixedRatePaid,
    CASE WHEN ABS(ISNULL(a.numCpnFixedRateRecv, @dflt_float) - ISNULL(b.numCpnFixedRateRecv, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numCpnFixedRateRecv,

    CASE WHEN ISNULL(a.strCpnIndexPaid    , @dflt_string) = ISNULL(b.strCpnIndexPaid    , @dflt_string) THEN 0 ELSE 1 END AS diff_strCpnIndexPaid,
    CASE WHEN ISNULL(a.strCpnIndexRecv    , @dflt_string) = ISNULL(b.strCpnIndexRecv    , @dflt_string) THEN 0 ELSE 1 END AS diff_strCpnIndexRecv,

    CASE WHEN ISNULL(a.strSwapFreqPaid    , @dflt_string) = ISNULL(b.strSwapFreqPaid    , @dflt_string) THEN 0 ELSE 1 END AS diff_strSwapFreqPaid,
    CASE WHEN ISNULL(a.strSwapFreqRecv    , @dflt_string) = ISNULL(b.strSwapFreqRecv    , @dflt_string) THEN 0 ELSE 1 END AS diff_strSwapFreqRecv,

    CASE WHEN ISNULL(a.strInstrumentTypeName1, @dflt_string) = ISNULL(b.strInstrumentTypeName1, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeName1,
    CASE WHEN ISNULL(a.strInstrumentTypeIRName1, @dflt_string) = ISNULL(b.strInstrumentTypeIRName1, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeIRName1,
    CASE WHEN ISNULL(a.strInstrumentTypeName3, @dflt_string) = ISNULL(b.strInstrumentTypeName3, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeName3,
    CASE WHEN ISNULL(a.strInstrumentTypeIRName3, @dflt_string) = ISNULL(b.strInstrumentTypeIRName3, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeIRName3,

    CASE WHEN ISNULL(a.strCoreAssetClaLvl1Lbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl1Lbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl1Lbl,
    CASE WHEN ISNULL(a.strCoreAssetClaLvl2Lbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl2Lbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl2Lbl,
    CASE WHEN ISNULL(a.strCoreAssetClaLvl3Lbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl3Lbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl3Lbl,
    CASE WHEN ISNULL(a.strCoreAssetClaLvl4Lbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl4Lbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl4Lbl,

    CASE WHEN ABS(ISNULL(a.LocalCurrencyMarketCap, @dflt_float) - ISNULL(b.LocalCurrencyMarketCap, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_LocalCurrencyMarketCap,
    CASE WHEN ABS(ISNULL(a.USDMarketCap           , @dflt_float) - ISNULL(b.USDMarketCap           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_USDMarketCap,
    CASE WHEN ABS(ISNULL(a.EURMarketCap           , @dflt_float) - ISNULL(b.EURMarketCap           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_EURMarketCap,

    CASE WHEN ABS(ISNULL(a.numInstYieldToMaturity       , @dflt_float) - ISNULL(b.numInstYieldToMaturity       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstYieldToMaturity,
    CASE WHEN ABS(ISNULL(a.numInstEffDuration          , @dflt_float) - ISNULL(b.numInstEffDuration          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstEffDuration,
    CASE WHEN ABS(ISNULL(a.numInstModifDuration        , @dflt_float) - ISNULL(b.numInstModifDuration        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstModifDuration,
    CASE WHEN ABS(ISNULL(a.numInstSpreadDuration       , @dflt_float) - ISNULL(b.numInstSpreadDuration       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstSpreadDuration,
    CASE WHEN ABS(ISNULL(a.numInstMCDuration          , @dflt_float) - ISNULL(b.numInstMCDuration          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstMCDuration,
    CASE WHEN ABS(ISNULL(a.numInstYield               , @dflt_float) - ISNULL(b.numInstYield               , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstYield,
    CASE WHEN ABS(ISNULL(a.numInstYieldToCall         , @dflt_float) - ISNULL(b.numInstYieldToCall         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstYieldToCall,
    CASE WHEN ABS(ISNULL(a.numInstYieldToMaturityPaid , @dflt_float) - ISNULL(b.numInstYieldToMaturityPaid , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstYieldToMaturityPaid,
    CASE WHEN ABS(ISNULL(a.numInstYieldToMaturityRecv , @dflt_float) - ISNULL(b.numInstYieldToMaturityRecv , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstYieldToMaturityRecv,

    CASE WHEN ISNULL(a.InstrSectorBBLevel1 , @dflt_string) = ISNULL(b.InstrSectorBBLevel1 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorBBLevel1,
    CASE WHEN ISNULL(a.InstrSectorBBLevel2 , @dflt_string) = ISNULL(b.InstrSectorBBLevel2 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorBBLevel2,
    CASE WHEN ISNULL(a.InstrSectorBBLevel3 , @dflt_string) = ISNULL(b.InstrSectorBBLevel3 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorBBLevel3,
    CASE WHEN ISNULL(a.InstrSectorBBLevel4 , @dflt_string) = ISNULL(b.InstrSectorBBLevel4 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorBBLevel4,

    CASE WHEN ISNULL(a.InstrSectorLHLevel1 , @dflt_string) = ISNULL(b.InstrSectorLHLevel1 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorLHLevel1,
    CASE WHEN ISNULL(a.InstrSectorLHLevel2 , @dflt_string) = ISNULL(b.InstrSectorLHLevel2 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorLHLevel2,
    CASE WHEN ISNULL(a.InstrSectorLHLevel3 , @dflt_string) = ISNULL(b.InstrSectorLHLevel3 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorLHLevel3,
    CASE WHEN ISNULL(a.InstrSectorLHLevel4 , @dflt_string) = ISNULL(b.InstrSectorLHLevel4 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorLHLevel4,

    CASE WHEN ISNULL(a.InstrSectorMLLevel1 , @dflt_string) = ISNULL(b.InstrSectorMLLevel1 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMLLevel1,
    CASE WHEN ISNULL(a.InstrSectorMLLevel2 , @dflt_string) = ISNULL(b.InstrSectorMLLevel2 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMLLevel2,
    CASE WHEN ISNULL(a.InstrSectorMLLevel3 , @dflt_string) = ISNULL(b.InstrSectorMLLevel3 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMLLevel3,
    CASE WHEN ISNULL(a.InstrSectorMLLevel4 , @dflt_string) = ISNULL(b.InstrSectorMLLevel4 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMLLevel4,

    CASE WHEN ISNULL(a.InstrSectorJPMLevel1, @dflt_string) = ISNULL(b.InstrSectorJPMLevel1, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorJPMLevel1,
    CASE WHEN ISNULL(a.InstrSectorJPMLevel2, @dflt_string) = ISNULL(b.InstrSectorJPMLevel2, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorJPMLevel2,
    CASE WHEN ISNULL(a.InstrSectorJPMLevel3, @dflt_string) = ISNULL(b.InstrSectorJPMLevel3, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorJPMLevel3,
    CASE WHEN ISNULL(a.InstrSectorJPMLevel4, @dflt_string) = ISNULL(b.InstrSectorJPMLevel4, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorJPMLevel4,

    CASE WHEN ISNULL(a.InstrSectorMSCILevel1, @dflt_string) = ISNULL(b.InstrSectorMSCILevel1, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMSCILevel1,
    CASE WHEN ISNULL(a.InstrSectorMSCILevel2, @dflt_string) = ISNULL(b.InstrSectorMSCILevel2, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMSCILevel2,
    CASE WHEN ISNULL(a.InstrSectorMSCILevel3, @dflt_string) = ISNULL(b.InstrSectorMSCILevel3, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMSCILevel3,
    CASE WHEN ISNULL(a.InstrSectorMSCILevel4, @dflt_string) = ISNULL(b.InstrSectorMSCILevel4, @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorMSCILevel4,

    CASE WHEN ISNULL(a.InstrSectorICBLevel1 , @dflt_string) = ISNULL(b.InstrSectorICBLevel1 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorICBLevel1,
    CASE WHEN ISNULL(a.InstrSectorICBLevel2 , @dflt_string) = ISNULL(b.InstrSectorICBLevel2 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorICBLevel2,
    CASE WHEN ISNULL(a.InstrSectorICBLevel3 , @dflt_string) = ISNULL(b.InstrSectorICBLevel3 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorICBLevel3,
    CASE WHEN ISNULL(a.InstrSectorICBLevel4 , @dflt_string) = ISNULL(b.InstrSectorICBLevel4 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrSectorICBLevel4,

    CASE WHEN ABS(ISNULL(a.numInstrWeight, @dflt_float) - ISNULL(b.numInstrWeight, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numInstrWeight,
    CASE WHEN ABS(ISNULL(a.numEffectDurationContrib, @dflt_float) - ISNULL(b.numEffectDurationContrib, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numEffectDurationContrib,
    CASE WHEN ABS(ISNULL(a.numMCDurationContrib    , @dflt_float) - ISNULL(b.numMCDurationContrib    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numMCDurationContrib,
    CASE WHEN ABS(ISNULL(a.numModifDurationContrib , @dflt_float) - ISNULL(b.numModifDurationContrib , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numModifDurationContrib,
    CASE WHEN ABS(ISNULL(a.numSpreadDurationContrib, @dflt_float) - ISNULL(b.numSpreadDurationContrib, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numSpreadDurationContrib,
    CASE WHEN ABS(ISNULL(a.numDurExposureInBenchCur, @dflt_float) - ISNULL(b.numDurExposureInBenchCur, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numDurExposureInBenchCur,
    CASE WHEN ABS(ISNULL(a.numCurExposureInBenchCur, @dflt_float) - ISNULL(b.numCurExposureInBenchCur, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numCurExposureInBenchCur,
    CASE WHEN ABS(ISNULL(a.numCurExposureWeight   , @dflt_float) - ISNULL(b.numCurExposureWeight   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numCurExposureWeight,
    CASE WHEN ABS(ISNULL(a.numDurExposureWeight   , @dflt_float) - ISNULL(b.numDurExposureWeight   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numDurExposureWeight,

    CASE WHEN ISNULL(a.strInstRtgSPStandardized  , @dflt_string) = ISNULL(b.strInstRtgSPStandardized  , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgSPStandardized,
    CASE WHEN ISNULL(a.strInstRtgMDStandardized  , @dflt_string) = ISNULL(b.strInstRtgMDStandardized  , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgMDStandardized,
    CASE WHEN ISNULL(a.strInstRtgFHStandardized  , @dflt_string) = ISNULL(b.strInstRtgFHStandardized  , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgFHStandardized,

    CASE WHEN ISNULL(a.strInstRtgCustom1, @dflt_string) = ISNULL(b.strInstRtgCustom1, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom1,
    CASE WHEN ISNULL(a.strInstRtgCustom2, @dflt_string) = ISNULL(b.strInstRtgCustom2, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom2,
    CASE WHEN ISNULL(a.strInstRtgCustom3, @dflt_string) = ISNULL(b.strInstRtgCustom3, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom3,
    CASE WHEN ISNULL(a.strInstRtgCustom4, @dflt_string) = ISNULL(b.strInstRtgCustom4, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom4,
    CASE WHEN ISNULL(a.strInstRtgCustom5, @dflt_string) = ISNULL(b.strInstRtgCustom5, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom5,
    CASE WHEN ISNULL(a.strInstRtgCustom6, @dflt_string) = ISNULL(b.strInstRtgCustom6, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom6,
    CASE WHEN ISNULL(a.strInstRtgCustom7, @dflt_string) = ISNULL(b.strInstRtgCustom7, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom7,
    CASE WHEN ISNULL(a.strInstRtgCustom8, @dflt_string) = ISNULL(b.strInstRtgCustom8, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom8,
    CASE WHEN ISNULL(a.strInstRtgCustom9, @dflt_string) = ISNULL(b.strInstRtgCustom9, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom9,
    CASE WHEN ISNULL(a.strInstRtgCustom10,@dflt_string)= ISNULL(b.strInstRtgCustom10,@dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom10,
    CASE WHEN ISNULL(a.strInstRtgCustom11,@dflt_string)= ISNULL(b.strInstRtgCustom11,@dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom11,
    CASE WHEN ISNULL(a.strInstRtgCustom12,@dflt_string)= ISNULL(b.strInstRtgCustom12,@dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom12,
    CASE WHEN ISNULL(a.strInstRtgCustom13,@dflt_string)= ISNULL(b.strInstRtgCustom13,@dflt_string) THEN 0 ELSE 1 END AS diff_strInstRtgCustom13,

    CASE WHEN ISNULL(a.numAuditId           , @dflt_int  ) = ISNULL(b.numAuditId           , @dflt_int  ) THEN 0 ELSE 1 END AS diff_numAuditId,

    CASE WHEN ABS(ISNULL(a.numESGGlbScoreWeighted, @dflt_float) - ISNULL(b.numESGGlbScoreWeighted, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbScoreWeighted,
    CASE WHEN ABS(ISNULL(a.numESGGlbScore        , @dflt_float) - ISNULL(b.numESGGlbScore        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbScore,

    CASE WHEN ABS(ISNULL(a.InstrESGGlbScore   , @dflt_float) - ISNULL(b.InstrESGGlbScore   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_InstrESGGlbScore,
    CASE WHEN ABS(ISNULL(a.InstrESGGlbScoreCov, @dflt_float) - ISNULL(b.InstrESGGlbScoreCov, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_InstrESGGlbScoreCov,

    CASE WHEN ABS(ISNULL(a.InstrCO2IntensEVEval   , @dflt_float) - ISNULL(b.InstrCO2IntensEVEval   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_InstrCO2IntensEVEval,
    CASE WHEN ABS(ISNULL(a.InstrCO2IntensEVEvalCov, @dflt_float) - ISNULL(b.InstrCO2IntensEVEvalCov, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_InstrCO2IntensEVEvalCov,

    CASE WHEN ISNULL(a.strCoreAssetClaLvl1LblBbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl1LblBbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl1LblBbl,
    CASE WHEN ISNULL(a.strCoreAssetClaLvl2LblBbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl2LblBbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl2LblBbl,
    CASE WHEN ISNULL(a.strCoreAssetClaLvl3LblBbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl3LblBbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl3LblBbl,
    CASE WHEN ISNULL(a.strCoreAssetClaLvl4LblBbl, @dflt_string) = ISNULL(b.strCoreAssetClaLvl4LblBbl, @dflt_string) THEN 0 ELSE 1 END AS diff_strCoreAssetClaLvl4LblBbl,

    CASE WHEN ABS(ISNULL(a.InstrMktCapEur   , @dflt_float) - ISNULL(b.InstrMktCapEur   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_InstrMktCapEur,
    CASE WHEN ISNULL(a.InstrMktCapEurTr1 , @dflt_string) = ISNULL(b.InstrMktCapEurTr1 , @dflt_string) THEN 0 ELSE 1 END AS diff_InstrMktCapEurTr1,
    CASE WHEN ISNULL(a.strInstRiskCountryLabel, @dflt_string) = ISNULL(b.strInstRiskCountryLabel, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstRiskCountryLabel,
    CASE WHEN ABS(ISNULL(a.InstrOAS, @dflt_float) - ISNULL(b.InstrOAS, @dflt_float)) < @tol THEN 0 ELSE 1 END AS diff_InstrOAS,
    CASE WHEN ISNULL(a.instrTypCd     , @dflt_string) = ISNULL(b.instrTypCd     , @dflt_string) THEN 0 ELSE 1 END AS diff_instrTypCd,
    CASE WHEN ISNULL(a.FNFHOrGNMA     , @dflt_string) = ISNULL(b.FNFHOrGNMA     , @dflt_string) THEN 0 ELSE 1 END AS diff_FNFHOrGNMA,

    CASE WHEN ISNULL(a.strInstrumentTypeName8 , @dflt_string) = ISNULL(b.strInstrumentTypeName8 , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeName8,
    CASE WHEN ISNULL(a.strInstrumentTypeIRName8, @dflt_string) = ISNULL(b.strInstrumentTypeIRName8, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeIRName8,
    CASE WHEN ISNULL(a.strInstrumentTypeName9 , @dflt_string) = ISNULL(b.strInstrumentTypeName9 , @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeName9,
    CASE WHEN ISNULL(a.strInstrumentTypeIRName9, @dflt_string) = ISNULL(b.strInstrumentTypeIRName9, @dflt_string) THEN 0 ELSE 1 END AS diff_strInstrumentTypeIRName9

FROM   DMIR.tblDMIRAPIBenchHolding AS a
JOIN   dbo.tblDMIRAPIBenchHolding AS b
  ON  a.Accountingdate  = b.Accountingdate
  AND a.BKGNCode        = b.BKGNCode
  AND a.InstrumentDWHID = b.InstrumentDWHID

WHERE
    a.Accountingdate = @accounting_date
  AND a.BKGNCode      = @bench_code;
