from pathlib import Path
import logging
import polars as pl

def get_data_folder(child_folder: str) -> Path:
    root_folder = Path("/opt/airflow/data/")
    (root_folder / child_folder).mkdir(exist_ok=True, parents=True)
    return root_folder / child_folder


def save_parquet(df: pl.DataFrame, name: str, child_folder: str, audit_id=None, part=None) -> str:
    destination = get_data_folder(child_folder) / (
        name
        + (f"_{audit_id}" if audit_id else "")
        + (f"_p{part}" if part else "")
        + ".parquet"
    )

    df = normalize_type(df)  # You already have the Polars version of normalize_type
    df.write_parquet(destination)
    logging.info(f"{len(df)} rows saved.")
    get_hardware_info()  # Assuming it's still needed
    return str(destination)


def load_parquet(str_infile: str, **kwargs) -> pl.DataFrame:
    df = pl.read_parquet(str_infile, **kwargs)
    df = normalize_type(df)
    logging.info(f"{len(df)} rows loaded.")
    get_hardware_info()
    return df
