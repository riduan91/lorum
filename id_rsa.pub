# ------------------------------------
# Core queries
# ------------------------------------

def fetch_group_counts(session, pair: dict, audit_id_cutoff: int, join_mode: str) -> pd.DataFrame:
    group_cols = pair["group_cols"]
    group_by = ", ".join(group_cols)
    table_legacy = pair["legacy"]
    table_python = pair["python"]
    dat_col = pair["dat_col"]
    cutoff = pair["cutoff"]

    join_on = _build_join(group_cols, "sum_a", "sum_b")

    # IMPORTANT: filter inside each side's CTE to preserve FULL OUTER symmetry
    sql = f"""
    WITH sum_a AS (
        SELECT {group_by}, COUNT(*) AS count_legacy
        FROM {table_legacy}
        WHERE numAuditId >= {audit_id_cutoff}
          AND {dat_col} >= '{cutoff}'
        GROUP BY {group_by}
    ),
    sum_b AS (
        SELECT {group_by}, COUNT(*) AS count_python
        FROM {table_python}
        WHERE numAuditId >= {audit_id_cutoff}
          AND {dat_col} >= '{cutoff}'
        GROUP BY {group_by}
    )
    SELECT ISNULL(sum_a.{group_cols[0]}, sum_b.{group_cols[0]}) AS {group_cols[0]},
           {', '.join([f'ISNULL(sum_a.{c}, sum_b.{c}) AS {c}' for c in group_cols[1:]])},
           count_legacy,
           count_python
    FROM sum_a
    {join_mode} sum_b
      ON {join_on}
    ORDER BY {', '.join(group_cols)};
    """
    logging.info(f"Running SQL query: {sql}.")
    df = run_sql_to_df(session, sql)
    if not df.empty:
        df["status"] = (df["count_legacy"] == df["count_python"]).map(lambda x: "OK" if x else "KO")
        df = df.sort_values(by="status")
    else:
        df["status"] = []
    return df


# Get common columns

def get_shared_columns(engine, table_legacy: str, table_python: str):
    insp = inspect(engine)
    cols_legacy = [
        c["name"]
        for c in insp.get_columns(table_legacy.split(".")[-1], schema=table_legacy.split(".")[0])
    ]
    cols_python = [
        c["name"]
        for c in insp.get_columns(table_python.split(".")[-1], schema=table_python.split(".")[0])
    ]
    return list(set(cols_legacy).intersection(cols_python))


# Get common columns with types

def get_shared_columns_with_types(engine, table_legacy: str, table_python: str):
    insp = inspect(engine)
    cols_legacy = {
        c["name"]: c["type"].__class__.__name__.lower()
        for c in insp.get_columns(table_legacy.split(".")[-1], schema=table_legacy.split(".")[0])
    }
    cols_python = {
        c["name"]: c["type"].__class__.__name__.lower()
        for c in insp.get_columns(table_python.split(".")[-1], schema=table_python.split(".")[0])
    }
    shared = set(cols_legacy).intersection(cols_python)
    return [(col, cols_legacy[col]) for col in shared]



def fetch_column_diffs(
    session,
    pair: dict,
    compare_cols_with_types: list,
    df_summary: pd.DataFrame,
    aligners=["strInstAladdin"],
    join_mode="FULL OUTER JOIN",
) -> pd.DataFrame:
    legacy = pair["legacy"]
    python = pair["python"]
    group_cols = pair["group_cols"]
    aligners = pair.get("aligner") or []  # ensure list
    pair_tol = pair.get("tol", FLOAT_TOLERANCE)

    # Prefer sampling KO groups; if none, sample from all
    if df_summary.empty:
        return pd.DataFrame(
            [{"column": col, "diff_count": 0} for col, _ in compare_cols_with_types]
        )

    base_rows = df_summary[df_summary["status"] == "KO"]
    if base_rows.empty:
        base_rows = df_summary

    rows = base_rows.sample(min(10, len(base_rows)), random_state=42)
    dfs = []

    # Null-safe join on group_cols where required
    join_on = _build_join(group_cols, "a", "b")

    for _, r in rows.iterrows():
        # WHERE for selected group (special-case PortfolioDWHID/PortfolioDWHGroupID)
        parts = []
        for col in group_cols:
            if col in ("PortfolioDWHID", "PortfolioDWHGroupID"):
                val = r[col]
                if pd.isna(val):
                    parts.append(f"a.{col} IS NULL")
                else:
                    parts.append(f"a.{col} = {int(val)}")
            else:
                lit = _sql_literal(r[col])
                if lit is None:
                    parts.append(f"a.{col} IS NULL")
                else:
                    parts.append(f"a.{col} = {lit}")
        where_clause = " AND ".join(parts)

        addition_select = ",\n".join([f"COALESCE(a.{col}, b.{col}) AS {col}" for col in group_cols])

        # keep only aligners that are present in shared columns
        aligners_effective = [
            aligner for aligner in aligners if any(col == aligner for col, _ in compare_cols_with_types)
        ]

        comparisons = []
        for col, coltype in compare_cols_with_types:
            if any(t in coltype for t in FLOAT_TYPES):
                clause = (
                    f"CASE WHEN ABS(ISNULL(a.{col}, 0) - ISNULL(b.{col}, 0)) > {pair_tol} "
                    f"THEN 1 ELSE 0 END AS diff_{col}"
                )
            else:
                clause = f"CASE WHEN ISNULL(a.{col}, '') <> ISNULL(b.{col}, '') THEN 1 ELSE 0 END AS diff_{col}"
            comparisons.append(clause)

        sql = "SELECT " + ",\n".join(comparisons) + f",\n {addition_select}"
        for aligner in aligners_effective:
            sql += f",\n a.{aligner} "

        sql += f"""
        FROM {legacy} a
        {join_mode} {python} b
          ON {join_on}
        """
        for aligner in aligners_effective:
            sql += f" AND a.{aligner} = b.{aligner} "

        sql += f"\nWHERE {where_clause} "
        if len(aligners_effective) > 0:
            sql += f"\nORDER BY {', '.join(aligners_effective)}"

        logging.info(f"Executing {sql}.")
        df = run_sql_to_df(session, sql)
        # Summarize diffs per column for this sampled group
        dfs.append(
            pd.DataFrame(
                [
                    {
                        "column": col,
                        f"Diff count for {where_clause.replace('a.', ' ')}": df.get(f"diff_{col}", pd.Series(dtype=int)).sum(),
                    }
                    for col, _ in compare_cols_with_types
                ]
            )
        )

    if not dfs:
        return pd.DataFrame([{"column": col} for col, _ in compare_cols_with_types])

    df_final = dfs[0]
    for df in dfs[1:]:
        df_final = df_final.merge(df, on="column")

    return df_final.sort_values(by="column")


# ------------------------------------
# Orchestrator
# ------------------------------------

def compare_schemas(**kwargs):
    params = kwargs.get("params", {}) or {}
    audit_id_cutoff = params.get("audit_id_cutoff")
    mode = (params.get("mode") or "").lower()

    join_mode = " FULL OUTER JOIN " if mode.endswith("full") else " INNER JOIN "
    suffix = "_full" if (params.get("mode") == "full" or mode.endswith("full")) else ""

    # (2) compute filenames with reporting date + audit id
    reporting_date = params.get("reporting_date") or datetime.now().strftime("%Y%m%d-%H%M")
    base_stub = f"schema_report_{_safe(reporting_date)}_audit{_safe(audit_id_cutoff)}{suffix}"
    html_path = Path(OUTDIR) / f"{base_stub}.html"
    zip_path = Path(OUTDIR) / f"{base_stub}.zip"

    session = get_session()
    engine = session.get_bind()

    # Select scope
    if mode.startswith("bench"):
        scopes = {k: v for k, v in PAIRS.items() if "Bench" in k}
    elif mode.startswith("lt") or mode.startswith("look"):
        scopes = {k: v for k, v in PAIRS.items() if "LT" in k}
    elif mode.startswith(("dwgn", "ma")):
        scopes = {k: v for k, v in PAIRS.items() if k.startswith("tblDWGN")}
    else:
        scopes = PAIRS

    csv_paths = []
    sections = []

    for tbl, pair in scopes.items():
        # 1) Summary counts
        df_summary = fetch_group_counts(session, pair, audit_id_cutoff, join_mode=join_mode)
        p_summary = Path(OUTDIR) / f"{tbl}_summary.csv"
        df_summary.to_csv(p_summary, index=False)
        csv_paths.append(p_summary)
        logging.info(f"Wrote {p_summary}")

        # 2) Column diffs
        cols_with_types = get_shared_columns_with_types(engine, pair["legacy"], pair["python"])
        df_col = fetch_column_diffs(session, pair, cols_with_types, df_summary, join_mode=join_mode)
        p_col = Path(OUTDIR) / f"{tbl}_column_diffs.csv"
        df_col.to_csv(p_col, index=False)
        csv_paths.append(p_col)
        logging.info(f"Wrote {p_col}")

        ok_count = int((df_summary["status"] == "OK").sum()) if not df_summary.empty else 0
        ko_count = int((df_summary["status"] == "KO").sum()) if not df_summary.empty else 0
        stats_html = f"""
        <div class="stats">
            <span class="pill ok">OK: {ok_count}</span>
            <span class="pill ko">KO: {ko_count}</span>
        </div>
        """

        # 3) Prepare HTML
        safe_id = re.sub(r"[^a-zA-Z0-9_-]", "_", tbl)
        summary_table_html = (
            df_summary.to_html(index=False)
            .replace("<td>OK</td>", '<td class="ok">OK</td>')
            .replace("<td>KO</td>", '<td class="ko">KO</td>')
        )
        sections.append(
            {
                "id": safe_id,
                "title": tbl,
                "summary_html": stats_html + summary_table_html,
                "diffs_html": df_col.to_html(index=False),
            }
        )

    # Build tabbed report
    tabs_html = "\n".join(
        f'<li class="tab{" active" if i == 0 else ""}" data-target="{s["id"]}">{s["title"]}</li>'
        for i, s in enumerate(sections)
    )
    panels_html = "\n".join(
        f"""
        <section id="{s["id"]}" class="panel{" active" if i == 0 else ""}">
            <h2>{s["title"]}</h2>
            <h3>Summary</h3>
            {s["summary_html"]}
            <h3>Column Diffs for 10 Random Groups</h3>
            {s["diffs_html"]}
        </section>
        """
        for i, s in enumerate(sections)
    )

    env = os.getenv("ENVIRONMENT", "dev")
    env_in_url = ".dev" if env == "dev" else ("" if env == "prod" else ".staging")
    zip_link = f"https://safir-dataloading.am{env_in_url}.echonet/monitoring/files/?file_location={zip_path}"

    html = f"""
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Schema Comparison Report - {reporting_date} - audit {audit_id_cutoff}</title>
<style>
  body {{ font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 16px; }}
  .tabs {{ list-style: none; padding: 0; display: flex; gap: 8px; border-bottom: 1px solid #ccc; margin-bottom: 12px; flex-wrap: wrap; }}
  .tab {{ padding: 8px 12px; cursor: pointer; border: 1px solid #ccc; border-bottom: none; border-radius: 6px 6px 0 0; background: #f7f7f7; }}
  .tab.active {{ background: white; font-weight: 600; }}
  .panel {{ display: none; }}
  .panel.active {{ display: block; }}
  .ok {{ background-color: #A4F4CF }}
  .ko {{ background-color: #FFEDD4 }}
  table {{ border-collapse: collapse; width: 100%; margin-bottom: 24px; }}
  th, td {{ border: 1px solid #e2e2e2; padding: 6px 8px; text-align: left; }}
  th {{ background: #fafafa; position: sticky; top: 0; }}
  h2 {{ margin: 8px 0 6px; }}
  h3 {{ margin: 14px 0 6px; }}
  .download {{ margin: 8px 0 16px; }}
</style>
</head>
<body>
  <h1>Schema Comparison Report</h1>
  <div class="download">
    <strong>Report date:</strong> {reporting_date}
    &nbsp; | &nbsp;
    <strong>Audit cutoff:</strong> {audit_id_cutoff}
    &nbsp; | &nbsp;
    <a href="{zip_link}">Download all results (ZIP)</a>
  </div>
  <p>(We are comparing records inserted/updated after
     {audit_id_cutoff[0:4]}-{audit_id_cutoff[4:6]}-{audit_id_cutoff[6:8]} {audit_id_cutoff[8:10]}:{audit_id_cutoff[10:12]}:{audit_id_cutoff[12:14]})</p>
  <ul class="tabs">
    {tabs_html}
  </ul>
  {panels_html}
<script>
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.panel');
  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.getAttribute('data-target');
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(target).classList.add('active');
    });
  });
</script>
</body>
</html>
"""
    with open(html_path, "w", encoding="utf-8") as f:
        f.write(html)
    logging.info(f"Wrote {html_path}")

    # (1) ZIP everything
    with zipfile.ZipFile(zip_path, "w", compression=zipfile.ZIP_DEFLATED) as zf:
        zf.write(html_path, arcname=html_path.name)
        for p in csv_paths:
            zf.write(p, arcname=p.name)
    logging.info(f"Wrote {zip_path}. Can be downloaded at {zip_link} .")

    session.close()
    return zip_link


with DAG(
    dag_id="Parallel_Run_Comparison",
    start_date=datetime(2023, 1, 1),
    schedule_interval=None,
    catchup=False,
    params={
        "audit_id_cutoff": (datetime.now() - timedelta(days=1)).strftime("%Y%m%d00000000000"),
        "mode": "standard",  # or "standard_full", "dwgn", "dwgn_full", "bench", "lt"
    },
    tags=["comparison"],
) as dag:

    compare_task = PythonOperator(
        task_id="compare_schemas", python_callable=compare_schemas, provide_context=True
    )

    compare_task
