def single_compute_instr_indicators_bkgn_2_instruments(i, chunk_aladdin_codes, retry=3):
    """Process a chunk of instrument Aladdin codes."""
    local_session = None
    print(f"Processing chunk {i}")
    try:
        local_session = get_local_session()
        results = []
        query = local_session.query(DMIRBRSInstrument).filter(
            DMIRBRSInstrument.strInstAladdin.in_(chunk_aladdin_codes)
        )
        for row in query:
            results.append(
                {
                    c.name: getattr(row, c.name)
                    for c in DMIRBRSInstrument.__table__.columns
                    if c.name != "_sa_instance_state"
                }
            )
        return results
    except Exception as e:
        safe_close(local_session)
        if retry > 0:
            print(f"Exception at attempt {4 - retry} for chunk {i}: {str(e)}")
            return single_compute_instr_indicators_bkgn_2_instruments(
                i,
                chunk_aladdin_codes,
                retry=retry - 1,
            )
    finally:
        safe_close(local_session)


def get_currency_quotes_for_date(valid_currency_ids, date):
    local_session = get_local_session()
    try:
        quotes = []
        for row in local_session.query(DMIRBRSCurrencyQuote).filter(
            DMIRBRSCurrencyQuote.datccyqDate == date,
            DMIRBRSCurrencyQuote.numCurrencyID.in_(valid_currency_ids),
        ):
            quotes.append(
                {
                    c.name: getattr(row, c.name)
                    for c in DMIRBRSCurrencyQuote.__table__.columns
                    if c.name != "_sa_instance_state"
                }
            )
        return quotes
    finally:
        safe_close(local_session)


def get_analytics_for_instruments(i, chunk_aladdin, reporting_days, retry=3):
    local_session = None
    print(f"Processing chunk {i}")
    try:
        local_session = get_local_session()
        analytics = []
        for row in local_session.query(
            DMIRBRSInstAnalytic.strInstAladdin,
            DMIRBRSInstAnalytic.datInstQuotationDate,
            DMIRBRSInstAnalytic.numInstConvexity,
            DMIRBRSInstAnalytic.numInstModifDuration,
            DMIRBRSInstAnalytic.numInstMCDuration,
            DMIRBRSInstAnalytic.numInstSpreadDuration,
            DMIRBRSInstAnalytic.numInstEffDuration,
        ).filter(
            DMIRBRSInstAnalytic.strInstAladdin.in_(chunk_aladdin),
            DMIRBRSInstAnalytic.datInstQuotationDate.in_(reporting_days),
        ):
            analytics.append(
                {
                    "strInstAladdin": row.strInstAladdin,
                    "datInstQuotationDate": row.datInstQuotationDate,
                    "numInstConvexity": row.numInstConvexity,
                    "numInstModifDuration": row.numInstModifDuration,
                    "numInstMCDuration": row.numInstMCDuration,
                    "numInstSpreadDuration": row.numInstSpreadDuration,
                    "numInstEffDuration": row.numInstEffDuration,
                }
            )
        return analytics
    except Exception as e:
        print(e)
        safe_close(local_session)
        if retry >= 0:
            return get_analytics_for_instruments(i, chunk_aladdin, reporting_days, retry=retry - 1)
    finally:
        safe_close(local_session)


def compute_instr_indicators_bkgn_2(df_tblDMIRBKGN):
    """
    Second step in computing DMIR BKGN table - merge with currency and instrument data.

    Args:
        df_tblDMIRBKGN: DataFrame from first step

    Returns:
        DataFrame with merged currency and instrument data
    """
    if df_tblDMIRBKGN is None or len(df_tblDMIRBKGN) == 0:
        return pd.DataFrame()

    session = get_local_session()

    try:
        sub_a_cols = [
            "numBenchFBAId",
            "strCompositionCd",
            "strPeriodTypeFlag",
            "datReportingDay",
            "numPFCurrencyRate",
            "strPFCurrencyISOCode",
            "datval",
            "strInstAladdin",
            "numInstId",
            "codinscurid",
            "numweight",
            "numinslclcurpri",
            "numinsqty",
            "numlclcurmktcap",
            "numusdmktcap",
            "numeurmktcap",
        ]
        df_a = df_tblDMIRBKGN[sub_a_cols].drop_duplicates().copy()

        valid_codinscurid = df_a["codinscurid"].unique().tolist()

        currency_query = session.query(
            DMIRTypCurrency.strExtCode, DMIRTypCurrency.numCurrencyId
        ).filter(DMIRTypCurrency.strExtCode.in_(valid_codinscurid))
        df_typ_currency = get_all_as_df(currency_query)

        df_a = pd.merge(
            df_a,
            df_typ_currency[["strExtCode", "numCurrencyId"]],
            left_on="codinscurid",
            right_on="strExtCode",
            how="left",
        )

        valid_dates = df_a["datval"].unique().tolist()
        valid_currency_ids = df_typ_currency["numCurrencyId"].dropna().astype(int).unique().tolist()

        quote_results = []
        num_cpus = os.cpu_count() or 4
        with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
            futures = {
                executor.submit(get_currency_quotes_for_date, valid_currency_ids, date): date
                for date in valid_dates
            }
            for future in concurrent.futures.as_completed(futures):
                try:
                    quotes = future.result()
                    quote_results.extend(quotes)
                except Exception as exc:
                    print(f"Date {futures[future]} generated an exception: {exc}")

        df_currency_quote = pd.DataFrame(quote_results)
        df_currency_quote["datccyqDate"] = pd.to_datetime(df_currency_quote["datccyqDate"])

        df_a = pd.merge(
            df_a,
            df_currency_quote[["numCurrencyID", "datccyqDate", "numccyqRate"]],
            left_on=["numCurrencyId", "datval"],
            right_on=["numCurrencyID", "datccyqDate"],
            how="left",
        )

        valid_inst_aladdin = df_a["strInstAladdin"].unique().tolist()
        chunk_size = max(1, min(2000, len(valid_inst_aladdin) // (num_cpus * 2)))
        aladdin_chunks = [
            valid_inst_aladdin[i : i + chunk_size]
            for i in range(0, len(valid_inst_aladdin), chunk_size)
        ]

        instrument_results = []
        with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
            futures = {
                executor.submit(single_compute_instr_indicators_bkgn_2_instruments, i, chunk): i
                for i, chunk in enumerate(aladdin_chunks)
            }
            for future in concurrent.futures.as_completed(futures):
                try:
                    chunk_results = future.result()
                    instrument_results.extend(chunk_results)
                except Exception as exc:
                    import trackback
                    print(f"Instrument chunk {futures[future]} generated an exception: {exc}")
                    trackback.print_exc()

        df_inst = pd.DataFrame(instrument_results)

        df_inst_ir = pd.DataFrame(
            [
                {
                    c.name: getattr(r, c.name)
                    for c in DMIRInstrumentIRType.__table__.columns
                    if c.name != "_sa_instance_state"
                }
                for r in session.query(DMIRInstrumentIRType)
                .filter(DMIRInstrumentIRType.strReportingType == "class7")
                .all()
            ]
        )

        df_inst_merged = pd.merge(
            df_inst,
            df_inst_ir,
            left_on="numInstTypeId",
            right_on="numInstrTypeID",
            how="left",
        )

        df_inst_subq = df_inst_merged.drop_duplicates(
            subset=[
                "strInstAladdin",
                "numInstID",
                "strInstrumentTypeIRName",
                "numInstUndrlygQty",
                "strInstPriceType",
            ]
        )

        valid_reporting_days = df_a["datReportingDay"].unique().tolist()

        analytics_results = []
        with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
            futures = {
                executor.submit(get_analytics_for_instruments, i, chunk, valid_reporting_days): i
                for i, chunk in enumerate(aladdin_chunks)
            }
            for future in concurrent.futures.as_completed(futures):
                try:
                    chunk_results = future.result()
                    analytics_results.extend(chunk_results)
                except Exception as exc:
                    print(f"Analytics chunk {futures[future]} generated an exception: {exc}")

        df_inst_analytic = pd.DataFrame(analytics_results)
        if len(df_inst_analytic) > 0:
            df_inst_analytic["datInstQuotationDate"] = pd.to_datetime(
                df_inst_analytic["datInstQuotationDate"]
            )

        df_a_chunks = np.array_split(df_a, 1)

        merged_results = []
        with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
            futures = {
                executor.submit(
                    process_merge_chunk_bkgn_2, i, chunk, df_inst_subq, df_inst_analytic
                ): i
                for i, chunk in enumerate(df_a_chunks)
            }
            for future in concurrent.futures.as_completed(futures):
                try:
                    chunk_result = future.result()
                    merged_results.append(chunk_result)
                except Exception as exc:
                    print(f"Merge chunk {futures[future]} generated an exception: {exc}")

        if merged_results:
            df_tblDMIRBKGN2 = pd.concat(merged_results, ignore_index=True)
            return df_tblDMIRBKGN2
        else:
            return pd.DataFrame()
    finally:
        safe_close(session)




def process_merge_chunk_bkgn_2(i, df_a_chunk, df_inst_subq, df_inst_analytic):
    print(f"Merging instr analytics for chunk {i}")
    right_keys = [
        "strInstAladdin",
        "numInstID",
        "strInstrumentTypeIRName",
        "numInstUndrlygQty",
        "strInstPriceType",
    ]
    if df_inst_subq.empty:
        df_inst_subq_cp = pd.DataFrame(columns=right_keys)
    else:
        df_inst_subq_cp = df_inst_subq[right_keys]

    # Merge with analytics data
    merged_df = pd.merge(
        df_a_chunk,
        df_inst_subq_cp,
        on="strInstAladdin",
        how="left",
    )

    if df_inst_analytic.empty:
        df_inst_analytic = pd.DataFrame(
            columns=[
                "strInstAladdin",
                "datInstQuotationDate",
                "numInstConvexity",
                "numInstModifDuration",
                "numInstMCDuration",
                "numInstSpreadDuration",
                "numInstEffDuration",
            ]
        )

    merged_df = pd.merge(
        merged_df,
        df_inst_analytic,
        left_on=["strInstAladdin", "datReportingDay"],
        right_on=["strInstAladdin", "datInstQuotationDate"],
        how="left",
    )

    merged_df = merged_df.drop(
        columns=[
            "datInstQuotationDate",
            "numInstID",
            "strExtCode",
            "numCurrencyId",
            "numCurrencyID",
            "datccyqDate",
        ],
        errors="ignore",
    )

    return merged_df


