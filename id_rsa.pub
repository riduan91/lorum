print("Computing nrLegs/signOfLeg (vectorized)")
get_hardware_info()

# group keys you already have
group_cols = [
    "strReportPortfGPSCode", "datPeriodLastDay",
    "numReportPortfGroupID", "numAuditId",
    "strInstAladdin", "numInstID"
]

# 1) size, min, max of numHoldQuantity per group
sign_stats = (
    df_lt.groupby(group_cols)
         .agg(
             nrLegs=("numHoldQuantity", "size"),
             q_min =("numHoldQuantity", "min"),
             q_max =("numHoldQuantity", "max"),
         )
         .reset_index()
)

# 2) vectorized sign:
#    - if all >= 0  -> q_min >= 0  -> +1
#    - if all <  0  -> q_max <  0  -> -1
#    - else -> 0
#    - and if nrLegs == 1 -> force 0
import numpy as np
sign = np.select(
    [sign_stats["q_min"] >= 0, sign_stats["q_max"] < 0],
    [1, -1],
    default=0,
)
sign = np.where(sign_stats["nrLegs"] == 1, 0, sign)

sign_stats = sign_stats.assign(signOfLeg=sign).drop(columns=["q_min", "q_max"])

# 3) attach to your aggregated frame
df_lt_agg = df_lt_agg.merge(sign_stats, on=group_cols, how="left")

print("nrLegs/signOfLeg computed")
get_hardware_info()
