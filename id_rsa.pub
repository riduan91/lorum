from __future__ import annotations

import re
from concurrent.futures import ProcessPoolExecutor
from typing import Iterable, Callable, Tuple, Any

from sqlalchemy import create_engine, text
from sqlalchemy.orm import sessionmaker

# ──────────────────────────────────────────────────────────────────────────────
# Internal helper run in each subprocess
# ──────────────────────────────────────────────────────────────────────────────
def _lookup_worker(
    args: Tuple[
        str,                # conn_str
        str,                # lookup_sql
        dict[str, Any],     # row
        list[str] | None,   # param_cols
        Callable[[dict], dict] | None,  # transform
    ]
) -> Tuple[bool, dict[str, Any]]:
    conn_str, lookup_sql, row, param_cols, transform = args

    # Create a short-lived session in this process
    engine = create_engine(conn_str, future=True)
    Session = sessionmaker(bind=engine, future=True)

    if param_cols:
        params = {col: row.get(col) for col in param_cols}
    else:
        used_keys = set(re.findall(r":(\w+)", lookup_sql))
        params = {k: v for k, v in row.items() if k in used_keys} if used_keys else row

    with Session() as session:
        result = session.execute(text(lookup_sql), params).fetchone()

    if result:
        extended = row.copy()
        extended.update(dict(result))
        if transform:
            extended = transform(extended)
        return True, extended          # matched → enriched
    return False, row                  # no match → rejected


# ──────────────────────────────────────────────────────────────────────────────
# Public parallel version
# ──────────────────────────────────────────────────────────────────────────────
def join_with_db_per_row_parallel(
    conn_str: str,
    records: Iterable[dict[str, Any]],
    lookup_sql: str,
    param_cols: list[str] | None = None,
    transform: Callable[[dict], dict] | None = None,
    return_rejected: bool = False,
    *,
    max_workers: int | None = None,
    chunksize: int = 25,
) -> list[dict] | tuple[list[dict], list[dict]]:
    """
    Enrich *records* by looking up extra columns via a DB query, using
    ProcessPoolExecutor for true parallelism.

    Parameters
    ----------
    conn_str
        SQLAlchemy connection URL (e.g. "postgresql+psycopg://user:pwd@host/db").
    records
        Iterable of dict-like rows to enrich.
    lookup_sql
        SQL containing named parameters (":col") that will be bound from *row*.
    param_cols
        Optional explicit list of columns to pick from *row* as parameters.
    transform
        Optional pure function: row -> row. Must be picklable.
    return_rejected
        If True, also return rows that produced no DB match.
    max_workers
        Sent straight to ProcessPoolExecutor; default uses number of CPU cores.
    chunksize
        Batch size passed to `executor.map` for throughput tuning.

    Returns
    -------
    enriched_rows
        List of rows extended with columns fetched from the DB.
    (enriched_rows, rejected_rows)
        If *return_rejected* is True.
    """
    tasks = (
        (conn_str, lookup_sql, r, param_cols, transform)
        for r in records
    )

    enriched: list[dict] = []
    rejected: list[dict] = []

    with ProcessPoolExecutor(max_workers=max_workers) as pool:
        for is_match, row in pool.map(_lookup_worker, tasks, chunksize=chunksize):
            (enriched if is_match else rejected).append(row)

    return (enriched, rejected) if return_rejected else enriched
