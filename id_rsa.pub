import numpy as np
import pandas as pd

# 1) Exchange rate factor: vp.numCcyqRateInv / vr.numCcyqRateInv (NaN if vr is NaN or 0)
den = df_final["numCcyqRateInv_vr"]
df_final["numPortfExRateInRptPtfCur"] = (
    df_final["numCcyqRateInv"].div(den).where(den.ne(0))
)

# 2) Adjusted AUM
df_final["numPortfAUMInRptPtfCur"] = (
    df_final["numPortfAUM"] * df_final["numPortfExRateInRptPtfCur"]
)

# 3) numHoldValueInPortfCur:
# If INTERNAL and a Forex instrument exists ⇒ Hedged_numHoldValuInPortfCur; else sum_numHoldValueInPortfCur
mask_internal = df_final["strSrcUndrlygHoldData"].eq("INTERNAL")
mask_fx       = df_final["strInstAladdin_forex"].notna()

df_final["numHoldValueInPortfCur"] = np.where(
    mask_internal & mask_fx,
    df_final["Hedged_numHoldValuInPortfCur"],
    df_final["sum_numHoldValueInPortfCur"],
)

# 4) numHoldQuantity:
# Default: sum_numHoldQuantity
# If INTERNAL and (swaps OR swaption) present ⇒ max_numHoldQuantity
# Else if INTERNAL and forex present ⇒ Hedged_numHoldQuantity
mask_sw_or_sn = df_final["strInstAladdin_swaps"].notna() | df_final["strInstAladdin_swaption"].notna()

# start from default
df_final["numHoldQuantity"] = df_final["sum_numHoldQuantity"]

# priority 1: swaps/swaption
idx = (mask_internal & mask_sw_or_sn)
df_final.loc[idx, "numHoldQuantity"] = df_final.loc[idx, "max_numHoldQuantity"]

# priority 2: forex (only where not already set by swaps/swaption)
idx = (mask_internal & ~mask_sw_or_sn & mask_fx)
df_final.loc[idx, "numHoldQuantity"] = df_final.loc[idx, "Hedged_numHoldQuantity"]

# 5) Average cost in report portfolio currency
df_final["numHoldAvrgCostInReportPortf"] = (
    df_final["numHoldAvrgCostInPortfCur"] * df_final["numPortfExRateInRptPtfCur"]
)
