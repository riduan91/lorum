# ------------------------------------
# Utilities
# ------------------------------------

def run_sql_to_df(session, sql: str) -> pd.DataFrame:
    result = session.execute(text(sql))
    cols = result.keys()
    rows = result.fetchall()
    return pd.DataFrame(rows, columns=cols)


def _safe(s) -> str:
    """Safe string for filenames."""
    return re.sub(r"[^A-Za-z0-9_.-]", "", str(s))


def _null_safe_eq(a_alias: str, b_alias: str, col: str) -> str:
    """Type-agnostic null-safe equality SQL fragment.
    Produces: ((a.col = b.col) OR (a.col IS NULL AND b.col IS NULL))
    """
    return f"(({a_alias}.{col} = {b_alias}.{col}) OR ({a_alias}.{col} IS NULL AND {b_alias}.{col} IS NULL))"


def _build_join(group_cols, a_alias="a", b_alias="b") -> str:
    """
    Build JOIN ON clause honoring null-safe rules.
    Special handling for PortfolioDWHID / PortfolioDWHGroupID uses ISNULL(...,'') as in the original logic.
    Other columns use a generic null-safe equality.
    """
    parts = []
    for c in group_cols:
        if c in ("PortfolioDWHID", "PortfolioDWHGroupID"):
            parts.append(f"ISNULL({a_alias}.{c}, '') = ISNULL({b_alias}.{c}, '')")
        else:
            parts.append(_null_safe_eq(a_alias, b_alias, c))
    return " AND ".join(parts)


def _sql_literal(val):
    """Return a SQL literal for WHERE clauses, or None for NULL.
    - numbers are unquoted
    - strings/dates are quoted with single-quote escaping
    """
    if pd.isna(val):
        return None
    if isinstance(val, (int, np.integer)):
        return str(int(val))
    if isinstance(val, (float, np.floating)):
        if np.isnan(val):
            return None
        # keep as-is; do not force int
        return str(val)
    # everything else -> quoted string
    return "'" + str(val).replace("'", "''") + "'"


