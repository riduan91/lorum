-- Create the extended table by merging Holding (h) + Indicators (i)
SELECT
    -- All original holding columns
    h.*,

    -- Additional columns from Indicators (no duplicates of h.*)
    i.strPeriodTypeFlag,
    i.datPeriodLastDay,
    i.datMarketDate,
    i.numBenchFBAId,
    i.numInstID,
    i.strPFCurrencyISOCode,

    i.numConvexityContrib,
    i.numConvexityContribWeight,
    i.numModifDurationContribWeight,
    i.numMCDurationContribWeight,
    i.numEffectDurationContribWeight,
    i.numSpreadDurationContribWeight,

    i.numInstPriceEarning,
    i.numInstYldToWorst,
    i.numInstBondFloor,
    i.numInstContribActivRisk,
    i.numInstContribTrackingError,
    i.numInstRiskFactor,
    i.numInstStressTestFactor,
    i.datModificationDate,

    i.numInstDivYld,
    i.numInstWAL,
    i.numInstWAM,
    i.numInstInflSens,
    i.numInstDebtEq,

    i.numESGGlbCovWeight,
    i.numESGGlbScoreCov,
    i.numESGEnvScore,
    i.numESGEnvCovWeight,
    i.numESGEnvScoreCov,
    i.numESGSocialScore,
    i.numESGSocialCovWeight,
    i.numESGSocialScoreCov,
    i.numESGGovernanceScore,
    i.numESGGovCovWeight,
    i.numESGGovernanceScoreCov,
    i.numESGDecile,
    i.numESGDecileCovWeight,
    i.numESGDecileCov,
    i.numESGGlbPotentialScoreCov,

    i.numCO2IntensRevEval,
    i.numCO2IntensRevEvalCovWeight,
    i.numCO2IntensRevEvalCov,
    i.numCO2IntensEVEvalCovWeight,
    i.numCO2EmmisionsScope12,
    i.numCO2EmmissionCovWeight,
    i.numCO2EmmisionsCov,

    i.numESGKPIGenderDiversityValu,
    i.numESGKPIGenderDivCovWeight,
    i.numESGKPIGenderDivValuCov,
    i.numESGKPIHumanRightsValu,
    i.numESGKPIHumanRightsCovWeight,
    i.numESGKPIHumanRightsValuCov,
    i.numESGKPIExposureControvESG,
    i.numESGKPIExpControvESGCovWeight,
    i.numESGKPIExpControvESGCov,
    i.numESGKPIExposureControvSocial,
    i.numESGKPIExpControvSocCovWeight,
    i.numESGKPIExpControvSocCov,
    i.numESGKPIEngmtEnv,
    i.numESGKPIEngmtSocial,
    i.numESGKPIEngmtGov,
    i.numESGKPIEngmtNumMeetings,
    i.numGrpPolicyRcoWeight,
    i.strESGKPIEngmtRcoIssrCd,
    i.strESGThematicSrc,
    i.strCO2ThematicSrc,

    i.numESGGlbCovWeightG,
    i.numCO2IntensEVEvalCovWeightG,
    i.numESGKPIGenderDivCovWeightG,
    i.numESGKPIHumanRightsCovWeightG,
    i.numESGKPIExpControvESGCovWeightG

INTO DMIR.tblDMIRAPIBenchHolding_Extended
FROM dbo.tblDMIRAPIBenchHolding AS h
JOIN dbo.tblDMIRBRSBenchInstrIndicators AS i
    ON i.datPeriodLastDay = h.AccountingDate
   AND i.numBenchFBAId   = h.BKGNCode
   AND i.numInstID       = h.InstrumentDWHID
WHERE i.datPeriodLastDay >= DATEFROMPARTS(2024, 3, 31)
  AND h.AccountingDate  >= DATEFROMPARTS(2024, 3, 31);
