# Parallelized versions of your functions.
# Notes:
# - We do NOT share SQLAlchemy sessions across threads. Each worker creates/uses its own session from the passed-in Session factory.
# - We parallelize the Python-side loops that iterate over CTE batches.
# - We keep the original function names unchanged and add private helpers for the threaded work.
# - Requires: concurrent.futures (standard lib).

from concurrent.futures import ThreadPoolExecutor, as_completed
import sqlalchemy
from sqlalchemy import and_, case, func, String, Integer
from sqlalchemy.sql import column
from sqlalchemy.exc import SQLAlchemyError

# ----------------------------------------------------------------------
# Original (unchanged) functions where no Python-side parallel loop existed
# ----------------------------------------------------------------------

def data_monitoring_temp1(Session: sqlalchemy.orm.Session, p_step: int):
    """Unchanged."""
    session = Session()
    logger.log.info("Get data monitoring temp1.")

    try:
        monitoring = (
            session.query(
                DMIRMonitoringLTWrk.datLastNAVDate, DMIRMonitoringLTWrk.strInvestedInPortfID
            )
            .filter(
                DMIRMonitoringLTWrk.numPortfLevel == p_step - 1,
                DMIRMonitoringLTWrk.numUndrlygLTflag == 1,
                DMIRMonitoringLTWrk.numPresUndrlygHoldData == 1,
                DMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
            )
            .distinct()
            .all()
        )
        monitoring = [dict(row._mapping) for row in monitoring]

        path_monitoring = dataprocess.save_json(
            data=monitoring,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_temp1",
        )

        logger.log.info(f"Get data monitoring temp1 is done. Scope size = {len(monitoring)}")
        return path_monitoring

    except SQLAlchemyError as e:
        session.rollback()
        logger.log.error(f"Error occurred when data_monitoring_temp1: {str(e)}.")
        raise

    finally:
        session.close()


def cte_data_monitoring_temp1(path_monitoring_temp1: str):
    """Unchanged."""
    data_monitoring = dataprocess.read_json(
        filename=path_monitoring_temp1,
    )

    columns_name = [
        column("datLastNAVDate", String),
        column("strInvestedInPortfID", String),
    ]
    if not data_monitoring:
        return (
            Values(
                *columns_name,
                name="values_data_monitoring_temp1",
                literal_binds=True,
            )
            .data([(None,) * len(columns_name)])
            .alias("values_data_monitoring_temp1")
        )

    data_monitoring = [tuple(row.values()) for row in data_monitoring]
    return (
        Values(
            *columns_name,
            name="values_data_monitoring_temp1",
            literal_binds=True,
        )
        .data(data_monitoring)
        .alias("values_data_monitoring_temp1")
    )


def data_monitoring_temp2(Session: sqlalchemy.orm.Session, path_monitoring_temp1: str):
    """Unchanged."""
    session = Session()
    logger.log.info("Get data monitoring temp2.")

    monitoring_temp1 = cte_data_monitoring_temp1(path_monitoring_temp1=path_monitoring_temp1)

    try:
        monitoring = (
            session.query(
                monitoring_temp1.c.datLastNAVDate,
                monitoring_temp1.c.strInvestedInPortfID,
                func.max(DMIRDMCHolding.datACCDATE).label("datmaxAccDate"),
            )
            .join(
                DMIRDMCHolding,
                and_(
                    monitoring_temp1.c.strInvestedInPortfID == DMIRDMCHolding.strPortfGPSCode,
                    DMIRDMCHolding.datACCDATE <= monitoring_temp1.c.datLastNAVDate,
                ),
            )
            .group_by(monitoring_temp1.c.datLastNAVDate, monitoring_temp1.c.strInvestedInPortfID)
            .all()
        )

        monitoring = [dict(row._mapping) for row in monitoring]

        path_monitoring = dataprocess.save_json(
            data=monitoring,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_temp2",
        )

        logger.log.info(f"Get data monitoring temp2 is done. Scope size = {len(monitoring)}")
        return path_monitoring

    except SQLAlchemyError as e:
        session.rollback()
        logger.log.error(f"Error occurred when data_monitoring_temp2: {str(e)}.")
        raise

    finally:
        session.close()


def cte_data_monitoring_temp2(path_monitoring_temp2: str):
    """Unchanged generator that yields batches (good for memory)."""
    data_monitoring = dataprocess.read_json(
        filename=path_monitoring_temp2,
    )

    columns_name = [
        column("datLastNAVDate", String),
        column("strInvestedInPortfID", String),
        column("datmaxAccDate", String),
    ]
    if not data_monitoring:
        yield (
            Values(
                *columns_name,
                name="values_data_monitoring_temp2",
                literal_binds=True,
            )
            .data([(None,) * len(columns_name)])
            .alias("values_data_monitoring_temp2")
        )
        return

    for batch in chunk_iterable(data_monitoring):
        batch_tuples = [tuple(row.values()) for row in batch]
        yield Values(*columns_name, name="values_data_monitoring_temp2", literal_binds=True).data(
            batch_tuples
        )


def cte_data_monitoring_temp3(path_monitoring_temp3: str):
    """Unchanged generator that yields batches (good for memory)."""
    data_monitoring = dataprocess.read_json(
        filename=path_monitoring_temp3,
    )

    columns_table = [
        column("strPortfGPSCode", String),
        column("datACCDATE", String),
        column("strInstAladdin", String),
        column("numInstrFKey", Integer),
        column("numHoldCrossCur", Integer),
        column("numHoldValuInPortfCur", Integer),
        column("numHoldQuantity", Integer),
        column("numHoldPrice", Integer),
        column("numHoldAccruedIntInstr", Integer),
        column("numHoldAccruedIntPortf", Integer),
        column("numInstID", Integer),
        column("numHoldAvrgCostInPortfCur", Integer),
        column("strUnderlSecCode", String),
    ]

    if not data_monitoring:
        yield Values(
            *columns_table,
            name="values_data_monitoring_temp3",
            literal_binds=True,
        ).data(
            [(None,) * 13]
        ).alias("values_data_monitoring_temp3")
        return

    for batch in chunk_iterable(data_monitoring):
        batch_tuples = [tuple(row.values()) for row in batch]
        yield Values(*columns_table, name="values_data_monitoring_temp3", literal_binds=True).data(
            batch_tuples
        )

