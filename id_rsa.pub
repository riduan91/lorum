def single_process_composition_codes(i, rows_batch, retry=3):
    """Process a batch of rows to retrieve composition codes."""
    local_session = None
    print(f"Processing chunk {i}.")
    try:
        local_session = get_local_session()
        results = []
        for row in rows_batch:
            constituent = (
                local_session.query(DMIRBRSBenchmarkConstituent.strCompositionCd)
                .filter(
                    DMIRBRSBenchmarkConstituent.datMarketDate == row["datPeriodLastMarketDay"],
                    DMIRBRSBenchmarkConstituent.numBenchFBAId == row["numBenchMarkId"],
                )
                .first()
            )

            composition_code = constituent.strCompositionCd if constituent else None
            results.append({"row_idx": row["row_idx"], "strCompositionCd": composition_code})
        return results
    except Exception as e:
        print(f"Exception at attempt {4 - retry} for chunk {i}: {str(e)}")
        if retry >= 0:
            return single_process_composition_codes(i, rows_batch, retry=retry - 1)
    finally:
        safe_close(local_session)



def single_compute_instr_indicators_bkgn_1(
    i, market_date_bench_ids, filtered_bench_scope_df, exclude_insts=[], retry=3
):
    """Process a complete chunk of benchmark data from retrieval to final processing.

    Args:
        i: Chunk index for logging
        market_date_bench_ids: List of (market_date, bench_id) tuples to process
        filtered_bench_scope_df: Pre-filtered benchmark scope DataFrame for just this chunk
        exclude_insts: List of instrument ALADDINs to exclude

    Returns:
        DataFrame with processed benchmark constituents
    """
    print(f"Processing chunk {i} with {market_date_bench_ids}")
    local_session = None
    if local_session is not None:
        safe_close(local_session)
    try:
        local_session = get_local_session()

        # 2. Query constituent data for this chunk
        constituent_dfs = []
        for market_date, bench_id in market_date_bench_ids:
            query = local_session.query(
                DMIRBRSBenchmarkConstituent.numBenchFBAId,
                DMIRBRSBenchmarkConstituent.datMarketDate,
                DMIRBRSBenchmarkConstituent.strInstAladdin,
                DMIRBRSBenchmarkConstituent.numInstId,
                DMIRBRSBenchmarkConstituent.codInstCurId,
                DMIRBRSBenchmarkConstituent.numBenchInstWeight,
                DMIRBRSBenchmarkConstituent.numInstLocalCurPrice,
                DMIRBRSBenchmarkConstituent.numInstQty,
                DMIRBRSBenchmarkConstituent.numInstLocalCurMktCap,
                DMIRBRSBenchmarkConstituent.numInstUSDMktCap,
                DMIRBRSBenchmarkConstituent.numInstEURMktCap,
            ).filter(
                DMIRBRSBenchmarkConstituent.datMarketDate == market_date,
                DMIRBRSBenchmarkConstituent.numBenchFBAId == bench_id,
            )

            df = get_all_as_df(query)
            if not df.empty:
                constituent_dfs.append(df)

        # If no constituents found, return empty DataFrame
        if not constituent_dfs:
            return pd.DataFrame()

        # Combine all constituent data for this chunk
        df_chunk = pd.concat(constituent_dfs, ignore_index=True)

        # 3. Process and merge with benchmark scope (similar to process_merge_chunk_bkgn_1)
        chunk_merged = pd.merge(
            df_chunk,
            filtered_bench_scope_df,
            left_on=["numBenchFBAId", "datMarketDate"],
            right_on=["numBenchMarkId", "datPeriodLastMarketDay"],
            how="left",
            suffixes=("", "_dup"),
        )

        # Compute additional columns
        chunk_merged["codinscurid"] = chunk_merged.apply(
            lambda row: "EUR" if row["numInstId"] == 50760 else row["codInstCurId"], axis=1
        )

        # Define the grouping columns
        group_cols = [
            "numBenchFBAId",
            "strCompositionCd",
            "strPeriodTypeFlag",
            "datReportingDay",
            "numPFCurrencyRate",
            "strPFCurrencyISOCode",
            "codinscurid",
            "datMarketDate",
            "strInstAladdin",
            "numInstId",
        ]

        # Define the aggregation functions
        agg_cols = {
            "numBenchInstWeight": "sum",
            "numInstLocalCurPrice": "sum",
            "numInstQty": "sum",
            "numInstLocalCurMktCap": "sum",
            "numInstUSDMktCap": "sum",
            "numInstEURMktCap": "sum",
        }

        chunk_result = chunk_merged.groupby(group_cols, as_index=False).agg(agg_cols)

        # Filter out specific instruments
        chunk_result = chunk_result[~chunk_result["strInstAladdin"].isin(exclude_insts)]

        # Rename columns for the output
        chunk_result["datval"] = chunk_result["datMarketDate"]
        chunk_result = chunk_result.drop(columns=["datMarketDate"])

        chunk_result.rename(
            columns={
                "numBenchInstWeight": "numweight",
                "numInstLocalCurPrice": "numinslclcurpri",
                "numInstQty": "numinsqty",
                "numInstLocalCurMktCap": "numlclcurmktcap",
                "numInstUSDMktCap": "numusdmktcap",
                "numInstEURMktCap": "numeurmktcap",
            },
            inplace=True,
        )
        print(f"Chunk {i} returned {len(chunk_result)} rows.")
        return chunk_result
    except Exception as e:
        if retry > 0:
            print(f"Exception at attempt {4 - retry} for chunk {i}: {str(e)}")
            return single_compute_instr_indicators_bkgn_1(
                i,
                market_date_bench_ids,
                filtered_bench_scope_df,
                exclude_insts=[],
                retry=retry - 1,
            )
    finally:
        safe_close(local_session)


def compute_instr_indicators_bkgn_1(df_bench_scope):
    """
    First step in computing DMIR BKGN table with optimized parallel processing.

    Args:
        df_bench_scope: DataFrame containing benchmark scope data

    Returns:
        DataFrame with benchmark constituents
    """
    if df_bench_scope.empty:
        return pd.DataFrame()

    # Filter rows with valid datPeriodLastMarketDay
    df_bs = df_bench_scope[df_bench_scope["datPeriodLastMarketDay"] != pd.to_datetime("1900-01-01")]

    # Rename column as needed
    df_bs.rename(columns={"datPeriodLastDay": "datReportingDay"}, inplace=True)

    # If bench scope is empty, return an empty DataFrame
    if df_bs.empty:
        return pd.DataFrame()

    # Get unique market date and benchmark ID combinations
    keys_df = df_bs[["datPeriodLastMarketDay", "numBenchMarkId"]].drop_duplicates()
    keys_list = [tuple(x) for x in keys_df.to_numpy()]

    session = get_local_session()
    try:
        exclude_insts = [
            r.strInstAladdin
            for r in session.query(DMIRBRSInstrument.strInstAladdin)
            .filter(DMIRBRSInstrument.numInstTypeId.in_([450, 451, 452]))
            .all()
        ]
    finally:
        safe_close(session)

    # Split the keys into chunks for parallel processing
    num_cpus = os.cpu_count() or 4
    chunk_size = max(1, min(50, len(keys_list) // num_cpus))
    key_chunks = [keys_list[i : i + chunk_size] for i in range(0, len(keys_list), chunk_size)]

    # Prepare filtered benchmark scope DataFrames for each chunk
    filtered_scope_chunks = []
    for chunk in key_chunks:
        # Create a set of (market_date, bench_id) tuples for efficient lookup
        market_date_bench_set = set(chunk)

        # Filter benchmark scope data for just the pairs in this chunk
        chunk_bs = df_bs[
            df_bs.apply(
                lambda row: (row["datPeriodLastMarketDay"], row["numBenchMarkId"])
                in market_date_bench_set,
                axis=1,
            )
        ].copy()

        filtered_scope_chunks.append(chunk_bs)

    # Process each chunk completely in parallel
    result_dfs = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
        futures = {
            executor.submit(
                single_compute_instr_indicators_bkgn_1,
                i,
                key_chunks[i],
                filtered_scope_chunks[i],
                exclude_insts,
            ): i
            for i in range(len(key_chunks))
        }

        for future in concurrent.futures.as_completed(futures):
            try:
                chunk_df = future.result()
                if not chunk_df.empty:
                    result_dfs.append(chunk_df)
            except Exception as exc:
                print(f"Chunk {futures[future]} generated an exception: {exc}")

    # Combine all processed chunks
    if not result_dfs:
        return pd.DataFrame()

    df_tblDMIRBKGN = pd.concat(result_dfs, ignore_index=True)
    return df_tblDMIRBKGN


def single_compute_instr_indicators_bkgn_1(
    i, market_date_bench_ids, filtered_bench_scope_df, exclude_insts=[], retry=3
):
    print(f"Processing chunk {i} with {market_date_bench_ids}")
    local_session = None
    try:
        local_session = get_local_session()

        constituent_dfs = []
        for market_date, bench_id in market_date_bench_ids:
            query = local_session.query(
                DMIRBRSBenchmarkConstituent.numBenchFBAId,
                DMIRBRSBenchmarkConstituent.datMarketDate,
                DMIRBRSBenchmarkConstituent.strInstAladdin,
                DMIRBRSBenchmarkConstituent.numInstId,
                DMIRBRSBenchmarkConstituent.codInstCurId,
                DMIRBRSBenchmarkConstituent.numBenchInstWeight,
                DMIRBRSBenchmarkConstituent.numInstLocalCurPrice,
                DMIRBRSBenchmarkConstituent.numInstQty,
                DMIRBRSBenchmarkConstituent.numInstLocalCurMktCap,
                DMIRBRSBenchmarkConstituent.numInstUSDMktCap,
                DMIRBRSBenchmarkConstituent.numInstEURMktCap,
            ).filter(
                DMIRBRSBenchmarkConstituent.datMarketDate == market_date,
                DMIRBRSBenchmarkConstituent.numBenchFBAId == bench_id,
            )

            df = get_all_as_df(query, mode="polars")
            if not df.is_empty():
                constituent_dfs.append(df)

        if not constituent_dfs:
            return pl.DataFrame()  # Return empty of same type

        df_chunk = pl.concat(constituent_dfs)

        # Merge with benchmark scope
        chunk_merged = df_chunk.join(
            filtered_bench_scope_df,
            left_on=["numBenchFBAId", "datMarketDate"],
            right_on=["numBenchMarkId", "datPeriodLastMarketDay"],
            how="left",
        )

        # codinscurid column
        chunk_merged = chunk_merged.with_columns(
            pl.when(pl.col("numInstId") == 50760)
            .then("EUR")
            .otherwise(pl.col("codInstCurId"))
            .alias("codinscurid")
        )

        group_cols = [
            "numBenchFBAId",
            "strCompositionCd",
            "strPeriodTypeFlag",
            "datReportingDay",
            "numPFCurrencyRate",
            "strPFCurrencyISOCode",
            "codinscurid",
            "datMarketDate",
            "strInstAladdin",
            "numInstId",
        ]
        agg_cols = {
            "numBenchInstWeight": "sum",
            "numInstLocalCurPrice": "sum",
            "numInstQty": "sum",
            "numInstLocalCurMktCap": "sum",
            "numInstUSDMktCap": "sum",
            "numInstEURMktCap": "sum",
        }

        chunk_result = chunk_merged.group_by(group_cols).agg(agg_cols)

        # Filter out instruments
        chunk_result = chunk_result.filter(~pl.col("strInstAladdin").is_in(exclude_insts))

        # Rename and drop
        chunk_result = chunk_result.with_columns([
            pl.col("datMarketDate").alias("datval")
        ]).drop("datMarketDate")

        chunk_result = chunk_result.rename({
            "numBenchInstWeight": "numweight",
            "numInstLocalCurPrice": "numinslclcurpri",
            "numInstQty": "numinsqty",
            "numInstLocalCurMktCap": "numlclcurmktcap",
            "numInstUSDMktCap": "numusdmktcap",
            "numInstEURMktCap": "numeurmktcap",
        })

        print(f"Chunk {i} returned {chunk_result.height} rows.")
        return chunk_result

    except Exception as e:
        if retry > 0:
            print(f"Exception at attempt {4 - retry} for chunk {i}: {str(e)}")
            return single_compute_instr_indicators_bkgn_1(
                i, market_date_bench_ids, filtered_bench_scope_df, exclude_insts, retry=retry - 1
            )
    finally:
        safe_close(local_session)


def compute_instr_indicators_bkgn_1(df_bench_scope):
    if df_bench_scope is None or len(df_bench_scope) == 0:
        return df_bench_scope.__class__()

    # Filter valid rows
    if isinstance(df_bench_scope, pl.DataFrame):
        df_bs = df_bench_scope.filter(pl.col("datPeriodLastMarketDay") != pl.date("1900-01-01"))
        df_bs = df_bs.with_columns(pl.col("datPeriodLastDay").alias("datReportingDay"))
    else:
        df_bs = df_bench_scope[df_bench_scope["datPeriodLastMarketDay"] != pd.to_datetime("1900-01-01")]
        df_bs = df_bs.rename(columns={"datPeriodLastDay": "datReportingDay"})

    if len(df_bs) == 0:
        return df_bs.__class__()

    # Extract keys
    if isinstance(df_bs, pl.DataFrame):
        keys_list = list(set(zip(
            df_bs["datPeriodLastMarketDay"].to_list(),
            df_bs["numBenchMarkId"].to_list()
        )))
    else:
        keys_df = df_bs[["datPeriodLastMarketDay", "numBenchMarkId"]].drop_duplicates()
        keys_list = [tuple(x) for x in keys_df.to_numpy()]

    session = get_local_session()
    try:
        exclude_insts = [
            r.strInstAladdin
            for r in session.query(DMIRBRSInstrument.strInstAladdin)
            .filter(DMIRBRSInstrument.numInstTypeId.in_([450, 451, 452]))
            .all()
        ]
    finally:
        safe_close(session)

    # Chunk keys
    num_cpus = os.cpu_count() or 4
    chunk_size = max(1, min(50, len(keys_list) // num_cpus))
    key_chunks = [keys_list[i:i + chunk_size] for i in range(0, len(keys_list), chunk_size)]

    # Filtered scope chunks
    filtered_scope_chunks = []
    for chunk in key_chunks:
        market_set = set(chunk)
        if isinstance(df_bs, pl.DataFrame):
            chunk_df = df_bs.filter(
                pl.struct(["datPeriodLastMarketDay", "numBenchMarkId"]).is_in(list(market_set))
            )
        else:
            chunk_df = df_bs[
                df_bs.apply(lambda row: (row["datPeriodLastMarketDay"], row["numBenchMarkId"]) in market_set, axis=1)
            ]
        filtered_scope_chunks.append(chunk_df)

    # Parallel compute
    result_dfs = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
        futures = {
            executor.submit(
                single_compute_instr_indicators_bkgn_1,
                i,
                key_chunks[i],
                filtered_scope_chunks[i],
                exclude_insts,
            ): i
            for i in range(len(key_chunks))
        }

        for future in concurrent.futures.as_completed(futures):
            try:
                chunk_df = future.result()
                if chunk_df is not None and len(chunk_df) > 0:
                    result_dfs.append(chunk_df)
            except Exception as exc:
                print(f"Chunk {futures[future]} generated an exception: {exc}")

    if not result_dfs:
        return df_bs.__class__()

    return pl.concat(result_dfs) if isinstance(result_dfs[0], pl.DataFrame) else pd.concat(result_dfs, ignore_index=True)
