def single_process_alpha_records(idx, key, chunk, ind_chunk):
    """
    Vectorized version:
      - Builds 'g' with groupby/agg instead of a dict of per-group dicts.
      - Fixes quotes chunk filter bug (uses chunk_curr_codes in IN clause).
      - Maps/merges ORM lookups onto 'g' using dictionaries and merges (no per-row Python dict growth).
      - Returns a DataFrame (not list of dicts).
    """
    import numpy as np
    import pandas as pd
    from pandas.tseries.offsets import MonthEnd
    session = None

    try:
        (rpt_code, period_end, group_id, audit) = key
        period_end = pd.to_datetime(period_end).normalize()

        # -------- 1) Pre-shrink dtypes (optional but helps) ----------
        def _shrink(df):
            if df is None or df.empty:
                return df
            for c in df.select_dtypes(include="integer").columns:
                df[c] = pd.to_numeric(df[c], downcast="integer")
            for c in df.select_dtypes(include="float").columns:
                df[c] = pd.to_numeric(df[c], downcast="float")
            for c in ["strInstAladdin", "strReportPortfGPSCode"]:
                if c in df.columns:
                    df[c] = df[c].astype("category")
            return df

        chunk = _shrink(chunk)
        ind_chunk = _shrink(ind_chunk)

        # -------- 2) Vectorized base aggregation ----------
        g = (
            chunk.groupby(["strInstAladdin", "numInstID"], sort=False)
                 .agg(
                     numHoldPrice=("numHoldPrice", "mean"),
                     numHoldAccruedIntPortf=("numHoldAccruedIntPortf", "sum"),
                     numWeightedAmtInReportPortf=("numWeightedAmtInReportPortf", "sum"),
                     numHoldCrossCur=("numHoldCrossCur", "mean"),
                     numWeightedQtqInReportPortf=("numWeightedQtqInReportPortf", "sum"),
                     numHoldAvrgCostInReportPortf=("numHoldAvrgCostInReportPortf", "sum"),
                 )
                 .reset_index()
        )

        # If get_sign_leg_and_nr_leg exists only in row/chunk form, aggregate once per group:
        # It should return a dict of scalar columns. Convert to DataFrame and merge by index.
        df_partition = chunk.groupby(["strInstAladdin", "numInstID"], sort=False)
        try:
            extra = df_partition.apply(lambda sub: pd.Series(get_sign_leg_and_nr_leg(sub)))
            extra = extra.reset_index()
            g = g.merge(extra, on=["strInstAladdin", "numInstID"], how="left")
        finally:
            del df_partition

        # Attach constants ONCE
        g = g.assign(
            strReportPortfGPSCode=rpt_code,
            datPeriodLastDay=period_end,
            numReportPortfGroupID=group_id,
            numAuditId=audit,
            strSource="ALP-LT",
            AccountingDate=period_end,
            PortfolioDWHID=None,
            PortfolioDWHGroupID=group_id,
            PortfolioName=None,
            PortfolioCurrency=None,
            InstrumentDWHID=lambda df: df["numInstID"],
        )

        # -------- 3) ORM pulls (bulk, then map/merge) ----------
        session = get_session()
        try:
            instruments = {}
            analytics = {}

            list_inst_alds = g["strInstAladdin"].astype(str).unique().tolist()

            for chunk_inst_alds in chunker(list_inst_alds, 2000):
                instruments.update({
                    rec.strInstAladdin: rec
                    for rec in session.query(DMIRBRSInstrument)
                    .filter(DMIRBRSInstrument.strInstAladdin.in_(chunk_inst_alds))
                    .all()
                })
                analytics.update({
                    rec.strInstAladdin: rec
                    for rec in session.query(DMIRBRSInstAnalytic)
                    .filter(
                        DMIRBRSInstAnalytic.strInstAladdin.in_(chunk_inst_alds),
                        DMIRBRSInstAnalytic.datInstQuotationDate == period_end,
                    )
                    .all()
                })

            # Currency quotes (FIXED BUG: use chunk_curr_codes)
            list_curr_codes = list({inst.strInstCurrCode for inst in instruments.values() if inst})
            quotes = {}
            for chunk_curr_codes in chunker(list_curr_codes, 2000):
                quotes.update({
                    rec.strCurrCode: rec
                    for rec in session.query(DMIRBRSCurrencyQuote)
                    .filter(
                        DMIRBRSCurrencyQuote.strCurrCode.in_(chunk_curr_codes),  # <-- FIXED
                        DMIRBRSCurrencyQuote.datccyqDate == period_end,
                    )
                    .all()
                })

            # AUM and group code (singletons)
            ptf_agg = (
                session.query(DMIRBRSALPHAPortfGroupIndicators.numAUM)
                .filter_by(
                    numPortfGroupFkey=int(group_id),
                    datPeriodLastDay=period_end,
                    strPeriodTypeFlag="M",
                )
                .first()
            )
            lnk = (
                session.query(DMIRPortfolioLnk.strPortfGroupDECALOGCode)
                .filter(
                    DMIRPortfolioLnk.numPortfGroupSkey == int(group_id),
                    DMIRPortfolioLnk.strPortfGroupType.in_(["A", "G"]),
                )
                .first()
            )

            # ---- IT* aliases (by type id, pivot to dicts then map) ----
            list_inst_type_ids = list({inst.numInstTypeId for inst in instruments.values() if inst})
            it_by_cls = {"1": {}, "3": {}, "8": {}, "9": {}}
            if list_inst_type_ids:
                # fetch each class in bulk
                for cls, Model in {"1": IT1, "3": IT3, "8": IT8, "9": IT9}.items():
                    rows = (
                        session.query(Model)
                        .filter(
                            Model.numInstrTypeID.in_(list_inst_type_ids),
                            Model.strReportingType == f"class{cls}",
                        )
                        .all()
                    )
                    for r in rows:
                        it_by_cls[cls][r.numInstrTypeID] = (
                            r.strInstrumentTypeName, r.strInstrumentTypeIRName
                        )

            # ---- Sector mappings (per agency) ----
            sb_maps = {}
            if list_inst_alds:
                # BNPP_BICS
                rows = (
                    session.query(SB_BB)
                    .filter(
                        SB_BB.strInstAladdin.in_(list_inst_alds),
                        SB_BB.strInstSectorAgy == "BNPP_BICS",
                    ).all()
                )
                sb_maps["BB"] = {
                    r.strInstAladdin: (
                        r.strInstSectorL1 or r.strIssSector1Label,
                        r.strInstSectorL2 or r.strIssSector2Label,
                        r.strInstSectorL3 or r.strIssSector3Label,
                    ) for r in rows
                }

                # LH
                rows = (
                    session.query(SB_LH)
                    .filter(
                        SB_LH.strInstAladdin.in_(list_inst_alds),
                        SB_LH.strInstSectorAgy == "LH",
                    ).all()
                )
                sb_maps["LH"] = {
                    r.strInstAladdin: (
                        r.strInstSectorL1 or r.strIssSector1Label,
                        r.strInstSectorL2 or r.strIssSector2Label,
                        r.strInstSectorL3 or r.strIssSector3Label,
                    ) for r in rows
                }

                # MSCI
                rows = (
                    session.query(SB_MSCI)
                    .filter(
                        SB_MSCI.strInstAladdin.in_(list_inst_alds),
                        SB_MSCI.strInstSectorAgy == "MSCI",
                    ).all()
                )
                sb_maps["MSCI"] = {
                    r.strInstAladdin: (
                        r.strInstSectorL1 or r.strIssSector1Label,
                        r.strInstSectorL2 or r.strIssSector2Label,
                        r.strInstSectorL3 or r.strIssSector3Label,
                    ) for r in rows
                }

                # ICB
                rows = (
                    session.query(SB_ICB)
                    .filter(
                        SB_ICB.strInstAladdin.in_(list_inst_alds),
                        SB_ICB.strInstSectorAgy == "ICB",
                    ).all()
                )
                sb_maps["ICB"] = {
                    r.strInstAladdin: (
                        r.strInstSectorL1 or r.strIssSector1Label,
                        r.strInstSectorL2 or r.strIssSector2Label,
                        r.strInstSectorL3 or r.strIssSector3Label,
                    ) for r in rows
                }

        finally:
            if session is not None:
                session.close()

        # -------- 4) Vectorized enrichment via maps/merges ----------

        # instruments → maps
        inst_curr = {k: v.strInstCurrCode for k, v in instruments.items() if v}
        inst_name = {k: v.strInstName for k, v in instruments.items() if v}
        inst_bb = {k: v.strBloombergCode for k, v in instruments.items() if v}
        inst_isin = {k: v.strInstISINCode for k, v in instruments.items() if v}
        inst_cpn = {k: v.numInstCouponRate for k, v in instruments.items() if v}
        inst_mat = {k: v.datInstMaturityDate for k, v in instruments.items() if v}
        inst_type = {k: v.numInstTypeId for k, v in instruments.items() if v}

        g["instrISOCur"] = g["strInstAladdin"].map(inst_curr)
        g["InstrumentName"] = g["strInstAladdin"].map(inst_name)
        g["BloombergCode"] = g["strInstAladdin"].map(inst_bb)
        g["InstrISINCode"] = g["strInstAladdin"].map(inst_isin)
        g["InstrCouponRate"] = g["strInstAladdin"].map(inst_cpn)
        g["InstrMaturityDate"] = g["strInstAladdin"].map(inst_mat)
        g["numInstTypeId"] = g["strInstAladdin"].map(inst_type)

        # quotes → exchange rate via instrument currency
        exch = {k: v.numccyqrateInv for k, v in quotes.items() if v}
        g["InstrExchangeRate"] = g["instrISOCur"].map(exch)

        # IT classes (per type id)
        for cls in ("1", "3", "8", "9"):
            name_map = {k: v[0] for k, v in it_by_cls[cls].items()}
            ir_map = {k: v[1] for k, v in it_by_cls[cls].items()}
            g[f"InstrumentTypeNameClass{cls}"] = g["numInstTypeId"].map(name_map)
            g[f"InstrumentTypeIRNameClass{cls}"] = g["numInstTypeId"].map(ir_map)

        # Sectors
        if "BB" in sb_maps:
            tup = g["strInstAladdin"].map(sb_maps["BB"])
            g["InstrSectorBBLevel1"] = tup.map(lambda x: x[0] if isinstance(x, tuple) else None)
            g["InstrSectorBBLevel2"] = tup.map(lambda x: x[1] if isinstance(x, tuple) else None)
            g["InstrSectorBBLevel3"] = tup.map(lambda x: x[2] if isinstance(x, tuple) else None)

        if "LH" in sb_maps:
            tup = g["strInstAladdin"].map(sb_maps["LH"])
            g["InstrSectorBarclaysLevel1"] = tup.map(lambda x: x[0] if isinstance(x, tuple) else None)
            g["InstrSectorBarclaysLevel2"] = tup.map(lambda x: x[1] if isinstance(x, tuple) else None)
            g["InstrSectorBarclaysLevel3"] = tup.map(lambda x: x[2] if isinstance(x, tuple) else None)

        if "MSCI" in sb_maps:
            tup = g["strInstAladdin"].map(sb_maps["MSCI"])
            g["InstrSectorMSCILevel1"] = tup.map(lambda x: x[0] if isinstance(x, tuple) else None)
            g["InstrSectorMSCILevel2"] = tup.map(lambda x: x[1] if isinstance(x, tuple) else None)
            g["InstrSectorMSCILevel3"] = tup.map(lambda x: x[2] if isinstance(x, tuple) else None)

        if "ICB" in sb_maps:
            tup = g["strInstAladdin"].map(sb_maps["ICB"])
            g["InstrSectorICBLevel1"] = tup.map(lambda x: x[0] if isinstance(x, tuple) else None)
            g["InstrSectorICBLevel2"] = tup.map(lambda x: x[1] if isinstance(x, tuple) else None)
            g["InstrSectorICBLevel3"] = tup.map(lambda x: x[2] if isinstance(x, tuple) else None)

        # Analytics basic fields
        ana_map = analytics  # strInstAladdin -> record
        def _map_attr(attr):
            return g["strInstAladdin"].map(lambda k: getattr(ana_map.get(k), attr) if ana_map.get(k) else None)

        g["InstrYieldToMaturity"] = _map_attr("numInstYieldToMaturity")
        g["InstrEffectiveDuration"] = _map_attr("numInstEffDuration")
        g["InstrModifiedDuration"] = _map_attr("numInstModifDuration")
        g["InstrSpreadDuration"] = _map_attr("numInstSpreadDuration")
        g["InstrMCDuration"] = _map_attr("numInstMCDuration")
        g["InstrYield"] = _map_attr("numInstYield")
        g["InstrYieldCalculatedToMaturity"] = _map_attr("numInstYieldToCall")
        g["InstrYieldToMaturityPaid"] = _map_attr("numInstYieldToMaturityPaid")
        g["InstrYieldToMaturityReceived"] = _map_attr("numInstYieldToMaturityRecv")
        g["InstrOAS"] = _map_attr("numInstOptionAdjSpread")

        # Market cap EUR and tier
        g["InstrMktCapEur"] = (
            g["strInstAladdin"].map(lambda k: getattr(ana_map.get(k), "nummktcap") if ana_map.get(k) else np.nan)
            * g["InstrExchangeRate"].astype(float)
        )

        bins = [-np.inf, 3e8, 2.5e9, 1e10, np.inf]
        labels = [
            "CR_DATA_MKTCAP1_4_0-300M",
            "CR_DATA_MKTCAP1_3_300M-2.5B",
            "CR_DATA_MKTCAP1_2_2.5B-10B",
            "CR_DATA_MKTCAP1_1_10B-MAX",
        ]
        g["InstrMktCapEurTr1"] = pd.cut(g["InstrMktCapEur"], bins=bins, labels=labels)
        g["InstrMktCapEurTr1"] = g["InstrMktCapEurTr1"].astype(object).fillna("CR_DATA_MKTCAP1_OTHER")

        # AUM weight (vectorized)
        aum = getattr(ptf_agg, "numAUM", None) if ptf_agg else None
        if aum:
            g["InstrWeight"] = g["numWeightedAmtInReportPortf"] / float(aum)

        # AladdinGroupCode
        if lnk:
            g["AladdinGroupCode"] = getattr(lnk, "strPortfGroupDECALOGCode", None)

        # -------- 5) Look-through indicators: merge once ----------
        if ind_chunk is not None and not ind_chunk.empty:
            # dedupe on strInstAladdin and select required columns to keep memory low
            keep_cols = [
                "strInstAladdin",
                "numEffectDurationContrib",
                "numMCDurationContrib",
                "numModifDurationContrib",
                "numSpreadDurationContrib",
                "numDurExposureInPortfCur",
                "numCurExposureInPortfCur",
                "numCurExposureWeight",
                "numDurExposureWeight",
                "strInstRtgSPStandardized",
                "strInstRtgMDStandardized",
                "strInstRtgFHStandardized",
                "numESGGlbScore", "numESGGlbScoreCov",
                "numCO2IntensEVEval", "numCO2IntensEVEvalCov",
            ] + [f"strInstRtgCustom{k}" for k in range(1, 14) if f"strInstRtgCustom{k}" in ind_chunk.columns]

            ind_sub = ind_chunk.loc[:, [c for c in keep_cols if c in ind_chunk.columns]].copy()
            ind_sub = ind_sub.drop_duplicates(subset=["strInstAladdin"])
            g = g.merge(ind_sub, on="strInstAladdin", how="left")

            # rename to target column names
            g = g.rename(columns={
                "numEffectDurationContrib": "InstrEffectiveDurationContribution",
                "numMCDurationContrib": "InstrMCDurationContribution",
                "numModifDurationContrib": "InstrModifiedDurationContribution",
                "numSpreadDurationContrib": "InstrSpreadDurationContribution",
                "numDurExposureInPortfCur": "InstrDurExposureInPortfCur",
                "numCurExposureInPortfCur": "InstrCurExposureInPortfCur",
                "numCurExposureWeight": "InstrCurExposureWeight",
                "numDurExposureWeight": "InstrDurExposureWeight",
                "strInstRtgSPStandardized": "InstRtgSPStandardized",
                "strInstRtgMDStandardized": "InstRtgMDStandardized",
                "strInstRtgFHStandardized": "InstRtgFHStandardized",
                "numESGGlbScore": "InstrESGGlbScore",
                "numESGGlbScoreCov": "InstrESGGlbScoreCov",
                "numCO2IntensEVEval": "InstrCO2IntensEVEval",
                "numCO2IntensEVEvalCov": "InstrCO2IntensEVEvalCov",
            })
            # Custom ratings already have target names: InstrCustomRating{k}
            for k in range(1, 13+1):
                src = f"strInstRtgCustom{k}"
                dst = f"InstrCustomRating{k}"
                if src in g.columns:
                    g.rename(columns={src: dst}, inplace=True)

        # -------- 6) Dates ----------
        g["dateEOM"] = period_end + MonthEnd(0)

        return g

    except Exception as exc:
        print(exc)
        # Return empty DataFrame with expected columns on error (to be safe downstream)
        return pd.DataFrame()


def process_alpha_records(
    df_lt: pd.DataFrame,
    df_scope_alpha: pd.DataFrame,
    df_lt_ind: pd.DataFrame,
    num_audit_id: int,
    max_workers: int = 32,  # you can tune this down if memory is tight
):
    """
    Vectorized pre-filter + parallel workers that now return DataFrames.
    Concatenates as results arrive (no giant list of dicts in memory).
    """
    import pandas as pd
    from concurrent.futures import ProcessPoolExecutor, as_completed

    # -------- 1) scope filter + audit id ----------
    df_lt = (
        df_lt.assign(numAuditId=num_audit_id)
        .merge(
            df_scope_alpha,
            left_on=["numReportPortfGroupID", "datPeriodLastDay"],
            right_on=["numPortfGroupFkey", "datPeriodLastDay"],
            how="inner",
        )
        .query(
            "numLowestInventoryflag == 1 and strReportPortfGPSCode == 'NA' and numReportPortfGroupID != -1"
        )
    )

    key_cols = [
        "strReportPortfGPSCode",
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "numAuditId",
    ]

    df_lt_groups = df_lt.groupby(key_cols, sort=False)
    df_lt_ind_groups = df_lt_ind.groupby(
        ["numPortfGroupFKey", "datPeriodLastDay"], sort=False
    )

    results = []
    futures = {}

    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        for idx, (key, chunk) in enumerate(df_lt_groups):
            try:
                ind_key = (key[2], key[1])  # (group_id, period_end)
                ind_chunk = df_lt_ind_groups.get_group(ind_key)
            except KeyError as ke:
                print(f"Warning: {ind_key} is not in instrIndicators. Error: {ke}.")
                ind_chunk = pd.DataFrame(columns=df_lt_ind.columns)

            fut = executor.submit(single_process_alpha_records, idx, key, chunk, ind_chunk)
            futures[fut] = idx

        for fut in as_completed(futures):
            idx = futures[fut]
            try:
                df_part = fut.result()
                if df_part is not None and not df_part.empty:
                    results.append(df_part)
            except Exception as exc:
                print(f"Batch {idx} generated an exception: {exc}")

    if not results:
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

    # Concatenate once at the end (keeps memory flatter than list-of-dicts growth)
    return pd.concat(results, ignore_index=True)

