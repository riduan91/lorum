import functools
import threading
import psutil

def get_memory_usage() -> float:
    return float(psutil.virtual_memory().percent)

def mem_heartbeat(interval: float = 60.0, label: str = "[mem]"):
    """Log memory usage every `interval` seconds while the function runs."""
    def deco(fn):
        @functools.wraps(fn)
        def wrapper(*args, **kwargs):
            stop = threading.Event()

            def ticker():
                while not stop.wait(interval):
                    print(f"{label} {get_memory_usage():.1f}%")

            t = threading.Thread(target=ticker, daemon=True)
            t.start()
            try:
                return fn(*args, **kwargs)
            finally:
                stop.set()
                t.join(timeout=1)
        return wrapper
    return deco
