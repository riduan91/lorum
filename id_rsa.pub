import polars as pl
import pandas as pd

def aggregate_indicators(df: pd.DataFrame) -> pd.DataFrame:
    """
    Polars (eager) version of the aggregation. No .lazy().
    """
    final_cols = [
        "datPeriodLastDay",
        "numPortfGroupFKey",
        "strPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "datPeriodLastNav",
        "strCurrencyISOCode",
        "numInstrWeight",
        "numDurExposureInPortfCur",
        "numCurExposureInPortfCur",
        "numDurExposureWeight",
        "numCurExposureWeight",
        "numConvexityContrib",
        "numModifDurationContrib",
        "numMCDurationContrib",
        "numEffectDurationContrib",
        "numSpreadDurationContrib",
        "numConvexityContribWeight",
        "numModifDurationContribWeight",
        "numMCDurationContribWeight",
        "numEffectDurationContribWeight",
        "numSpreadDurationContribWeight",
        "numDeltaAdjustedSpread",
        "strPortfGroupFkey",
    ]
    if df.empty:
        return pd.DataFrame(columns=final_cols)

    keys = [
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "strInstAladdin",
        "numInstID",
    ]

    p = pl.from_pandas(df)

    # Per-row columns
    p = p.with_columns([
        # durExp: CASE WHEN delta!=0 AND qty!=0 THEN |qty|/|hold_qty|*delta ELSE amt
        pl.when(
            (pl.col("numDeltaAdjustedSpread").fill_null(0) != 0)
            & (pl.col("numHoldQuantity").fill_null(0) != 0)
        )
        .then(
            pl.col("numWeightedQtqInReportPortf").abs()
            / pl.col("numHoldQuantity").abs()
            * pl.col("numDeltaAdjustedSpread")
        )
        .otherwise(pl.col("numWeightedAmtInReportPortf"))
        .alias("durExp"),

        # curExp: Forex special handling, else amount
        pl.when(
            (pl.col("strInstrumentTypeIRName").fill_null("") == "Forex")
            & (~pl.col("strInstISINCode").fill_null("").str.starts_with("FWD"))
            & (pl.col("numLength") < 12)
        )
        .then(
            pl.when(pl.col("numHoldCrossCur").fill_null(0) != 0)
            .then(pl.col("numWeightedQtyForex") / pl.col("numHoldCrossCur") * pl.col("numPortfExRateInRptPtfCur"))
            .otherwise(0)
        )
        .otherwise(pl.col("numWeightedAmtInReportPortf"))
        .alias("curExp"),

        pl.col("numInstConvexity").abs().alias("numInstConvexityAbs"),
    ])

    # Group aggregation
    agg = (
        p.groupby(keys)
         .agg([
            pl.col("datHoldDate").max().alias("datPeriodLastNav"),
            pl.col("strReportPortfISOCur").max().alias("strCurrencyISOCode"),
            pl.col("numReportPortfAUM").max().alias("maxAUM"),
            pl.col("numWeightedAmtInReportPortf").sum().alias("sumAmt"),
            pl.col("durExp").sum().alias("sumDurExp"),
            pl.col("curExp").sum().alias("sumCurExp"),
            pl.col("numInstConvexityAbs").max().alias("maxConvexity"),
            pl.col("numInstModifDuration").max().alias("maxModifDuration"),
            pl.col("numInstMCDuration").max().alias("maxMCDuration"),
            pl.col("numInstEffDuration").max().alias("maxEffDuration"),
            pl.col("numInstSpreadDuration").max().alias("maxSpreadDuration"),
            pl.col("strInstrumentTypeIRName").fill_null("").str.to_uppercase().max().alias("maxInstrTypeUpper"),
            pl.col("numDeltaAdjustedSpread").sum().alias("sumDelta"),
        ])
    )

    # Weights, exposures
    agg = agg.with_columns([
        (pl.col("sumAmt") / pl.col("maxAUM")).fill_null(0).alias("numInstrWeight"),
        pl.col("sumDurExp").alias("numDurExposureInPortfCur"),
        pl.col("sumCurExp").alias("numCurExposureInPortfCur"),
        (pl.col("sumDurExp") / pl.col("maxAUM")).fill_null(0).alias("numDurExposureWeight"),
        (pl.col("sumCurExp") / pl.col("maxAUM")).fill_null(0).alias("numCurExposureWeight"),
    ])

    # Contributions with SWAPS abs() rule
    agg = agg.with_columns([
        (pl.col("numDurExposureWeight") * pl.col("maxConvexity")).alias("numConvexityContrib"),

        # Modified Duration
        pl.when(pl.col("maxInstrTypeUpper") == "SWAPS").then(pl.col("maxModifDuration").abs()).otherwise(pl.col("maxModifDuration")).alias("_md"),
        (pl.col("numDurExposureWeight") * pl.col("_md")).alias("numModifDurationContrib"),

        # MC Duration
        pl.when(pl.col("maxInstrTypeUpper") == "SWAPS").then(pl.col("maxMCDuration").abs()).otherwise(pl.col("maxMCDuration")).alias("_mcd"),
        (pl.col("numDurExposureWeight") * pl.col("_mcd")).alias("numMCDurationContrib"),

        # Effective Duration
        pl.when(pl.col("maxInstrTypeUpper") == "SWAPS").then(pl.col("maxEffDuration").abs()).otherwise(pl.col("maxEffDuration")).alias("_ed"),
        (pl.col("numDurExposureWeight") * pl.col("_ed")).alias("numEffectDurationContrib"),

        # Spread Duration
        pl.when(pl.col("maxInstrTypeUpper") == "SWAPS").then(pl.col("maxSpreadDuration").abs()).otherwise(pl.col("maxSpreadDuration")).alias("_sd"),
        (pl.col("numDurExposureWeight") * pl.col("_sd")).alias("numSpreadDurationContrib"),
    ]).drop(["_md", "_mcd", "_ed", "_sd"])

    # Renames/extras for final schema
    agg = agg.with_columns([
        pl.col("sumDelta").cast(pl.Float64).alias("numDeltaAdjustedSpread"),
        pl.col("numReportPortfGroupID").alias("numPortfGroupFKey"),
        pl.col("numReportPortfGroupID").cast(pl.Utf8).alias("strPortfGroupFkey"),
    ])

    # Portfolio-level sums for contribution weights
    sums = (
        agg.groupby(["datPeriodLastDay", "numPortfGroupFKey", "strReportPortfGPSCode"])
           .agg([
               pl.col("numConvexityContrib").sum().alias("sumNumConvexityContrib"),
               pl.col("numModifDurationContrib").sum().alias("sumNumModifDurationContrib"),
               pl.col("numMCDurationContrib").sum().alias("sumNumMCDurationContrib"),
               pl.col("numEffectDurationContrib").sum().alias("sumNumEffectDurationContrib"),
               pl.col("numSpreadDurationContrib").sum().alias("sumNumSpreadDurationContrib"),
           ])
    )

    merged = agg.join(
        sums,
        on=["datPeriodLastDay", "numPortfGroupFKey", "strReportPortfGPSCode"],
        how="left",
    ).with_columns([
        (pl.col("numConvexityContrib") / pl.col("sumNumConvexityContrib")).fill_null(0).alias("numConvexityContribWeight"),
        (pl.col("numModifDurationContrib") / pl.col("sumNumModifDurationContrib")).fill_null(0).alias("numModifDurationContribWeight"),
        (pl.col("numMCDurationContrib") / pl.col("sumNumMCDurationContrib")).fill_null(0).alias("numMCDurationContribWeight"),
        (pl.col("numEffectDurationContrib") / pl.col("sumNumEffectDurationContrib")).fill_null(0).alias("numEffectDurationContribWeight"),
        (pl.col("numSpreadDurationContrib") / pl.col("sumNumSpreadDurationContrib")).fill_null(0).alias("numSpreadDurationContribWeight"),
    ])

    # Select in final order and convert back to pandas
    merged = merged.select([
        "datPeriodLastDay",
        "numPortfGroupFKey",
        "strPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "datPeriodLastNav",
        "strCurrencyISOCode",
        "numInstrWeight",
        "numDurExposureInPortfCur",
        "numCurExposureInPortfCur",
        "numDurExposureWeight",
        "numCurExposureWeight",
        "numConvexityContrib",
        "numModifDurationContrib",
        "numMCDurationContrib",
        "numEffectDurationContrib",
        "numSpreadDurationContrib",
        "numConvexityContribWeight",
        "numModifDurationContribWeight",
        "numMCDurationContribWeight",
        "numEffectDurationContribWeight",
        "numSpreadDurationContribWeight",
        "numDeltaAdjustedSpread",
        "strPortfGroupFkey",
    ])

    out = merged.to_pandas()
    return out[final_cols]
