import numpy as np
import pandas as pd
import gc

# ----------------------------------------------------------------------
#  main build – pandas-only, helper fns reused from DMC branch
# ----------------------------------------------------------------------
def process_alpha_records_vectorised(
    df_lt: pd.DataFrame,
    df_scope_alpha: pd.DataFrame,
    df_lt_ind: pd.DataFrame,
    num_audit_id: int,
) -> pd.DataFrame:
    # ────────────────────────────────────────────────────────────────────
    # 1)  scope filter  + audit flag
    # ────────────────────────────────────────────────────────────────────
    df_lt = (
        df_lt.assign(numAuditId=num_audit_id)
             .merge(
                 df_scope_alpha,
                 left_on=["numReportPortfGroupID", "datPeriodLastDay"],
                 right_on=["numPortfGroupFkey",    "datPeriodLastDay"],
                 how="inner",
             )
             .query(
                 "numLowestInventoryflag == 1 "
                 "and strReportPortfGPSCode == 'NA' "
                 "and numReportPortfGroupID != -1"
             )
    )

    if df_lt.empty:
        print("Alpha-LT: nothing to process after scope filter.")
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

    print(f"Alpha-LT rows after filter: {len(df_lt):,}")
    get_hardware_info()

    # ────────────────────────────────────────────────────────────────────
    # 2)  pandas aggregation (means / sums + nrLegs & signOfLeg)
    # ────────────────────────────────────────────────────────────────────
    group_cols = [
        "strReportPortfGPSCode", "datPeriodLastDay",
        "numReportPortfGroupID", "numAuditId",
        "strInstAladdin", "numInstID"
    ]

    agg_spec = {
        "numHoldPrice":                 "mean",
        "numHoldAccruedIntPortf":       "sum",
        "numWeightedAmtInReportPortf":  "sum",
        "numHoldCrossCur":              "mean",
        "numWeightedQtqInReportPortf":  "sum",
        "numHoldAvrgCostInReportPortf": "sum",
        "numHoldQuantity":              ["size", "min", "max"],
    }

    print("pandas groupby/agg …")
    get_hardware_info()

    # pandas ≥2.1 supports engine="pyarrow" for faster multi-threaded group-by;
    # if you have it, uncomment the next line.
    # df_agg = df_lt.groupby(group_cols, as_index=False, engine="pyarrow").agg(agg_spec)
    df_agg = df_lt.groupby(group_cols, as_index=False).agg(agg_spec)

    # flatten MultiIndex columns created by the last entry
    df_agg.columns = [
        "_".join(filter(None, col)).rstrip("_") if isinstance(col, tuple) else col
        for col in df_agg.columns
    ]
    df_agg = df_agg.rename(columns={
        "numHoldQuantity_size": "nrLegs",
        "numHoldQuantity_min":  "q_min",
        "numHoldQuantity_max":  "q_max",
    })

    # vectorised signOfLeg
    df_agg["signOfLeg"] = np.select(
        [df_agg["q_min"] >= 0, df_agg["q_max"] < 0],
        [1, -1],
        default=0,
    )
    df_agg.loc[df_agg["nrLegs"] == 1, "signOfLeg"] = 0
    df_agg = df_agg.drop(columns=["q_min", "q_max"])

    print("Aggregation complete")
    get_hardware_info()

    # ────────────────────────────────────────────────────────────────────
    # 3)  parallel metadata fetches (helpers already defined)
    # ────────────────────────────────────────────────────────────────────
    inst_alds   = set(df_agg["strInstAladdin"])
    period_ends = set(df_agg["datPeriodLastDay"])
    grp_ids     = set(df_agg["numReportPortfGroupID"])

    df_i = pd.DataFrame(fetch_instruments_parallel(inst_alds, 2_000, max_workers=8))
    df_a = pd.DataFrame(fetch_analytics_parallel(inst_alds, period_ends, 2_000, max_workers=8))
    df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb = fetch_sectors_parallel(
        inst_alds, chunk_size=2_000, max_workers=8
    )

    # ────────────────────────────────────────────────────────────────────
    # 4)  serial pulls (quotes, AUM, link)
    # ────────────────────────────────────────────────────────────────────
    curr_codes = set(df_i["strInstCurrCode"].dropna())
    session = get_session()
    try:
        quotes_rows = (
            session.query(DMIRBRSCurrencyQuote)
                   .filter(DMIRBRSCurrencyQuote.strCurrCode.in_(list(curr_codes)),
                           DMIRBRSCurrencyQuote.datccyqDate.in_(list(period_ends)))
                   .all()
        )
        df_q = pd.DataFrame([
            {"strCurrCode": q.strCurrCode,
             "datccyqDate": q.datccyqDate,
             "numccyqrateInv": q.numccyqrateInv}
            for q in quotes_rows
        ])

        aum_rows = (
            session.query(DMIRBRSALPHAPortfGroupIndicators)
                   .filter(DMIRBRSALPHAPortfGroupIndicators.numPortfGroupFkey.in_(list(grp_ids)),
                           DMIRBRSALPHAPortfGroupIndicators.datPeriodLastDay.in_(list(period_ends)),
                           DMIRBRSALPHAPortfGroupIndicators.strPeriodTypeFlag == "M")
                   .all()
        )
        df_aum = pd.DataFrame([
            {"numReportPortfGroupID": r.numPortfGroupFkey,
             "datPeriodLastDay":      r.datPeriodLastDay,
             "numAUM":                r.numAUM}
            for r in aum_rows
        ])

        link_rows = (
            session.query(DMIRPortfolioLnk.numPortfGroupSkey,
                          DMIRPortfolioLnk.strPortfGroupDECALOGCode)
                   .filter(DMIRPortfolioLnk.numPortfGroupSkey.in_(list(map(int, grp_ids))),
                           DMIRPortfolioLnk.strPortfGroupType.in_(["A","G"]))
                   .all()
        )
        df_link = pd.DataFrame([
            {"numReportPortfGroupID": r.numPortfGroupSkey,
             "strPortfGroupDECALOGCode": r.strPortfGroupDECALOGCode}
            for r in link_rows
        ])
    finally:
        session.close()

    # ────────────────────────────────────────────────────────────────────
    # 5)  merge all metadata
    # ────────────────────────────────────────────────────────────────────
    print("Merging metadata …")
    get_hardware_info()

    df = df_agg.merge(df_i, on="strInstAladdin", how="left")
    if not df_a.empty:
        df = df.merge(
            df_a,
            left_on=["strInstAladdin","datPeriodLastDay"],
            right_on=["strInstAladdin","datInstQuotationDate"],
            how="left"
        ).drop(columns=["datInstQuotationDate"], errors="ignore")

    if not df_q.empty:
        df = df.merge(
            df_q,
            left_on=["strInstCurrCode","datPeriodLastDay"],
            right_on=["strCurrCode","datccyqDate"],
            how="left"
        ).drop(columns=["strCurrCode","datccyqDate"], errors="ignore")

    for dfsb in (df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb):
        if not dfsb.empty:
            df = df.merge(dfsb, on="strInstAladdin", how="left")

    df = df.merge(df_link, on="numReportPortfGroupID", how="left") \
           .merge(df_aum, on=["numReportPortfGroupID","datPeriodLastDay"], how="left")

    # ────────────────────────────────────────────────────────────────────
    # 6)  merge ratings/exposures (df_lt_ind)
    # ────────────────────────────────────────────────────────────────────
    def _norm_date(s):
        s = pd.to_datetime(s, errors="coerce")
        try: s = s.dt.tz_localize(None)
        except Exception: pass
        return s.dt.normalize()
    def _nstr(s): return s.astype("string").str.strip()

    df["datPeriodLastDay"]       = _norm_date(df["datPeriodLastDay"])
    df["strInstAladdin"]         = _nstr(df["strInstAladdin"])
    df_lt_ind["datPeriodLastDay"]= _norm_date(df_lt_ind["datPeriodLastDay"])
    df_lt_ind["strInstAladdin"]  = _nstr(df_lt_ind["strInstAladdin"])

    df = df.merge(
        df_lt_ind,
        left_on=["numReportPortfGroupID","datPeriodLastDay","strInstAladdin"],
        right_on=["numPortfGroupFKey",   "datPeriodLastDay","strInstAladdin"],
        how="left",
        suffixes=("","_ind"),
    ).drop(columns=["numPortfGroupFKey"], errors="ignore")

    # overwrite/complete indicator columns from _ind
    overwrite_map = {
        "InstrEffectiveDurationContribution": "numEffectDurationContrib",
        "InstrMCDurationContribution":        "numMCDurationContrib",
        "InstrModifiedDurationContribution":  "numModifDurationContrib",
        "InstrSpreadDurationContribution":    "numSpreadDurationContrib",
        "InstrDurExposureInPortfCur":         "numDurExposureInPortfCur",
        "InstrCurExposureInPortfCur":         "numCurExposureInPortfCur",
        "InstrCurExposureWeight":             "numCurExposureWeight",
        "InstrDurExposureWeight":             "numDurExposureWeight",
        "InstRtgSPStandardized":              "strInstRtgSPStandardized",
        "InstRtgMDStandardized":              "strInstRtgMDStandardized",
        "InstRtgFHStandardized":              "strInstRtgFHStandardized",
        "InstrESGGlbScore":                   "numESGGlbScore",
        "InstrESGGlbScoreCov":                "numESGGlbScoreCov",
        "InstrCO2IntensEVEval":               "numCO2IntensEVEval",
        "InstrCO2IntensEVEvalCov":            "numCO2IntensEVEvalCov",
    }
    for out_col, src in overwrite_map.items():
        if src in df.columns:
            df[out_col] = df[src].combine_first(df[out_col])

    for k in range(1,14):
        base = f"InstrCustomRating{k}"
        src  = f"strInstRtgCustom{k}"
        if src in df.columns:
            df[base] = df[src].combine_first(df.get(base))

    # ────────────────────────────────────────────────────────────────────
    # 7)  derived fields (weight, mkt-cap tier, etc.)
    # ────────────────────────────────────────────────────────────────────
    df["strSource"]              = "ALP-LT"
    df["AccountingDate"]         = pd.to_datetime(df["datPeriodLastDay"]).dt.normalize()
    df["PortfolioDWHID"]         = None
    df["PortfolioDWHGroupID"]    = df["numReportPortfGroupID"]
    df["InstrumentDWHID"]        = df["numInstID"]
    df["InstrLastPriceDate"]     = df["numHoldPrice"]
    df["InstrQuantity"]          = df["numWeightedQtqInReportPortf"]
    df["InstrLastPrice"]         = df["numHoldPrice"]
    df["InstrExchangeRate"]      = df["numccyqrateInv"]
    df["InstrMktCapEur"]         = df["nummktcap"] * df["numccyqrateInv"]
    df["InstrWeight"]            = df["numWeightedAmtInReportPortf"] / df["numAUM"]

    bins   = [-np.inf, 3e8, 2.5e9, 1e10, np.inf]
    labels = ["CR_DATA_MKTCAP1_4_0-300M",
              "CR_DATA_MKTCAP1_3_300M-2.5B",
              "CR_DATA_MKTCAP1_2_2.5B-10B",
              "CR_DATA_MKTCAP1_1_10B-MAX"]
    df["InstrMktCapEurTr1"] = pd.cut(df["InstrMktCapEur"], bins=bins, labels=labels)
    df.loc[df["InstrMktCapEur"].isna(), "InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_OTHER"
    df["InstrMktCapEurTr1"] = df["InstrMktCapEurTr1"].astype("object")

    df["dateEOM"] = pd.to_datetime(df["datPeriodLastDay"]) + pd.offsets.MonthEnd(0)

    print(f"Alpha-LT build complete – rows: {len(df):,}")
    get_hardware_info()

    if df.empty:
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

    gc.collect()
    return df
