CREATE UNIQUE NONCLUSTERED INDEX UQ_DMIRAPILTHolding_GroupDate_NullPortfolio
ON dbo.DMIRAPILTHolding (PortfolioDWHGroupID, AccountingDate)
WHERE PortfolioDWHID IS NULL;

CREATE UNIQUE NONCLUSTERED INDEX UQ_DMIRAPILTHolding_PortfolioDate_NullGroup
ON dbo.DMIRAPILTHolding (PortfolioDWHID, AccountingDate)
WHERE PortfolioDWHGroupID IS NULL;
