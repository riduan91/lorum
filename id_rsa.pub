import gc
import numpy as np
import pandas as pd

def process_final_step_3(
    df_DMIRTransparizLTWrk: pd.DataFrame,
    df_instrument: pd.DataFrame,
    df_instrument_irtype: pd.DataFrame,
):
    # ---- Ensure lean dtypes (optional but recommended) ---------------
    cat_cols = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID",
        "strInvestedInPortfISOCur","strInvestedInPortfID"
    ]
    for c in cat_cols:
        if c in df_DMIRTransparizLTWrk and df_DMIRTransparizLTWrk[c].dtype == "object":
            df_DMIRTransparizLTWrk[c] = df_DMIRTransparizLTWrk[c].astype("category")

    # --- Prep lookup (lowest-level rows) ------------------------------
    lkp_cols = [
        "strReportPeriod",
        "strPortfLevelID",
        "strInvestedInInstrID",
        "strInvestedInPortfISOCur",
        "numReportLevelID",
    ]
    df_lkp = (
        df_DMIRTransparizLTWrk.loc[df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 1, lkp_cols]
        .drop_duplicates()
    )
    print("df_lkp", df_lkp.shape, get_hardware_info())

    # ---------- PART 1: exact four-key join ---------------------------
    cond_master = (
        (df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 0)
        & (
            df_DMIRTransparizLTWrk["strInvestedInPortfID"].isna()
            | (df_DMIRTransparizLTWrk["numUndrlygIRLTflag"] == 0)
            | (df_DMIRTransparizLTWrk["numPresUndrlygHoldData"] == 0)
        )
    )
    df_master = df_DMIRTransparizLTWrk.loc[cond_master, [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur",
        "numInventoryLevel"
    ]].copy()
    print("df_master", df_master.shape, get_hardware_info())

    join_keys4 = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur",
    ]

    part1 = df_master.merge(
        df_lkp[join_keys4 + ["numReportLevelID"]].rename(columns={"numReportLevelID": "numReportLevelID_lkp"}),
        on=join_keys4,
        how="left",
        copy=False,
    )
    print("part1", part1.shape, get_hardware_info())
    del df_master
    gc.collect()
    get_hardware_info()

    # ---------- PART 2: hierarchical LIKE join ------------------------
    cond_part2 = (
        (df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 0)
        & df_DMIRTransparizLTWrk["strInvestedInPortfID"].notna()
        & (df_DMIRTransparizLTWrk["numUndrlygIRLTflag"] == 1)
        & (df_DMIRTransparizLTWrk["numPresUndrlygHoldData"] == 1)
    )
    df_part2 = df_DMIRTransparizLTWrk.loc[cond_part2, [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur",
        "strInvestedInPortfID","numInventoryLevel"
    ]].copy()
    print("part2", df_part2.shape, get_hardware_info())

    df_part2["parent_prefix"] = (
        df_part2["strPortfLevelID"].astype(str) + "." + df_part2["strInvestedInPortfID"].astype(str)
    )

    lkp_like = df_lkp.copy()
    lkp_like["strPortfLevelID"] = lkp_like["strPortfLevelID"].astype(str).fillna("")
    lkp_like = lkp_like.rename(columns={
        "strPortfLevelID": "strPortfLevelID_parent",
        "numReportLevelID": "numReportLevelID_parent"
    })

    prelim = df_part2.merge(
        lkp_like[["strReportPeriod","strInvestedInInstrID","strInvestedInPortfISOCur",
                  "strPortfLevelID_parent","numReportLevelID_parent"]],
        on=["strReportPeriod","strInvestedInInstrID","strInvestedInPortfISOCur"],
        how="left",
        copy=False,
    )
    print("prelim", prelim.shape, get_hardware_info())

    mask_like = np.char.startswith(
        prelim["parent_prefix"].to_numpy(dtype=str),
        (prelim["strPortfLevelID_parent"].astype(str) + ".").to_numpy()
    )

    prelim_like = prelim.loc[mask_like, [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur",
        "numReportLevelID_parent"
    ]].rename(columns={"numReportLevelID_parent": "numReportLevelID"})

    grp_like = ["strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur"]

    min_levels = (
        prelim_like.groupby(grp_like, as_index=False)["numReportLevelID"]
        .min()
        .rename(columns={"numReportLevelID": "numReportLevelID_lkp"})
    )

    part2_final = df_part2.merge(min_levels, on=grp_like, how="left", copy=False)
    print("part2_final", part2_final.shape, get_hardware_info())
    part2_final = part2_final.drop(columns=["parent_prefix", "strInvestedInPortfID"])
    del prelim, prelim_like, min_levels
    gc.collect()
    get_hardware_info()

    # ---------- UNION the two branches --------------------------------
    keep_cols = [
        "strReportPeriod","numInventoryLevel","strPortfLevelID",
        "strInvestedInInstrID","strInvestedInPortfISOCur","numReportLevelID_lkp"
    ]
    part1 = part1[keep_cols]
    part2_final = part2_final[keep_cols]

    df_step_final_3 = pd.concat([part1, part2_final], ignore_index=True)
    print("df_step_final_3", df_step_final_3.shape, get_hardware_info())
    del part1, part2_final
    gc.collect()
    get_hardware_info()

    # ---------- Update main table -------------------------------------
    join_keys_full = [
        "strReportPeriod","numInventoryLevel","strPortfLevelID",
        "strInvestedInInstrID","strInvestedInPortfISOCur",
    ]
    df_updated = df_DMIRTransparizLTWrk.merge(
        df_step_final_3[join_keys_full + ["numReportLevelID_lkp"]],
        on=join_keys_full,
        how="left",
        copy=False,
    )
    del df_step_final_3
    print("df_updated", df_updated.shape, get_hardware_info())
    gc.collect()
    get_hardware_info()

    changed = df_updated["numReportLevelID_lkp"].notna()
    if "numReportLevelID" in df_updated.columns:
        df_updated.loc[changed, "numReportLevelID"] = df_updated.loc[changed, "numReportLevelID_lkp"]
    else:
        df_updated["numReportLevelID"] = df_updated["numReportLevelID_lkp"]
    df_updated.loc[changed, "datLastModifDate"] = pd.Timestamp.now()
    df_updated.drop(columns="numReportLevelID_lkp", inplace=True)

    # --- Deletion 1 ---------------------------------------------------
    df_updated = df_updated.loc[
        ~(
            (df_updated["numInstID"].fillna(-1) == -1)
            & (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
        )
    ]
    print("df_updated", df_updated.shape, get_hardware_info())

    # --- Deletion 2 (Forex class7) -----------------------------------
    if df_instrument_irtype.empty:
        df_instrument_irtype = pd.DataFrame(
            columns=["numInstrTypeID", "strReportingType", "strInstrumentTypeIRName"]
        )

    forex_type_ids = df_instrument_irtype.loc[
        (df_instrument_irtype["strReportingType"] == "class7")
        & (df_instrument_irtype["strInstrumentTypeIRName"] == "Forex"),
        "numInstrTypeID",
    ].unique()

    df_updated = df_updated.merge(
        df_instrument[["numInstID", "numInstTypeId"]],
        on="numInstID",
        how="left",
        copy=False,
    )
    print("df_updated (2)", df_updated.shape, get_hardware_info())

    mask_forex = (
        df_updated["numInstTypeId"].isin(forex_type_ids)
        & (df_updated["numWeightedQtqInReportPortf"].fillna(0) == 0.0)
        & (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
    )
    df_updated = df_updated.loc[~mask_forex].drop(columns="numInstTypeId")
    print("df_updated (3)", df_updated.shape, get_hardware_info())

    return df_updated
