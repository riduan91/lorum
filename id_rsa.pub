DECLARE
    @fba_id        INT        = 202069,       -- random selected from fba
    @market_date   DATE       = '2025-06-27',
    @flag          VARCHAR(1) = 'W',
    @zero          FLOAT      = 0.0,          -- default zero for numeric comparison
    @tol           FLOAT      = 1e-6;         -- tolerance = 10e-7

SELECT
    a.datMarketDate    AS datMarketDate,
    a.strPeriodTypeFlag AS strPeriodTypeFlag,
    a.datPeriodLastDay AS datPeriodLastDay,
    a.numBenchFBAId    AS numBenchFBAId,
    a.numInstID        AS numInstID,
    a.strInstAladdin   AS strInstAladdin,

    /* exact (string/date) comparisons */
    CASE WHEN ISNULL(a.strPeriodTypeFlag, '')       = ISNULL(b.strPeriodTypeFlag, '')       THEN 0 ELSE 1 END AS diff_strPeriodTypeFlag,
    CASE WHEN ISNULL(a.datPeriodLastDay,   '')       = ISNULL(b.datPeriodLastDay,   '')       THEN 0 ELSE 1 END AS diff_datPeriodLastDay,
    CASE WHEN ISNULL(a.datMarketDate,      '')       = ISNULL(b.datMarketDate,      '')       THEN 0 ELSE 1 END AS diff_datMarketDate,
    CASE WHEN ISNULL(a.numBenchFBAId,      '')       = ISNULL(b.numBenchFBAId,      '')       THEN 0 ELSE 1 END AS diff_numBenchFBAId,
    CASE WHEN ISNULL(a.numInstID,          '')       = ISNULL(b.numInstID,          '')       THEN 0 ELSE 1 END AS diff_numInstID,
    CASE WHEN ISNULL(a.strInstAladdin,     '')       = ISNULL(b.strInstAladdin,     '')       THEN 0 ELSE 1 END AS diff_strInstAladdin,
    CASE WHEN ISNULL(a.strPFCurrencyISOCode, '')     = ISNULL(b.strPFCurrencyISOCode, '')     THEN 0 ELSE 1 END AS diff_strPFCurrencyISOCode,

    /* numeric comparisons with tolerance */
    CASE WHEN ABS(ISNULL(a.numInstrWeight                , @zero) - ISNULL(b.numInstrWeight                , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstrWeight,
    CASE WHEN ABS(ISNULL(a.numCurExposureInBenchCur      , @zero) - ISNULL(b.numCurExposureInBenchCur      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCurExposureInBenchCur,
    CASE WHEN ABS(ISNULL(a.numDurExposureInBenchCur      , @zero) - ISNULL(b.numDurExposureInBenchCur      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numDurExposureInBenchCur,
    CASE WHEN ABS(ISNULL(a.numCurExposureWeight          , @zero) - ISNULL(b.numCurExposureWeight          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCurExposureWeight,
    CASE WHEN ABS(ISNULL(a.numDurExposureWeight          , @zero) - ISNULL(b.numDurExposureWeight          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numDurExposureWeight,
    CASE WHEN ABS(ISNULL(a.numConvexityContrib           , @zero) - ISNULL(b.numConvexityContrib           , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numConvexityContrib,
    CASE WHEN ABS(ISNULL(a.numConvexityContribWeight     , @zero) - ISNULL(b.numConvexityContribWeight     , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numConvexityContribWeight,
    CASE WHEN ABS(ISNULL(a.numModifDurationContrib       , @zero) - ISNULL(b.numModifDurationContrib       , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numModifDurationContrib,
    CASE WHEN ABS(ISNULL(a.numModifDurationContribWeight , @zero) - ISNULL(b.numModifDurationContribWeight , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numModifDurationContribWeight,
    CASE WHEN ABS(ISNULL(a.numMCDurationContrib          , @zero) - ISNULL(b.numMCDurationContrib          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numMCDurationContrib,
    CASE WHEN ABS(ISNULL(a.numMCDurationContribWeight    , @zero) - ISNULL(b.numMCDurationContribWeight    , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numMCDurationContribWeight,
    CASE WHEN ABS(ISNULL(a.numEffectDurationContrib      , @zero) - ISNULL(b.numEffectDurationContrib      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numEffectDurationContrib,
    CASE WHEN ABS(ISNULL(a.numEffectDurationContribWeight, @zero) - ISNULL(b.numEffectDurationContribWeight, @zero)) < @tol THEN 0 ELSE 1 END AS diff_numEffectDurationContribWeight,
    CASE WHEN ABS(ISNULL(a.numSpreadDurationContrib      , @zero) - ISNULL(b.numSpreadDurationContrib      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numSpreadDurationContrib,
    CASE WHEN ABS(ISNULL(a.numSpreadDurationContribWeight, @zero) - ISNULL(b.numSpreadDurationContribWeight, @zero)) < @tol THEN 0 ELSE 1 END AS diff_numSpreadDurationContribWeight,
    CASE WHEN ABS(ISNULL(a.numInstPriceEarning           , @zero) - ISNULL(b.numInstPriceEarning           , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstPriceEarning,
    CASE WHEN ABS(ISNULL(a.numInstYldToWorst             , @zero) - ISNULL(b.numInstYldToWorst             , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstYldToWorst,
    CASE WHEN ABS(ISNULL(a.numInstBondFloor              , @zero) - ISNULL(b.numInstBondFloor              , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstBondFloor,
    CASE WHEN ABS(ISNULL(a.numInstContribActivRisk        , @zero) - ISNULL(b.numInstContribActivRisk        , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstContribActivRisk,
    CASE WHEN ABS(ISNULL(a.numInstContribTrackingError    , @zero) - ISNULL(b.numInstContribTrackingError    , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstContribTrackingError,
    CASE WHEN ABS(ISNULL(a.numInstRiskFactor             , @zero) - ISNULL(b.numInstRiskFactor             , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstRiskFactor,
    CASE WHEN ABS(ISNULL(a.numInstStressTestFactor       , @zero) - ISNULL(b.numInstStressTestFactor       , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstStressTestFactor,

    /* string comparisons for rating fields */
    CASE WHEN ISNULL(a.strInstRtgSPStandardized, '')    = ISNULL(b.strInstRtgSPStandardized, '')    THEN 0 ELSE 1 END AS diff_strInstRtgSPStandardized,
    CASE WHEN ISNULL(a.strInstRtgMDStandardized, '')    = ISNULL(b.strInstRtgMDStandardized, '')    THEN 0 ELSE 1 END AS diff_strInstRtgMDStandardized,
    CASE WHEN ISNULL(a.strInstRtgFHStandardized, '')    = ISNULL(b.strInstRtgFHStandardized, '')    THEN 0 ELSE 1 END AS diff_strInstRtgFHStandardized,
    CASE WHEN ISNULL(a.strInstRtgCustom1, '')           = ISNULL(b.strInstRtgCustom1, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom1,
    CASE WHEN ISNULL(a.strInstRtgCustom2, '')           = ISNULL(b.strInstRtgCustom2, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom2,
    CASE WHEN ISNULL(a.strInstRtgCustom3, '')           = ISNULL(b.strInstRtgCustom3, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom3,
    CASE WHEN ISNULL(a.strInstRtgCustom4, '')           = ISNULL(b.strInstRtgCustom4, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom4,
    CASE WHEN ISNULL(a.strInstRtgCustom5, '')           = ISNULL(b.strInstRtgCustom5, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom5,
    CASE WHEN ISNULL(a.strInstRtgCustom6, '')           = ISNULL(b.strInstRtgCustom6, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom6,
    CASE WHEN ISNULL(a.strInstRtgCustom7, '')           = ISNULL(b.strInstRtgCustom7, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom7,
    CASE WHEN ISNULL(a.strInstRtgCustom8, '')           = ISNULL(b.strInstRtgCustom8, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom8,
    CASE WHEN ISNULL(a.strInstRtgCustom9, '')           = ISNULL(b.strInstRtgCustom9, '')           THEN 0 ELSE 1 END AS diff_strInstRtgCustom9,
    CASE WHEN ISNULL(a.strInstRtgCustom10, '')          = ISNULL(b.strInstRtgCustom10, '')          THEN 0 ELSE 1 END AS diff_strInstRtgCustom10,
    CASE WHEN ISNULL(a.strInstRtgCustom11, '')          = ISNULL(b.strInstRtgCustom11, '')          THEN 0 ELSE 1 END AS diff_strInstRtgCustom11,
    CASE WHEN ISNULL(a.strInstRtgCustom12, '')          = ISNULL(b.strInstRtgCustom12, '')          THEN 0 ELSE 1 END AS diff_strInstRtgCustom12,
    CASE WHEN ISNULL(a.strInstRtgCustom13, '')          = ISNULL(b.strInstRtgCustom13, '')          THEN 0 ELSE 1 END AS diff_strInstRtgCustom13,

    /* more numeric with tolerance */
    CASE WHEN ABS(ISNULL(a.numInstDivYld               , @zero) - ISNULL(b.numInstDivYld               , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstDivYld,
    CASE WHEN ABS(ISNULL(a.numInstWAL                  , @zero) - ISNULL(b.numInstWAL                  , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstWAL,
    CASE WHEN ABS(ISNULL(a.numInstWAM                  , @zero) - ISNULL(b.numInstWAM                  , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstWAM,
    CASE WHEN ABS(ISNULL(a.numInstInflSens             , @zero) - ISNULL(b.numInstInflSens             , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstInflSens,
    CASE WHEN ABS(ISNULL(a.numInstDebtEq               , @zero) - ISNULL(b.numInstDebtEq               , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numInstDebtEq,
    CASE WHEN ABS(ISNULL(a.numESGGlbScore              , @zero) - ISNULL(b.numESGGlbScore              , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbScore,
    CASE WHEN ABS(ISNULL(a.numESGGlbCovWeight          , @zero) - ISNULL(b.numESGGlbCovWeight          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGGlbScoreCov           , @zero) - ISNULL(b.numESGGlbScoreCov           , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGEnvScore              , @zero) - ISNULL(b.numESGEnvScore              , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGEnvScore,
    CASE WHEN ABS(ISNULL(a.numESGEnvCovWeight          , @zero) - ISNULL(b.numESGEnvCovWeight          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGEnvCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGEnvScoreCov           , @zero) - ISNULL(b.numESGEnvScoreCov           , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGEnvScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGSocialScore           , @zero) - ISNULL(b.numESGSocialScore           , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGSocialScore,
    CASE WHEN ABS(ISNULL(a.numESGSocialCovWeight       , @zero) - ISNULL(b.numESGSocialCovWeight       , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGSocialCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGSocialScoreCov        , @zero) - ISNULL(b.numESGSocialScoreCov        , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGSocialScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGGovernanceScore       , @zero) - ISNULL(b.numESGGovernanceScore       , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGovernanceScore,
    CASE WHEN ABS(ISNULL(a.numESGGovCovWeight          , @zero) - ISNULL(b.numESGGovCovWeight          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGovCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGGovernanceScoreCov     , @zero) - ISNULL(b.numESGGovernanceScoreCov     , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGovernanceScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGDecile                , @zero) - ISNULL(b.numESGDecile                , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGDecile,
    CASE WHEN ABS(ISNULL(a.numESGDecileCovWeight       , @zero) - ISNULL(b.numESGDecileCovWeight       , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGDecileCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGDecileCov             , @zero) - ISNULL(b.numESGDecileCov             , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGDecileCov,
    CASE WHEN ABS(ISNULL(a.numESGGlbPotentialScoreCov  , @zero) - ISNULL(b.numESGGlbPotentialScoreCov  , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbPotentialScoreCov,
    CASE WHEN ABS(ISNULL(a.numCO2IntensRevEval         , @zero) - ISNULL(b.numCO2IntensRevEval         , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensRevEval,
    CASE WHEN ABS(ISNULL(a.numCO2IntensRevEvalCovWeight, @zero) - ISNULL(b.numCO2IntensRevEvalCovWeight, @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensRevEvalCovWeight,
    CASE WHEN ABS(ISNULL(a.numCO2IntensRevEvalCov      , @zero) - ISNULL(b.numCO2IntensRevEvalCov      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensRevEvalCov,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEval          , @zero) - ISNULL(b.numCO2IntensEVEval          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensEVEval,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEvalCovWeight , @zero) - ISNULL(b.numCO2IntensEVEvalCovWeight , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensEVEvalCovWeight,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEvalCov       , @zero) - ISNULL(b.numCO2IntensEVEvalCov       , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensEVEvalCov,
    CASE WHEN ABS(ISNULL(a.numCO2EmmisionsScope12      , @zero) - ISNULL(b.numCO2EmmisionsScope12      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2EmmisionsScope12,
    CASE WHEN ABS(ISNULL(a.numCO2EmmissionCovWeight    , @zero) - ISNULL(b.numCO2EmmissionCovWeight    , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2EmmissionCovWeight,
    CASE WHEN ABS(ISNULL(a.numCO2EmmisionsCov          , @zero) - ISNULL(b.numCO2EmmisionsCov          , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2EmmisionsCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDiversityValu     , @zero) - ISNULL(b.numESGKPIGenderDiversityValu     , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIGenderDiversityValu,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDivCovWeight      , @zero) - ISNULL(b.numESGKPIGenderDivCovWeight      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIGenderDivCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDivValuCov        , @zero) - ISNULL(b.numESGKPIGenderDivValuCov        , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIGenderDivValuCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsValu         , @zero) - ISNULL(b.numESGKPIHumanRightsValu         , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIHumanRightsValu,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsCovWeight    , @zero) - ISNULL(b.numESGKPIHumanRightsCovWeight    , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIHumanRightsCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsValuCov      , @zero) - ISNULL(b.numESGKPIHumanRightsValuCov      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIHumanRightsValuCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIExposureControvESG      , @zero) - ISNULL(b.numESGKPIExposureControvESG      , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExposureControvESG,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvESGCovWeight  , @zero) - ISNULL(b.numESGKPIExpControvESGCovWeight  , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExpControvESGCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvESGCov        , @zero) - ISNULL(b.numESGKPIExpControvESGCov        , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExpControvESGCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIExposureControvSocial    , @zero) - ISNULL(b.numESGKPIExposureControvSocial    , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExposureControvSocial,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvSocCovWeight   , @zero) - ISNULL(b.numESGKPIExpControvSocCovWeight   , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExpControvSocCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvSocCov         , @zero) - ISNULL(b.numESGKPIExpControvSocCov         , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExpControvSocCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtEnv                , @zero) - ISNULL(b.numESGKPIEngmtEnv                , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIEngmtEnv,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtSocial             , @zero) - ISNULL(b.numESGKPIEngmtSocial             , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIEngmtSocial,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtGov                , @zero) - ISNULL(b.numESGKPIEngmtGov                , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIEngmtGov,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtNumMeetings        , @zero) - ISNULL(b.numESGKPIEngmtNumMeetings        , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIEngmtNumMeetings,
    CASE WHEN ABS(ISNULL(a.numGrpPolicyRcoWeight            , @zero) - ISNULL(b.numGrpPolicyRcoWeight            , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numGrpPolicyRcoWeight,

    /* string comparisons */
    CASE WHEN ISNULL(a.strESGKPIEngmtRcoIssrCd, '')    = ISNULL(b.strESGKPIEngmtRcoIssrCd, '')    THEN 0 ELSE 1 END AS diff_strESGKPIEngmtRcoIssrCd,
    CASE WHEN ISNULL(a.strESGThematicSrc, '')          = ISNULL(b.strESGThematicSrc, '')          THEN 0 ELSE 1 END AS diff_strESGThematicSrc,
    CASE WHEN ISNULL(a.strCO2ThematicSrc, '')          = ISNULL(b.strCO2ThematicSrc, '')          THEN 0 ELSE 1 END AS diff_strCO2ThematicSrc,

    /* final numeric with tolerance */
    CASE WHEN ABS(ISNULL(a.numESGGlbCovWeightG           , @zero) - ISNULL(b.numESGGlbCovWeightG           , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGGlbCovWeightG,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEvalCovWeightG  , @zero) - ISNULL(b.numCO2IntensEVEvalCovWeightG  , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numCO2IntensEVEvalCovWeightG,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDivCovWeightG  , @zero) - ISNULL(b.numESGKPIGenderDivCovWeightG  , @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIGenderDivCovWeightG,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsCovWeightG, @zero) - ISNULL(b.numESGKPIHumanRightsCovWeightG, @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIHumanRightsCovWeightG,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvESGCovWeightG, @zero) - ISNULL(b.numESGKPIExpControvESGCovWeightG, @zero)) < @tol THEN 0 ELSE 1 END AS diff_numESGKPIExpControvESGCovWeightG,

    /* duplicate strInstAladdin diff at end */
    CASE WHEN ISNULL(a.strInstAladdin, '') = ISNULL(b.strInstAladdin, '') THEN 0 ELSE 1 END AS diff_strInstAladdin,

    /* raw values for inspection */
    a.numESGKPIExpControvESGCovWeight AS numESGKPIExpControvESGCovWeight_a,
    b.numESGKPIExpControvESGCovWeight AS numESGKPIExpControvESGCovWeight_b

FROM DMIR.tblDMIRBRSBenchInstrIndicators AS a
JOIN dbo.tblDMIRBRSBenchInstrIndicators AS b
  ON  a.strPeriodTypeFlag = b.strPeriodTypeFlag
  AND a.datPeriodLastDay  = b.datPeriodLastDay
  AND a.numBenchFBAId     = b.numBenchFBAId
  AND a.numInstID         = b.numInstID
  AND a.strInstAladdin    = b.strInstAladdin
WHERE
    a.datPeriodLastDay  = @market_date
    AND a.numBenchFBAId = @fba_id
    AND a.strPeriodTypeFlag = @flag;
