# ---- second-level sector / country override (option-on-future, etc.) ----
def _propagate_sector_country(src, tgt):
    """Copy sector L1-L3 (all taxonomies) + country labels when present."""
    mapping = {
        # Barclays / BB
        "InstrSectorBBLevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorBBLevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorBBLevel3": ("strInstSectorL3", "strIssSector3Label"),
        # LH
        "InstrSectorLHLevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorLHLevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorLHLevel3": ("strInstSectorL3", "strIssSector3Label"),
        # MSCI
        "InstrSectorMSCILevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorMSCILevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorMSCILevel3": ("strInstSectorL3", "strIssSector3Label"),
        # ICB
        "InstrSectorICBLevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorICBLevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorICBLevel3": ("strInstSectorL3", "strIssSector3Label"),
    }

    for tgt_key, (l_key, ll_key) in mapping.items():
        val = getattr(src, l_key) or getattr(src, ll_key)
        if val:
            tgt[tgt_key] = val

    # country labels
    for k in (
        "strInstIssueCountryLabel",
        "strInstIssuerCountryLabel",
        "strInstRiskCountryLabel",
    ):
        if getattr(src, k):
            tgt[k] = getattr(src, k)


# ---------- second-level lookup ----------------
second_level_types = {
    "Listed Option On Future On Bond",
    "Listed Option On Future On Index",
    "Listed Option On Future On Stock",
    "OTC Option On Future On Bond",
    "OTC Option On Future On Index",
    "OTC Option On Future On Stock",
}

for record in results:
    if record.get("strInstrumentTypeIRName3") in second_level_types:
        inst = instruments.get(record["InstrumentDWHID"])
        if inst and inst.numInstUndrlygID:
            lvl1 = instruments.get(inst.numInstUndrlygID)
            lvl2 = (
                level2_instruments.get(lvl1.numInstUndrlygID)
                if lvl1 and lvl1.numInstUndrlygID
                else None
            )
            if lvl2:
                _propagate_sector_country(lvl2, record)
