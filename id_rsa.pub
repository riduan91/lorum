from sqlalchemy import values, column, and_, select, func, String, Date

def enrich_external_with_nav(session: Session, df_ext_agg: pd.DataFrame) -> pd.DataFrame:
    """
    For each (strInstISINCode, strReportPeriod), pick the row in
    tempDMIRExtPortfHolding with the MAX(datACCDate) such that
    datACCDate <= agg.datHoldDate. Bring back (AUM, CCY, datACCDate).
    """
    if df_ext_agg.empty:
        return df_ext_agg.copy()

    key_df = (
        df_ext_agg.loc[df_ext_agg["datHoldDate"].notna(),
                       ["strInstISINCode", "strReportPeriod", "datHoldDate"]]
        .drop_duplicates()
    )
    if key_df.empty:
        out = df_ext_agg.copy()
        out["numInvestedInPortfAUM"] = np.nan
        out["strInvestedInPortfISOCur"] = np.nan
        out["datLastNAVDate"] = pd.NaT
        out["numPresUndrlygHoldData"] = 0
        return out

    Ext = tempDMIRExtPortfHolding  # your ORM model

    # Inline key list (avoids reflection)
    k = (
        values(
            column("strPortfISINCode", Ext.strPortfISINCode.type),
            column("strReportPeriod", String),
            column("datHoldDate", Ext.datACCDate.type),
            name="key_list",
        )
        .data(list(key_df.itertuples(index=False, name=None)))
        .alias("k")
    )

    tmax = (
        select(
            k.c.strPortfISINCode.label("strPortfISINCode"),
            k.c.strReportPeriod.label("strReportPeriod"),
            func.max(Ext.datACCDate).label("datAccDate"),
        )
        .select_from(k)
        .join(
            Ext,
            and_(
                Ext.strPortfISINCode == k.c.strPortfISINCode,
                Ext.datACCDate <= k.c.datHoldDate,
            ),
        )
        .group_by(k.c.strPortfISINCode, k.c.strReportPeriod)
    ).subquery()

    rows = session.execute(
        select(
            tmax.c.strPortfISINCode,
            tmax.c.strReportPeriod,
            tmax.c.datAccDate,
            Ext.strPortfISOCur,
            Ext.numAUMInPortfCur,
        ).join(
            Ext,
            and_(
                Ext.strPortfISINCode == tmax.c.strPortfISINCode,
                Ext.datACCDate == tmax.c.datAccDate,
            ),
        )
    ).all()

    enrich = pd.DataFrame(
        rows,
        columns=[
            "strInstISINCode",
            "strReportPeriod",
            "datLastNAVDate",              # ← SQL ext.datAccDate
            "strInvestedInPortfISOCur",    # ← SQL ext.strPortfISOCur (…H)
            "numInvestedInPortfAUM",       # ← SQL ext.numAUMInPortfCur
        ],
    )

    out = df_ext_agg.merge(enrich, on=["strInstISINCode", "strReportPeriod"], how="left")
    out["numPresUndrlygHoldData"] = np.where(out["numInvestedInPortfAUM"].isna(), 0, 1)
    return out


def enrich_internal_with_nav(session: Session, df_int_agg: pd.DataFrame) -> pd.DataFrame:
    """
    For each (strInvestedInPortfID, strReportPeriod), pick the row in
    tempDMIRIntPortfHolding with the MAX(datACCDate) such that
    datACCDate <= agg.datHoldDate. Bring back (AUM, CCY, datACCDate).
    """
    if df_int_agg.empty:
        return df_int_agg.copy()

    key_df = (
        df_int_agg.loc[df_int_agg["datHoldDate"].notna(),
                       ["strInvestedInPortfID", "strReportPeriod", "datHoldDate"]]
        .drop_duplicates()
    )
    if key_df.empty:
        out = df_int_agg.copy()
        out["numInvestedInPortfAUM"] = np.nan
        out["strInvestedInPortfISOCur"] = np.nan
        out["datLastNAVDate"] = pd.NaT
        out["numPresUndrlygHoldData"] = 0
        return out

    Int = tempDMIRIntPortfHolding  # your ORM model (use your exact class name)

    k = (
        values(
            column("strPortfGPSCode", Int.strPortfGPSCode.type),
            column("strReportPeriod", String),
            column("datHoldDate", Int.datACCDate.type),
            name="key_list",
        )
        .data(list(key_df.itertuples(index=False, name=None)))
        .alias("k")
    )

    tmax = (
        select(
            k.c.strPortfGPSCode.label("strPortfGPSCode"),
            k.c.strReportPeriod.label("strReportPeriod"),
            func.max(Int.datACCDate).label("datAccDate"),
        )
        .select_from(k)
        .join(
            Int,
            and_(
                Int.strPortfGPSCode == k.c.strPortfGPSCode,
                Int.datACCDate <= k.c.datHoldDate,
            ),
        )
        .group_by(k.c.strPortfGPSCode, k.c.strReportPeriod)
    ).subquery()

    rows = session.execute(
        select(
            tmax.c.strPortfGPSCode,
            tmax.c.strReportPeriod,
            tmax.c.datAccDate,
            Int.strPortfISOCur,
            Int.numActifNetTotalOpcvm,
        ).join(
            Int,
            and_(
                Int.strPortfGPSCode == tmax.c.strPortfGPSCode,
                Int.datACCDate == tmax.c.datAccDate,
            ),
        )
    ).all()

    enrich = pd.DataFrame(
        rows,
        columns=[
            "strInvestedInPortfID",
            "strReportPeriod",
            "datLastNAVDate",              # ← SQL internal.datACCDate
            "strInvestedInPortfISOCur",    # ← SQL internal.strPortfISOCur (…H)
            "numInvestedInPortfAUM",       # ← SQL internal.numActifNetTotalOpcvm
        ],
    )

    out = df_int_agg.merge(enrich, on=["strInvestedInPortfID", "strReportPeriod"], how="left")
    out["numPresUndrlygHoldData"] = np.where(out["numInvestedInPortfAUM"].isna(), 0, 1)
    return out
