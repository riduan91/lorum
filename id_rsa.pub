INSERT dbo.tblDWAULoggingGraphDetail
      (datEntryDate,                               numAuditId,              numOrder, numRecords, strDescription,  strEntryType)
SELECT DATEADD(HOUR, -2, datLocal) AS datEntryDate, numAuditId,              numOrder, numRecords, strDescription,  strEntryType
FROM src
ORDER BY numAuditId, datLocal, numOrder;




