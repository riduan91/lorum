@monitor_mem()
def fetch_instrument_metadata(idx, pairs: list[int]):
    print(f"Fetching instruments for chunk {idx}")
    session = get_session()
    inst_ids = set([inst for inst, _ in pairs])
    hold_dates = set([dt.strftime("%Y%m%d") for _, dt in pairs])
    try:
        a = aliased(DMIRBRSInstAnalytic)
        i = aliased(DMIRBRSInstrument)
        it = aliased(DMIRInstrumentIRType)
        u = aliased(DMIRBRSInstrument)

        query = (
            session.query(
                i.numInstID,
                a.datInstQuotationDate,
                a.numInstEffDuration,
                a.numInstModifDuration,
                a.numInstConvexity,
                a.numInstMCDuration,
                a.numInstSpreadDuration,
                a.numInstUndrlygPrice,
                a.numInstDelta,
                i.strInstAladdin,
                i.numInstUndrlygQty,
                i.strCpnRateTypPaid,
                i.strCpnRateTypeRecv,
                i.strInstLegType,
                i.strInstPriceType,
                i.strInstISINCode,
                i.numInstTypeId,
                i.strInstUnderlygAladdin,
                it.strInstrumentTypeIRName,
                u.numInstUndrlygQty.label("UnumInstUndrlygQty"),
                u.strInstPriceType.label("ustrInstPriceType"),
            )
            .select_from(i)
            .outerjoin(a, and_(a.numInstID == i.numInstID, a.datInstQuotationDate.in_(hold_dates)))
            .outerjoin(
                it, (i.numInstTypeId == it.numInstrTypeID) & (it.strReportingType == "class7")
            )
            .outerjoin(u, i.strInstUnderlygAladdin == u.strInstAladdin)
            .filter(i.numInstID.in_(inst_ids))
        )

        df_instr = get_all_as_df(query)
        return df_instr
    finally:
        session.close()


def build_transpariz_data(df_tblDMIRTransparizLTWrk: pd.DataFrame, from_table=False, max_workers=8):
    """
    Replicates Task 2:
    - Aggregate DMIR.tblDMIRScopeLT
    - Inner-join to df_tblDMIRTransparizLTWrk (flagged rows)
    - Left-join analytics, instrument metadata, type, underlying
    - 16 workers: The job is running at the same time as Transpariz integration. Don't put higher workers
    """
    session = get_session()
    # 1. Fetch and aggregate scope
    query = session.query(
        DMIRScopeLT.datPeriodLastDay,
        DMIRScopeLT.numReportPortfGroupID,
        DMIRScopeLT.strReportPortfGPSCode,
        func.max(DMIRScopeLT.datHoldDate).label("datHoldDate"),
        DMIRScopeLT.strReportPortfISOCur,
        DMIRScopeLT.numReportPortfAUM,
    ).group_by(
        DMIRScopeLT.datPeriodLastDay,
        DMIRScopeLT.numReportPortfGroupID,
        DMIRScopeLT.strReportPortfGPSCode,
        DMIRScopeLT.strReportPortfISOCur,
        DMIRScopeLT.numReportPortfAUM,
    )
    df_s = get_all_as_df(query)

    if df_s.empty:
        df_s = pd.DataFrame(
            columns=[
                "datPeriodLastDay",
                "numReportPortfGroupID",
                "strReportPortfGPSCode",
                "datHoldDate",
                "strReportPortfISOCur",
                "numReportPortfAUM",
            ]
        )

    if from_table or df_tblDMIRTransparizLTWrk is None:
        max_audit_subq = select(func.max(DMIRTransparizLT.numAuditId)).scalar_subquery()

        query = session.query(
            DMIRTransparizLT.datReportDate,
            DMIRTransparizLT.strReportPeriod,
            DMIRTransparizLT.numPortfLevel,
            DMIRTransparizLT.numInventoryLevel,
            DMIRTransparizLT.strReportPortfHoldSrc,
            DMIRTransparizLT.numReportPortfGroupID,
            DMIRTransparizLT.strReportPortfGPSCode,
            DMIRTransparizLT.strPortfID,
            DMIRTransparizLT.strPortfName,
            DMIRTransparizLT.strPortfLevelID,
            DMIRTransparizLT.numPortfAUM,
            DMIRTransparizLT.strPortfISOCur,
            DMIRTransparizLT.numPortfExRateInRptPtfCur,
            DMIRTransparizLT.numPortfAUMInRptPtfCur,
            DMIRTransparizLT.strInvestedInPortfID,
            DMIRTransparizLT.strInvestedInInstrID,
            DMIRTransparizLT.strInvestedInPortfName,
            DMIRTransparizLT.strInstISINCode,
            DMIRTransparizLT.strInstCatName,
            DMIRTransparizLT.strInvestedInPortfISOCur,
            DMIRTransparizLT.numHoldCrossCur,
            DMIRTransparizLT.numHoldValueInPortfCur,
            DMIRTransparizLT.numHoldQuantity,
            DMIRTransparizLT.datHoldDate,
            DMIRTransparizLT.datLastNAVDate,
            DMIRTransparizLT.numUndrlygIRLTflag,
            DMIRTransparizLT.numHoldValueInReportPortfCur,
            DMIRTransparizLT.numPctReportPortfInUndrlyg,
            DMIRTransparizLT.numWeightedAmtInReportPortf,
            DMIRTransparizLT.numWeightedQtqInReportPortf,
            DMIRTransparizLT.numLowestInventoryflag,
            DMIRTransparizLT.numReportLevelID,
            DMIRTransparizLT.datLastModifDate,
            DMIRTransparizLT.datPeriodLastDay,
            DMIRTransparizLT.numInstID,
            DMIRTransparizLT.numHoldAvrgCostInReportPortf,
            DMIRTransparizLT.numPresUndrlygHoldData,
            DMIRTransparizLT.numAuditId,
            DMIRTransparizLT.numHoldPrice,
            DMIRTransparizLT.numHoldAccruedIntInstr,
            DMIRTransparizLT.numHoldAccruedIntPortf,
            DMIRTransparizLT.strLevel1IsinCode,
            DMIRTransparizLT.strReportPortfISOCur,
            DMIRTransparizLT.strInstAladdin,
        ).filter(DMIRTransparizLT.numAuditId == max_audit_subq)
        df_tblDMIRTransparizLTWrk = get_all_as_df(query)

    print("df_s.columns", df_s.columns)
    session.close()

    # 2. Merge scope + transpariz
    df_joined = df_s.merge(
        df_tblDMIRTransparizLTWrk[df_tblDMIRTransparizLTWrk["numLowestInventoryflag"] == 1],
        on=["datPeriodLastDay", "numReportPortfGroupID", "strReportPortfGPSCode"],
        how="inner",
        suffixes=("", "_wrk"),
    )
    print("df_joined", df_joined.shape)
    print(
        df_joined[
            (df_joined["strReportPortfGPSCode"] == "3048")
            & (df_joined["numLowestInventoryflag"] == 1)
        ].to_json(orient="records")
    )

    # 3. Join analytics, instrument
    inst_ids = df_joined["numInstID"].dropna().unique().tolist()
    hold_dates = df_joined["datHoldDate_wrk"].dropna().unique().tolist()
    pairs = df_joined[["numInstID", "datHoldDate_wrk"]].dropna().drop_duplicates().values.tolist()
    instr_dfs = []

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(fetch_instrument_metadata, i, chunk): i
            for i, chunk in enumerate(list(chunker(pairs, 1000)))
        }
        for future in as_completed(futures):
            instrs = future.result()
            instr_dfs.append(instrs)
            print(f"Chunk inserted {len(instrs)} rows")

    if len(instr_dfs) > 0:
        df_instr = pd.concat(instr_dfs, ignore_index=True)
    else:
        df_instr = pd.DataFrame(columns=["numInstID", "datInstQuotationDate"])
        normalize_type(df_instr)

    df_instr = df_instr.drop_duplicates(subset=["numInstID", "datInstQuotationDate"], keep="first")
    # df_joined["datHoldDate"] = pd.to_datetime(df_joined["datHoldDate"])
    df_joined = df_joined.merge(
        df_instr,
        how="left",
        left_on=["numInstID", "datHoldDate_wrk"],
        right_on=["numInstID", "datInstQuotationDate"],
        suffixes=("", "_inst"),
    )
    print("df_joined3", df_joined.shape)
    print("df_instr", df_instr.shape)
    print(
        df_joined[
            (df_joined["strReportPortfGPSCode"] == "3048")
            & (df_joined["numLowestInventoryflag"] == 1)
        ].to_json(orient="records")
    )
    del df_instr

    # numHoldCrossCur: null or 0 → 1
    df_joined["numHoldCrossCur"] = np.where(
        df_joined["numHoldCrossCur"].isna() | (df_joined["numHoldCrossCur"] == 0),
        1,
        df_joined["numHoldCrossCur"],
    )

    # initial delta & original qty
    df_joined["numDeltaAdjustedSpread"] = df_joined["numWeightedAmtInReportPortf"]
    df_joined["OriginalQty"] = df_joined["numWeightedAmtInReportPortf"]

    # forex qty
    df_joined["numWeightedQtyForex"] = np.where(
        df_joined["numWeightedQtqInReportPortf"].fillna(0) > 0,
        df_joined["numWeightedQtqInReportPortf"],
        0,
    )

    # string length
    df_joined["numLength"] = df_joined["strPortfID"].str.len()

    # extract numeric part to match SQL PATINDEX logic
    mask = (
        df_joined["strPortfID"].notna()
        & (df_joined["numLength"] != 12)
        & ~df_joined["strPortfID"].astype(str).str.contains("_", na=False)
        & (df_joined["strReportPortfHoldSrc"] == "ALP")
    )
    df_joined["strPortfIDNumPart"] = None
    # Match SQL: convert(INT, substring(strPortfID, PATINDEX('%[0-9]%', strPortfID), ...))
    # This extracts the first continuous sequence of digits
    df_joined.loc[mask, "strPortfIDNumPart"] = df_joined.loc[mask, "strPortfID"].str.extract(
        r"(\d+)", expand=False
    )
    print("df_joined4", df_joined.shape)
    print(
        df_joined[
            (df_joined["strReportPortfGPSCode"] == "3048")
            & (df_joined["numLowestInventoryflag"] == 1)
        ].to_json(orient="records")
    )

    # 4. Update
    # UPDATE #tmpTransparizLTWrk
    # SET numDeltaAdjustedSpread = 0.00
    #  	,OriginalQty = 0.00
    df_joined["numDeltaAdjustedSpread"] = 0.0
    df_joined["OriginalQty"] = 0.0
    print(
        "df_joined4",
        df_joined.shape,
    )
    print(
        df_joined[
            (df_joined["strReportPortfGPSCode"] == "3048")
            & (df_joined["numLowestInventoryflag"] == 1)
        ].to_json(orient="records")
    )

    final_cols = [
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "datHoldDate",
        "strReportPortfISOCur",
        "numReportPortfAUM",
        "numWeightedAmtInReportPortf",
        "numWeightedQtqInReportPortf",
        "numHoldCrossCur",
        "numHoldAvrgCostInReportPortf",
        "strInstAladdin",
        "numInstID",
        "numPortfExRateInRptPtfCur",
        "numHoldQuantity",
        "numHoldPrice",
        "datInstQuotationDate",
        "numInstEffDuration",
        "numInstModifDuration",
        "numInstConvexity",
        "numInstMCDuration",
        "numInstSpreadDuration",
        "numInstUndrlygPrice",
        "numInstDelta",
        "numInstUndrlygQty",
        "strInstrumentTypeIRName",
        "strCpnRateTypPaid",
        "strCpnRateTypeRecv",
        "strInstLegType",
        "strInstPriceType",
        "UnumInstUndrlygQty",
        "ustrInstPriceType",
        "strInstISINCode",
        "numDeltaAdjustedSpread",
        "OriginalQty",
        "strPortfID",
        "numLength",
        "numWeightedQtyForex",
        "strPortfIDNumPart",
    ]

    if df_joined.empty:
        return pd.DataFrame(columns=final_cols)
    return df_joined[final_cols]


@monitor_mem()
def build_portf_scope(df_transpariz: pd.DataFrame):
    df_scope = (
        df_transpariz[["numReportPortfGroupID", "strPortfID", "datPeriodLastDay"]]
        .drop_duplicates()
        .rename(
            columns={
                "numReportPortfGroupID": "numPortfGroupFkey",
                "strPortfID": "strPortfGPSCode",
            }
        )
        .reset_index(drop=True)
    )
    return df_scope


@monitor_mem()
def extract_derivative_positions(df_scope: pd.DataFrame):
    session = get_session()
    scope_pairs = (
        df_scope[["datPeriodLastDay", "strPortfGPSCode"]]
        .drop_duplicates()
        .to_dict(orient="records")
    )
    results = []

    # DMC instrument types (matches SQL for DMC)
    instrument_types = [
        "FUTURE_INDEX",
        "OPTION_EQUITY",
        "OPTION_FUTURE",
        "OPTION_CUROTC",
        "FUTURE_FIN",
        "SWAP_TRSWAP",
        "SWAP_SWAP",
    ]

    for i, pair in enumerate(scope_pairs):
        print(f"Processing row {i+1}/{len(scope_pairs)}")
        dat = pair["datPeriodLastDay"]
        if isinstance(dat, pd.Timestamp):
            dat = dat.to_pydatetime().date()
        code = pair["strPortfGPSCode"]

        q = (
            session.query(
                DWGNInvestmentPositions.strInstrmtCd,
                DWGNInvestmentPositions.strProdCd,
                func.max(DWGNInvestmentPositions.datPosDt).label("posDt"),
            )
            .filter(
                DWGNInvestmentPositions.strProdCd == code,
                DWGNInvestmentPositions.datPosDt <= dat,
                DWGNInvestmentPositions.datPosDt > dat - timedelta(days=7),
                DWGNInvestmentPositions.strInstrmtTypCd.in_(instrument_types),
            )
            .group_by(DWGNInvestmentPositions.strInstrmtCd, DWGNInvestmentPositions.strProdCd)
        )

        df_chunk = get_all_as_df(q)
        if df_chunk.empty:
            continue

        df_chunk["datPeriodLastDay"] = dat
        df_chunk["strPortfGPSCode"] = code
        results.append(df_chunk)

    if results:
        df_investmentpos_sq = pd.concat(results, ignore_index=True)
    else:
        df_investmentpos_sq = pd.DataFrame(
            columns=[
                "strInstrmtCd",
                "strProdCd",
                "posDt",
                "datPeriodLastDay",
                "strPortfGPSCode",
            ]
        )
    return df_investmentpos_sq


def _compute_delta_dmc_single(row_idx, row, excluded_pocs):
    session = get_session()
    try:
        if row_idx % 100 == 0:
            print(f"Processing compute_delta_dmc for row {row_idx}...")
        instr = row["strInstrmtCd"]
        code = row["strPortfGPSCode"]
        posDt = row["posDt"]
        rptDay = row["datPeriodLastDay"]

        # Build ORM query
        q = session.query(
            func.sum(DWGNInvestmentPositions.numDeltaAdjedNotionalValu).label(
                "numDeltaAdjedNotionalValu"
            ),
            func.sum(
                case(
                    [
                        (
                            DWGNInvestmentPositions.strPosQtySign == "-",
                            -DWGNInvestmentPositions.numPosQty,
                        )
                    ],
                    else_=DWGNInvestmentPositions.numPosQty,
                )
            ).label("numPosQty"),
        ).filter(
            DWGNInvestmentPositions.strInstrmtCd == instr,
            DWGNInvestmentPositions.strProdCd == code,
            DWGNInvestmentPositions.datPosDt == posDt,
            or_(
                DWGNInvestmentPositions.strPocCd.is_(None),
                ~DWGNInvestmentPositions.strPocCd.in_(excluded_pocs),
            ),
        )

        delta_val, qty_val = q.one()
        return {
            "strInstrmtCd": instr,
            "strProdCd": code,
            "numPortfGroupFkey": -1,
            "numPtfFkey": -1,
            "datPeriodLastDay": rptDay,
            "numDeltaAdjedNotionalValu": delta_val or 0.0,
            "numPosQty": qty_val or 0.0,
        }
    finally:
        session.close()


@monitor_mem()
def compute_delta_dmc(df_investmentpos_sq: pd.DataFrame, max_workers=24):
    # The set of POC codes to exclude
    excluded_pocs = {
        "139_17",
        "14781_12",
        "15282_9",
        "15444_9",
        "190_4",
        "2903_9",
        "43270_2",
        "43585_24",
        "44370_2",
        "44407_1",
        "44408_1",
        "44414_2",
        "44420_4",
        "44479_1",
        "44494_2",
        "44548_1",
        "44591_2",
        "44355_1",
    }

    results = []
    keys_df = df_investmentpos_sq[
        ["strInstrmtCd", "strPortfGPSCode", "posDt", "datPeriodLastDay"]
    ].drop_duplicates()
    # Ensure unique tuples

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_compute_delta_dmc_single, row_idx, row, excluded_pocs): row_idx
            for row_idx, row in keys_df.iterrows()
        }
        for future in as_completed(futures):
            res = future.result()
            results.append(res)
            print(f"Chunk inserted {len(results)} rows")

    # Concatenate all chunks into a DataFrame
    if results:
        df_delta = pd.DataFrame(results)
    else:
        df_delta = pd.DataFrame(
            columns=[
                "strInstrmtCd",
                "strProdCd",
                "numPortfGroupFkey",
                "numPtfFkey",
                "datPeriodLastDay",
                "numDeltaAdjedNotionalValu",
                "numPosQty",
            ]
        )

    return df_delta


def build_sq1_loop(session: Session, df_scope: pd.DataFrame):
    # Alpha instrument types (matches SQL for Alpha)
    instr_types = [
        "FUTURE_INDEX",
        "OPTION_EQUITY",
        "OPTION_FUTURE",
        "OPTION_CUROTC",
        "FUTURE_FIN",
        "SWAP_TRSWAP",
        "SWAP_SWAP",
        "SWAP_CDSWAP",
        "SYNTH_FLOOR",
        "SYNTH_OTC",
        "xxxxSYNTH_SWAPTION",
    ]
    records = []
    # unique scope pairs
    scope_pairs = df_scope[["datPeriodLastDay", "numPortfGroupFkey"]].drop_duplicates()
    for _, row in scope_pairs.iterrows():
        print(f"Processing row {_} / {len(scope_pairs)}.")
        rpt_day = row["datPeriodLastDay"]
        group_fk = row["numPortfGroupFkey"]

        q = (
            session.query(
                DWGNInvestmentPositions.strInstrmtCd.label("strInstrmtCd"),
                DWGNInvestmentPositions.numPtfFkey.label("numPtfFkey"),
                func.max(DWGNInvestmentPositions.datPosDt).label("posDt"),
            )
            .join(
                DMIRPortfolioLnk,
                DMIRPortfolioLnk.numPortfSkey == DWGNInvestmentPositions.numPtfFkey,
            )
            .filter(
                DMIRPortfolioLnk.numPortfGroupSkey == group_fk,
                DWGNInvestmentPositions.strInstrmtTypCd.in_(instr_types),
                DWGNInvestmentPositions.datPosDt <= rpt_day,
                DWGNInvestmentPositions.datPosDt > rpt_day - timedelta(days=7),
            )
            .group_by(DWGNInvestmentPositions.strInstrmtCd, DWGNInvestmentPositions.numPtfFkey)
        )

        df_chunk = get_all_as_df(q)
        if df_chunk.empty:
            continue

        df_chunk["datPeriodLastDay"] = rpt_day
        df_chunk["numPortfGroupFkey"] = group_fk
        records.append(df_chunk)

    if records:
        return pd.concat(records, ignore_index=True)
    else:
        return pd.DataFrame(
            columns=["strInstrmtCd", "numPtfFkey", "posDt", "datPeriodLastDay", "numPortfGroupFkey"]
        )


def _compute_delta_alpha_single(row_idx, row, excluded_pocs):
    session = get_session()
    try:
        print(f"Processing compute_delta_alpha for row {row_idx}...")

        instr = row["strInstrmtCd"]
        pfk = row["numPortfGroupFkey"]
        ptfk = row["numPtfFkey"]
        posdt = row["posDt"]
        rpt = row["datPeriodLastDay"]

        q = session.query(
            func.sum(DWGNInvestmentPositions.numDeltaAdjedNotionalValu).label(
                "numDeltaAdjedNotionalValu"
            ),
            func.sum(
                case(
                    [
                        (
                            DWGNInvestmentPositions.strPosQtySign == "-",
                            -DWGNInvestmentPositions.numPosQty,
                        )
                    ],
                    else_=DWGNInvestmentPositions.numPosQty,
                )
            ).label("numPosQty"),
        ).filter(
            DWGNInvestmentPositions.strInstrmtCd == instr,
            DWGNInvestmentPositions.numPtfFkey == ptfk,
            DWGNInvestmentPositions.datPosDt == posdt,
            or_(
                DWGNInvestmentPositions.strPocCd.is_(None),
                ~DWGNInvestmentPositions.strPocCd.in_(excluded_pocs),
            ),
        )

        delta_val, qty_val = q.one()
        return {
            "strInstrmtCd": instr,
            "strProdCd": -1,
            "numPortfGroupFkey": pfk,
            "numPtfFkey": ptfk,
            "datPeriodLastDay": rpt,
            "numDeltaAdjedNotionalValu": float(delta_val or 0.0),
            "numPosQty": float(qty_val or 0.0),
        }
    finally:
        session.close()


@monitor_mem()
def compute_delta_alpha(df_scope: pd.DataFrame, max_workers=24):
    session = get_session()
    df_sq1 = build_sq1_loop(session, df_scope)
    session.close()
    excluded_pocs = {
        "139_17",
        "14781_12",
        "15282_9",
        "15444_9",
        "190_4",
        "2903_9",
        "43270_2",
        "43585_24",
        "44370_2",
        "44407_1",
        "44408_1",
        "44414_2",
        "44420_4",
        "44479_1",
        "44494_2",
        "44548_1",
        "44591_2",
        "44355_1",
    }
    records = []

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_compute_delta_alpha_single, row_idx, row, excluded_pocs): row_idx
            for row_idx, row in df_sq1.iterrows()
        }
        for future in as_completed(futures):
            res = future.result()
            records.append(res)
            print(f"Chunk inserted {len(records)} rows")

    if records:
        return pd.DataFrame(records)
    else:
        return pd.DataFrame(
            columns=[
                "strInstrmtCd",
                "numPortfGroupFkey",
                "numPtfFkey",
                "datPeriodLastDay",
                "numDeltaAdjedNotionalValu",
                "numPosQty",
            ]
        )


def _apply_delta_adjustments_instruments_single(chunk_idx, chunk):
    session = get_session()
    try:
        print(f"apply_delta_adjustments_instruments for chunk {chunk_idx}.")
        df_chunk = get_all_as_df(
            session.query(
                DMIRBRSInstrument.strInstAladdin, DMIRInstrumentIRType.strInstrumentTypeIRName
            )
            .outerjoin(
                DMIRInstrumentIRType,
                DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
            )
            .filter(
                DMIRBRSInstrument.strInstAladdin.in_(chunk),
                DMIRInstrumentIRType.strReportingType == "class2",
                func.upper(DMIRInstrumentIRType.strInstrumentTypeIRName) != "FUTURES ON CURRENCIES",
            )
        )
        return df_chunk
    finally:
        session.close()


@monitor_mem()
def apply_delta_adjustments(df_tmp: pd.DataFrame, df_delta: pd.DataFrame, max_workers=24):
    inst_codes = df_tmp["strInstAladdin"].dropna().unique().tolist()
    chunks = [inst_codes[i : i + 1000] for i in range(0, len(inst_codes), 1000)]
    columns = df_tmp.columns

    dfs_instr = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_apply_delta_adjustments_instruments_single, idx, chunk): idx
            for idx, chunk in enumerate(chunks)
        }
        for f in as_completed(futures):
            dfs_instr.append(f.result())

    if not dfs_instr:
        return pd.DataFrame(columns=columns)

    df_instr = pd.concat(dfs_instr, ignore_index=True)
    df_tmp = df_tmp.merge(df_instr, on="strInstAladdin", how="left", suffixes=("", "_instr"))
    eligible_alpha = set(df_instr["strInstAladdin"])

    df_tmp.drop(columns=["strInstrumentTypeIRName"], inplace=True)
    df_tmp.rename(
        columns={"strInstrumentTypeIRName_instr": "strInstrumentTypeIRName"}, inplace=True
    )

    # Split delta adjustments to match SQL logic exactly

    # 1. First apply alpha adjustments (matching SQL's first UPDATE)
    alpha_df = df_delta[df_delta["strProdCd"] == -1].copy()
    alpha_df = alpha_df.rename(
        columns={
            "strInstrmtCd": "strInstAladdin",
            "numPortfGroupFkey": "numReportPortfGroupID",
            "numPtfFkey": "strPortfIDNumPart",
        }
    )

    # Handle null values to match SQL's isnull logic
    alpha_df["strPortfIDNumPart"] = alpha_df["strPortfIDNumPart"].fillna("-2").astype(str)
    df_tmp["strPortfIDNumPart"] = df_tmp["strPortfIDNumPart"].fillna("-2").astype(str)

    # Vectorized Alpha adjustments - replace iterrows() with merge
    alpha_df_filtered = alpha_df[alpha_df["numPosQty"].notna()].copy()

    if not alpha_df_filtered.empty:
        # Create merge keys for alpha
        alpha_df_filtered["merge_key"] = (
            alpha_df_filtered["strInstAladdin"].astype(str)
            + "|"
            + alpha_df_filtered["datPeriodLastDay"].astype(str)
            + "|"
            + alpha_df_filtered["numReportPortfGroupID"].astype(str)
            + "|"
            + alpha_df_filtered["strPortfIDNumPart"].astype(str)
        )

        df_tmp_alpha = df_tmp[
            df_tmp["strInstAladdin"].isin(eligible_alpha)
            & df_tmp["strInstAladdin"].isin(alpha_df_filtered["strInstAladdin"])
        ].copy()

        df_tmp_alpha["merge_key"] = (
            df_tmp_alpha["strInstAladdin"].astype(str)
            + "|"
            + df_tmp_alpha["datPeriodLastDay"].astype(str)
            + "|"
            + df_tmp_alpha["numReportPortfGroupID"].astype(str)
            + "|"
            + df_tmp_alpha["strPortfIDNumPart"].astype(str)
        )

        # Merge to get matching records
        merged_alpha = df_tmp_alpha.merge(
            alpha_df_filtered[["merge_key", "numDeltaAdjedNotionalValu", "numPosQty"]],
            on="merge_key",
            how="inner",
            suffixes=("", "_delta"),
        )

        if not merged_alpha.empty:
            # Calculate vectorized updates
            merged_alpha["new_numDeltaAdjustedSpread"] = (
                merged_alpha["numDeltaAdjedNotionalValu"]
                / merged_alpha["numPosQty"]
                * merged_alpha["numHoldQuantity"]
            )

            # Apply updates back to df_tmp
            df_tmp.loc[merged_alpha.index, "numDeltaAdjustedSpread"] = merged_alpha[
                "new_numDeltaAdjustedSpread"
            ]
            df_tmp.loc[merged_alpha.index, "OriginalQty"] = merged_alpha["numPosQty"]

    # 2. Vectorized DMC adjustments - replace iterrows() with merge
    dmc_df = df_delta[df_delta["strProdCd"] != -1].copy()
    dmc_df = dmc_df.rename(columns={"strInstrmtCd": "strInstAladdin", "strProdCd": "strPortfID"})

    # Handle null values for DMC
    df_tmp["strPortfID"] = df_tmp["strPortfID"].fillna("-2")

    dmc_df_filtered = dmc_df[dmc_df["numDeltaAdjedNotionalValu"] != 0].copy()

    if not dmc_df_filtered.empty:
        # Create merge keys for DMC
        dmc_df_filtered["merge_key"] = (
            dmc_df_filtered["strInstAladdin"].astype(str)
            + "|"
            + dmc_df_filtered["datPeriodLastDay"].astype(str)
            + "|"
            + dmc_df_filtered["strPortfID"].astype(str)
        )

        df_tmp["merge_key"] = (
            df_tmp["strInstAladdin"].astype(str)
            + "|"
            + df_tmp["datPeriodLastDay"].astype(str)
            + "|"
            + df_tmp["strPortfID"].astype(str)
        )

        # Merge to get matching records
        merged_dmc = df_tmp.merge(
            dmc_df_filtered[["merge_key", "numDeltaAdjedNotionalValu", "numPosQty"]],
            on="merge_key",
            how="inner",
            suffixes=("", "_delta"),
        )

        if not merged_dmc.empty:
            # Apply updates back to df_tmp
            df_tmp.loc[merged_dmc.index, "numDeltaAdjustedSpread"] = merged_dmc[
                "numDeltaAdjedNotionalValu"
            ]
            df_tmp.loc[merged_dmc.index, "OriginalQty"] = merged_dmc["numPosQty"]

    return df_tmp


@monitor_mem()
def aggregate_indicators(df: pd.DataFrame) -> pd.DataFrame:
    """
    Polars (eager) version of the aggregation. No .lazy().
    """
    final_cols = [
        "datPeriodLastDay",
        "numPortfGroupFKey",
        "strPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "datPeriodLastNav",
        "strCurrencyISOCode",
        "numInstrWeight",
        "numDurExposureInPortfCur",
        "numCurExposureInPortfCur",
        "numDurExposureWeight",
        "numCurExposureWeight",
        "numConvexityContrib",
        "numModifDurationContrib",
        "numMCDurationContrib",
        "numEffectDurationContrib",
        "numSpreadDurationContrib",
        "numConvexityContribWeight",
        "numModifDurationContribWeight",
        "numMCDurationContribWeight",
        "numEffectDurationContribWeight",
        "numSpreadDurationContribWeight",
        "numDeltaAdjustedSpread",
        "strPortfGroupFkey",
    ]
    if df.empty:
        return pd.DataFrame(columns=final_cols)

    keys = [
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "strInstISINCode",
    ]

    p = pl.from_pandas(df)
    print(
        "Read from pandas OK",
    )

    # Per-row columns - match SQL logic exactly
    p = p.with_columns(
        [
            # durExp: CASE WHEN delta!=0 AND qty!=0 THEN |qty|/|hold_qty|*delta ELSE amt
            # Match SQL: isnull(numDeltaAdjustedSpread, 0) <> 0
            pl.when(
                (pl.col("numDeltaAdjustedSpread").is_not_null() & (pl.col("numDeltaAdjustedSpread") != 0))
                & (pl.col("numHoldQuantity").is_not_null() & (pl.col("numHoldQuantity") != 0))
            )
            .then(
                pl.col("numWeightedQtqInReportPortf").abs()
                / pl.col("numHoldQuantity").abs()
                * pl.col("numDeltaAdjustedSpread")
            )
            .otherwise(pl.col("numWeightedAmtInReportPortf"))
            .alias("durExp"),
        ]
    )
    print(
        "durExp OK.",
    )

    # Group aggregation
    agg = p.group_by(keys).agg(
        [
            pl.col("datHoldDate").max().alias("datPeriodLastNav"),
            pl.col("strReportPortfISOCur").max().alias("strCurrencyISOCode"),
            pl.col("numReportPortfAUM").max().alias("maxAUM"),
            pl.col("numWeightedAmtInReportPortf").sum().alias("sumAmt"),
            pl.col("durExp").sum().alias("sumDurExp"),
            pl.col("curExp").sum().alias("sumCurExp"),
            pl.col("numInstConvexityAbs").max().alias("maxConvexity"),
            pl.col("numInstModifDuration").max().alias("maxModifDuration"),
            pl.col("numInstModifDuration").abs().max().alias("maxAbsModifDuration"),
            pl.col("numInstMCDuration").max().alias("maxMCDuration"),
            pl.col("numInstMCDuration").abs().max().alias("maxAbsMCDuration"),
            pl.col("numInstEffDuration").max().alias("maxEffDuration"),
            pl.col("numInstEffDuration").abs().max().alias("maxAbsEffDuration"),
            pl.col("numInstSpreadDuration").max().alias("maxSpreadDuration"),
            pl.col("numInstSpreadDuration").abs().max().alias("maxAbsSpreadDuration"),
            pl.col("strInstrumentTypeIRName").fill_null("").max().alias("maxInstrType"),
            pl.col("numDeltaAdjustedSpread").sum().alias("sumDelta"),
        ]
    )
    print(
        "Aggregation OK.",
    )

    # Weights, exposures
    agg = agg.with_columns(
        [
            # Match SQL: CASE WHEN max(numReportPortfAUM) <> 0 THEN ... ELSE 0 END
            pl.when(pl.col("maxAUM") != 0)
            .then(pl.col("sumAmt") / pl.col("maxAUM"))
            .otherwise(0)
            .alias("numInstrWeight"),
            pl.col("sumDurExp").alias("numDurExposureInPortfCur"),
            pl.col("sumCurExp").alias("numCurExposureInPortfCur"),
            pl.when(pl.col("maxAUM") != 0)
            .then(pl.col("sumDurExp") / pl.col("maxAUM"))
            .otherwise(0)
            .alias("numDurExposureWeight"),
            pl.when(pl.col("maxAUM") != 0)
            .then(pl.col("sumCurExp") / pl.col("maxAUM"))
            .otherwise(0)
            .alias("numCurExposureWeight"),
        ]
    )
    print(
        "Weights, exposures OK.",
    )

    # Contributions with SWAPS abs() rule
    agg = agg.with_columns(
        [
            (pl.col("numDurExposureWeight") * pl.col("maxConvexity")).alias("numConvexityContrib"),
            # Modified Duration - Match SQL: max(isnull(strInstrumentTypeIRName, '')) = 'Swaps'
            pl.when(pl.col("maxInstrType") == "Swaps")
            .then(pl.col("maxAbsModifDuration"))
            .otherwise(pl.col("maxModifDuration"))
            .alias("_md"),
        ],
    )

    agg = agg.with_columns(
        [
            (pl.col("numDurExposureWeight") * pl.col("_md")).alias("numModifDurationContrib"),
            # MC Duration
            pl.when(pl.col("maxInstrType") == "Swaps")
            .then(pl.col("maxAbsMCDuration"))
            .otherwise(pl.col("maxMCDuration"))
            .alias("_mcd"),
        ],
    )

    agg = agg.with_columns(
        [
            (pl.col("numDurExposureWeight") * pl.col("_mcd")).alias("numMCDurationContrib"),
            # Effective Duration
            pl.when(pl.col("maxInstrType") == "Swaps")
            .then(pl.col("maxAbsEffDuration"))
            .otherwise(pl.col("maxEffDuration"))
            .alias("_ed"),
        ],
    )

    agg = agg.with_columns(
        [
            (pl.col("numDurExposureWeight") * pl.col("_ed")).alias("numEffectDurationContrib"),
            # Spread Duration
            pl.when(pl.col("maxInstrType") == "Swaps")
            .then(pl.col("maxAbsSpreadDuration"))
            .otherwise(pl.col("maxSpreadDuration"))
            .alias("_sd"),
        ],
    )

    agg = agg.with_columns(
        [
            (pl.col("numDurExposureWeight") * pl.col("_sd")).alias("numSpreadDurationContrib"),
        ]
    ).drop(["_md", "_mcd", "_ed", "_sd"])
    print(
        "Weights, exposures OK.",
    )

    # Renames/extras for final schema
    agg = agg.with_columns(
        [
            pl.col("sumDelta").cast(pl.Float64).alias("numDeltaAdjustedSpread"),
            pl.col("numReportPortfGroupID").alias("numPortfGroupFKey"),
            pl.col("numReportPortfGroupID").cast(pl.Utf8).alias("strPortfGroupFkey"),
        ]
    )

    # Portfolio-level sums for contribution weights
    sums = agg.group_by(["datPeriodLastDay", "numPortfGroupFKey", "strReportPortfGPSCode"]).agg(
        [
            pl.col("numConvexityContrib").sum().alias("sumNumConvexityContrib"),
            pl.col("numModifDurationContrib").sum().alias("sumNumModifDurationContrib"),
            pl.col("numMCDurationContrib").sum().alias("sumNumMCDurationContrib"),
            pl.col("numEffectDurationContrib").sum().alias("sumNumEffectDurationContrib"),
            pl.col("numSpreadDurationContrib").sum().alias("sumNumSpreadDurationContrib"),
        ]
    )

    merged = agg.join(
        sums,
        on=["datPeriodLastDay", "numPortfGroupFKey", "strReportPortfGPSCode"],
        how="left",
    ).with_columns(
        [
            # Match SQL: CASE WHEN sq.sumConvexityContribWeight = 0 THEN 0 ELSE ... END
            pl.when(pl.col("sumNumConvexityContrib") == 0)
            .then(0)
            .otherwise(pl.col("numConvexityContrib") / pl.col("sumNumConvexityContrib"))
            .alias("numConvexityContribWeight"),
            pl.when(pl.col("sumNumModifDurationContrib") == 0)
            .then(0)
            .otherwise(pl.col("numModifDurationContrib") / pl.col("sumNumModifDurationContrib"))
            .alias("numModifDurationContribWeight"),
            pl.when(pl.col("sumNumMCDurationContrib") == 0)
            .then(0)
            .otherwise(pl.col("numMCDurationContrib") / pl.col("sumNumMCDurationContrib"))
            .alias("numMCDurationContribWeight"),
            pl.when(pl.col("sumNumEffectDurationContrib") == 0)
            .then(0)
            .otherwise(pl.col("numEffectDurationContrib") / pl.col("sumNumEffectDurationContrib"))
            .alias("numEffectDurationContribWeight"),
            pl.when(pl.col("sumNumSpreadDurationContrib") == 0)
            .then(0)
            .otherwise(pl.col("numSpreadDurationContrib") / pl.col("sumNumSpreadDurationContrib"))
            .alias("numSpreadDurationContribWeight"),
        ]
    )

    merged = merged.with_columns(
        [
            pl.col("strReportPortfGPSCode").alias("strPortfGPSCode"),
        ]
    )

    # Select in final order and convert back to pandas
    merged = merged.select(
        [
            "datPeriodLastDay",
            "numPortfGroupFKey",
            "strPortfGPSCode",
            "strInstAladdin",
            "numInstID",
            "datPeriodLastNav",
            "strCurrencyISOCode",
            "numInstrWeight",
            "numDurExposureInPortfCur",
            "numCurExposureInPortfCur",
            "numDurExposureWeight",
            "numCurExposureWeight",
            "numConvexityContrib",
            "numModifDurationContrib",
            "numMCDurationContrib",
            "numEffectDurationContrib",
            "numSpreadDurationContrib",
            "numConvexityContribWeight",
            "numModifDurationContribWeight",
            "numMCDurationContribWeight",
            "numEffectDurationContribWeight",
            "numSpreadDurationContribWeight",
            "numDeltaAdjustedSpread",
            "strPortfGroupFkey",
        ]
    )

    out = merged.to_pandas()
    return out[final_cols]


def _build_instruments_for_esg_scope_single(batch_idx, batch):
    session = get_session()
    try:
        print(f"Building instrument scope for {batch_idx}")
        query = session.query(
            DMIRBRSInstrument.numInstID,
            DMIRBRSInstrument.strInstIssuerCode,
            DMIRBRSInstrument.strinstrmttypcd,
        ).filter(DMIRBRSInstrument.numInstID.in_(batch))
        df_part = get_all_as_df(query)
        return df_part
    finally:
        session.close()


@monitor_mem()
def build_esg_scope(df_tmp_indicators: pd.DataFrame):

    # 1. Extract required fields from df_tmp_indicators
    df_scope = df_tmp_indicators[
        [
            "numPortfGroupFKey",
            "datPeriodLastDay",
            "strPortfGPSCode",
            "strInstAladdin",
            "numInstID",
            "numInstrWeight",
        ]
    ].drop_duplicates()

    # 2. Derive 'myKey' column
    df_scope["myKey"] = df_scope.apply(
        lambda row: (
            row["strPortfGPSCode"]
            if row["numPortfGroupFKey"] == -1
            else str(row["numPortfGroupFKey"])
        ),
        axis=1,
    )

    # 3. Prepare to batch query for instrument info from DB
    inst_ids = df_scope["numInstID"].dropna().unique().tolist()
    batches = [inst_ids[i : i + 1000] for i in range(0, len(inst_ids), 1000)]

    df_instruments = pd.DataFrame(columns=["numInstID", "strInstIssuerCode", "strinstrmttypcd"])

    with ProcessPoolExecutor(max_workers=128) as executor:
        futures = {
            executor.submit(_build_instruments_for_esg_scope_single, batch_idx, batch)
            for batch_idx, batch in enumerate(batches)
        }
        # wait for completion and propagate errors
        for future in as_completed(futures):
            df_part = future.result()
            df_instruments = pd.concat([df_instruments, df_part], ignore_index=True)

    # 4. Merge with df_scope
    df_esg_scope = df_scope.merge(df_instruments, on="numInstID", how="left")

    # 5. Rename and reorder columns
    df_esg_scope = df_esg_scope[
        [
            "myKey",
            "datPeriodLastDay",  # This is the reporting date
            "strInstAladdin",
            "numInstID",
            "strInstIssuerCode",
            "strinstrmttypcd",
            "numInstrWeight",
        ]
    ].rename(columns={"datPeriodLastDay": "datReportingDay"})

    return df_esg_scope


def _fetch_esg_ratings_single(chunk_id, reporting_day, inst_aladdins):
    session = get_session()
    reporting_day = reporting_day.strftime("%Y-%m-%d")
    try:
        print(f"ESG rating for row {chunk_id}")
        query = (
            session.query(
                # key columns
                DMIRBRSInstrument.strInstAladdin.label("strInstAladdin"),
                literal(reporting_day).label("datReportingDay"),
                # instrument‐rating standardized fields
                DMIRBRSInstRating.strInstRtgSPStandardized,
                DMIRBRSInstRating.strInstRtgMDStandardized,
                DMIRBRSInstRating.strInstRtgFHStandardized,
                # instrument‐rating custom fields
                DMIRBRSInstRating.strInstRtgCustom1,
                DMIRBRSInstRating.strInstRtgCustom2,
                DMIRBRSInstRating.strInstRtgCustom3,
                DMIRBRSInstRating.strInstRtgCustom4,
                DMIRBRSInstRating.strInstRtgCustom5,
                DMIRBRSInstRating.strInstRtgCustom6,
                DMIRBRSInstRating.strInstRtgCustom7,
                DMIRBRSInstRating.strInstRtgCustom8,
                DMIRBRSInstRating.strInstRtgCustom9,
                DMIRBRSInstRating.strInstRtgCustom10,
                DMIRBRSInstRating.strInstRtgCustom11,
                DMIRBRSInstRating.strInstRtgCustom12,
                DMIRBRSInstRating.strInstRtgCustom13,
                # issuer‐rating standardized fields
                DMIRBRSIssuerRating.strIssuerRtgSPStandardized,
                DMIRBRSIssuerRating.strIssuerRtgMDStandardized,
                DMIRBRSIssuerRating.strIssuerRtgFHStandardized,
                # issuer‐rating custom fields
                DMIRBRSIssuerRating.strIssuerRtgCustom1,
                DMIRBRSIssuerRating.strIssuerRtgCustom2,
                DMIRBRSIssuerRating.strIssuerRtgCustom3,
                DMIRBRSIssuerRating.strIssuerRtgCustom4,
                DMIRBRSIssuerRating.strIssuerRtgCustom5,
                DMIRBRSIssuerRating.strIssuerRtgCustom6,
                DMIRBRSIssuerRating.strIssuerRtgCustom7,
                DMIRBRSIssuerRating.strIssuerRtgCustom8,
                DMIRBRSIssuerRating.strIssuerRtgCustom9,
                DMIRBRSIssuerRating.strIssuerRtgCustom10,
                DMIRBRSIssuerRating.strIssuerRtgCustom11,
                DMIRBRSIssuerRating.strIssuerRtgCustom12,
                DMIRBRSIssuerRating.strIssuerRtgCustom13,
            )
            .select_from(DMIRBRSInstrument)
            .outerjoin(
                DMIRBRSInstRating,
                and_(
                    DMIRBRSInstRating.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                    DMIRBRSInstRating.datInstRtgDate == reporting_day,
                    DMIRBRSInstRating.strInstRtgVision == "M",
                ),
            )
            .outerjoin(
                DMIRBRSIssuerRating,
                and_(
                    DMIRBRSInstrument.strInstIssuerCode == DMIRBRSIssuerRating.strInstIssuerCode,
                    DMIRBRSIssuerRating.datIssuerRtgDate == reporting_day,
                    DMIRBRSIssuerRating.strIssuerRtgVision == "M",
                ),
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(inst_aladdins))
        )

        return get_all_as_df(query)
    finally:
        session.close()


def fetch_esg_ratings(
    df_ind: pd.DataFrame, df_esg: pd.DataFrame, scope: str, audit_id, max_workers=48
):
    df_esg = df_esg.dropna(subset=["strInstAladdin", "datReportingDay"])
    df_esg["datReportingDay"] = pd.to_datetime(df_esg["datReportingDay"])

    esg_columns = set(df_esg.columns)
    ind_columns = set(df_ind.columns)

    df_esg["myKey"] = df_esg["myKey"].astype(str)

    df_esg = df_ind.merge(
        df_esg,
        how="left",
        left_on=[
            "strPortfGPSCode" if scope == "DMC" else "strPortfGroupFkey",
            "strInstAladdin",
            "datPeriodLastDay",
        ],
        right_on=["myKey", "strInstAladdin", "datReportingDay"],
        suffixes=("", "_dup"),
    )

    if df_esg.empty:
        df_esg = pd.DataFrame(columns=list(esg_columns | ind_columns))

    print("numPortfGroupFKey unique", df_esg["numPortfGroupFKey"].unique())
    if scope == "DMC":
        df_esg = df_esg[df_esg["numPortfGroupFKey"] == -1]
    elif scope == "ALP":
        df_esg = df_esg[df_esg["numPortfGroupFKey"] != -1]

    df_esg_partition = df_esg.groupby(["datPeriodLastDay"])

    dfs = []
    for (reporting_day,), partition in df_esg_partition:
        print(f"Retrieving esg for {reporting_day}")
        inst_aladdins = partition["strInstAladdin"].unique().tolist()
        print(f"Number of instruments : {len(inst_aladdins)}")
        with ProcessPoolExecutor(max_workers=max_workers) as executor:
            futures = {
                executor.submit(_fetch_esg_ratings_single, chunk_idx, reporting_day, chunk)
                for chunk_idx, chunk in enumerate(chunker(inst_aladdins, 2000))
            }
            # wait for completion and propagate errors
            for future in as_completed(futures):
                res = future.result()
                dfs.append(res)

    rating_col_suffixes = ["SPStandardized", "MDStandardized", "FHStandardized"] + [
        f"Custom{i}" for i in range(1, 14)
    ]

    if len(dfs) > 0:
        df_result = pd.concat(dfs, ignore_index=True)
        for col in rating_col_suffixes:
            inst_col = f"strInstRtg{col}"
            iss_col = f"strIssuerRtg{col}"
            df_result[inst_col] = df_result.apply(
                lambda r: (
                    r[inst_col]
                    if (r[inst_col] if pd.notna(r[inst_col]) else "NR") != "NR"
                    else r[iss_col]
                ),
                axis=1,
            )
        df_result = df_result[
            ["datReportingDay", "strInstAladdin"]
            + [f"strInstRtg{col}" for col in rating_col_suffixes]
        ]
    else:
        df_result = pd.DataFrame(
            columns=["datReportingDay", "strInstAladdin", "datInstRtgDate"]
            + [f"strInstRtg{col}" for col in rating_col_suffixes]
        )

    for col in [
        "numInstPriceEarning",
        "numInstYldToWorst",
        "numInstBondFloor",
        "numInstContribActivRisk",
        "numInstContribTrackingError",
        "numInstRiskFactor",
        "numInstStressTestFactor",
    ]:
        df_result[col] = None

    df_result["datReportingDay"] = pd.to_datetime(df_result["datReportingDay"])

    # Merge into original ESG dataframe
    df_final = df_esg.merge(
        df_result,
        how="left",
        left_on=["strInstAladdin", "datReportingDay"],
        right_on=["strInstAladdin", "datReportingDay"],
        suffixes=("", "_dup"),
    )
    df_final["numAuditId"] = audit_id
    df_final["datModificationDate"] = get_date_from_audit_id(audit_id)

    return df_final


def _upsert_group_single(i, key_tuple, df_group, audit_id, retry=10):
    """
    Deletes existing rows for the key_tuple, then inserts all rows in df_group.
    key_tuple is:
      (datPeriodLastDay, numPortfGroupFKey, strPortfGPSCode, strInstAladdin)
    """
    session = get_session()
    # if i % 1000 == 0:
    #    print(f"Processing tuple {i}")
    try:
        dt, grp_fk, gps = key_tuple

        # 1) Delete existing rows for this key
        session.query(DMIRBRSLTPortfInstrIndicators).filter_by(
            datPeriodLastDay=dt,
            numPortfGroupFKey=int(grp_fk) if not pd.isna(grp_fk) else -1,
            strPortfGPSCode=gps,
        ).delete(synchronize_session=False)

        # 2) Insert new rows for this key
        mappings = []
        existed = {}
        for rec in df_group.to_dict(orient="records"):
            rec["numAuditId"] = audit_id
            for k, v in rec.items():
                if k == "numPortfGroupFKey" and pd.isna(v):
                    rec[k] = -1
                if isinstance(v, decimal.Decimal):
                    rec[k] = float(v)
                if v == "" or v == " " or pd.isna(v):
                    rec[k] = None
            if rec["strInstAladdin"] not in existed:
                mappings.append(rec)
                existed[rec["strInstAladdin"]] = 1

        # 3) Bulk insert
        if mappings:
            session.bulk_insert_mappings(DMIRBRSLTPortfInstrIndicators, mappings)

        session.commit()
        return len(mappings)
    except:
        if retry > 0:
            time.sleep(10)
            session.rollback()
            return _upsert_group_single(i, key_tuple, df_group, audit_id, retry=retry - 1)
        else:
            raise
    finally:
        session.close()


def final_upsert_instr_indicators(df_final, num_audit_id, max_workers=128):
    """
    Delete+insert on (datPeriodLastDay, numPortfGroupFKey, strPortfGPSCode)
    """
    # 1. Group by the four key columns
    key_cols = ["datPeriodLastDay", "numPortfGroupFKey", "strPortfGPSCode"]
    groups = list(df_final.groupby(key_cols))
    total_count = 0

    # 2. Dispatch parallel upserts
    with ProcessPoolExecutor(max_workers=128) as executor:
        futures = {
            executor.submit(_upsert_group_single, i, key, group_df, num_audit_id): i
            for i, (key, group_df) in enumerate(groups)
        }
        # wait for completion and propagate errors
        for future in as_completed(futures):
            inserted = future.result()
            if inserted is not None:
                total_count += inserted
                print(
                    f"[{futures[future]}] Inserted {inserted} records. Total inserted: {total_count}."
                )
    return total_count
