def compute_master_df_step_4_2_1(df_src: pd.DataFrame, inventory_level: int) -> pd.DataFrame:
    """
    Python port of the first half of stpDMIRLTTranspariz_Step4_2:
      - builds AUM (ROW_NUMBER() = 1 → MIN AUM per partition incl. datHoldDate)
      - builds Lyg (sum pct at level-1, keyed by period + (lvl + '.' + investedID))
      - for rows at *exactly* `inventory_level`, recomputes the four metrics
        and returns them ready to be merged back (update branch).
    """
    if df_src.empty:
        return pd.DataFrame(columns=df_src.columns)

    now = pd.Timestamp.utcnow()
    canonical_cols = df_src.columns.tolist()

    # ----------------------- master (only = inventory_level) -----------------------
    master = df_src[df_src["numInventoryLevel"] == inventory_level].copy()
    if master.empty:
        return pd.DataFrame(columns=df_src.columns)

    # ----------------------- AUM (ROW_NUMBER() = 1 over partition incl. datHoldDate)
    aum_grp_cols = [
        "strReportPortfHoldSrc",
        "strReportPeriod",
        "strReportPortfGPSCode",
        "numReportPortfGroupID",
        "strPortfID",
        "datHoldDate",
    ]
    aum = (
        df_src.sort_values("numPortfAUMInRptPtfCur", ascending=True)
        .drop_duplicates(subset=aum_grp_cols, keep="first")
        .loc[:, aum_grp_cols + ["numPortfAUMInRptPtfCur"]]
        .rename(columns={"strPortfID": "strInvestedInPortfID"})
    )

    # ----------------------- Lyg – level-1 pct -----------------------
    prev_level = inventory_level - 1
    lyg_raw = df_src[df_src["numInventoryLevel"] == prev_level].copy()
    lyg_raw["lookup_level"] = lyg_raw["strPortfLevelID"] + "." + lyg_raw["strInvestedInPortfID"]
    lyg = (
        lyg_raw.groupby(["strReportPeriod", "lookup_level"], as_index=False)
        .agg(numPctReportPortfInUndrlyg=("numPctReportPortfInUndrlyg", "sum"))
    )

    # ----------------------- join master ↔ AUM -----------------------
    merge_keys = [
        "strReportPortfHoldSrc",
        "strReportPeriod",
        "strReportPortfGPSCode",
        "numReportPortfGroupID",
        "strInvestedInPortfID",
    ]
    merged = pd.merge(master, aum, on=merge_keys, how="left", suffixes=("", "_aum"))

    # keep rows where NAV-date = AUM datHoldDate (SQL join condition)
    merged = merged[merged["datLastNAVDate"] == merged["datHoldDate"]].copy()
    if merged.empty:
        return pd.DataFrame(columns=df_src.columns)

    # ----------------------- reproduce LIKE join with prefixes -----------------------
    merged = merged.reset_index(drop=True)
    merged["orig_idx"] = merged.index
    merged["prefixes"] = (
        merged["strPortfLevelID"]
        .fillna("")
        .astype(str)
        .str.split("-")
        .map(lambda parts: ["-".join(parts[: i + 1]) for i in range(len(parts))])
    )
    exploded = merged.explode("prefixes")

    exploded = exploded.merge(
        lyg,
        left_on=["strReportPeriod", "prefixes"],
        right_on=["strReportPeriod", "lookup_level"],
        how="left",
        suffixes=("", "_lyg"),
    )
    # take the first non-null pct per original row (closest prefix)
    pct_series = (
        exploded.sort_values("prefixes")
        .groupby("orig_idx")["numPctReportPortfInUndrlyg"]
        .first()
    )
    merged["LygPct"] = merged["orig_idx"].map(pct_series)

    # ----------------------- recompute the four metrics -----------------------
    # HoldValueInReport = value * exrate (SQL uses ISNULL(exrate,1) in step 4.2 master CTE)
    merged["numPortfExRateInRptPtfCur"] = merged["numPortfExRateInRptPtfCur"].fillna(1)
    hold_val_rpt = merged["numHoldValueInPortfCur"] * merged["numPortfExRateInRptPtfCur"]

    denom = merged["numPortfAUMInRptPtfCur"]
    pct = np.where(
        denom.notna() & (denom != 0) & merged["LygPct"].notna(),
        hold_val_rpt * merged["LygPct"] / denom,
        np.nan,
    )

    merged["numHoldValueInReportPortfCur"] = hold_val_rpt
    merged["numPctReportPortfInUndrlyg"] = pct
    merged["numWeightedAmtInReportPortf"] = hold_val_rpt * merged["LygPct"]
    merged["numWeightedQtqInReportPortf"] = merged["numHoldQuantity"] * merged["LygPct"]
    merged["datLastModifDate"] = now

    # keep only columns that exist in table (no helper cols)
    keep_cols = canonical_cols
    return merged[keep_cols]


def process_step_4_2(df_tblDMIRTransparizLTWrk, df_update_branch, df_insert_branch):
    if df_tblDMIRTransparizLTWrk.empty:
        return df_tblDMIRTransparizLTWrk

    if df_update_branch.empty:
        df_update_branch = pd.DataFrame(columns=df_tblDMIRTransparizLTWrk.columns)

    join_keys = [
        "strReportPeriod",
        "numInventoryLevel",
        "strPortfLevelID",
        "strInvestedInInstrID",
        "strInvestedInPortfISOCur",
        "datHoldDate",
    ]

    chunk_size = 3_000_000
    nb_chunks = math.ceil(len(df_tblDMIRTransparizLTWrk) / chunk_size)
    chunks = [
        df_tblDMIRTransparizLTWrk[i * chunk_size : (i + 1) * chunk_size] for i in range(nb_chunks)
    ]
    cols = df_tblDMIRTransparizLTWrk.columns
    now = pd.Timestamp.utcnow()

    dfs = []
    for chunk in chunks:
        df = pd.merge(chunk, df_update_branch, on=join_keys, how="left", suffixes=("", "_upd"))

        update_cols = [
            "numHoldValueInReportPortfCur",
            "numPctReportPortfInUndrlyg",
            "numWeightedAmtInReportPortf",
            "numWeightedQtqInReportPortf",
        ]

        any_change = pd.Series(False, index=df.index)
        for col in update_cols:
            upd = f"{col}_upd"
            if upd not in df.columns:
                continue
            mask = df[upd].notnull() & (df[col].fillna(0) != df[upd].fillna(0))
            df.loc[mask, col] = df.loc[mask, upd]
            any_change |= mask

        # datLastModifDate: take df_update_branch's value if present, else set now for changed rows
        if "datLastModifDate_upd" in df.columns:
            df.loc[any_change, "datLastModifDate"] = df.loc[any_change, "datLastModifDate_upd"].fillna(now)
        else:
            df.loc[any_change, "datLastModifDate"] = now

        dfs.append(df[cols])

    df_final = pd.concat(dfs + [df_insert_branch], ignore_index=True)
    return df_final
