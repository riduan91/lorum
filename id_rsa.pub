import polars as pl
import numpy as np

def save_bench_parquet(df, task_name, description, mode="pandas", **kwargs):
    """Save DataFrame to parquet and push standard XComs with metadata."""
    
    # Construct filename
    data_file = get_data_folder(**kwargs) / f"{df.scope}_{task_name}.parquet"

    print(f"Saving parquet to {data_file}...")

    # Save DataFrame to parquet
    if mode == "pandas":
        df_clean = df.replace({np.nan: None})
        df_clean.to_parquet(data_file)
    elif mode == "polars":
        df_clean = df.fill_null(None)
        df_clean.write_parquet(data_file)

    # Push standard XComs
    kwargs["ti"].xcom_push(key="n_rows", value=len(df))

    if mode == "pandas":
        kwargs["ti"].xcom_push(
            key="examples",
            value=df_clean.head(N_ROWS_FOR_EXAMPLES).to_json(
                orient="records", date_format="iso"
            ),
        )
    elif mode == "polars":
        head_json = (
            df_clean.head(N_ROWS_FOR_EXAMPLES)
            .to_pandas()
            .to_json(orient="records", date_format="iso")
        )
        kwargs["ti"].xcom_push(key="examples", value=head_json)

    kwargs["ti"].xcom_push(key="description", value=description)

    # Return file path as string
    print("Save completed.")
    return str(data_file)
