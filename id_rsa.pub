@monitor_mem()
def load_base_portfolio(df_portf_instr_indicators: pd.DataFrame):
    """
    Creates the initial staging DataFrame of unique portfolio keys.
    """
    df_portf_indicators_wrk = (
        df_portf_instr_indicators[
            ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey", "strCurrencyISOCode"]
        ]
        .drop_duplicates()
        .reset_index(drop=True)
    )
    return df_portf_indicators_wrk


_ANALYTIC_COLS = [
    DMIRBRSInstAnalytic.numInstID,
    DMIRBRSInstAnalytic.datInstQuotationDate,
    DMIRBRSInstAnalytic.numInstYieldToMaturity,
    DMIRBRSInstAnalytic.numInstEffDuration,
    DMIRBRSInstAnalytic.numInstModifDuration,
    DMIRBRSInstAnalytic.numInstIRSensitivity,
    DMIRBRSInstAnalytic.numInstConvexity,
    DMIRBRSInstAnalytic.numInstSpreadDuration,
    DMIRBRSInstAnalytic.numInstGamma,
    DMIRBRSInstAnalytic.numInstDelta,
    DMIRBRSInstAnalytic.numInstVega,
    DMIRBRSInstAnalytic.numInstTheta,
    DMIRBRSInstAnalytic.numInstRho,
    DMIRBRSInstAnalytic.numInstMCDuration,
    DMIRBRSInstAnalytic.numInstPremium,
    DMIRBRSInstAnalytic.numInstYield,
    DMIRBRSInstAnalytic.numInstYieldToCall,
    DMIRBRSInstAnalytic.numyldtoworst,
    DMIRBRSInstAnalytic.numInstUndrlygPrice,
    DMIRBRSInstAnalytic.numCpnRatePaid,
    DMIRBRSInstAnalytic.numCpnRateRecv,
    DMIRBRSInstAnalytic.numInstMCDurationPaid,
    DMIRBRSInstAnalytic.numInstMCDurationRecv,
    DMIRBRSInstAnalytic.numInstModifDurationPaid,
    DMIRBRSInstAnalytic.numInstModifDurationRecv,
    DMIRBRSInstAnalytic.numInstYieldToMaturityPaid,
    DMIRBRSInstAnalytic.numInstYieldToMaturityRecv,
    DMIRBRSInstAnalytic.datCreationDate,
    DMIRBRSInstAnalytic.datModificationDate,
    DMIRBRSInstAnalytic.nummoddurtocall,
    DMIRBRSInstAnalytic.numVolAvg3M,
    DMIRBRSInstAnalytic.nummktcap,
    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
    DMIRBRSInstAnalytic.numBondFloor,
    DMIRBRSInstAnalytic.numInflationFctr,
    DMIRBRSInstAnalytic.numWAC,
    DMIRBRSInstAnalytic.numWAM,
    DMIRBRSInstAnalytic.numWAL,
    DMIRBRSInstAnalytic.numWALA,
    DMIRBRSInstAnalytic.numAuditId,
    DMIRBRSInstAnalytic.numExposureCoefficient,
    DMIRBRSInstAnalytic.numClosingPx,
    DMIRBRSInstAnalytic.strInstAladdin,
]


def _fetch_analytic_chunk(idx: int, chunk: list):
    """
    Worker: fetch analytics for this instrument chunk and *all*
    required quotation dates in one go.
    """
    print(f"[ANA] chunk {idx:>3} - instruments={len(chunk)}")
    session = get_session()
    try:
        q = session.query(*_ANALYTIC_COLS).filter(
            or_(
                *[
                    and_(
                        DMIRBRSInstAnalytic.strInstAladdin == inst,
                        DMIRBRSInstAnalytic.datInstQuotationDate == dat.strftime("%Y-%m-%d"),
                    )
                    for inst, dat in chunk
                ]
            )
        )
        df_part = get_all_as_df(q)
        return df_part
    finally:
        session.close()


@monitor_mem()
def fetch_analytics_parallel(df_instr: pd.DataFrame, max_workers: int = 24) -> pd.DataFrame:
    """
    Parallel version of the analytics pull: splits unique instruments
    """
    if df_instr.empty:
        return pd.DataFrame(columns=[c.key for c in _ANALYTIC_COLS])

    chunks = df_instr[["strInstAladdin", "datPeriodLastDay"]].drop_duplicates().values.tolist()

    dfs = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futs = {
            exe.submit(_fetch_analytic_chunk, idx, chunk): idx
            for idx, chunk in enumerate(chunker(chunks, 1_000))
        }
        for fut in as_completed(futs):
            dfs.append(fut.result())

    if dfs:
        return pd.concat(dfs, ignore_index=True)
    return pd.DataFrame(columns=[c.key for c in _ANALYTIC_COLS])


@monitor_mem()
def aggregate_exposure_duration(
    df_instr: pd.DataFrame,
    df_tmp: pd.DataFrame,
    *,
    analytic_workers: int = 24,
) -> pd.DataFrame:
    """
    * Fetches instrument analytics in parallel (see above).
    * Performs portfolio aggregation with pure Pandas/NumPy.
    * Overwrites the RG02/RG03/RG.. fields inside **df_tmp**.
    """
    if df_instr.empty:
        return df_tmp.copy()

    # 2‑A  merge analytics ---------------------------------------------------------
    df_ana = fetch_analytics_parallel(df_instr, max_workers=analytic_workers)

    joined = df_instr.merge(
        df_ana,
        left_on=["strInstAladdin", "datPeriodLastDay"],
        right_on=["strInstAladdin", "datInstQuotationDate"],
        how="left",
        suffixes=("", "_ana"),
    )

    # 2‑B  vector helpers ----------------------------------------------------------
    dur_w = joined["numDurExposureWeight"].astype(float).fillna(0.0)
    mod_w = joined["numModifDurationContribWeight"].astype(float).fillna(0.0)
    ytm = joined["numInstYieldToMaturity"].astype(float).fillna(0.0)
    cnvx = joined["numInstConvexity"].astype(float).fillna(0.0)
    oas = joined["numInstOptionAdjSpread"].astype(float).fillna(0.0)
    spr_dur = joined["numInstSpreadDuration"].astype(float).fillna(0.0)

    joined["w_YTM"] = np.where(joined["numDurExposureInPortfCur"] == 0, 0.0, ytm * dur_w)
    joined["w_Convexity"] = cnvx * dur_w
    joined["w_YTM_Dur"] = ytm * mod_w
    joined["w_OAS"] = oas * dur_w
    joined["w_DTS"] = oas * spr_dur * dur_w

    # 2‑C  group‑by aggregation ----------------------------------------------------
    gcols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    agg = (
        joined.groupby(gcols, sort=False, observed=True)
        .agg(
            numCurExposurePortf=("numCurExposureInPortfCur", "sum"),
            numDurExposurePortf=("numDurExposureInPortfCur", "sum"),
            numEffectDurationPortf=("numEffectDurationContrib", "sum"),
            numModifDurationPortf=("numModifDurationContrib", "sum"),
            numMCDurationPortf=("numMCDurationContrib", "sum"),
            numSpreadDurationPortf=("numSpreadDurationContrib", "sum"),
            numPtfAvgYTM=("w_YTM", "sum"),
            numPtfAvgConvexity=("w_Convexity", "sum"),
            numPtfAvgYTMDurWeighted=("w_YTM_Dur", "sum"),
            numPtfAvgOas=("w_OAS", "sum"),
            numPtfAvgDts=("w_DTS", "sum"),
        )
        .reset_index()
    )

    # 2‑D  merge back into staging --------------------------------------------------
    df = df_tmp.merge(
        agg,
        on=gcols,
        how="left",
        suffixes=("", "_new"),
    )

    repl_cols = [
        "numCurExposurePortf",
        "numDurExposurePortf",
        "numEffectDurationPortf",
        "numModifDurationPortf",
        "numMCDurationPortf",
        "numSpreadDurationPortf",
        "numPtfAvgYTM",
        "numPtfAvgConvexity",
        "numPtfAvgYTMDurWeighted",
        "numPtfAvgOas",
        "numPtfAvgDts",
    ]
    for c in repl_cols:
        if f"{c}_new" in df.columns:
            df[c] = df.pop(f"{c}_new")

    return df


def _fetch_instr_meta(chunk_id: int, aladdins: list[str]) -> pd.DataFrame:
    """Return coupon / maturity info for ≤2 000 instruments."""
    session = get_session()
    try:
        I = DMIRBRSInstrument
        q = session.query(
            I.strInstAladdin,
            I.numInstCouponRate,
            I.datInstMaturityDate,
            I.blncall,
            I.datInstCallDate,
        ).filter(I.strInstAladdin.in_(aladdins))
        return get_all_as_df(q)
    finally:
        session.close()


@monitor_mem()
def compute_maturity_coupon(
    df_instr: pd.DataFrame,  # indicators wrk (already contains weights)
    df_tmp: pd.DataFrame,  # staging table we update
    max_workers: int = 48,
) -> pd.DataFrame:
    """
    Re‑implements the SQL UPDATE that fills:
        • datPtfAvgMaturityLife
        • numPtfAvgCoupon
    """

    if df_instr.empty:
        return df_tmp.copy()

    # make sure date is datetime64[ns]
    df_instr["datPeriodLastDay"] = pd.to_datetime(df_instr["datPeriodLastDay"])

    # ---------------------------------- 1. load instrument meta in parallel
    uni = df_instr["strInstAladdin"].dropna().unique().tolist()
    meta_parts = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futs = {
            exe.submit(_fetch_instr_meta, i, chunk): i for i, chunk in enumerate(chunker(uni, 1000))
        }
        for fut in as_completed(futs):
            meta_parts.append(fut.result())

    if meta_parts:
        df_meta = pd.concat(meta_parts, ignore_index=True)
    else:  # nothing fetched → nothing to update
        return df_tmp.copy()

    # ---------------------------------- 2. vectorised join & calculations
    J = df_instr.merge(
        df_meta, on="strInstAladdin", how="left", validate="many_to_one", suffixes=("", "_meta")
    ).assign(
        numInstrWeight=lambda d: d["numInstrWeight"].fillna(0.0).astype(float),
        numInstCouponRate=lambda d: d["numInstCouponRate"].fillna(0.0).astype(float),
    )

    # choose call‑date when applicable, else maturity‑date
    J["matDate"] = np.where(
        (J["blncall"] == 1) & J["datInstCallDate"].notna(),
        J["datInstCallDate"],
        J["datInstMaturityDate"],
    )
    # weighted coupon
    J["wCoupon"] = J["numInstCouponRate"] * J["numInstrWeight"]

    # weighted maturity‑days
    J["daysDiff"] = (J["matDate"] - J["datPeriodLastDay"]).dt.days
    J["wMatDays"] = J["daysDiff"].fillna(0) * J["numInstrWeight"]

    key_cols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]

    agg = (
        J.groupby(key_cols, observed=True, sort=False)
        .agg(
            numPtfAvgCoupon=("wCoupon", "sum"),
            numPtfAvgMaturityLife=("wMatDays", "sum"),
        )
        .reset_index()
    )

    # ---------------------------------- 3. derive *date* column
    try:
        agg["datPtfAvgMaturityLife"] = np.where(
            (agg["numPtfAvgMaturityLife"] < 36500) & (agg["numPtfAvgMaturityLife"] > -100),
            agg["datPeriodLastDay"]
            + pd.to_timedelta(agg["numPtfAvgMaturityLife"].round().astype(int), unit="D"),
            pd.NaT,
        )
    except:
        agg["datPtfAvgMaturityLife"] = None

    # ---------------------------------- 4. merge into staging tmp table
    df_out = df_tmp.merge(
        agg[key_cols + ["numPtfAvgCoupon", "datPtfAvgMaturityLife"]],
        on=key_cols,
        how="left",
        suffixes=("", "_new"),
    )

    # overwrite / drop the *_new columns
    for c in ["numPtfAvgCoupon", "datPtfAvgMaturityLife"]:
        if f"{c}_new" in df_out.columns:
            df_out[c] = df_out.pop(f"{c}_new")

    return df_out


def _load_fi_chunks(chunk_idx: int, chunk: list[str]) -> pd.DataFrame:
    """Pulls coupon / maturity (Instrument) *and* analytic metrics for one chunk."""
    print(f"Loading chunk {chunk_idx}.")
    session = get_session()
    try:
        A = DMIRBRSInstAnalytic
        I = DMIRBRSInstrument
        IT = DMIRInstrumentIRType

        q = (
            session.query(
                I.strInstAladdin,
                I.numInstCouponRate,
                I.datInstMaturityDate,
                I.blncall,
                I.datInstCallDate,
                I.strInstIssuerCode,
                A.numInstYieldToMaturity,
                A.numInstConvexity,
                A.numInstOptionAdjSpread,
                A.numInstSpreadDuration,
                A.numInstEffDuration,
                A.numInstModifDuration,
                A.numInstMCDuration,
            )
            .join(
                IT,
                and_(
                    IT.numInstrTypeID == I.numInstTypeId,
                    IT.strReportingType == "class4",
                    IT.strInstrumentTypeIRName.in_(
                        ["Fixed Income", "Derivatives - Fixed Income", "MF - Fixed Income"]
                    ),
                ),
            )
            .outerjoin(
                A,
                and_(
                    A.strInstAladdin == I.strInstAladdin,
                    or_(
                        *[
                            # Use coalesce to match SQL: isnull(I.datPeriodLastNav, I.datPeriodLastDay)
                            A.datInstQuotationDate == analytics_date.strftime("%Y-%m-%d")
                            for inst, analytics_date in chunk
                        ]
                    ),
                ),
            )
            .filter(I.strInstAladdin.in_([inst for inst, _ in chunk]))
        )
        return get_all_as_df(q)
    finally:
        session.close()


def _pull_fi_metadata(df_instr: pd.DataFrame, max_workers: int = 32) -> pd.DataFrame:
    """Parallel fan‑out, fan‑in loader – returns one big dataframe.
    
    CRITICAL: Uses correct analytics date matching SQL logic: isnull(datPeriodLastNav, datPeriodLastDay)
    """
    # Prepare chunks with correct analytics date (coalesce logic)
    df_prep = df_instr[["strInstAladdin", "datPeriodLastDay", "datPeriodLastNav"]].drop_duplicates()
    df_prep["analytics_date"] = df_prep["datPeriodLastNav"].fillna(df_prep["datPeriodLastDay"])
    
    chunks = df_prep[["strInstAladdin", "analytics_date"]].values.tolist()
    if not chunks:
        return pd.DataFrame()

    dfs = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futs = {
            exe.submit(_load_fi_chunks, idx, chunk): idx
            for idx, chunk in enumerate(chunker(chunks, 1000))
        }
        for f in as_completed(futs):
            dfs.append(f.result())

    return pd.concat(dfs, ignore_index=True) if dfs else pd.DataFrame()


# -----------------------------------------------------------------------
# 2)  vectorised aggregation   (faithful to the SQL SELECT  X   CTE)
# -----------------------------------------------------------------------
@monitor_mem()
def compute_fi_weighted_metrics(
    df_instr: pd.DataFrame, df_tmp: pd.DataFrame, max_workers: int = 32
) -> pd.DataFrame:
    df_instr = df_instr[df_instr["numDurExposureInPortfCur"].notna()].copy()
    if df_instr.empty:
        return df_tmp  # nothing to update

    df_meta = _pull_fi_metadata(df_instr, max_workers=max_workers)
    df_join = df_instr.merge(df_meta, on="strInstAladdin", how="inner", suffixes=("", "_meta"))

    # helper weights (all already float)
    w_dur = df_join["numDurExposureWeight"].fillna(0).astype(float)
    w_dur_mod = df_join["numModifDurationContribWeight"].fillna(0).astype(float)
    w_instr = df_join["numInstrWeight"].fillna(0).astype(float)

    df_join = df_join.assign(
        w_coupon=df_join["numInstCouponRate"].fillna(0).astype(float) * w_instr,
        w_ytm=df_join["numInstYieldToMaturity"].fillna(0).astype(float) * w_dur,
        w_convexity=df_join["numInstConvexity"].fillna(0).astype(float) * w_dur,
        w_ytm_dur_w=df_join["numInstYieldToMaturity"].fillna(0).astype(float) * w_dur_mod,
        w_oas=df_join["numInstOptionAdjSpread"].fillna(0).astype(float) * w_dur,
        w_dts=(
            df_join["numInstOptionAdjSpread"].fillna(0).astype(float)
            * df_join["numInstSpreadDuration"].fillna(0).astype(float)
            * w_dur
        ),
        w_maturity_days=(
            # Match SQL logic exactly:
            # CASE WHEN Instrument.datInstMaturityDate <= I.datPeriodLastDay THEN 0
            #      WHEN Instrument.blncall = 1 AND Instrument.datInstCallDate IS NOT NULL 
            #           THEN DATEDIFF(DAY, I.datPeriodLastDay, Instrument.datInstCallDate)
            #      ELSE DATEDIFF(DAY, I.datPeriodLastDay, Instrument.datInstMaturityDate) END
            np.where(
                df_join["datInstMaturityDate"] <= df_join["datPeriodLastDay"],
                0,  # Maturity already passed
                np.where(
                    (df_join["blncall"].fillna(0) == 1) & df_join["datInstCallDate"].notna(),
                    (df_join["datInstCallDate"] - df_join["datPeriodLastDay"]).dt.days,
                    (df_join["datInstMaturityDate"] - df_join["datPeriodLastDay"]).dt.days,
                )
            ) * w_instr
        ),
    )

    # ------------------------------------------------------------------
    # group‑by portfolio key & sum
    # ------------------------------------------------------------------
    gcols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    agg = (
        df_join.groupby(gcols, sort=False, observed=True)
        .agg(
            numEffectDurationPortfFI=("numEffectDurationContrib", "sum"),
            numModifDurationPortfFI=("numModifDurationContrib", "sum"),
            numMCDurationPortfFI=("numMCDurationContrib", "sum"),
            numSpreadDurationPortfFI=("numSpreadDurationContrib", "sum"),
            numPtfAvgCouponFI=("w_coupon", "sum"),
            numPtfAvgYTMFI=("w_ytm", "sum"),
            numPtfAvgConvexityFI=("w_convexity", "sum"),
            numPtfAvgYTMDurWeightedFI=("w_ytm_dur_w", "sum"),
            numPtfAvgMaturityLife_sum=("w_maturity_days", "sum"),
            numPtfAvgOasFI=("w_oas", "sum"),
            numPtfAvgDtsFI=("w_dts", "sum"),
            sumNumInstrWeight=("numInstrWeight", "sum"),
            numNumberOfIssuersFI=("strInstIssuerCode", "nunique"),
        )
        .reset_index()
    )

    # ------------------------------------------------------------------
    # divide by weight where required  +   maturity date
    # ------------------------------------------------------------------
    denom = agg["sumNumInstrWeight"].replace({0: np.nan})

    for col in [
        "numEffectDurationPortfFI",
        "numModifDurationPortfFI",
        "numMCDurationPortfFI",
        "numSpreadDurationPortfFI",
        "numPtfAvgCouponFI",
        "numPtfAvgYTMFI",
        "numPtfAvgConvexityFI",
        "numPtfAvgYTMDurWeightedFI",
        "numPtfAvgOasFI",
        "numPtfAvgDtsFI",
    ]:
        agg[col] = agg[col] / denom

    # maturity: only if (days / weight) is in a realistic range AND > 0
    # Match SQL: WHEN (X.numPtfAvgMaturityLife / X.sumNumInstrWeight) > 0
    days_adj = agg["numPtfAvgMaturityLife_sum"] / denom
    ok = days_adj.between(-100, 36500) & (days_adj > 0)  # Added > 0 condition like SQL
    agg["datPtfAvgMaturityLifeFI"] = np.where(
        ok,
        agg["datPeriodLastDay"] + pd.to_timedelta(days_adj.round().astype("Int64"), unit="D"),
        pd.NaT,
    )

    # ------------------------------------------------------------------
    # merge back into tmp, overwrite 11 target cols
    # ------------------------------------------------------------------
    df_out = df_tmp.merge(
        agg.drop(columns="numPtfAvgMaturityLife_sum"), on=gcols, how="left", suffixes=("", "_y")
    )

    cols_to_patch = [
        "numEffectDurationPortfFI",
        "numModifDurationPortfFI",
        "numMCDurationPortfFI",
        "numSpreadDurationPortfFI",
        "numPtfAvgCouponFI",
        "numPtfAvgYTMFI",
        "numPtfAvgConvexityFI",
        "numPtfAvgYTMDurWeightedFI",
        "datPtfAvgMaturityLifeFI",
        "numPtfAvgOasFI",
        "numNumberOfIssuersFI",
        "numPtfAvgDtsFI",
    ]
    # rename_map = {c: f"{c}_y" for c in cols_to_patch}  # pandas merge suffix

    for c in cols_to_patch:
        if f"{c}_y" in df_out.columns:
            df_out[c] = df_out[f"{c}_y"]
            df_out.drop(columns=f"{c}_y", inplace=True)

    return df_out


def _fetch_existing_valid_instruments(chunk_id: int, aladdins: list[str]) -> pd.DataFrame:
    """
    Return instruments that:
    1. Exist in DMIRBRSInstrument table (INNER JOIN equivalent)
    2. Are NOT Cash (class4) or Forex (class7) types
    
    This matches the SQL logic exactly:
    INNER JOIN DMIR.tblDMIRBRSInstrument Instrument ON Instrument.strInstAladdin = I.strInstAladdin
    WHERE Instrument.numInstTypeId NOT IN (excluded types)
    """
    session = get_session()
    try:
        IT = DMIRInstrumentIRType
        Ins = DMIRBRSInstrument

        # First get the excluded type IDs
        excluded_types_q = session.query(IT.numInstrTypeID).filter(
            or_(
                and_(IT.strReportingType == "class4", IT.strInstrumentTypeIRName == "Cash"),
                and_(IT.strReportingType == "class7", IT.strInstrumentTypeIRName == "Forex"),
            )
        ).distinct()
        
        excluded_type_ids = [row[0] for row in excluded_types_q.all()]

        # Then get instruments that exist AND are not excluded types
        # This matches the SQL INNER JOIN + WHERE logic
        q = session.query(Ins.strInstAladdin).filter(
            Ins.strInstAladdin.in_(aladdins),
            ~Ins.numInstTypeId.in_(excluded_type_ids) if excluded_type_ids else True
        )

        return get_all_as_df(q)  # one col: strInstAladdin
    finally:
        session.close()


@monitor_mem()
def count_holdings(
    df_wrk: pd.DataFrame, df_tmp: pd.DataFrame, max_workers: int = 48
) -> pd.DataFrame:
    """
    Re‑implements the SQL block that sets  numHoldingsNumber  (RG22).

    Parameters
    ----------
    df_wrk : dataframe with all rows from DMIR.tblDMIRBRSLTPortfInstrIndicatorsWrk
             (must contain at least strInstAladdin + the three key columns)
    df_tmp : staging dataframe that already contains the columns from
             #tmpPortfIndicatorsWrk.  It will receive / overwrite the
             column *numHoldingsNumber*.
    """
    # ------------------------------------------------------------------
    # A. Pull instrument *filter* (parallel, DB)
    # ------------------------------------------------------------------
    inst_codes = df_wrk["strInstAladdin"].dropna().unique().tolist()
    allowed_codes = []

    with ProcessPoolExecutor(max_workers=max_workers) as pool:
        futures = {
            pool.submit(_fetch_existing_valid_instruments, idx, chunk): idx
            for idx, chunk in enumerate(chunker(inst_codes, 2_000))
        }
        for fut in as_completed(futures):
            allowed_codes.append(fut.result())

    if allowed_codes:
        df_allowed = pd.concat(allowed_codes, ignore_index=True)
        allowed_set = set(df_allowed["strInstAladdin"]) if not df_allowed.empty else set()
    else:
        # nothing survives the INNER JOIN filter ⇒ no holdings will be counted
        allowed_set = set()

    # ------------------------------------------------------------------
    # B. Compute the DISTINCT count per (day, code, fkey)
    # Only count instruments that passed the INNER JOIN filter
    # ------------------------------------------------------------------
    mask = df_wrk["strInstAladdin"].isin(allowed_set)
    grp_cols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]

    df_nr = (
        df_wrk.loc[mask, grp_cols + ["strInstAladdin"]]
        .drop_duplicates()
        .groupby(grp_cols, observed=True)["strInstAladdin"]
        .nunique()
        .reset_index(name="numHoldingsNumber")  # <-- “nr” in SQL
    )

    # ------------------------------------------------------------------
    # C. Merge into tmp and overwrite  numHoldingsNumber
    # ------------------------------------------------------------------
    df_out = df_tmp.merge(
        df_nr,
        on=grp_cols,
        how="left",
        suffixes=("", "_nr"),
    )

    if "numHoldingsNumber_nr" in df_out.columns:
        df_out["numHoldingsNumber"] = df_out["numHoldingsNumber_nr"]
        df_out.drop(columns="numHoldingsNumber_nr", inplace=True)

    return df_out


def _load_rating_maps(session) -> dict[str, dict[int, str]]:
    """Return {'SP': {num→str}, 'MOODY': {...}, 'FITCH': {...}, 'SP_c1': {...}, … }"""
    IT = DMIRRatingIREvaluation
    rows = session.query(
        IT.strRatingAgency,
        IT.numRatingValue,
        IT.strRatingValue,
    ).all()

    maps: dict[str, dict[int, str]] = {}
    for ag, num, txt in rows:
        if ag not in maps:
            maps[ag] = {}
        maps[ag][int(num)] = txt

    for i in range(1, 14):
        maps[f"C{i}"] = maps["SP"].copy()
    return maps


def _fetch_ratings_chunk(chunk_id: int, aladdins: list[str], day: pd.Timestamp) -> pd.DataFrame:
    """Return numeric ratings for *aladdins* on *day*."""
    session = get_session()
    try:
        IR = DMIRBRSInstRating

        cols_sql = [
            IR.strInstAladdin,
            IR.strInstRtgSPStandardized.label("SP"),
            IR.strInstRtgMDStandardized.label("MOODY"),
            IR.strInstRtgFHStandardized.label("FITCH"),
        ] + [getattr(IR, f"strInstRtgCustom{i}").label(f"C{i}") for i in range(1, 14)]

        q = session.query(*cols_sql).filter(
            IR.strInstAladdin.in_(aladdins),
            IR.datInstRtgDate == day.strftime("%Y-%m-%d"),
            IR.strInstRtgVision == "M",
        )
        return get_all_as_df(q)
    finally:
        session.close()


@monitor_mem()
def compute_average_rating(
    df_instr: pd.DataFrame, df_tmp: pd.DataFrame, max_workers: int = 48
) -> pd.DataFrame:

    if df_instr.empty:
        return df_tmp

    # --- distinct (day, code, fkey) & instrument universe -------------
    key_cols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    df_instr["datPeriodLastDay"] = pd.to_datetime(df_instr["datPeriodLastDay"])
    all_days = df_instr["datPeriodLastDay"].unique()
    inst_universe = df_instr["strInstAladdin"].dropna().unique().tolist()

    # --- load rating ↔ numeric maps once ------------------------------
    with get_session() as s:
        rating_maps = _load_rating_maps(s)  # e.g. maps['SP'][1] = 'AAA'

    # --- fetch ratings in parallel ------------------------------------
    fetched = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_fetch_ratings_chunk, idx, chunk, day): (idx, day)
            for day in all_days
            for idx, chunk in enumerate(chunker(inst_universe, 2_000))
        }
        for fut in as_completed(futures):
            fetched.append(fut.result())

    if not fetched:  # nothing came back
        return df_tmp

    df_rate = pd.concat(fetched, ignore_index=True)

    # melt → long ‑> (Aladdin, Agency, numVal)
    df_long = df_rate.melt(
        id_vars="strInstAladdin",
        var_name="Agency",
        value_name="RatingStr",
    ).dropna(subset=["RatingStr"])

    # map rating→numeric ( vectorised with replace )
    numeric_maps = {ag: {v: k for k, v in mp.items()} for ag, mp in rating_maps.items()}
    df_long["RatingNum"] = df_long.apply(
        lambda r: numeric_maps.get(r["Agency"], {}).get(r["RatingStr"]), axis=1
    )

    # join weights
    df_join = (
        df_instr[key_cols + ["strInstAladdin", "numInstrWeight"]]
        .merge(df_long, on="strInstAladdin", how="inner")
        .dropna(subset=["RatingNum"])
    )

    # weighted averages per group × agency
    df_join["wRated"] = df_join["RatingNum"].astype(float) * df_join["numInstrWeight"]
    avg = (
        df_join.groupby(key_cols + ["Agency"], observed=True)
        .agg(
            sum_w=("numInstrWeight", "sum"),
            sum_wr=("wRated", "sum"),
        )
        .reset_index()
    )
    avg["AvgNum"] = (avg["sum_wr"] / avg["sum_w"]).round().astype("Int64")

    # map numeric→rating string
    avg["AvgRating"] = avg.apply(
        lambda r: rating_maps.get(r["Agency"], {}).get(
            int(r["AvgNum"]) if pd.notna(r["AvgNum"]) else -100, None
        ),
        axis=1,
    )

    # pivot wide
    df_wide = avg.pivot_table(
        index=key_cols,
        columns="Agency",
        values="AvgRating",
        aggfunc="first",
    ).reset_index()
    # rename to target column names
    rename_map = {
        "SP": "strPtfAvgRtgSP",
        "MOODY": "strPtfAvgRtgMD",
        "FITCH": "strPtfAvgRtgFH",
        **{f"C{i}": f"strPtfAvgRtgCustom{i}" for i in range(1, 14)},
    }
    df_wide = df_wide.rename(columns=rename_map)

    # --- merge back into tmp ------------------------------------------
    df_out = df_tmp.merge(df_wide, on=key_cols, how="left")

    return df_out


@monitor_mem()
def compute_esg_aggregates(df_instr: pd.DataFrame, df_tmp: pd.DataFrame):
    esg_cols = [
        col for col in df_instr.columns if col.startswith("numESG") or col.startswith("numCO2")
    ]
    df_X = df_instr.groupby(
        ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"], as_index=False
    )[esg_cols].sum()

    if df_X.empty:
        df_X = pd.DataFrame(
            columns=["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"] + esg_cols
        )
        normalize_type(df_X)

    df_merged = df_tmp.merge(
        df_X, on=["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"], how="left"
    )

    return df_merged


@monitor_mem()
def compute_esg_engagement(df_instr: pd.DataFrame, df_tmp: pd.DataFrame):
    # 2. Filter valid engagement rows - match SQL WHERE clause exactly
    cols = ["numESGKPIEngmtEnv", "numESGKPIEngmtSocial", "numESGKPIEngmtGov"]
    df_valid = df_instr.dropna(subset=cols)

    # 3. Two-level aggregation to match SQL exactly
    # First level: Group by portfolio + issuer, take MAX per issuer (like SQL)
    df_valid["strESGKPIEngmtRcoIssrCd"] = df_valid["strESGKPIEngmtRcoIssrCd"].fillna("")
    
    df_first_agg = df_valid.groupby(
        ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey", "strESGKPIEngmtRcoIssrCd"], 
        as_index=False
    ).agg(
        numESGKPIEngmtEnv=("numESGKPIEngmtEnv", "max"),
        numESGKPIEngmtSocial=("numESGKPIEngmtSocial", "max"), 
        numESGKPIEngmtGov=("numESGKPIEngmtGov", "max"),
        numESGKPIEngmtNumMeetings=("numESGKPIEngmtNumMeetings", "max"),
    )
    
    # Second level: Group by portfolio, take SUM of max values + COUNT of issuers
    df_grouped = df_first_agg.groupby(
        ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"], as_index=False
    ).agg(
        numESGKPIEngmtGlob=("strESGKPIEngmtRcoIssrCd", "nunique"),
        numESGKPIEngmtEnv=("numESGKPIEngmtEnv", "sum"),
        numESGKPIEngmtSocial=("numESGKPIEngmtSocial", "sum"),
        numESGKPIEngmtGov=("numESGKPIEngmtGov", "sum"),
        numESGKPIEngmtNumMeetings=("numESGKPIEngmtNumMeetings", "sum"),
    )

    for c in ["numESGKPIEngmtEnv", "numESGKPIEngmtSocial", "numESGKPIEngmtGov"]:
        df_grouped[f"{c}_tmp"] = df_grouped[c]

    total = (
        df_grouped["numESGKPIEngmtEnv_tmp"]
        + df_grouped["numESGKPIEngmtSocial_tmp"]
        + df_grouped["numESGKPIEngmtGov_tmp"]
    )
    for c in ["numESGKPIEngmtEnv", "numESGKPIEngmtSocial", "numESGKPIEngmtGov"]:
        df_grouped[c] = np.where(total.fillna(0) == 0, 0.0, df_grouped[f"{c}_tmp"] / total)
    df_grouped["numESGKPIAllTypEngmt"] = np.where(
        total.fillna(0) == 0, 0, df_grouped["numESGKPIEngmtGlob"]
    )

    # 5. Merge back into staging DataFrame
    df_merged = df_tmp.merge(
        df_grouped,
        on=["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"],
        how="left",
        suffixes=("_raw", ""),
    )
    df_merged.drop(
        columns=[c for c in df_merged.columns if "_raw" in c or "_tmp" in c], inplace=True
    )
    return df_merged


def _get_esg_voting_single(i, dat, code, fkey):
    session = get_session()
    try:
        print(f"_get_esg_voting_single for {i}, {dat}, {code}, {fkey}")
        dat = pd.to_datetime(dat)
        year = dat.year

        # 2a. Latest vote date in same year
        max_vote_date = (
            session.query(func.max(DWGNProductVote.datVoteValuDt))
            .filter(
                DWGNProductVote.strProdCd == code,
                DWGNProductVote.strVoteValuDtRng == "Y",
                DWGNProductVote.strProdVoteOrigin != "Std",
                extract("year", DWGNProductVote.datVoteValuDt) == year,
            )
            .scalar()
        )

        if not max_vote_date:
            return {
                **{"datPeriodLastDay": dat, "strPortfGPSCode": code, "numPortfGroupFKey": fkey},
                **{
                    col: 0
                    for col in [
                        "numNumMeetingsVoted",
                        "numPctgMeetingsVotedWithResv",
                        "numPctgMeetingsVotedFor",
                        "numNumItemsVoted",
                        "numPctgVotesFor",
                        "numPctgVotesAbstain",
                        "numPctgVotesAgainst",
                        "numPctgVotesWithhold",
                    ]
                },
            }

        # 2b. Latest extractionTS for that vote date
        max_extraction = (
            session.query(func.max(DWGNProductVote.datExtractionTS))
            .filter(
                DWGNProductVote.strProdCd == code, DWGNProductVote.datVoteValuDt == max_vote_date
            )
            .scalar()
        )

        # 3. Fetch vote record
        vote = (
            session.query(DWGNProductVote)
            .filter(
                DWGNProductVote.strProdCd == code,
                DWGNProductVote.datVoteValuDt == max_vote_date,
                DWGNProductVote.datExtractionTS == max_extraction,
            )
            .order_by(DWGNProductVote.datExtractionTS.desc())
            .first()
        )

        if not vote:
            return {
                **{"datPeriodLastDay": dat, "strPortfGPSCode": code, "numPortfGroupFKey": fkey},
                **{
                    col: 0
                    for col in [
                        "numNumMeetingsVoted",
                        "numPctgMeetingsVotedWithResv",
                        "numPctgMeetingsVotedFor",
                        "numNumItemsVoted",
                        "numPctgVotesFor",
                        "numPctgVotesAbstain",
                        "numPctgVotesAgainst",
                        "numPctgVotesWithhold",
                    ]
                },
            }

        # 4. Compute metrics
        n_items = vote.numNumItemsVoted or 0
        pct_for = (vote.numNumVotesFor or 0) / n_items if n_items else 0.0
        pct_abstain = (vote.numNumVotesAbstain or 0) / n_items if n_items else 0.0
        pct_against = (vote.numNumVotesAgainst or 0) / n_items if n_items else 0.0
        pct_withhold = (vote.numNumVotesWithhold or 0) / n_items if n_items else 0.0
        pct_meet_withresv = vote.numPctgMeetingsVotedWithResv or 0.0

        return {
            "datPeriodLastDay": dat,
            "strPortfGPSCode": code,
            "numPortfGroupFKey": fkey,
            "numNumMeetingsVoted": vote.numNumMeetingsVoted or 0,
            "numPctgMeetingsVotedWithResv": pct_meet_withresv,
            "numPctgMeetingsVotedFor": 1.0 - pct_meet_withresv,
            "numNumItemsVoted": n_items,
            "numPctgVotesFor": pct_for,
            "numPctgVotesAbstain": pct_abstain,
            "numPctgVotesAgainst": pct_against,
            "numPctgVotesWithhold": pct_withhold,
        }
    finally:
        session.close()


@monitor_mem()
def compute_esg_voting(df_instr: pd.DataFrame, df_tmp: pd.DataFrame, max_workers=48):
    # 1. Extract distinct key tuples
    keys = (
        df_tmp[["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]]
        .drop_duplicates()
        .to_records(index=False)
    )

    records = []
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        futures = {
            executor.submit(_get_esg_voting_single, i, dat, code, fkey): i
            for i, (dat, code, fkey) in enumerate(keys)
        }
        for future in as_completed(futures):
            rec = future.result()
            records.append(rec)

    # 5. Build results DataFrame
    df_X = pd.DataFrame(
        records,
        columns=[
            "datPeriodLastDay",
            "strPortfGPSCode",
            "numPortfGroupFKey",
            "numNumMeetingsVoted",
            "numPctgMeetingsVotedWithResv",
            "numPctgMeetingsVotedFor",
            "numNumItemsVoted",
            "numPctgVotesFor",
            "numPctgVotesAbstain",
            "numPctgVotesAgainst",
            "numPctgVotesWithhold",
        ],
    )
    if df_X.empty:
        normalize_type(df_X)

    # 6. Merge into staging DataFrame
    df_merged = df_tmp.merge(
        df_X, on=["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"], how="left"
    )
    return df_merged


def delete_task(key):
    session = get_session()
    dat, code, fkey = key
    dat = pd.to_datetime(dat)
    fkey = int(fkey)
    deleted = (
        session.query(DMIRBRSLTPortfIndicators)
        .filter(
            DMIRBRSLTPortfIndicators.datPeriodLastDay == dat,
            DMIRBRSLTPortfIndicators.strPortfGPSCode == code,
            DMIRBRSLTPortfIndicators.numPortfGroupFkey == fkey,
        )
        .delete(synchronize_session=False)
    )
    session.commit()
    session.close()
    return deleted


# Define insert task
def insert_task(group):
    session = get_session()
    records = group.to_dict(orient="records")
    for rec in records:
        for k, v in rec.items():
            if isinstance(v, decimal.Decimal):
                rec[k] = float(v)
            elif k == "strPortfGPSCode" and pd.isna(v):
                rec[k] = "NA"
            elif v == "" or v == " " or pd.isna(v):
                rec[k] = None
        if "numPortfGroupFkey" not in rec:
            rec["numPortfGroupFkey"] = rec["numPortfGroupFKey"] or -1
        if "strReportPortfHoldSrc" not in rec:
            rec["strReportPortfHoldSrc"] = "MA" if rec["numPortfGroupFkey"] != -1 else "DMC"
    records = [
        rec for rec in records if rec["numPortfGroupFkey"] != -1 or rec["strPortfGPSCode"] != "NA"
    ]
    session.bulk_insert_mappings(DMIRBRSLTPortfIndicators, records)
    session.commit()
    session.close()
    return True


@monitor_mem()
def upsert_indicators_table(df_working: pd.DataFrame, audit_id: str, max_workers: int = 48):
    df_working["numAuditId"] = int(audit_id)
    # 1. Unique key tuples
    keys_df = df_working[
        ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    ].drop_duplicates()
    key_tuples = [tuple(x) for x in keys_df.to_records(index=False)]

    # Define delete task
    # 2. Parallel delete
    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        delete_futures = [executor.submit(delete_task, key) for key in key_tuples]
        for future in as_completed(delete_futures):
            res = future.result()  # propagate exceptions

            print(f"Deleted {res} records.")

        # 3. Parallel insert: group df_working by keys
        grouped = df_working.groupby(["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"])
        insert_futures = [executor.submit(insert_task, group) for _, group in grouped]
        for future in as_completed(insert_futures):
            future.result()  # propagate exceptions

            print("Inserted records for key.")
