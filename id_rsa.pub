
# Get common columns with types
def get_shared_columns_with_types(engine, table_legacy: str, table_python: str):
    insp = inspect(engine)
    cols_legacy = {c["name"]: c["type"].__class__.__name__.lower() for c in insp.get_columns(table_legacy.split('.')[-1], schema=table_legacy.split('.')[0])}
    cols_python = {c["name"]: c["type"].__class__.__name__.lower() for c in insp.get_columns(table_python.split('.')[-1], schema=table_python.split('.')[0])}
    shared = set(cols_legacy).intersection(cols_python)
    return [(col, cols_legacy[col]) for col in shared]

# Column diffs with float tolerance
def fetch_column_diffs(session, pair: dict, compare_cols_with_types: list) -> pd.DataFrame:
    legacy = pair["legacy"]
    python = pair["python"]
    group_by = pair["group_cols"]

    comparisons = []
    for col, coltype in compare_cols_with_types:
        if any(t in coltype for t in FLOAT_TYPES):
            clause = f"SUM(CASE WHEN ABS(ISNULL(a.{col}, 0) - ISNULL(b.{col}, 0)) > {FLOAT_TOLERANCE} THEN 1 ELSE 0 END) AS {col}"
        else:
            clause = f"SUM(CASE WHEN ISNULL(a.{col}, '') <> ISNULL(b.{col}, '') THEN 1 ELSE 0 END) AS {col}"
        comparisons.append(clause)

    sql = f"""
    SELECT {', '.join(comparisons)}
    FROM {legacy} a
    FULL OUTER JOIN {python} b
      ON {" AND ".join([f"a.{c} = b.{c}" for c in group_by])}
    """
    df = run_sql_to_df(session, sql)
    return pd.DataFrame([{"column": col, "diff_count": int(df[col].iloc[0])} for col, _ in compare_cols_with_types])

# Main

def compare_schemas(**kwargs):
    audit_id_cutoff = kwargs["params"].get("audit_id_cutoff")
    session = get_session()
    engine = session.get_bind()
    sections = []
    for tbl, pair in PAIRS.items():
        df_summary = fetch_group_counts(session, pair, audit_id_cutoff)
        df_summary.to_csv(f"{OUTDIR}/{tbl}_summary.csv", index=False)

        cols_with_types = get_shared_columns_with_types(engine, pair["legacy"], pair["python"])
        df_col = fetch_column_diffs(session, pair, cols_with_types)
        df_col.to_csv(f"{OUTDIR}/{tbl}_column_diffs.csv", index=False)

        sections.append(f"""
            <h2>{tbl}</h2>
            <h3>Summary</h3>
            {df_summary.head(20).to_html(index=False)}
            <h3>Column Diffs</h3>
            {df_col.head(20).to_html(index=False)}
            <hr>
        """)

    # Write HTML
    with open(f"{OUTDIR}/report.html", "w", encoding="utf-8") as f:
        f.write(f"""
        <html><head><title>Schema Comparison Report</title></head><body>
        <h1>Schema Comparison Report</h1>
        {''.join(sections)}
        </body></html>
        """)
    session.close()
