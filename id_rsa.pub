# ─── NEW IMPORTS ────────────────────────────────────────────────────────────────
from sqlalchemy import func, cast, String
from common.models import (
    DMIRLinkFBAToBKGN,              # <─ link table
    DWGNBenchmarkCharacteristic,    # <─ benchmark characteristics
    DWGNGPSProduct,                 # <─ product master
)

# ─── … keep the rest of the file unchanged until after “Update 8…” ──────────────
print("Update 8...")
# … forex mapping logic …

# ─── UPDATE 9 : INSERT NEW ALADDIN BENCHMARKS IN LINK TABLE ────────────────────
print("Update 9...")
ten_days_ago = date_today - datetime.timedelta(days=10)

# already-linked FBA codes
existing_fba = {
    row[0]
    for row in session.query(DMIRLinkFBAToBKGN.numBenchIdFBA)
    .filter(DMIRLinkFBAToBKGN.strSource == "ALADDIN")
    .all()
}

# candidates that meet the SQL criteria
q_new = (
    session.query(
        DWGNBenchmarkCharacteristic.strBnchmkCd,
        DWGNBenchmarkCharacteristic.strCompositionCd,
    )
    .join(
        DWGNGPSProduct,
        DWGNGPSProduct.strOfficialBnchmkID
        == DWGNBenchmarkCharacteristic.strBnchmkCd,
    )
    .filter(
        DWGNBenchmarkCharacteristic.strBnchmkStat == "12",
        DWGNBenchmarkCharacteristic.strCompositionCd.isnot(None),
        DWGNGPSProduct.strStatus == "G",
    )
)
to_insert = []
for bnchmk_cd, compo_cd in q_new:
    if int(bnchmk_cd) not in existing_fba:
        to_insert.append(
            {
                "numBenchIdFBA": int(bnchmk_cd),
                "strSource": "ALADDIN",
                "numidBKGN": None,
                "datStartDate": ten_days_ago,
                "datEndDate": None,
                "strCompositionCd": compo_cd,
            }
        )

if to_insert:
    print(f"Link-table insert : {len(to_insert)} new rows.")
    session.bulk_insert_mappings(DMIRLinkFBAToBKGN, to_insert)
else:
    print("Link-table insert : nothing to do.")

# ─── UPDATE 10 : HANDLE COMPOSITION CHANGES ────────────────────────────────────
print("Update 10...")
eight_days_ago = date_today - datetime.timedelta(days=8)
nine_days_ago = date_today - datetime.timedelta(days=9)

# join the link table with characteristics to find mismatches
q_change = (
    session.query(
        DMIRLinkFBAToBKGN.numBenchIdFBA,
        DMIRLinkFBAToBKGN.strCompositionCd.label("compo_asis"),
        DWGNBenchmarkCharacteristic.strCompositionCd.label("compo_tobe"),
        DMIRLinkFBAToBKGN.datStartDate,
    )
    .join(
        DWGNBenchmarkCharacteristic,
        DWGNBenchmarkCharacteristic.strBnchmkCd
        == cast(DMIRLinkFBAToBKGN.numBenchIdFBA, String),
    )
    .filter(
        DMIRLinkFBAToBKGN.strSource == "ALADDIN",
        DMIRLinkFBAToBKGN.datEndDate.is_(None),
        DWGNBenchmarkCharacteristic.strBnchmkStat == "12",
        DMIRLinkFBAToBKGN.strCompositionCd
        != DWGNBenchmarkCharacteristic.strCompositionCd,
    )
    .all()
)

updates, new_links = 0, []
# cache of (bench, compo) that already exists → skip duplicate insert
current_pairs = {
    (row.numBenchIdFBA, row.strCompositionCd)
    for row in session.query(
        DMIRLinkFBAToBKGN.numBenchIdFBA, DMIRLinkFBAToBKGN.strCompositionCd
    ).filter(DMIRLinkFBAToBKGN.strSource == "ALADDIN")
}

for rec in q_change:
    # ignore “one-character” cosmetic changes (mimics LEFT / LEN in SQL)
    if rec.compo_asis[:-1] == rec.compo_tobe:
        continue

    # 1️⃣ close the current row
    upd_count = (
        session.query(DMIRLinkFBAToBKGN)
        .filter(
            DMIRLinkFBAToBKGN.numBenchIdFBA == rec.numBenchIdFBA,
            DMIRLinkFBAToBKGN.strCompositionCd == rec.compo_asis,
            DMIRLinkFBAToBKGN.datStartDate == rec.datStartDate,
            DMIRLinkFBAToBKGN.datEndDate.is_(None),
        )
        .update({"datEndDate": nine_days_ago}, synchronize_session=False)
    )
    updates += upd_count

    # 2️⃣ open a new row starting eight days ago (if not already present)
    key = (rec.numBenchIdFBA, rec.compo_tobe)
    if key not in current_pairs:
        new_links.append(
            {
                "numBenchIdFBA": rec.numBenchIdFBA,
                "strSource": "ALADDIN",
                "numidBKGN": None,
                "datStartDate": eight_days_ago,
                "datEndDate": None,
                "strCompositionCd": rec.compo_tobe,
            }
        )
        current_pairs.add(key)

if updates:
    print(f"Composition change : {updates} rows closed.")
if new_links:
    print(f"Composition change : {len(new_links)} new rows opened.")
    session.bulk_insert_mappings(DMIRLinkFBAToBKGN, new_links)
else:
    print("Composition change : nothing to insert.")

# ─── commit EVERYTHING (forex updates + link-table logic) ───────────────────────
session.commit()
print("All updates committed.")
