from sqlalchemy import and_, or_

# Step 1: Get primary keys
pk_fields = [
    "strReportPeriod",
    "strPortfID",
    "strPortfLevelID",
    "strReportPortfGPSCode",
    "strPortfName",
    "strPortfGroupID",
    "strPortfTypeID",
]

# Step 2: Build `or_` filter dynamically
filters = []
for obj in objects:
    filters.append(and_(
        getattr(DMIRMonitoringLTWrk, field) == getattr(obj, field)
        for field in pk_fields
    ))

# Step 3: Delete matching rows
if filters:
    session.query(DMIRMonitoringLTWrk).filter(or_(*filters)).delete(synchronize_session=False)

# Step 4: Insert new rows
session.bulk_save_objects(objects)
session.commit()
