@monitor_mem()
def apply_delta_adjustments(df_tmp: pd.DataFrame, df_delta: pd.DataFrame, max_workers=24):
    # 1. Chunked load of instrument→type mapping
    inst_codes = df_tmp["strInstAladdin"].dropna().unique().tolist()
    chunks = [inst_codes[i:i + 1000] for i in range(0, len(inst_codes), 1000)]
    columns = df_tmp.columns

    dfs_instr = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_apply_delta_adjustments_instruments_single, idx, chunk): idx
            for idx, chunk in enumerate(chunks)
        }
        for future in as_completed(futures):
            res = future.result()
            dfs_instr.append(res)
            print(f"Chunk inserted {len(dfs_instr)} rows")

    if not dfs_instr:
        return pd.DataFrame(columns=columns)

    # 2. Merge instrument metadata
    df_instr = pd.concat(dfs_instr, ignore_index=True)
    df_tmp = df_tmp.merge(df_instr, on="strInstAladdin", how="left", suffixes=("", "_instr"))

    # Eligible alpha set
    eligible_alpha = set(df_instr["strInstAladdin"])

    # 3. Prepare alpha lookup (fillna(-2) for key match)
    alpha_df = df_delta.rename(columns={
        "strInstrmtCd": "strInstAladdin",
        "numPortfGroupFkey": "numReportPortfGroupID",
        "numPtfFkey": "strPortfIDNumPart"
    }).copy()
    alpha_df["strPortfIDNumPart"] = alpha_df["strPortfIDNumPart"].fillna(-2)

    # 4. Prepare DMC lookup
    dmc_df = df_delta.rename(columns={
        "strInstrmtCd": "strInstAladdin",
        "strProdCd": "strPortfID"
    }).copy()

    # 5. Build unique tuple list (for hold_qty scaling)
    insts_df = (
        df_tmp[[
            "strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID",
            "strPortfIDNumPart", "strPortfID", "numHoldQuantity"
        ]]
        .drop_duplicates()
    )
    insts_df["strPortfIDNumPart"] = insts_df["strPortfIDNumPart"].fillna(-2)

    # Mark alpha-eligible rows
    insts_df["eligible_alpha"] = insts_df["strInstAladdin"].isin(eligible_alpha)

    # Merge alpha
    insts_df = insts_df.merge(
        alpha_df[[
            "strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart",
            "numDeltaAdjedNotionalValu", "numPosQty"
        ]],
        on=["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart"],
        how="left",
        suffixes=("", "_alpha")
    )

    # Compute alpha factor only for eligible
    insts_df["alpha_factor"] = np.where(
        insts_df["eligible_alpha"] & insts_df["numDeltaAdjedNotionalValu"].notna(),
        np.where(
            insts_df["numPosQty"] != 0,
            (insts_df["numDeltaAdjedNotionalValu"] / insts_df["numPosQty"]) * insts_df["numHoldQuantity"],
            0.0
        ),
        np.nan
    )
    insts_df["alpha_posqty"] = np.where(
        insts_df["eligible_alpha"] & insts_df["numDeltaAdjedNotionalValu"].notna(),
        insts_df["numPosQty"],
        np.nan
    )

    # Identify rows with no alpha applied
    missing_mask = insts_df["alpha_factor"].isna()

    # Merge DMC for missing
    insts_df = insts_df.merge(
        dmc_df[[
            "strInstAladdin", "datPeriodLastDay", "strPortfID",
            "numDeltaAdjNotionalValue", "numPosQty"
        ]],
        on=["strInstAladdin", "datPeriodLastDay", "strPortfID"],
        how="left",
        suffixes=("", "_dmc")
    )

    insts_df["dmc_factor"] = np.where(
        missing_mask & insts_df["numDeltaAdjNotionalValue"].notna(),
        insts_df["numDeltaAdjNotionalValue"],
        np.nan
    )
    insts_df["dmc_posqty"] = np.where(
        missing_mask & insts_df["numDeltaAdjNotionalValue"].notna(),
        insts_df["numPosQty_dmc"],
        np.nan
    )

    # Final factor & posqty
    insts_df["final_factor"] = insts_df["alpha_factor"].fillna(insts_df["dmc_factor"])
    insts_df["final_posqty"] = insts_df["alpha_posqty"].fillna(insts_df["dmc_posqty"])

    # Map back to df_tmp
    df_tmp = df_tmp.merge(
        insts_df[[
            "strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart", "strPortfID",
            "final_factor", "final_posqty"
        ]],
        on=["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart", "strPortfID"],
        how="left"
    )

    df_tmp["numDeltaAdjustedSpread"] = df_tmp["final_factor"]
    df_tmp["OriginalQty"] = df_tmp["final_posqty"]

    return df_tmp.drop(columns=["final_factor", "final_posqty"])
