from __future__ import annotations

"""
Airflow DAG that reproduces, in Python, the logic of
`DMIR.stpDMIRLTMonitoringWrk_StepN`.

Key points requested by the user:
• **Pure ORM** – every query is built with SQLAlchemy Core/ORM, no `pd.read_sql`.
• **One plain‐Python function per original SQL block** – each returns either a
  list of ORM objects or a `pandas.DataFrame` built from Python objects.
• **`get_session()`** – a helper that yields a SQLAlchemy Session is imported
  from `dags.common.utils` and used everywhere.

The real stored‑procedure is ~1 500 lines; below we collapse some large joins
into helper utilities to keep the DAG readable.  The business logic matches the
SQL step‑for‑step, but feel free to expand any helper when you drill into the
details.
"""

from datetime import datetime
from typing import List, Tuple

import pandas as pd
from airflow.decorators import dag, task
from airflow.utils.dates import days_ago
from sqlalchemy import func, select, and_, case, literal_column, text
from sqlalchemy.orm import Session

from dags.common.utils import get_session

# ────────────────────────────────────────────────────────────────────────────
# ORM MODELS
#   We assume a declarative_base() somewhere in your shared project code and
#   that these classes are already generated / hand‑written.  Only a subset of
#   columns required for this step are shown – extend as needed.
# ────────────────────────────────────────────────────────────────────────────

from dmir_models import (
    TblDMIRMonitoringLTWrk,
    TblDMIRExternalSpecialHolding,
    TblDMIRBRSInstrument,
    TblDMIRInstrumentIRType,
    TblDMIRScopeLT,
    VieDMIRBRSCurrencyQuote,
    TblDMIRDMCHolding,
    TblDMIRExtPortfHoldingTemp,
    TblDMIRIntPortfHoldingTemp,
    TblDMIRDMCVALO,
    TblDMIRLTExclude,
)

# Helper -------------------------------------------------------------------------------------------------------------

def to_df(rows, columns: List[str]) -> pd.DataFrame:  # noqa: D401 – simple util
    """Helper to convert a list[tuple] to a DataFrame without using read_sql."""
    return pd.DataFrame(list(rows), columns=columns)

# Block‑A – External -------------------------------------------------------------------------------------------------

def fetch_external_prev_step(session: Session, step: int) -> pd.DataFrame:
    """Replicates the *External data* temp‑table with the **instrument join added**.

    This now mirrors the T‑SQL sub‑query:
        * base rows from `TblDMIRMonitoringLTWrk` (step‑1, EXT/SPECIAL)
        * join **TblDMIRExternalSpecialHolding** on ISIN‑code + date filter
        * join **TblDMIRBRSInstrument** / **TblDMIRInstrumentIRType** to bring
          `strInvestedInPortfID`, `strInvestedInPortfName`, `strInstISINCode`,
          `strInstrumentTypeIRName`.
        * keep only the latest `datHoldDate` per
          (`strInvestedInPortfID`, `datPeriodLastDay`) like the original
          `RANK() OVER … = 1` filter.
    """

    # ── aliases for readability ------------------------------------------------
    esh = TblDMIRExternalSpecialHolding
    brs = TblDMIRBRSInstrument
    irt = TblDMIRInstrumentIRType
    wrk = TblDMIRMonitoringLTWrk

    s = (
        select(
            wrk.datReportDate,
            wrk.strReportPeriod,
            wrk.strReportPortfHoldSrc,
            wrk.numReportPortfGroupID,
            wrk.strReportPortfGPSCode,
            wrk.strInvestedInPortfID.label("strPortfID"),
            wrk.strInvestedInPortfName.label("strPortfName"),
            wrk.numInvestedInPortfAUM.label("numPortfAUM"),
            wrk.strInvestedInPortfISOCur.label("strPortfISOCur"),
            wrk.strSrcUndrlygHoldData,
            esh.strInstAladdin.label("strInvestedInInstrID"),
            esh.numHoldCrossCur,
            esh.numHoldValuInPortfCur,
            esh.numHoldQuantity,
            esh.datHoldDate,
            esh.numHoldPrice,
            esh.numHoldAccruedIntInstr,
            esh.numHoldAccruedIntPortf,
            wrk.numWeightInReportPortfAUM,
            (wrk.strPortfLevelID + "." + wrk.strInvestedInPortfID).label("strPortfLevelID"),
            wrk.datPeriodLastDay,
            esh.strInstAladdin,
            esh.numInstID,
            brs.strInstISINCode.label("strInvestedInPortfID"),
            brs.strInstName.label("strInvestedInPortfName"),
            brs.strInstISINCode.label("strInstISINCode"),
            irt.strInstrumentTypeIRName,
            wrk.strLevel1IsinCode,
            wrk.strReportPortfISOCur,
        )
        # join ExternalSpecialHolding (same as before)
        .join(
            esh,
            wrk.strInvestedInPortfID == esh.strPortfISINCode,
        )
        # join BRS‑instrument & IR‑type (missing in previous version) ---------
        .join(brs, brs.strInstAladdin == esh.strInstAladdin)
        .join(
            irt,
            and_(
                irt.numInstrTypeID == brs.numInstTypeId,
                irt.strReportingType == "class2",
                func.lower(irt.strInstrumentTypeIRName).in_(
                    ["mutual funds", "index", "monetary funds"]
                ),
            ),
        )
        .where(
            wrk.numPortfLevel == step - 1,
            wrk.numUndrlygLTflag == 1,
            wrk.numPresUndrlygHoldData == 1,
            wrk.strSrcUndrlygHoldData.in_(["SPECIAL", "EXTERNAL"]),
        )
    )

    rows = session.execute(s).all()
    cols = [c.key for c in s.selected_columns]
    df = to_df(rows, cols)

    # ── replicate RANK() OVER (InvestedInPortfID, PeriodLastDay) ---------------
    df.sort_values(
        ["strInvestedInPortfID", "datHoldDate"], ascending=[True, False], inplace=True
    )
    df = df.drop_duplicates(
        subset=["strInvestedInPortfID", "datPeriodLastDay"], keep="first"
    )

    return df

# Block‑B – Internal -------------------------------------------------------------------------------------------------

def fetch_internal_prev_step(session: Session, step: int) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Replicates the *Internal‑data* portion of the procedure (block‑B).

    Returns **two** DataFrames that correspond to the original temp tables:

    * ``df_int_raw``   – equivalent to **#tmpMonitoringPreviousStepInternal**
    * ``df_int_enrich`` – equivalent to **#tmpMonitoringPreviousStepInternal_2**

    The function performs every join with SQLAlchemy ORM, then switches to
    pandas for the de‑dup / concat logic (mirroring the stored‑procedure
    semantics one‑for‑one).
    """

    # ------------------------------------------------------------------
    # temp‑1  – distinct NAV‑dates for underlying INTERNAL funds
    # ------------------------------------------------------------------
    t1_rows = session.execute(
        select(
            TblDMIRMonitoringLTWrk.datLastNAVDate,
            TblDMIRMonitoringLTWrk.strInvestedInPortfID,
        ).where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step - 1,
            TblDMIRMonitoringLTWrk.numUndrlygLTflag == 1,
            TblDMIRMonitoringLTWrk.numPresUndrlygHoldData == 1,
            TblDMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
        ).distinct()
    ).all()
    temp1 = to_df(t1_rows, ["datLastNAVDate", "strInvestedInPortfID"])

    # ------------------------------------------------------------------
    # temp‑2  – latest ACCDATE ≤ NAV for each (fund, NAV‑date)
    # ------------------------------------------------------------------
    h = TblDMIRDMCHolding.__table__.alias("h")
    t2_rows = session.execute(
        select(
            temp1.c.datLastNAVDate,
            temp1.c.strInvestedInPortfID,
            func.max(h.c.datACCDATE).label("datmaxAccDate"),
        )
        .select_from(temp1.join(h, temp1.c.strInvestedInPortfID == h.c.strPortfGPSCode))
        .where(h.c.datACCDATE <= temp1.c.datLastNAVDate)
        .group_by(temp1.c.datLastNAVDate, temp1.c.strInvestedInPortfID)
    ).all()
    temp2 = to_df(t2_rows, ["datLastNAVDate", "strInvestedInPortfID", "datmaxAccDate"])

    # ------------------------------------------------------------------
    # temp‑3  – snapshot of DMCHolding on that max ACCDATE
    # ------------------------------------------------------------------
    t3_rows = session.execute(
        select(
            TblDMIRDMCHolding.strPortfGPSCode,
            TblDMIRDMCHolding.datACCDATE,
            TblDMIRDMCHolding.strInstAladdin,
            TblDMIRDMCHolding.numInstrFKey,
            TblDMIRDMCHolding.numHoldCrossCur,
            TblDMIRDMCHolding.numHoldValuInPortfCur,
            TblDMIRDMCHolding.numHoldQuantity,
            TblDMIRDMCHolding.numHoldPrice,
            TblDMIRDMCHolding.numHoldAccruedIntInstr,
            TblDMIRDMCHolding.numHoldAccruedIntPortf,
            TblDMIRDMCHolding.numInstrFKey.label("numInstID"),
            TblDMIRDMCHolding.numHoldAvrgCostInPortfCur,
            TblDMIRDMCHolding.strUnderlSecCode,
        )
        .select_from(
            TblDMIRDMCHolding.join(
                temp2,
                and_(
                    TblDMIRDMCHolding.strPortfGPSCode == temp2.c.strInvestedInPortfID,
                    TblDMIRDMCHolding.datACCDATE == temp2.c.datmaxAccDate,
                ),
            )
        )
    ).all()
    temp3 = to_df(
        t3_rows,
        [
            "strPortfGPSCode",
            "datACCDATE",
            "strInstAladdin",
            "numInstrFKey",
            "numHoldCrossCur",
            "numHoldValuInPortfCur",
            "numHoldQuantity",
            "numHoldPrice",
            "numHoldAccruedIntInstr",
            "numHoldAccruedIntPortf",
            "numInstID",
            "numHoldAvrgCostInPortfCur",
            "strUnderlSecCode",
        ],
    )

    # ------------------------------------------------------------------
    # tmpMonitoringPreviousStepInternal  (first INSERT) -------------------
    # ------------------------------------------------------------------
    # pull parent rows (level‑(step‑1) INTERNAL) once ----------------------
    parent_rows = session.execute(
        select(
            TblDMIRMonitoringLTWrk.datReportDate,
            TblDMIRMonitoringLTWrk.strReportPeriod,
            TblDMIRMonitoringLTWrk.strReportPortfHoldSrc,
            TblDMIRMonitoringLTWrk.numReportPortfGroupID,
            TblDMIRMonitoringLTWrk.strReportPortfGPSCode,
            TblDMIRMonitoringLTWrk.strInvestedInPortfID.label("strPortfID"),
            TblDMIRMonitoringLTWrk.strInvestedInPortfName.label("strPortfName"),
            TblDMIRMonitoringLTWrk.numInvestedInPortfAUM.label("numPortfAUM"),
            TblDMIRMonitoringLTWrk.strInvestedInPortfISOCur.label("strPortfISOCur"),
            TblDMIRMonitoringLTWrk.numWeightInReportPortfAUM,
            TblDMIRMonitoringLTWrk.strPortfLevelID,
            TblDMIRMonitoringLTWrk.datPeriodLastDay,
            TblDMIRMonitoringLTWrk.strSrcUndrlygHoldData,
            TblDMIRMonitoringLTWrk.datLastNAVDate,
            TblDMIRMonitoringLTWrk.strLevel1IsinCode,
            TblDMIRMonitoringLTWrk.strReportPortfISOCur,
        ).where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step - 1,
            TblDMIRMonitoringLTWrk.numUndrlygLTflag == 1,
            TblDMIRMonitoringLTWrk.numPresUndrlygHoldData == 1,
            TblDMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
        )
    ).all()
    parent_df = to_df(
        parent_rows,
        [
            "datReportDate",
            "strReportPeriod",
            "strReportPortfHoldSrc",
            "numReportPortfGroupID",
            "strReportPortfGPSCode",
            "strPortfID",
            "strPortfName",
            "numPortfAUM",
            "strPortfISOCur",
            "numWeightInReportPortfAUM",
            "strPortfLevelID",
            "datPeriodLastDay",
            "strSrcUndrlygHoldData",
            "datLastNAVDate",
            "strLevel1IsinCode",
            "strReportPortfISOCur",
        ],
    )

    # merge parent with temp2 to get max ACCDATE
    parent_df = parent_df.merge(
        temp2,
        left_on=["datLastNAVDate", "strPortfID"],
        right_on=["datLastNAVDate", "strInvestedInPortfID"],
        how="left",
    )

    # merge with temp3 snapshot to pull holding metrics --------------------
    df_int_raw = parent_df.merge(
        temp3,
        left_on=["strPortfID", "datmaxAccDate"],
        right_on=["strPortfGPSCode", "datACCDATE"],
        how="left",
    )

    # select / rename columns exactly like SQL INSERT ----------------------
    df_int_raw = df_int_raw[
        [
            "datReportDate",
            "strReportPeriod",
            "strReportPortfHoldSrc",
            "numReportPortfGroupID",
            "strReportPortfGPSCode",
            "strPortfID",
            "strPortfName",
            "numPortfAUM",
            "strPortfISOCur",
            "strInstAladdin_x",  # becomes strInvestedInInstrID later
            "numHoldCrossCur",
            "numHoldValuInPortfCur",
            "numHoldQuantity",
            "datACCDATE",
            "numHoldPrice",
            "numHoldAccruedIntInstr",
            "numHoldAccruedIntPortf",
            "numWeightInReportPortfAUM",
            "strPortfLevelID",
            "datPeriodLastDay",
            "strSrcUndrlygHoldData",
            "strInstAladdin_x",
            "numInstID",
            "numHoldAvrgCostInPortfCur",
            "strLevel1IsinCode",
            "strReportPortfISOCur",
        ]
    ]
    df_int_raw.rename(
        columns={
            "strInstAladdin_x": "strInstAladdin",
            "datACCDATE": "datHoldDate",
        },
        inplace=True,
    )

    # ------------------------------------------------------------------
    # Build the instrument / portfolio lookup (inst) --------------------
    # ------------------------------------------------------------------
    inst_rows = session.execute(
        select(
            TblDMIRBRSInstrument.strInstAladdin.label("strInstAladdin"),
            TblDMIRBRSInstrument.numInstID.label("numInstID"),
            func.coalesce(
                TblDMIRPortfolio.strPortfGPSCode,
                TblDMIRBRSInstrument.strInstISINCode,
            ).label("strInvestedInPortfID"),
            func.coalesce(
                TblDMIRPortfolio.strPtfName,
                TblDMIRBRSInstrument.strInstName,
            ).label("strInvestedInPortfName"),
            TblDMIRInstrumentIRType.strInstrumentTypeIRName,
            TblDMIRPortfolio.strPortfGPSCode.label("strPortfGPSCode"),
            TblDMIRBRSInstrument.strInstISINCode.label("strInstISINCode"),
        ).select_from(
            TblDMIRBRSInstrument
            .join(
                TblDMIRInstrumentIRType,
                and_(
                    TblDMIRInstrumentIRType.numInstrTypeID == TblDMIRBRSInstrument.numInstrTypeId,
                    TblDMIRInstrumentIRType.strReportingType == "class2",
                    func.lower(TblDMIRInstrumentIRType.strInstrumentTypeIRName).in_(
                        ["mutual funds", "index", "monetary funds"]
                    ),
                ),
            )
            .outerjoin(
                TblDMIRShare,
                and_(
                    TblDMIRShare.strShISINCode == TblDMIRBRSInstrument.strInstISINCode,
                    TblDMIRShare.strShStatusLabel == "Launched",
                ),
            )
            .outerjoin(
                TblDMIRPortfolio,
                TblDMIRPortfolio.strPortfGPSCode == TblDMIRShare.strPortfGpsCode,
            )
        ).distinct()
    ).all()

    inst_df = to_df(
        inst_rows,
        [
            "strInstAladdin",
            "numInstID_inst",
            "strInvestedInPortfID_inst",
            "strInvestedInPortfName",
            "strInstrumentTypeIRName",
            "strPortfGPSCode_inst",
            "strInstISINCode",
        ],
    )

    # merge df_int_raw with inst_df ----------------------------------------
    df_int_enrich = df_int_raw.merge(
        inst_df,
        left_on="strInstAladdin",
        right_on="strInstAladdin",
        how="left",
    )

    # ------------------------------------------------------------------
    # Special‑funds logic  → derive strSrcUndrlygHoldData -----------------
    # ------------------------------------------------------------------
    sf_rows = session.execute(
        select(
            TblDMIRSpecialFunds.strSPISINCode,
            TblDMIRSpecialFunds.strPortfLevelID,
            TblDMIRSpecialFunds.datValidBegin,
            TblDMIRSpecialFunds.datValidEnd,
        )
    ).all()
    sf_df = to_df(
        sf_rows,
        ["strSPISINCode", "strPortfLevelID", "datValidBegin", "datValidEnd"],
    )

    # Merge & flag ----------------------------------------------------------
    df_int_enrich = df_int_enrich.merge(
        sf_df,
        left_on=["strInstISINCode", "strPortfLevelID"],
        right_on=["strSPISINCode", "strPortfLevelID"],
        how="left",
    )

    def _src_flag(row):
        if pd.notna(row["strSPISINCode"]):
            return "SPECIAL"
        if pd.notna(row["strPortfGPSCode_inst"]):
            return "INTERNAL"
        return "EXTERNAL"

    df_int_enrich["strSrcUndrlygHoldData"] = df_int_enrich.apply(_src_flag, axis=1)

    # tidy columns -----------------------------------------------------------
    df_int_enrich.rename(
        columns={
            "numInstID_inst": "numInstID",
            "strInvestedInPortfID_inst": "strInvestedInPortfID",
            "strPortfGPSCode_inst": "strPortfGPSCode_inst",
        },
        inplace=True,
    )

    return df_int_raw, df_int_enrich


# ── helpers.py ──────────────────────────────────────────────────────────────
from __future__ import annotations

from collections import defaultdict
from datetime import date
from typing import Dict, Iterable, List, Tuple

import pandas as pd
from sqlalchemy import and_, func, select
from sqlalchemy.orm import Session

from dmir_models import (
    TblDMIRScopeLT,
    VieDMIRBRSCurrencyQuote,
)

##############################################################################
# BLOCK C  –  “Move Internal → External data”
##############################################################################


def move_internal_to_external(
    df_internal_enrich: pd.DataFrame,
) -> Tuple[pd.DataFrame, pd.DataFrame]:
    """Replicates procedure block‑C.

    *T‑SQL summary*
      1. INSERT rows with ``strSrcUndrlygHoldData`` in (EXTERNAL, SPECIAL)
         from **#tmpMonitoringPreviousStepInternal_2** into the external temp.
      2. DELETE those rows from the internal temp.
      3. Handle duplicate keys
         (period, portfLevelID, investedInPortfID) → append "‑instrID" to
         ``strPortfLevelID`` for *all* duplicated rows.

    In Python we simply *split* the enriched internal DataFrame into two:

    * ``external_df`` – the rows that must migrate to the “external” stream;
    * ``clean_internal_df`` – remaining rows, de‑duplicated exactly like SQL.
    """

    if df_internal_enrich.empty:
        # nothing to split
        return df_internal_enrich.iloc[0:0].copy(), df_internal_enrich.copy()

    # 1️⃣  select rows to move -------------------------------------------------
    mask_move = df_internal_enrich["strSrcUndrlygHoldData"].isin([
        "EXTERNAL",
        "SPECIAL",
    ])
    external_df = df_internal_enrich.loc[mask_move].copy()

    clean_internal_df = df_internal_enrich.loc[~mask_move].copy()

    # 2️⃣  handle duplicates exactly like SQL HAVING COUNT(*) > 1 -------------
    dup_keys = (
        clean_internal_df.groupby(
            [
                "strReportPeriod",
                "strPortfLevelID",
                "strInvestedInPortfID",
            ]
        )
        .size()
        .loc[lambda s: s > 1]
        .reset_index()[
            [
                "strReportPeriod",
                "strPortfLevelID",
                "strInvestedInPortfID",
            ]
        ]
    )

    if not dup_keys.empty:
        # inner‑merge to identify duplicated rows
        dup_index = clean_internal_df.merge(dup_keys, how="inner").index
        clean_internal_df.loc[dup_index, "strPortfLevelID"] = (
            clean_internal_df.loc[dup_index, "strPortfLevelID"]
            + "-"
            + clean_internal_df.loc[dup_index, "strInvestedInInstrID"].astype(str)
        )

    return external_df, clean_internal_df

##############################################################################
# Utility – FX rates in one round-trip
##############################################################################


##############################################################################
# BLOCK D  –  “Calculation for External data”
##############################################################################


# helpers_external.py
from __future__ import annotations

from datetime import date
from typing import Dict, Iterable, List, Tuple

import numpy as np
import pandas as pd
from sqlalchemy import func, select
from sqlalchemy.orm import Session

from dmir_models import (
    TblDMIRScopeLT,
    VieDMIRBRSCurrencyQuote,
)


# ─────────────────────────────────────────────────────────────────────────────
# small utility — one trip to grab the FX rates we’ll need
# ─────────────────────────────────────────────────────────────────────────────
def _collect_rates(
    session: Session, pairs: Iterable[Tuple[str, date]]
) -> Dict[Tuple[str, date], float]:
    pairs = set(pairs)
    if not pairs:
        return {}

    iso_list = {p[0] for p in pairs}
    date_list = {p[1] for p in pairs}

    rows = session.execute(
        select(
            VieDMIRBRSCurrencyQuote.strCurrCode,
            func.date(VieDMIRBRSCurrencyQuote.datccyqDate),
            VieDMIRBRSCurrencyQuote.numccyqrateInv,
        ).where(
            VieDMIRBRSCurrencyQuote.strCurrCode.in_(iso_list),
            func.date(VieDMIRBRSCurrencyQuote.datccyqDate).in_(date_list),
        )
    ).all()

    return {(iso, dt): rate for iso, dt, rate in rows}


# ─────────────────────────────────────────────────────────────────────────────
# main routine — corresponds to #tmpMonitoringPreviousStepExternalAgg
# ─────────────────────────────────────────────────────────────────────────────
def aggregate_external(df_external: pd.DataFrame, session: Session) -> pd.DataFrame:
    """
    Python equivalent of the stored-procedure’s *external-data* aggregation.

    Key fidelity points vs. SQL:
    ① One-row-per-(period, levelID, instrID) using the same `ROW_NUMBER()` rule.  
    ② Exact SUM/AVG measures promoted to the final column names.  
    ③ Legacy spelling `numHoldValuInPortfCur` removed.  
    ④ Descriptive columns restored after the group-by so the final DataFrame
       matches all columns inserted into *tblDMIRMonitoringLTWrk*.  
    ⑤ FX conversion & LT-threshold join identical to SQL logic.
    """

    if df_external.empty:
        return df_external.copy()

    # ------------------------------------------------------------------ #
    # 1️⃣  Deduplicate   (ROW_NUMBER() OVER (…) = 1)                      #
    # ------------------------------------------------------------------ #
    df_external = (
        df_external.sort_values(
            [
                "strReportPeriod",
                "strPortfLevelID",
                "strInvestedInInstrID",
                "datHoldDate",
            ],
            ascending=[True, True, True, False],
        )
        .drop_duplicates(
            subset=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
            keep="first",
        )
    )
    dedup = df_external.copy()

    # ------------------------------------------------------------------ #
    # 2️⃣  Numeric aggregation (SUM / AVG)                                #
    # ------------------------------------------------------------------ #
    agg_num = (
        df_external.groupby(
            ["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
            as_index=False,
        )
        .agg(
            numHoldQuantity=("numHoldQuantity", "sum"),
            numHoldValueInPortfCur=("numHoldValuInPortfCur", "sum"),  # <- no-e  col
            numHoldPrice=("numHoldPrice", "mean"),
            numHoldAccruedIntInstr=("numHoldAccruedIntInstr", "sum"),
            numHoldAccruedIntPortf=("numHoldAccruedIntPortf", "sum"),
        )
    )

    merged = pd.merge(
        dedup,
        agg_num,
        on=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
        how="inner",
        suffixes=("", "_agg"),
    )

    # ------------------------------------------------------------------ #
    # 3️⃣  Promote aggregated columns & clean legacy spelling             #
    # ------------------------------------------------------------------ #
    agg_cols = [
        "numHoldQuantity",
        "numHoldValueInPortfCur",
        "numHoldPrice",
        "numHoldAccruedIntInstr",
        "numHoldAccruedIntPortf",
    ]
    for c in agg_cols:
        merged[c] = merged.pop(f"{c}_agg")

    # drop original no-e spelling
    merged.drop(columns=["numHoldValuInPortfCur"], errors="ignore", inplace=True)

    # ------------------------------------------------------------------ #
    # 4️⃣  RG-03  –  weight within report-portfolio AUM                   #
    # ------------------------------------------------------------------ #
    merged["numWeightInReportPortfAUM"] = np.where(
        merged["numPortfAUM"].fillna(0) != 0,
        merged["numHoldValueInPortfCur"]
        * merged["numWeightInReportPortfAUM"]
        / merged["numPortfAUM"],
        np.nan,
    )

    # ------------------------------------------------------------------ #
    # 5️⃣  Join DMIR scope (report ccy, hold-date, LT threshold)          #
    # ------------------------------------------------------------------ #
    scope_key_df = merged[
        ["numReportPortfGroupID", "strReportPortfGPSCode", "strReportPeriod"]
    ].drop_duplicates()

    scope_rows = session.execute(
        select(
            TblDMIRScopeLT.numReportPortfGroupID,
            TblDMIRScopeLT.strReportPortfGPSCode,
            TblDMIRScopeLT.strReportPeriod,
            TblDMIRScopeLT.strReportPortfISOCur,
            TblDMIRScopeLT.datHoldDate,
            TblDMIRScopeLT.numLTThreshold,
        ).where(
            TblDMIRScopeLT.datHoldDate.is_not(None),
            tuple_(
                TblDMIRScopeLT.numReportPortfGroupID,
                TblDMIRScopeLT.strReportPortfGPSCode,
                TblDMIRScopeLT.strReportPeriod,
            ).in_(scope_key_df.itertuples(index=False, name=None)),
        )
    ).all()

    scope_df = pd.DataFrame(
        scope_rows,
        columns=[
            "numReportPortfGroupID",
            "strReportPortfGPSCode",
            "strReportPeriod",
            "strReportPortfISOCur",
            "datHoldDate_scope",
            "numLTThreshold",
        ],
    )

    merged = pd.merge(
        merged,
        scope_df,
        on=["numReportPortfGroupID", "strReportPortfGPSCode", "strReportPeriod"],
        how="left",
    )

    # ------------------------------------------------------------------ #
    # 6️⃣  FX conversions  (RG-02)                                        #
    # ------------------------------------------------------------------ #
    rate_pairs: List[Tuple[str, date]] = []
    for portf_iso, rpt_iso, dt in merged[
        ["strPortfISOCur", "strReportPortfISOCur", "datHoldDate_scope"]
    ].itertuples(index=False, name=None):
        if dt:
            rate_pairs.extend([(portf_iso, dt), (rpt_iso, dt)])

    rate_map = _collect_rates(session, rate_pairs)

    def _fx_ratio(portf_iso: str, rpt_iso: str, d: date) -> float | None:
        p = rate_map.get((portf_iso, d))
        r = rate_map.get((rpt_iso, d))
        if p is None or r in (None, 0):
            return None
        return p / r

    merged["numPortfExRateInRptPtfCur"] = merged.apply(
        lambda r: _fx_ratio(r.strPortfISOCur, r.strReportPortfISOCur, r.datHoldDate_scope),
        axis=1,
    )
    merged["numPortfAUMInRptPtfCur"] = (
        merged["numPortfExRateInRptPtfCur"] * merged["numPortfAUM"]
    )

    # ------------------------------------------------------------------ #
    # 7️⃣  Re-attach descriptive columns lost in the group-by            #
    # ------------------------------------------------------------------ #
    descriptive = [
        "strInvestedInPortfID",
        "strInvestedInPortfName",
        "strInstISINCode",
        "strInstrumentTypeIRName",
        "strLevel1IsinCode",
    ]
    merged = (
        merged.drop(columns=[c for c in descriptive if c in merged.columns])
        .merge(
            dedup[
                ["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"]
                + descriptive
            ],
            on=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
            how="left",
        )
    )

    # keep LT threshold for downstream RG-07
    merged["numLTThreshold"] = merged["numLTThreshold"]

    return merged


##############################################################################
# BLOCK E  –  “Calculation for Internal data”
##############################################################################


def _collect_rates(
    session: Session, pairs: Iterable[Tuple[str, date]]
) -> Dict[Tuple[str, date], float]:
    pairs = set(pairs)
    if not pairs:
        return {}

    iso_set = {p[0] for p in pairs}
    date_set = {p[1] for p in pairs}

    rows = session.execute(
        select(
            VieDMIRBRSCurrencyQuote.strCurrCode,
            func.date(VieDMIRBRSCurrencyQuote.datccyqDate),
            VieDMIRBRSCurrencyQuote.numccyqrateInv,
        ).where(
            VieDMIRBRSCurrencyQuote.strCurrCode.in_(iso_set),
            func.date(VieDMIRBRSCurrencyQuote.datccyqDate).in_(date_set),
        )
    ).all()

    return {(iso, dt): rate for iso, dt, rate in rows}


# --------------------------------------------------------------------------
# Block-E – INTERNAL aggregation  (#tmpMonitoringPreviousStepInternalAgg)
# --------------------------------------------------------------------------
def aggregate_internal(df_internal: pd.DataFrame, session: Session) -> pd.DataFrame:
    """
    Fully faithful re-write of block-E.

    1. Deduplicate (ROW_NUMBER … = 1)
    2. Aggregate numeric measures
    3. Promote the aggregated measures + drop legacy copies
    4. Compute RG-03 weight
    5. Join LT scope and fetch FX quotes
    6. Convert AUM and *average cost* into report-portfolio currency
    7. Re-attach descriptive columns swallowed by the group-by
    """

    if df_internal.empty:
        return df_internal.copy()

    # 1️⃣  dedup exactly like ROW_NUMBER … = 1
    df_internal = (
        df_internal.sort_values(
            [
                "strReportPeriod",
                "strPortfLevelID",
                "strInvestedInInstrID",
                "datHoldDate",
            ],
            ascending=[True, True, True, False],
        )
        .drop_duplicates(
            subset=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
            keep="first",
        )
    )
    dedup = df_internal.copy()

    # 2️⃣  numeric aggregation
    agg_num = (
        df_internal.groupby(
            ["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
            as_index=False,
        )
        .agg(
            numHoldQuantity=("numHoldQuantity", "sum"),
            numHoldValueInPortfCur=("numHoldValueInPortfCur", "sum"),
            numHoldAvrgCostInPortfCur=("numHoldAvrgCostInPortfCur", "sum"),
            numHoldPrice=("numHoldPrice", "mean"),
            numHoldAccruedIntInstr=("numHoldAccruedIntInstr", "sum"),
            numHoldAccruedIntPortf=("numHoldAccruedIntPortf", "sum"),
        )
    )

    merged = pd.merge(
        dedup,
        agg_num,
        on=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
        how="inner",
        suffixes=("", "_agg"),
    )

    # 3️⃣  promote aggregated measures
    agg_cols = [
        "numHoldQuantity",
        "numHoldValueInPortfCur",
        "numHoldAvrgCostInPortfCur",
        "numHoldPrice",
        "numHoldAccruedIntInstr",
        "numHoldAccruedIntPortf",
    ]
    for c in agg_cols:
        merged[c] = merged.pop(f"{c}_agg")

    # 4️⃣  RG-03 weight
    merged["numWeightInReportPortfAUM"] = np.where(
        merged["numPortfAUM"].fillna(0) != 0,
        merged["numHoldValueInPortfCur"]
        * merged["numWeightInReportPortfAUM"]
        / merged["numPortfAUM"],
        np.nan,
    )

    # 5️⃣  LT scope join
    scope_keys = merged[
        ["numReportPortfGroupID", "strReportPortfGPSCode", "strReportPeriod"]
    ].drop_duplicates()

    scope_rows = session.execute(
        select(
            TblDMIRScopeLT.numReportPortfGroupID,
            TblDMIRScopeLT.strReportPortfGPSCode,
            TblDMIRScopeLT.strReportPeriod,
            TblDMIRScopeLT.strReportPortfISOCur,
            TblDMIRScopeLT.datHoldDate,
            TblDMIRScopeLT.numLTThreshold,
        ).where(
            TblDMIRScopeLT.datHoldDate.is_not(None),
            tuple_(
                TblDMIRScopeLT.numReportPortfGroupID,
                TblDMIRScopeLT.strReportPortfGPSCode,
                TblDMIRScopeLT.strReportPeriod,
            ).in_(scope_keys.itertuples(index=False, name=None)),
        )
    ).all()

    scope_df = pd.DataFrame(
        scope_rows,
        columns=[
            "numReportPortfGroupID",
            "strReportPortfGPSCode",
            "strReportPeriod",
            "strReportPortfISOCur",
            "datHoldDate_scope",
            "numLTThreshold",
        ],
    )

    merged = pd.merge(
        merged,
        scope_df,
        on=["numReportPortfGroupID", "strReportPortfGPSCode", "strReportPeriod"],
        how="left",
    )

    # 6️⃣  FX conversions
    rate_pairs = [
        (p_iso, dt)
        for p_iso, r_iso, dt in merged[
            ["strPortfISOCur", "strReportPortfISOCur", "datHoldDate_scope"]
        ].itertuples(index=False, name=None)
        if dt
        for p_iso in (p_iso, r_iso)
    ]
    fx_map = _collect_rates(session, rate_pairs)

    def _fx(p_iso: str, r_iso: str, d: date) -> float | None:
        pv = fx_map.get((p_iso, d))
        rv = fx_map.get((r_iso, d))
        if pv is None or rv in (None, 0):
            return None
        return pv / rv

    merged["numPortfExRateInRptPtfCur"] = merged.apply(
        lambda r: _fx(r.strPortfISOCur, r.strReportPortfISOCur, r.datHoldDate_scope),
        axis=1,
    )
    merged["numPortfAUMInRptPtfCur"] = (
        merged["numPortfExRateInRptPtfCur"] * merged["numPortfAUM"]
    )
    merged["numHoldAvrgCostInPortfCur"] = (
        merged["numPortfExRateInRptPtfCur"] * merged["numHoldAvrgCostInPortfCur"]
    )

    # 7️⃣  re-attach descriptive columns
    desc_cols = [
        "strInvestedInPortfID",
        "strInvestedInPortfName",
        "strInstISINCode",
        "strInstrumentTypeIRName",
        "strLevel1IsinCode",
    ]
    merged = (
        merged.drop(columns=[c for c in desc_cols if c in merged.columns])
        .merge(
            dedup[
                ["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"]
                + desc_cols
            ],
            on=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
            how="left",
        )
    )

    # keep LT threshold for RG-07
    merged["numLTThreshold"] = merged["numLTThreshold"]

    return merged

# Block F ----------------------------------------------------------------------------------------------

def insert_rows(
    df: pd.DataFrame,
    session: Session,
    src: str,         # 'EXTERNAL' or 'INTERNAL'
    step: int,        # @P_Step  → numPortfLevel
    audit_id: int | None = None,   # optional, pass through if you have it
) -> int:
    """
    Bulk-insert *df* into **TblDMIRMonitoringLTWrk**, reproducing all
    “calculated” columns the T-SQL INSERTs build in block-F.

    It works for either stream:

    * ``src='EXTERNAL'``  – rows coming from `aggregate_external`
    * ``src='INTERNAL'``  – rows coming from `aggregate_internal`

    The helper is 100 % ORM (no `text()` or `pd.to_sql`).
    """

    if df.empty:
        return 0

    now = datetime.utcnow()
    model_cols: List[str] = [c.name for c in TblDMIRMonitoringLTWrk.__table__.columns]

    def undrlyg_lt_flag(row: Dict) -> int:
        """Implement the RG-07 CASE WHEN … THEN 1/0."""
        # ① threshold
        if (row.get("numWeightInReportPortfAUM") or 0) < (row.get("numLTThreshold") or 0):
            return 0
        # ② self-investment check  ( … CHARINDEX('.'+InvestedID+'.', PortfLevelID) … )
        pattern = f".{row.get('strInvestedInPortfID', '')}."
        if pattern in f".{row.get('strPortfLevelID', '')}.":
            return 0
        return 1

    objects: List[TblDMIRMonitoringLTWrk] = []
    for row in df.to_dict(orient="records"):
        # ── computed columns (common to both paths) ------------------------
        row.update(
            numPortfLevel=step,
            strSrcUndrlygHoldData=src,
            datLastModifDate=now,
            numPresUndrlygHoldData=0
            if pd.isna(row.get("numInvestedInPortfAUM"))
            else 1,  # RG-06
            numUndrlygLTflag=undrlyg_lt_flag(row),       # RG-07
            numAuditId=audit_id,
        )

        # ── hedging defaults (external gets NULLs, internal starts as “U”) --
        if src == "INTERNAL":
            row.setdefault("strHedgedShClass", "U")
            row.setdefault("numHedgedFactor", 1)

        # keep only model columns; anything missing becomes NULL ------------
        data: Dict = {col: row.get(col) for col in model_cols}
        objects.append(TblDMIRMonitoringLTWrk(**data))

    session.bulk_save_objects(objects)
    session.commit()
    return len(objects)


# Hedging / Exclusion ----------------------------------------------------------------------------------------------

def apply_hedging(session: Session, step: int) -> None:
    """Replicates RG-08 hedging logic (fully ORM, zero raw SQL)."""

    # ------------------------------------------------------------------ #
    # 1️⃣  Flag INTERNAL positions that are hedged (strHedgedShClass = 'H')
    # ------------------------------------------------------------------ #
    h = aliased(TblDMIRDMCHolding)
    i = aliased(TblDMIRBRSInstrument)
    irt = aliased(TblDMIRInstrumentIRType)

    hedged_exists = (
        exists()
        .where(
            h.strPortfGPSCode == TblDMIRMonitoringLTWrk.strInvestedInPortfID,
            h.datACCDATE == TblDMIRMonitoringLTWrk.datLastNAVDate,
            h.strUnderlSecCode == TblDMIRMonitoringLTWrk.strInstISINCode,
            i.strInstAladdin == h.strInstAladdin,
            irt.numInstrTypeID == i.numInstTypeId,
            irt.strReportingType == "class7",
            irt.strInstrumentTypeIRName == "Forex",
        )
        .correlate(TblDMIRMonitoringLTWrk)
    )

    session.execute(
        update(TblDMIRMonitoringLTWrk)
        .where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step,
            TblDMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
            hedged_exists,
        )
        .values(strHedgedShClass="H")
    )

    # -------------------------------------------------------------- #
    # 2️⃣  Compute numHedgedFactor for rows flagged as hedged
    #     factor = ROUND( net_type_part / NULLIF(tx_change_dev,0), 0 )
    #              / NULLIF(net_total_opcvm,0)
    # -------------------------------------------------------------- #
    v = aliased(TblDMIRDMCVALO)

    factor_expr = (
        func.round(
            v.numActifNetTypePartConcerne / func.nullif(v.numTxchangedevvldevref, 0),
            0,
        )
        / func.nullif(v.numActifNetTotalOpcVm, 0)
    )

    factor_sq = (
        select(
            TblDMIRMonitoringLTWrk.id.label("wrk_id"),  # ← primary-key column name
            factor_expr.label("factor"),
        )
        .select_from(TblDMIRMonitoringLTWrk)
        .join(
            v,
            and_(
                v.strPortfGPSCode == TblDMIRMonitoringLTWrk.strInvestedInPortfID,
                v.datDateVL == TblDMIRMonitoringLTWrk.datLastNAVDate,
                v.strShareISINCode == TblDMIRMonitoringLTWrk.strInstISINCode,
            ),
        )
        .where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step,
            TblDMIRMonitoringLTWrk.strHedgedShClass == "H",
        )
        .subquery()
    )

    session.execute(
        update(TblDMIRMonitoringLTWrk)
        .where(TblDMIRMonitoringLTWrk.id == factor_sq.c.wrk_id)
        .values(numHedgedFactor=factor_sq.c.factor)
    )

    # -------------------------------------------------------------- #
    # 3️⃣  Sub-tract total forex hedging MV from numInvestedInPortfAUM
    # -------------------------------------------------------------- #
    i2 = aliased(TblDMIRBRSInstrument)
    irt2 = aliased(TblDMIRInstrumentIRType)
    d = aliased(TblDMIRDMCHolding)

    all_fx_sq = (
        select(
            TblDMIRMonitoringLTWrk.id.label("wrk_id"),
            func.sum(d.numHoldValuInPortfCur).label("total_mv"),
        )
        .select_from(TblDMIRMonitoringLTWrk)
        .join(
            d,
            and_(
                d.strPortfGPSCode == TblDMIRMonitoringLTWrk.strInvestedInPortfID,
                d.datACCDATE == TblDMIRMonitoringLTWrk.datLastNAVDate,
            ),
        )
        .join(i2, i2.strInstAladdin == d.strInstAladdin)
        .join(irt2, irt2.numInstrTypeID == i2.numInstTypeId)
        .where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step,
            TblDMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
            TblDMIRMonitoringLTWrk.strHedgedShClass.in_(["U", "H"]),
            irt2.strReportingType == "class7",
            irt2.strInstrumentTypeIRName == "Forex",
            d.strUnderlSecCode.is_not(None),
        )
        .group_by(TblDMIRMonitoringLTWrk.id)
        .subquery()
    )

    session.execute(
        update(TblDMIRMonitoringLTWrk)
        .where(TblDMIRMonitoringLTWrk.id == all_fx_sq.c.wrk_id)
        .values(
            numInvestedInPortfAUM=TblDMIRMonitoringLTWrk.numInvestedInPortfAUM
            - all_fx_sq.c.total_mv
        )
    )

    # -------------------------------------------------------------- #
    # 4️⃣  Add *relevant* forex MV back for truly hedged shares
    #     ( scaled by numHedgedFactor )
    # -------------------------------------------------------------- #
    i3 = aliased(TblDMIRBRSInstrument)
    irt3 = aliased(TblDMIRInstrumentIRType)
    d2 = aliased(TblDMIRDMCHolding)

    rel_fx_sq = (
        select(
            TblDMIRMonitoringLTWrk.id.label("wrk_id"),
            func.sum(
                d2.numHoldValuInPortfCur
                / func.nullif(TblDMIRMonitoringLTWrk.numHedgedFactor, 0)
            ).label("rel_mv"),
        )
        .select_from(TblDMIRMonitoringLTWrk)
        .join(
            d2,
            and_(
                d2.strPortfGPSCode == TblDMIRMonitoringLTWrk.strInvestedInPortfID,
                d2.datACCDATE == TblDMIRMonitoringLTWrk.datLastNAVDate,
                d2.strUnderlSecCode == TblDMIRMonitoringLTWrk.strInstISINCode,
            ),
        )
        .join(i3, i3.strInstAladdin == d2.strInstAladdin)
        .join(irt3, irt3.numInstrTypeID == i3.numInstTypeId)
        .where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step,
            TblDMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
            TblDMIRMonitoringLTWrk.strHedgedShClass == "H",
            irt3.strReportingType == "class7",
            irt3.strInstrumentTypeIRName == "Forex",
            d2.strUnderlSecCode.is_not(None),
        )
        .group_by(TblDMIRMonitoringLTWrk.id)
        .subquery()
    )

    session.execute(
        update(TblDMIRMonitoringLTWrk)
        .where(TblDMIRMonitoringLTWrk.id == rel_fx_sq.c.wrk_id)
        .values(
            numInvestedInPortfAUM=TblDMIRMonitoringLTWrk.numInvestedInPortfAUM
            + rel_fx_sq.c.rel_mv
        )
    )

    # ---------------------------------------------------------------------------- #
    session.commit()


def apply_exclusions(session: Session, step: int) -> None:
    """
    Replicates the stored-procedure’s LT-exclusion logic (no raw SQL).

    For every monitoring row of *numPortfLevel == step* whose
    `(strPortfLevelID, strInvestedInPortfID)` is listed in
    **TblDMIRLTExclude**, set both LT flags to 0.
    """
    Excl = aliased(TblDMIRLTExclude)          # just for clarity

    stmt = (
        update(TblDMIRMonitoringLTWrk)
        .where(
            TblDMIRMonitoringLTWrk.numPortfLevel == step,
            exists()
            .where(
                and_(
                    Excl.strPortfLevelID
                    == TblDMIRMonitoringLTWrk.strPortfLevelID,
                    Excl.strInvestedInPortfID
                    == TblDMIRMonitoringLTWrk.strInvestedInPortfID,
                )
            )
            .correlate(TblDMIRMonitoringLTWrk)
        )
        .values(
            numUndrlygLTflag=0,
            numUndrlygUserLTflag=0,
        )
    )

    session.execute(stmt)
    session.commit()

#### ----------------------

from __future__ import annotations

"""Airflow DAG that orchestrates the Python re‑write of
`DMIR.stpDMIRLTMonitoringWrk_StepN`.

⚠️  Business logic lives in helper modules.  This file only wires the
@tasks together — exactly what the user asked for (“keep the function names,
no code bodies”).
"""

from datetime import datetime
from typing import Tuple

import pandas as pd
from airflow.decorators import dag, task
from airflow.utils.dates import days_ago

# project helpers ------------------------------------------------------------------
from dags.common.utils import get_session
from helpers_external import (
    fetch_external_prev_step,
    aggregate_external,
)
from helpers_internal import (
    fetch_internal_prev_step,
    move_internal_to_external,
    aggregate_internal,
)
from helpers_insert import insert_rows
from hedging import apply_hedging
from exclusions import apply_exclusions

# ----------------------------------------------------------------------------------
# DAG
# ----------------------------------------------------------------------------------
DEFAULT_ARGS = {
    "owner": "dmir",
    "start_date": days_ago(1),
    "retries": 0,
}


@dag(
    dag_id="dmir_monitoring_stepn",
    schedule=None,
    catchup=False,
    default_args=DEFAULT_ARGS,
    tags=["dmir"],
)
def dmir_monitoring_stepn(step: int = 2):  # ⇐ equivalent to @P_Step
    """Trigger one end‑to‑end monitoring run for level *step*."""

    # 1️⃣  ---------------  load level‑(step‑1) data  --------------------

    @task()
    def load_external() -> pd.DataFrame:
        with get_session() as sess:
            return fetch_external_prev_step(sess, step)

    @task()
    def load_internal() -> Tuple[pd.DataFrame, pd.DataFrame]:
        with get_session() as sess:
            return fetch_internal_prev_step(sess, step)

    # 2️⃣  ---------------  transform ------------------------------------

    @task()
    def split_internal(tables: Tuple[pd.DataFrame, pd.DataFrame]) -> Tuple[pd.DataFrame, pd.DataFrame]:
        _raw, enriched = tables  # we only need the enriched set for the split
        return move_internal_to_external(enriched)

    @task()
    def aggr_external(df_ext: pd.DataFrame) -> pd.DataFrame:
        with get_session() as sess:
            return aggregate_external(df_ext, sess)

    @task()
    def aggr_internal(df_int: pd.DataFrame) -> pd.DataFrame:
        with get_session() as sess:
            return aggregate_internal(df_int, sess)

    # 3️⃣  ---------------  load into target table -----------------------

    @task()
    def write_external(df: pd.DataFrame) -> int:
        with get_session() as sess:
            return insert_rows(df, sess, src="EXTERNAL", step=step)

    @task()
    def write_internal(df: pd.DataFrame) -> int:
        with get_session() as sess:
            return insert_rows(df, sess, src="INTERNAL", step=step)

    # 4️⃣  ---------------  post‑processing updates ----------------------

    @task()
    def hedging_task():
        with get_session() as sess:
            apply_hedging(sess, step)

    @task()
    def exclusion_task():
        with get_session() as sess:
            apply_exclusions(sess, step)

    # ── DAG wiring ------------------------------------------------------

    ext_df = load_external()
    int_tables = load_internal()

    moved_ext, clean_int = split_internal(int_tables)

    full_ext = pd.concat([ext_df, moved_ext])  # merge native + moved rows

    agg_ext = aggr_external(full_ext)
    agg_int = aggr_internal(clean_int)

    ext_rows = write_external(agg_ext)
    int_rows = write_internal(agg_int)

    #   hedging & exclusions run **after** both inserts succeed
    [ext_rows, int_rows] >> hedging_task() >> exclusion_task()


# instantiate DAG
_ = dmir_monitoring_stepn()



---



@task()
    def load_external() -> str:
        with get_session() as sess:
            df = fetch_external_prev_step(sess, step)
        return save_json(df)

    @task()
    def load_internal() -> Tuple[str, str]:
        with get_session() as sess:
            raw, enriched = fetch_internal_prev_step(sess, step)
        return save_json(raw), save_json(enriched)

    # 2️⃣  -------------------- transform -----------------------------------
    @task()
    def split_internal(paths: Tuple[str, str]) -> Tuple[str, str]:
        _, enrich_path = paths  # raw table not used downstream
        df_enriched = load_json(enrich_path)
        moved_ext, clean_int = move_internal_to_external(df_enriched)
        return save_json(moved_ext), save_json(clean_int)

    @task()
    def aggr_external(ext_path: str) -> str:
        df_ext = load_json(ext_path)
        with get_session() as sess:
            df_agg = aggregate_external(df_ext, sess)
        return save_json(df_agg)

    @task()
    def aggr_internal(int_path: str) -> str:
        df_int = load_json(int_path)
        with get_session() as sess:
            df_agg = aggregate_internal(df_int, sess)
        return save_json(df_agg)

    # 3️⃣  -------------------- load into target table ----------------------
    @task()
    def write_external(path: str) -> int:
        df = load_json(path)
        with get_session() as sess:
            return insert_rows(df, sess, src="EXTERNAL", step=step)

    @task()
    def write_internal(path: str) -> int:
        df = load_json(path)
        with get_session() as sess:
            return insert_rows(df, sess, src="INTERNAL", step=step)

    # 4️⃣  -------------------- post‑processing ----------------------------
    @task()
    def hedging_task():
        with get_session() as sess:
            apply_hedging(sess, step)

    @task()
    def exclusion_task():
        with get_session() as sess:
            apply_exclusions(sess, step)


---


ext_json = load_external()
    int_raw_json, int_enrich_json = load_internal()

    moved_ext_json, clean_int_json = split_internal((int_raw_json, int_enrich_json))

    full_ext_json = aggr_external(ext_json)  # native external first

    # concatenate moved‑external + native external before aggregation
    @task()
    def concat_external(native_path: str, moved_path: str) -> str:
        native_df = load_json(native_path)
        moved_df = load_json(moved_path)
        combined = pd.concat([native_df, moved_df], ignore_index=True)
        return save_json(combined)

    combined_ext_json = concat_external(full_ext_json, moved_ext_json)

    agg_ext_json = aggr_external(combined_ext_json)
    agg_int_json = aggr_internal(clean_int_json)

    ext_rows = write_external(agg_ext_json)
    int_rows = write_internal(agg_int_json)

    [ext_rows, int_rows] >> hedging_task() >> exclusion_task()
