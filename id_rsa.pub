import pandas as pd
import polars as pl
import numpy as np
import gc

def process_final_step_3(
    df_DMIRTransparizLTWrk: pd.DataFrame,
    df_instrument: pd.DataFrame,
    df_instrument_irtype: pd.DataFrame,
):
    # ---------- pandas -> polars --------------------------------------
    dfl = pl.from_pandas(df_DMIRTransparizLTWrk, include_index=False)
    dfinst = pl.from_pandas(df_instrument, include_index=False)
    dftir = pl.from_pandas(df_instrument_irtype, include_index=False)

    print("start dfl", (dfl.height, dfl.width), get_hardware_info())

    # Optional compaction
    cat_cols = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID",
        "strInvestedInPortfISOCur","strInvestedInPortfID"
    ]
    for c in cat_cols:
        if c in dfl.columns and dfl.schema[c] == pl.Utf8:
            dfl = dfl.with_columns(pl.col(c).cast(pl.Categorical))

    num_int_cols = ["numReportLevelID","numInventoryLevel","numInstID","numUndrlygIRLTflag","numPresUndrlygHoldData"]
    for c in num_int_cols:
        if c in dfl.columns:
            dfl = dfl.with_columns(pl.col(c).cast(pl.Int64))

    float_cols = ["numWeightedAmtInReportPortf","numWeightedQtqInReportPortf"]
    for c in float_cols:
        if c in dfl.columns:
            dfl = dfl.with_columns(pl.col(c).cast(pl.Float64))

    print("after dtype tightening", (dfl.height, dfl.width), get_hardware_info())

    # ---------- Keys ---------------------------------------------------
    join_keys = ["strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur"]
    join_keys_full = ["strReportPeriod","numInventoryLevel","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur"]
    base_cols = join_keys + ["numReportLevelID"]

    # ---------- Prep lookup of lowest-level rows ----------------------
    df_lkp = (
        dfl.filter(pl.col("numLowestInventoryflag") == 1)
           .select(base_cols)
           .unique(maintain_order=True)
    )
    print("df_lkp", (df_lkp.height, df_lkp.width), get_hardware_info())

    # ---------- PART 1 (exact 4-key join; keep numInventoryLevel) -----
    cond_master = (
        (pl.col("numLowestInventoryflag") == 0) &
        (
            pl.col("strInvestedInPortfID").is_null() |
            (pl.col("numUndrlygIRLTflag") == 0) |
            (pl.col("numPresUndrlygHoldData") == 0)
        )
    )
    part1 = (
        dfl.filter(cond_master)
           .select(join_keys_full)
           .join(df_lkp.select(join_keys + ["numReportLevelID"]), on=join_keys, how="left")
           .rename({"numReportLevelID": "numReportLevelID_lkp"})
    )
    print("part1", (part1.height, part1.width), get_hardware_info())
    gc.collect(); get_hardware_info()

    # ---------- PART 2 (SQL-correct descendant LIKE) ------------------
    # SQL conditions:
    #   h.numLowestInventoryflag = 0
    #   h.strInvestedInPortfID IS NOT NULL
    #   h.numUndrlygIRLTflag = 1
    #   h.numPresUndrlygHoldData = 1
    cond_part2 = (
        (pl.col("numLowestInventoryflag") == 0) &
        pl.col("strInvestedInPortfID").is_not_null() &
        (pl.col("numUndrlygIRLTflag") == 1) &
        (pl.col("numPresUndrlygHoldData") == 1)
    )
    h = (
        dfl.filter(cond_part2)
           .select(join_keys_full + ["strInvestedInPortfID"])
           .with_columns(
               parent_prefix = (pl.col("strPortfLevelID").cast(pl.Utf8) + pl.lit(".") + pl.col("strInvestedInPortfID").cast(pl.Utf8))
           )
    )
    print("part2 seed", (h.height, h.width), get_hardware_info())

    # Lowest-level lookup for Part 2: only what SQL uses for LIKE + level id
    lkp_part2 = (
        dfl.filter(pl.col("numLowestInventoryflag") == 1)
           .select(["strReportPeriod","strPortfLevelID","numReportLevelID"])
           .unique(maintain_order=True)
    )

    # Join on strReportPeriod, then keep descendants via starts_with(parent_prefix)
    pre = (
        h.join(lkp_part2, on="strReportPeriod", how="left")  # right strPortfLevelID -> 'strPortfLevelID_right'
         .filter(pl.col("strPortfLevelID_right").cast(pl.Utf8).str.starts_with(pl.col("parent_prefix")))
         .groupby(join_keys_full, maintain_order=True)
         .agg(pl.col("numReportLevelID").min().alias("numReportLevelID_lkp"))
    )
    print("part2 pre-agg", (pre.height, pre.width), get_hardware_info())

    part2_final = pre.select(join_keys_full + ["numReportLevelID_lkp"])
    print("part2_final", (part2_final.height, part2_final.width), get_hardware_info())

    del pre, h, lkp_part2
    gc.collect(); get_hardware_info()

    # ---------- UNION the two branches (carry numInventoryLevel) ------
    df_step_final_3 = pl.concat([part1, part2_final], how="vertical_relaxed")
    print("df_step_final_3", (df_step_final_3.height, df_step_final_3.width), get_hardware_info())
    del part1, part2_final
    gc.collect(); get_hardware_info()

    # ---------- Update main table on join_keys_full -------------------
    df_updated = dfl.join(
        df_step_final_3.select(join_keys_full + ["numReportLevelID_lkp"]),
        on=join_keys_full,
        how="left",
    )
    print("df_updated (post-join)", (df_updated.height, df_updated.width), get_hardware_info())

    # Upsert numReportLevelID + timestamp (matches your UPDATE step)
    now_ts = pd.Timestamp.now()
    df_updated = df_updated.with_columns(
        changed = pl.col("numReportLevelID_lkp").is_not_null()
    ).with_columns(
        numReportLevelID = pl.when(pl.col("changed"))
                              .then(pl.col("numReportLevelID_lkp").cast(pl.Int64))
                              .otherwise(pl.col("numReportLevelID")),
        datLastModifDate = pl.when(pl.col("changed"))
                              .then(pl.lit(now_ts).cast(pl.Datetime))
                              .otherwise(pl.col("datLastModifDate")),
    ).drop(["numReportLevelID_lkp","changed"])
    print("df_updated (after upsert)", (df_updated.height, df_updated.width), get_hardware_info())

    # --- Deletion 1 (kept as before; you said 3 not important) -------
    df_updated = df_updated.filter(
        ~(
            (pl.col("numInstID").fill_null(-1) == -1) &
            (pl.col("numWeightedAmtInReportPortf").fill_null(0.0) == 0.0)
        )
    )
    print("df_updated (after deletion1)", (df_updated.height, df_updated.width), get_hardware_info())

    # --- Deletion 2 (Forex class7) -----------------------------------
    if dftir.is_empty():
        dftir = pl.DataFrame(
            {"numInstrTypeID": pl.Series([], dtype=pl.Int64),
             "strReportingType": pl.Series([], dtype=pl.Utf8),
             "strInstrumentTypeIRName": pl.Series([], dtype=pl.Utf8)}
        )

    forex_type_ids = (
        dftir.filter(
            (pl.col("strReportingType") == "class7") &
            (pl.col("strInstrumentTypeIRName") == "Forex")
        )
        .select("numInstrTypeID")
        .unique()
        .to_series()
        .to_list()
    )

    df_updated = df_updated.join(
        dfinst.select(["numInstID","numInstTypeId"]).unique(maintain_order=True),
        on="numInstID",
        how="left",
    )
    print("df_updated (mapped inst type)", (df_updated.height, df_updated.width), get_hardware_info())

    mask_forex = (
        pl.col("numInstTypeId").is_in(forex_type_ids)
        & (pl.col("numWeightedQtqInReportPortf").fill_null(0.0) == 0.0)
        & (pl.col("numWeightedAmtInReportPortf").fill_null(0.0) == 0.0)
    )
    df_updated = df_updated.filter(~mask_forex).drop("numInstTypeId")
    print("df_updated (final)", (df_updated.height, df_updated.width), get_hardware_info())

    # ---------- polars -> pandas --------------------------------------
    result_pd = df_updated.to_pandas()
    return result_pd
