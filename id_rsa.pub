from datetime import date, timedelta
from typing import Iterable, Tuple

import pandas as pd
from sqlalchemy import func, and_, text

# ------------------------------------------------------------------
# helpers ----------------------------------------------------------
# ------------------------------------------------------------------
def _eom_prev_month(d: date) -> date:
    """Return the last calendar day of the previous month."""
    first_of_month = d.replace(day=1)
    return first_of_month - timedelta(days=1)


def _yyyymm(d: date) -> str:
    """Return YYYYMM string for a date."""
    return d.strftime("%Y%m")


# ------------------------------------------------------------------
# main -------------------------------------------------------------
# ------------------------------------------------------------------
def _build_df_to_remove_dmc(current_date: date | None = None) -> pd.DataFrame:
    """
    Build the set of (GPS, period) pairs that *should* be removed from
    DMIR.tblDMIRScopeLT for the DMC data‑source, faithfully reproducing the
    logic in the latest SQL procedure.

    Returns
    -------
    pd.DataFrame
        Columns → num_transp, num_scope, gps, period
        (empty if nothing qualifies).
    """
    current_date = current_date or date.today()
    eom_prev = _eom_prev_month(current_date)
    prev_report_period = _yyyymm(eom_prev)

    session = get_session()
    try:
        # ----------------------------------------------------------
        # 1)  first cut – rows where TRANSPARIZ AUM ≈ Scope AUM ----
        # ----------------------------------------------------------
        agg_q = (
            session.query(
                func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
                DMIRScopeLT.numReportPortfAUM.label("num_scope"),
                DMIRScopeLT.strReportPortfGPSCode.label("gps"),
                DMIRScopeLT.strReportPeriod.label("period"),
            )
            .select_from(DMIRScopeLT)
            .join(
                DMIRTransparizLT,
                and_(
                    DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
                    DMIRTransparizLT.strReportPortfGPSCode
                    == DMIRScopeLT.strReportPortfGPSCode,
                ),
            )
            .filter(
                DMIRScopeLT.strReportPortfHoldSrc == "DMC",
                DMIRTransparizLT.numLowestInventoryflag == 1,
                DMIRTransparizLT.numInstID > 1,
            )
            .group_by(
                DMIRScopeLT.numReportPortfAUM,
                DMIRScopeLT.strReportPortfGPSCode,
                DMIRScopeLT.strReportPeriod,
            )
        )

        df = pd.DataFrame(session.execute(agg_q).mappings().all())
        normalize_type(df)

        if df.empty:
            return pd.DataFrame(columns=["num_transp", "num_scope", "gps", "period"])

        # AUM‑difference tolerance
        df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

        # ----------------------------------------------------------
        # 2)  pairs having INST‑ID  = –1  → exclude ----------------
        # ----------------------------------------------------------
        bad_pairs = get_all_as_df(
            session.query(
                DMIRTransparizLT.strReportPortfGPSCode,
                DMIRTransparizLT.strReportPeriod,
            )
            .filter(
                DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
                DMIRTransparizLT.numInstID == -1,
            )
            .distinct()
        )
        exclude_missing_instid = set(bad_pairs.apply(tuple, axis=1))

        df = df[
            ~df.apply(lambda r: (r.gps, r.period) in exclude_missing_instid, axis=1)
        ]

        # ----------------------------------------------------------
        # 3)  do‑not‑delete list for the *latest* month ------------
        # ----------------------------------------------------------
        audit_subq = (
            session.query(
                DMIRDMCHolding.strPortfGPSCode.label("gps"),
                func.max(DMIRDMCHolding.numAuditId).label("holdings_audit_id"),
            )
            .join(
                DMIRBRSDMCPortfIndicators,
                and_(
                    DMIRBRSDMCPortfIndicators.strPortfGPSCode
                    == DMIRDMCHolding.strPortfGPSCode,
                    DMIRBRSDMCPortfIndicators.datPeriodLastNav
                    == DMIRDMCHolding.datACCDATE,
                ),
            )
            .filter(DMIRBRSDMCPortfIndicators.datPeriodLastDay == eom_prev)
            .group_by(DMIRDMCHolding.strPortfGPSCode)
            .subquery()
        )

        gps_do_not_delete = get_all_as_df(
            session.query(DMIRTransparizLT.strReportPortfGPSCode)
            .join(
                audit_subq,
                audit_subq.c.gps == DMIRTransparizLT.strReportPortfID,
            )
            .filter(
                DMIRTransparizLT.datPeriodLastDay == eom_prev,
                DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
                audit_subq.c.holdings_audit_id > DMIRTransparizLT.numAuditId,
            )
            .distinct()
        )["strReportPortfGPSCode"].tolist()

        df = df[
            ~(
                (df.period == prev_report_period)
                & (df.gps.isin(gps_do_not_delete))
            )
        ]

        # ----------------------------------------------------------
        # 4)  external / special data safeguard -------------------
        # ----------------------------------------------------------
        ext_pairs_q = (
            session.query(
                DMIRMonitoringLT.strReportPortfGPSCode.label("gps"),
                DMIRMonitoringLT.strReportPeriod.label("period"),
            )
            .filter(
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_(["EXTERNAL", "SPECIAL"]),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .join(
                DMIRExternalSpecialHolding,
                and_(
                    DMIRExternalSpecialHolding.strPortfISINCode
                    == DMIRMonitoringLT.strInstISINCode,
                    DMIRExternalSpecialHolding.datHoldDate
                    >= func.coalesce(
                        DMIRMonitoringLT.datLastNAVDate, date(2000, 1, 1)
                    ),
                    DMIRExternalSpecialHolding.datHoldDate
                    <= DMIRMonitoringLT.datHoldDate,
                    DMIRExternalSpecialHolding.numAuditId
                    > DMIRMonitoringLT.numAuditId,
                ),
            )
            .distinct()
        )

        ext_pairs = set(get_all_as_df(ext_pairs_q).apply(tuple, axis=1))
        df = df[
            ~df.apply(lambda r: (r.gps, r.period) in ext_pairs, axis=1)
        ]

        # ----------------------------------------------------------
        # 5)  done -------------------------------------------------
        # ----------------------------------------------------------
        return (
            df[["num_transp", "num_scope", "gps", "period"]]
            if not df.empty
            else pd.DataFrame(columns=["num_transp", "num_scope", "gps", "period"])
        )

    finally:
        session.close()
