for tbl, pair in scopes.items():
    # 1) Summary counts
    df_summary = fetch_group_counts(session, pair, audit_id_cutoff, join_mode=join_mode)
    p_summary = Path(OUTDIR) / f"{tbl}_summary.csv"
    df_summary.to_csv(p_summary, index=False)
    csv_paths.append(p_summary)
    logging.info(f"Wrote {p_summary}")

    # 2) Column diffs
    cols_with_types = get_shared_columns_with_types(engine, pair["legacy"], pair["python"])
    df_col = fetch_column_diffs(session, pair, cols_with_types, df_summary, join_mode=join_mode)
    p_col = Path(OUTDIR) / f"{tbl}_column_diffs.csv"
    df_col.to_csv(p_col, index=False)
    csv_paths.append(p_col)
    logging.info(f"Wrote {p_col}")

    # >>> NEW: compute OK / KO counts and build a small stats bar
    ok_count = int((df_summary["status"] == "OK").sum()) if not df_summary.empty else 0
    ko_count = int((df_summary["status"] == "KO").sum()) if not df_summary.empty else 0
    stats_html = f'''
      <div class="stats">
        <span class="pill ok">OK: {ok_count}</span>
        <span class="pill ko">KO: {ko_count}</span>
      </div>
    '''

    # 3) Prepare HTML
    safe_id = re.sub(r"[^a-zA-Z0-9_-]", "_", tbl)
    summary_table_html = (
        df_summary.to_html(index=False)
        .replace("<td>OK</td>", '<td class="ok">OK</td>')
        .replace("<td>KO</td>", '<td class="ko">KO</td>')
    )
    sections.append(
        {
            "id": safe_id,
            "title": tbl,
            # >>> NEW: prepend stats bar above the table
            "summary_html": stats_html + summary_table_html,
            "diffs_html": df_col.to_html(index=False),
        }
    )
