            # default instr-id like SQL: external → '-1'
            strInvestedInInstrID=row.get("strInvestedInInstrID") or ("-1" if src == "EXTERNAL" else "XX"),
        )

        # ── hedging defaults only for INTERNAL path ------------------------
        if src == "INTERNAL":
            row.setdefault("strHedgedShClass", "U")
            row.setdefault("numHedgedFactor", 1)
