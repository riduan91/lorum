@monitor_mem()
def apply_delta_adjustments(df_tmp: pd.DataFrame, df_delta: pd.DataFrame, max_workers=24):
    inst_codes = df_tmp["strInstAladdin"].dropna().unique().tolist()
    chunks = [inst_codes[i:i + 1000] for i in range(0, len(inst_codes), 1000)]
    columns = df_tmp.columns

    dfs_instr = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {exe.submit(_apply_delta_adjustments_instruments_single, idx, chunk): idx
                   for idx, chunk in enumerate(chunks)}
        for f in as_completed(futures):
            dfs_instr.append(f.result())

    if not dfs_instr:
        return pd.DataFrame(columns=columns)

    df_instr = pd.concat(dfs_instr, ignore_index=True)
    df_tmp = df_tmp.merge(df_instr, on="strInstAladdin", how="left", suffixes=("", "_instr"))
    eligible_alpha = set(df_instr["strInstAladdin"])

    # Prepare alpha and DMC data
    alpha_df = df_delta.rename(columns={
        "strInstrmtCd": "strInstAladdin",
        "numPortfGroupFkey": "numReportPortfGroupID",
        "numPtfFkey": "strPortfIDNumPart"
    })
    alpha_df["strPortfIDNumPart"] = alpha_df["strPortfIDNumPart"].fillna(-2)

    dmc_df = df_delta.rename(columns={
        "strInstrmtCd": "strInstAladdin",
        "strProdCd": "strPortfID"
    })

    # Unique tuples for scaling
    insts = df_tmp[[
        "strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID",
        "strPortfIDNumPart", "strPortfID", "numHoldQuantity"
    ]].drop_duplicates()
    insts["strPortfIDNumPart"] = insts["strPortfIDNumPart"].fillna(-2)

    # Merge alpha (only eligible)
    alpha_merge = insts[insts["strInstAladdin"].isin(eligible_alpha)].merge(
        alpha_df, on=["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart"],
        how="left"
    )
    alpha_merge["factor"] = np.where(
        alpha_merge["numPosQty"] != 0,
        (alpha_merge["numDeltaAdjedNotionalValu"] / alpha_merge["numPosQty"]) * alpha_merge["numHoldQuantity"],
        0.0
    )

    # Fill back to insts
    insts = insts.merge(
        alpha_merge[["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart",
                     "factor", "numPosQty"]],
        on=["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart"],
        how="left"
    )

    # DMC for missing
    missing = insts[insts["factor"].isna()].merge(
        dmc_df, on=["strInstAladdin", "datPeriodLastDay", "strPortfID"], how="left"
    )
    insts.loc[insts["factor"].isna(), ["factor", "numPosQty"]] = missing[
        ["numDeltaAdjNotionalValue", "numPosQty"]
    ].values

    # Map back to df_tmp
    df_tmp = df_tmp.merge(
        insts[["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart", "strPortfID",
               "factor", "numPosQty"]],
        on=["strInstAladdin", "datPeriodLastDay", "numReportPortfGroupID", "strPortfIDNumPart", "strPortfID"],
        how="left"
    )
    df_tmp["numDeltaAdjustedSpread"] = df_tmp["factor"]
    df_tmp["OriginalQty"] = df_tmp["numPosQty"]

    return df_tmp.drop(columns=["factor", "numPosQty"])
