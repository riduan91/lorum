    for row in df.to_dict(orient="records"):
        # ── computed columns (common to both paths) ------------------------
        # RG-06 presence flag uses the *_with_nav enrichments
        pres = 0 if row.get("numInvestedInPortfAUM") in (None, np.nan) else 1

        row.update(
