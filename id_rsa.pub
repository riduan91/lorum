def nearest_label(avg_in, agency: str, df_IRRatingsBetween: pd.DataFrame) -> pd.Series:
    """
    Map numeric averages to the nearest string rating for a given agency.
    Accepts a Series or a 1-col DataFrame.
    """
    # coerce to a 1D Series
    if isinstance(avg_in, pd.DataFrame):
        if avg_in.shape[1] != 1:
            raise ValueError("nearest_label expects a Series or a 1-column DataFrame.")
        s = avg_in.iloc[:, 0]
    else:
        s = avg_in

    s = pd.to_numeric(s, errors="coerce")

    ref = (
        df_IRRatingsBetween[df_IRRatingsBetween["strRatingAgency"] == agency]
        [["strRating", "numRating"]]
        .drop_duplicates()
        .sort_values("numRating")
        .reset_index(drop=True)
    )
    if ref.empty:
        return pd.Series(["NR"] * len(s), index=s.index)

    vals = ref["numRating"].to_numpy()
    labels = ref["strRating"].to_numpy()

    x = s.to_numpy()
    # indices of the first value >= x
    idx_upper = np.searchsorted(vals, x, side="left")
    idx_lower = idx_upper - 1

    # clip to valid range
    idx_upper = np.clip(idx_upper, 0, len(vals) - 1)
    idx_lower = np.clip(idx_lower, 0, len(vals) - 1)

    # distances
    lower_diff = np.abs(x - vals[idx_lower])
    upper_diff = np.abs(vals[idx_upper] - x)

    # choose closer (ties -> lower), NaN -> "NR"
    choose_upper = (upper_diff < lower_diff) & ~np.isnan(x)
    idx = np.where(choose_upper, idx_upper, idx_lower)

    out = pd.Series(labels[idx], index=s.index)
    out[pd.isna(s)] = "NR"
    return out
