# ---------------------------
# Helpers
# ---------------------------
def _normalize_gps_code(v):
    if v is None or (isinstance(v, float) and np.isnan(v)) or (hasattr(pd, "isna") and pd.isna(v)):
        return None
    try:
        s = str(v).strip()
        f = float(s)
        return str(int(f)) if f.is_integer() else s
    except Exception:
        return str(v).strip()

def _clean_transpariz_record(rec: dict) -> dict:
    # decimals/empties → None
    for k, v in list(rec.items()):
        if isinstance(v, decimal.Decimal):
            rec[k] = float(v)
        elif v == "" or v == " " or (v is not None and hasattr(pd, "isna") and pd.isna(v)):
            rec[k] = None
    # business rules from your current insert
    if "strInvestedInPortfISOCur" not in rec or not rec.get("strInvestedInPortfISOCur"):
        rec["strInvestedInPortfISOCur"] = rec.get("strPortfISOCur")
    if "strInvestedInPortfISOCur" not in rec or not rec.get("strInvestedInPortfISOCur"):
        rec["numHoldValueInPortfCur"] = " "
    if rec.get("numPortfLevel") == 1:
        rec["strLevel1IsinCode"] = None
    if rec.get("strInvestedInInstrID") is None:
        rec["strInvestedInInstrID"] = -1
    return rec

# ---------------------------
# Worker: delete THEN insert (same txn) for ONE key
# ---------------------------
def _delete_then_insert_key(i: int, side: str, key_tuple, df_group: pd.DataFrame,
                            retry=5, backoff=2):
    """
    side: 'ALP' or 'DMC'
    key_tuple:
      - ALP: (numReportPortfGroupID:int, strReportPeriod:str)
      - DMC: (strReportPortfGPSCode:str, strReportPeriod:str)
    """
    session = None
    try:
        session = get_session()

        if side == "ALP":
            gid, period = key_tuple
            print(f"[{i}] ALP key -> (period={period}, gid={gid})")
            # DELETE for this key
            del_stmt = (
                delete(DMIRTransparizLT)
                .where(
                    DMIRTransparizLT.strReportPortfHoldSrc == "ALP",
                    DMIRTransparizLT.numReportPortfGroupID == int(gid),
                    DMIRTransparizLT.strReportPeriod == str(period),
                )
            )
        else:  # DMC
            gps, period = key_tuple
            print(f"[{i}] DMC key -> (period={period}, gps={gps})")
            if gps is None:
                print(f"[{i}] DMC skipped: gps=None")
                return 0
            del_stmt = (
                delete(DMIRTransparizLT)
                .where(
                    DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
                    DMIRTransparizLT.strReportPortfGPSCode == str(gps),
                    DMIRTransparizLT.strReportPeriod == str(period),
                )
            )

        # --- DELETE ---
        del_res = session.execute(del_stmt)
        deleted = del_res.rowcount or 0
        print(f"[DEL][{i}] -> deleted {deleted}")

        # --- INSERT (group rows for this key) ---
        df_local = df_group.copy()
        df_local = df_local.replace({np.nan: None})
        df_local["strReportPeriod"] = df_local["strReportPeriod"].astype(str)
        if side == "DMC" and "strReportPortfGPSCode" in df_local.columns:
            df_local["strReportPortfGPSCode"] = df_local["strReportPortfGPSCode"].map(_normalize_gps_code)

        # Keep only expected columns that exist in the DF
        cols = [c for c in TRANSPARIZ_COLUMNS if c in df_local.columns]
        records = df_local[cols].to_dict(orient="records")
        for rec in records:
            _clean_transpariz_record(rec)

        if records:
            session.bulk_insert_mappings(DMIRTransparizLT, records)

        get_hardware_info()
        session.commit()
        print(f"[INS][{i}] -> inserted {len(records)}")
        return len(records)

    except Exception as e:
        if session:
            session.rollback()
        print(f"[{i}] ERROR: {e}")
        if retry > 0:
            time.sleep(backoff)
            return _delete_then_insert_key(i, side, key_tuple, df_group,
                                           retry=retry - 1, backoff=min(30, backoff * 2))
        raise
    finally:
        if session:
            session.close()

# ---------------------------
# Orchestration: per-key parallel delete→insert
# ---------------------------
def final_upsert_transparizlt_strategy1(df_final: pd.DataFrame,
                                        max_workers: int = 32) -> int:
    """
    For each key, in its OWN worker:
      - delete rows for that key
      - insert that key's rows
    No OR, no TOP; one delete per key; same transaction per key.
    """
    if df_final.empty:
        return 0

    df = df_final.copy()
    df["strReportPeriod"] = df["strReportPeriod"].astype(str)
    if "strReportPortfGPSCode" in df.columns:
        df["__gps_norm__"] = df["strReportPortfGPSCode"].map(_normalize_gps_code)
    else:
        df["__gps_norm__"] = None

    # Build per-key groups for ALP and DMC
    inserted_total = 0
    futures = {}

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        # ALP: group by (gid, period)
        if {"strReportPortfHoldSrc", "numReportPortfGroupID", "strReportPeriod"}.issubset(df.columns):
            df_alp = df[df["strReportPortfHoldSrc"] == "ALP"]
            for (gid, period), gdf in df_alp.groupby(["numReportPortfGroupID", "strReportPeriod"], dropna=False):
                if pd.isna(gid) or pd.isna(period):
                    continue
                key = (int(gid), str(period))
                futures[exe.submit(_delete_then_insert_key, len(futures), "ALP", key, gdf)] = key

        # DMC: group by (gps_norm, period)
        if {"strReportPortfHoldSrc", "strReportPortfGPSCode", "strReportPeriod"}.issubset(df.columns):
            df_dmc = df[df["strReportPortfHoldSrc"] == "DMC"]
            for (gps, period), gdf in df_dmc.groupby(["__gps_norm__", "strReportPeriod"], dropna=False):
                if gps is None or pd.isna(period):
                    continue
                key = (gps, str(period))
                futures[exe.submit(_delete_then_insert_key, len(futures), "DMC", key, gdf)] = key

        # Collect results
        for fut in as_completed(futures):
            key = futures[fut]
            try:
                cnt = fut.result() or 0
                inserted_total += cnt
                print(f"[OK] {key} -> inserted {cnt} (total {inserted_total})")
            except Exception as e:
                print(f"[ERROR] {key}: {e}")

    print(f"Total inserted: {inserted_total}.")
    return inserted_total
