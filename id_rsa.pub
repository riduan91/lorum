python -c "from airflow.settings import Session; from airflow.models import DagRun, DagModel; from airflow.utils import timezone as tz; dag_id='my_dag'; run_id='scheduled__2025-08-12T00:00:00+00:00'; queued=tz.parse('2025-08-12T08:00:00+00:00'); started=tz.parse('2025-08-12T08:05:00+00:00'); last_dec=tz.parse('2025-08-12T09:00:00+00:00'); s=Session(); s.query(DagRun).filter(DagRun.dag_id==dag_id, DagRun.run_id==run_id).update({'queued_at': queued, 'start_date': started}); s.query(DagModel).filter(DagModel.dag_id==dag_id).update({'last_scheduling_decision': last_dec}); s.commit(); s.close(); print('✅ updated queued_at, start_date, and last_scheduling_decision')"
