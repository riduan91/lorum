python -c "from airflow.settings import Session; from airflow.models import DagRun; from datetime import datetime; dag_id='my_dag'; run_id='manual__2025-08-12T00:00:00+00:00'; start=datetime(2025,8,12,8,15); end=datetime(2025,8,12,8,17,45); s=Session(); s.query(DagRun).filter(DagRun.dag_id==dag_id, DagRun.run_id==run_id).update({'start_date': start, 'end_date': end}); s.commit(); s.close(); print('✅ DAG run timestamps restored')"
