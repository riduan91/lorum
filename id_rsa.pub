import numpy as np
import pandas as pd


def aggregate_indicators(df: pd.DataFrame) -> pd.DataFrame:
    """
    Vectorised replacement for the original aggregate_indicators().
    Runtime improvement comes from removing apply/row-loops and using
    built-in reductions in groupby/agg.

    Parameters
    ----------
    df : pd.DataFrame
        Position-level holdings data (≈ millions of rows).

    Returns
    -------
    pd.DataFrame
        One row per instrument *per portfolio* with exposure,
        contribution and weight columns, ready to load into the target
        table.
    """

    # ------------------------------------------------------------------
    # 1. Pre-compute row-level exposures – fully vectorised
    # ------------------------------------------------------------------

    # ----- 1a  Duration exposure --------------------------------------
    mask_dur = (df["numDeltaAdjustedSpread"] != 0) & (df["numHoldQuantity"] != 0)

    df["durExp"] = df["numWeightedAmtInReportPortf"]  # default
    df.loc[mask_dur, "durExp"] = (
        df.loc[mask_dur, "numWeightedQtqInReportPortf"]
        .abs()
        .div(df.loc[mask_dur, "numHoldQuantity"].abs())
        .mul(df.loc[mask_dur, "numDeltaAdjustedSpread"])
    )

    # ----- 1b  Currency exposure --------------------------------------
    mask_fx = (
        (df["strInstrumentTypeIRName"] == "Forex")
        & df["strInstISINCode"].notna()
        & ~df["strInstISINCode"].str.startswith("FWD")
        & (df["numLength"] < 12)
    )

    fx_val = (
        df["numWeightedQtyForex"]
        .div(df["numHoldCrossCur"])
        .mul(df["numPortfExRateInRptPtfCur"])
        .where(df["numHoldCrossCur"] != 0, 0)
    )

    df["curExp"] = np.where(mask_fx, fx_val, df["numWeightedAmtInReportPortf"])

    # ------------------------------------------------------------------
    # 2. Helper columns for absolute max reductions
    # ------------------------------------------------------------------
    duration_src = [
        "numInstConvexity",
        "numInstModifDuration",
        "numInstMCDuration",
        "numInstEffDuration",
        "numInstSpreadDuration",
    ]
    for c in duration_src:
        df[c + "Abs"] = df[c].abs()

    # ------------------------------------------------------------------
    # 3. First-level aggregation (instrument within portfolio)
    # ------------------------------------------------------------------
    keys = [
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "strInstAladdin",
        "numInstID",
    ]

    agg_spec = {
        "datPeriodLastNav":           ("datHoldDate", "max"),
        "strCurrencyISOCode":         ("strReportPortfISOCur", "max"),
        "maxAUM":                     ("numReportPortfAUM", "max"),
        "sumAmt":                     ("numWeightedAmtInReportPortf", "sum"),
        "sumDurExp":                  ("durExp", "sum"),
        "sumCurExp":                  ("curExp", "sum"),
        "sumDelta":                   ("numDeltaAdjustedSpread", "sum"),
        "maxConvexity":               ("numInstConvexityAbs", "max"),
        "maxModifDuration":           ("numInstModifDurationAbs", "max"),
        "maxMCDuration":              ("numInstMCDurationAbs", "max"),
        "maxEffDuration":             ("numInstEffDurationAbs", "max"),
        "maxSpreadDuration":          ("numInstSpreadDurationAbs", "max"),
    }

    agg = (
        df.groupby(keys, sort=False, observed=True)
          .agg(**agg_spec)
          .reset_index()
    )

    # ------------------------------------------------------------------
    # 4. Post-aggregation vector maths
    # ------------------------------------------------------------------
    # Portfolio weights & exposures
    agg = agg.assign(
        numInstrWeight           = agg["sumAmt"].div(agg["maxAUM"]).fillna(0),
        numDurExposureInPortfCur = agg["sumDurExp"],
        numCurExposureInPortfCur = agg["sumCurExp"],
        numDurExposureWeight     = agg["sumDurExp"].div(agg["maxAUM"]).fillna(0),
        numCurExposureWeight     = agg["sumCurExp"].div(agg["maxAUM"]).fillna(0),
    )

    # Duration-driven contributions
    for label in [
        "Convexity",
        "ModifDuration",
        "MCDuration",
        "EffDuration",
        "SpreadDuration",
    ]:
        agg[f"num{label}Contrib"] = (
            agg["numDurExposureWeight"] * agg[f"max{label}"].astype(float)
        )

    # Simple renames & extras
    agg = (
        agg.rename(
            columns={
                "numReportPortfGroupID": "numPortfGroupFKey",
                "strReportPortfGPSCode": "strPortfGPSCode",
            }
        )
        .assign(
            numDeltaAdjustedSpread = agg["sumDelta"].astype(float),
            strPortfGroupFkey      = agg["numPortfGroupFKey"].astype(str),
        )
    )

    # ------------------------------------------------------------------
    # 5. Portfolio-level sums & contribution weights
    # ------------------------------------------------------------------
    sum_cols = {
        f"num{label}Contrib": f"sumnum{label}Contrib"
        for label in ["Convexity", "ModifDuration", "MCDuration", "EffDuration", "SpreadDuration"]
    }

    sums = (
        agg.groupby(["datPeriodLastDay", "numPortfGroupFKey", "strPortfGPSCode"],
                    sort=False, observed=True)[list(sum_cols.keys())]
           .sum()
           .rename(columns=sum_cols)
           .reset_index()
    )

    df_final = agg.merge(
        sums,
        on=["datPeriodLastDay", "numPortfGroupFKey", "strPortfGPSCode"],
        how="left",
    )

    # Normalise contributions → weights
    for label in ["Convexity", "ModifDuration", "MCDuration", "EffDuration", "SpreadDuration"]:
        num   = f"num{label}Contrib"
        denom = f"sumnum{label}Contrib"
        w     = f"num{label}ContribWeight"
        df_final[w] = df_final[num].div(df_final[denom]).fillna(0)

    # ------------------------------------------------------------------
    # 6. Final column order
    # ------------------------------------------------------------------
    final_cols = [
        "datPeriodLastDay",
        "numPortfGroupFKey",
        "strPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "datPeriodLastNav",
        "strCurrencyISOCode",
        "numInstrWeight",
        "numDurExposureInPortfCur",
        "numCurExposureInPortfCur",
        "numDurExposureWeight",
        "numCurExposureWeight",
        "numConvexityContrib",
        "numModifDurationContrib",
        "numMCDurationContrib",
        "numEffDurationContrib",
        "numSpreadDurationContrib",
        "numConvexityContribWeight",
        "numModifDurationContribWeight",
        "numMCDurationContribWeight",
        "numEffDurationContribWeight",
        "numSpreadDurationContribWeight",
        "numDeltaAdjustedSpread",
        "strPortfGroupFkey",
    ]

    return df_final[final_cols]
