/* ============================================================================
   Row-by-row comparison with tolerance – DMIR.tblDMIRBRSBenchIndicators
   ============================================================================*/
DECLARE @fba_id            INT         = 202069;          -- random selected from fba
DECLARE @market_date       DATE        = '2025-06-27';
DECLARE @flag              VARCHAR(1)  = 'W';

-- Tolerance and default sentinels
DECLARE @tolerance         FLOAT       = 1e-6;            -- 10e-7
DECLARE @dflt_date         DATE        = '1900-01-01';
DECLARE @dflt_int          INT         = 0;
DECLARE @dflt_float        FLOAT       = 0;
DECLARE @dflt_str          VARCHAR(1)  = '';

SELECT
    a.datMarketDate        AS datMarketDate,
    a.strPeriodTypeFlag    AS strPeriodTypeFlag,
    a.datPeriodLastDay     AS datPeriodLastDay,
    a.numBenchFBAId        AS numBenchFBAId,

    /* 0/1 mismatch flags */
    CASE WHEN NULLIF(a.strPeriodTypeFlag,@dflt_str) = NULLIF(b.strPeriodTypeFlag,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strPeriodTypeFlag,
    CASE WHEN a.datPeriodLastDay = b.datPeriodLastDay THEN 0 ELSE 1 END
        AS valid_datPeriodLastDay,
    CASE WHEN a.datMarketDate = b.datMarketDate THEN 0 ELSE 1 END
        AS valid_datMarketDate,
    CASE WHEN ABS(COALESCE(a.numBenchFBAId,@dflt_int) - COALESCE(b.numBenchFBAId,@dflt_int)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchFBAId,
    CASE WHEN NULLIF(a.strPFCurrencyISOCode,@dflt_str) = NULLIF(b.strPFCurrencyISOCode,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strPFCurrencyISOCode,
    CASE WHEN ABS(COALESCE(a.numDurExposureBench,@dflt_float) - COALESCE(b.numDurExposureBench,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numDurExposureBench,
    CASE WHEN ABS(COALESCE(a.numCurExposureBench,@dflt_float) - COALESCE(b.numCurExposureBench,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numCurExposureBench,
    CASE WHEN a.datBenchAvgMaturityLife = b.datBenchAvgMaturityLife THEN 0 ELSE 1 END
        AS valid_datBenchAvgMaturityLife,
    CASE WHEN ABS(COALESCE(a.numEffectDurationBench,@dflt_float) - COALESCE(b.numEffectDurationBench,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numEffectDurationBench,
    CASE WHEN ABS(COALESCE(a.numModifDurationBench,@dflt_float) - COALESCE(b.numModifDurationBench,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numModifDurationBench,
    CASE WHEN ABS(COALESCE(a.numMCDurationBench,@dflt_float) - COALESCE(b.numMCDurationBench,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numMCDurationBench,
    CASE WHEN ABS(COALESCE(a.numSpreadDurationBench,@dflt_float) - COALESCE(b.numSpreadDurationBench,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numSpreadDurationBench,
    CASE WHEN ABS(COALESCE(a.numBenchAvgCoupon,@dflt_float) - COALESCE(b.numBenchAvgCoupon,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchAvgCoupon,
    CASE WHEN ABS(COALESCE(a.numBenchAvgYTM,@dflt_float) - COALESCE(b.numBenchAvgYTM,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchAvgYTM,
    CASE WHEN ABS(COALESCE(a.numBenchAvgConvexity,@dflt_float) - COALESCE(b.numBenchAvgConvexity,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchAvgConvexity,
    CASE WHEN ABS(COALESCE(a.numHoldingsNumber,@dflt_float) - COALESCE(b.numHoldingsNumber,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numHoldingsNumber,
    CASE WHEN ABS(COALESCE(a.numBenchPriceEarnRatio,@dflt_float) - COALESCE(b.numBenchPriceEarnRatio,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchPriceEarnRatio,
    CASE WHEN ABS(COALESCE(a.numBenchPriceToBook,@dflt_float) - COALESCE(b.numBenchPriceToBook,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchPriceToBook,
    CASE WHEN ABS(COALESCE(a.numBenchDivYld,@dflt_float) - COALESCE(b.numBenchDivYld,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchDivYld,
    CASE WHEN ABS(COALESCE(a.numBenchPriceCash,@dflt_float) - COALESCE(b.numBenchPriceCash,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchPriceCash,
    CASE WHEN ABS(COALESCE(a.numBench35YrForecastEarnGrowth,@dflt_float) - COALESCE(b.numBench35YrForecastEarnGrowth,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBench35YrForecastEarnGrowth,
    CASE WHEN ABS(COALESCE(a.numBenchROE,@dflt_float) - COALESCE(b.numBenchROE,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchROE,
    CASE WHEN ABS(COALESCE(a.numBenchEvEbit,@dflt_float) - COALESCE(b.numBenchEvEbit,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchEvEbit,
    CASE WHEN ABS(COALESCE(a.numBenchEvSales,@dflt_float) - COALESCE(b.numBenchEvSales,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchEvSales,
    CASE WHEN ABS(COALESCE(a.numBenchEvEbitda,@dflt_float) - COALESCE(b.numBenchEvEbitda,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchEvEbitda,
    CASE WHEN ABS(COALESCE(a.numBenchTotalExpenseRatio,@dflt_float) - COALESCE(b.numBenchTotalExpenseRatio,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchTotalExpenseRatio,
    CASE WHEN NULLIF(a.strBenchAvgRtgSP,@dflt_str) = NULLIF(b.strBenchAvgRtgSP,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgSP,
    CASE WHEN NULLIF(a.strBenchAvgRtgMD,@dflt_str) = NULLIF(b.strBenchAvgRtgMD,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgMD,
    CASE WHEN NULLIF(a.strBenchAvgRtgFH,@dflt_str) = NULLIF(b.strBenchAvgRtgFH,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgFH,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom1,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom1,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom1,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom2,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom2,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom2,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom3,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom3,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom3,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom4,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom4,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom4,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom5,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom5,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom5,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom6,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom6,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom6,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom7,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom7,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom7,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom8,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom8,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom8,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom9,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom9,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom9,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom10,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom10,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom10,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom11,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom11,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom11,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom12,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom12,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom12,
    CASE WHEN NULLIF(a.strBenchAvgRtgCustom13,@dflt_str) = NULLIF(b.strBenchAvgRtgCustom13,@dflt_str) THEN 0 ELSE 1 END
        AS valid_strBenchAvgRtgCustom13,
    CASE WHEN ABS(COALESCE(a.numBenchWAL,@dflt_float) - COALESCE(b.numBenchWAL,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchWAL,
    CASE WHEN ABS(COALESCE(a.numBenchWAM,@dflt_float) - COALESCE(b.numBenchWAM,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchWAM,
    CASE WHEN ABS(COALESCE(a.numBenchInflSens,@dflt_float) - COALESCE(b.numBenchInflSens,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchInflSens,
    CASE WHEN ABS(COALESCE(a.numBenchDebtEq,@dflt_float) - COALESCE(b.numBenchDebtEq,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchDebtEq,
    CASE WHEN ABS(COALESCE(a.numBenchWAMarketCap,@dflt_float) - COALESCE(b.numBenchWAMarketCap,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchWAMarketCap,
    CASE WHEN ABS(COALESCE(a.numEffectDurationBenchFI,@dflt_float) - COALESCE(b.numEffectDurationBenchFI,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numEffectDurationBenchFI,
    CASE WHEN ABS(COALESCE(a.numModifDurationBenchFI,@dflt_float) - COALESCE(b.numModifDurationBenchFI,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numModifDurationBenchFI,
    CASE WHEN ABS(COALESCE(a.numMCDurationBenchFI,@dflt_float) - COALESCE(b.numMCDurationBenchFI,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numMCDurationBenchFI,
    CASE WHEN ABS(COALESCE(a.numBenchAvgCouponFI,@dflt_float) - COALESCE(b.numBenchAvgCouponFI,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchAvgCouponFI,
    CASE WHEN ABS(COALESCE(a.numBenchAvgYTMFI,@dflt_float) - COALESCE(b.numBenchAvgYTMFI,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numBenchAvgYTMFI,
    CASE WHEN a.datBenchAvgMaturityLifeFI = b.datBenchAvgMaturityLifeFI THEN 0 ELSE 1 END
        AS valid_datBenchAvgMaturityLifeFI,
    CASE WHEN ABS(COALESCE(a.numSpreadDurationBenchFI,@dflt_float) - COALESCE(b.numSpreadDurationBenchFI,@dflt_float)) < @tolerance THEN 0 ELSE 1 END
        AS valid_numSpreadDurationBenchFI
FROM
    DMIR.tblDMIRBRSBenchIndicators AS a
INNER JOIN
    dbo.tblDMIRBRSBenchIndicators AS b
  ON a.strPeriodTypeFlag = b.strPeriodTypeFlag
 AND a.datPeriodLastDay  = b.datPeriodLastDay
 AND a.numBenchFBAId     = b.numBenchFBAId
WHERE
    a.datPeriodLastDay    = @market_date
 AND a.numBenchFBAId     = @fba_id
 AND a.strPeriodTypeFlag = @flag;
