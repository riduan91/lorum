# Step 1. Find duplicated key combinations (like SQL HAVING COUNT(*) > 1)
dup_keys = (
    clean_internal_df
    .value_counts(subset=["strReportPeriod", "strPortfLevelID", "strInvestedInPortfID"])
    .reset_index(name="count")
    .query("count > 1")
    .drop(columns="count")
)

if not dup_keys.empty:
    # Step 2. Create composite keys for fast matching
    dup_keys["__dup_key__"] = (
        dup_keys["strReportPeriod"] + "|" +
        dup_keys["strPortfLevelID"] + "|" +
        dup_keys["strInvestedInPortfID"]
    )
    
    clean_internal_df["__dup_key__"] = (
        clean_internal_df["strReportPeriod"] + "|" +
        clean_internal_df["strPortfLevelID"] + "|" +
        clean_internal_df["strInvestedInPortfID"]
    )

    # Step 3. Boolean mask aligned with clean_internal_df
    mask = clean_internal_df["__dup_key__"].isin(dup_keys["__dup_key__"])

    # Step 4. Apply fix to duplicated rows
    clean_internal_df.loc[mask, "strPortfLevelID"] = (
        clean_internal_df.loc[mask, "strPortfLevelID"] + "." +
        clean_internal_df.loc[mask, "strInvestedInInstrID"].astype(str)
    )

    # Step 5. Clean up temporary columns
    clean_internal_df.drop(columns="__dup_key__", inplace=True)
