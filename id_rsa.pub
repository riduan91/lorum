def _build_df_to_remove_alp(gps_exempt: Set[int], current_date: date | None = None) -> pd.DataFrame:
    """
    Reproduce the logic of the `#to_remove2` temp‑table in SQL, i.e. decide
    which (numReportPortfGroupID, report‑period) pairs must be deleted from
    Scope LT for the ALP data‑source.

    Parameters
    ----------
    gps_exempt : set[int]
        The *portf‑group IDs* that must **not** be deleted for the latest
        reporting period because more up‑to‑date DMC holdings exist
        (equivalent to the `portfGroupDoNotDelete` CTE in SQL).
    current_date : date, optional
        Equivalent to `@varCurrentDate` in the proc.  Defaults to today.
    """
    current_date = current_date or date.today()
    eom_prev = _eom_prev_month(current_date)
    prev_period = _yyyymm(eom_prev)

    session = get_session()
    try:
        # ----------------------------------------------------------
        # 1) scope AUM per (period, group) -------------------------
        # ----------------------------------------------------------
        scope_sum = (
            session.query(
                DMIRScopeLT.strReportPeriod.label("period"),
                DMIRScopeLT.numReportPortfGroupID.label("grp"),
                func.sum(DMIRScopeLT.numPortfAUM).label("num_scope"),
            )
            .filter(DMIRScopeLT.strReportPortfHoldSrc == "ALP")
            .group_by(DMIRScopeLT.strReportPeriod, DMIRScopeLT.numReportPortfGroupID)
            .subquery()
        )

        # ----------------------------------------------------------
        # 2) transparized AUM per (period, group) ------------------
        # ----------------------------------------------------------
        agg_q = (
            session.query(
                func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
                scope_sum.c.num_scope,
                scope_sum.c.grp,
                scope_sum.c.period,
            )
            .join(
                scope_sum,
                and_(
                    DMIRTransparizLT.strReportPeriod == scope_sum.c.period,
                    DMIRTransparizLT.numReportPortfGroupID == scope_sum.c.grp,
                ),
            )
            .filter(
                DMIRTransparizLT.numLowestInventoryflag == 1,
                DMIRTransparizLT.numInstID > 1,
            )
            .group_by(scope_sum.c.num_scope, scope_sum.c.grp, scope_sum.c.period)
        )

        df = pd.DataFrame(session.execute(agg_q).mappings().all())
        normalize_type(df)

        if df.empty:
            return pd.DataFrame(columns=["num_transp", "num_scope", "grp", "period"])

        # tolerance: |transp ‑ scope| ≤ 0.05
        df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

        # ----------------------------------------------------------
        # 3) EXTERNAL / SPECIAL underlying holdings ----------------
        # ----------------------------------------------------------
        ext_pairs_q = (
            session.query(
                DMIRMonitoringLT.numReportPortfGroupID.label("grp"),
                DMIRMonitoringLT.strReportPeriod.label("period"),
            )
            .filter(
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_(["EXTERNAL", "SPECIAL"]),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .join(
                DMIRExternalSpecialHolding,
                and_(
                    DMIRExternalSpecialHolding.strPortfISINCode
                    == DMIRMonitoringLT.strInstISINCode,
                    DMIRExternalSpecialHolding.datHoldDate
                    >= func.coalesce(DMIRMonitoringLT.datLastNAVDate, date(2000, 1, 1)),
                    DMIRExternalSpecialHolding.datHoldDate <= DMIRMonitoringLT.datHoldDate,
                    DMIRExternalSpecialHolding.numAuditId > DMIRMonitoringLT.numAuditId,
                ),
            )
            .distinct()
        )
        ext_pairs = set(get_all_as_df(ext_pairs_q).apply(tuple, axis=1))
        df = df[
            ~df.apply(lambda r: (r.grp, r.period) in ext_pairs, axis=1)
        ]

        # ----------------------------------------------------------
        # 4) “do‑not‑delete” groups (more recent DMC holdings) -----
        #     passed in via `gps_exempt` ---------------------------
        # ----------------------------------------------------------
        df = df[
            ~(
                (df.period == prev_period)
                & (df.grp.isin(gps_exempt))
            )
        ]

        # ----------------------------------------------------------
        # 5) groups with a newer MACC‑NAV audit id -----------------
        # ----------------------------------------------------------
        nav_pairs_q = (
            session.query(DMIRMaccNav.numPortfGroupFKey.label("grp"))
            .outerjoin(
                DMIRBRSLTPortfIndicators,
                and_(
                    DMIRBRSLTPortfIndicators.datPeriodLastDay == DMIRMaccNav.datNavDate,
                    DMIRBRSLTPortfIndicators.numPortfGroupFkey
                    == DMIRMaccNav.numPortfGroupFKey,
                ),
            )
            .filter(
                DMIRMaccNav.datNavDate == eom_prev,
                DMIRMaccNav.numAuditId
                > func.coalesce(DMIRBRSLTPortfIndicators.numAuditId, 0),
                DMIRMaccNav.numTotalAUM != 0,
                DMIRMaccNav.strPerformanceStatus.in_(["Validated Data", "Preliminary Data"]),
            )
            .distinct()
        )
        nav_exclude = {t[0] for t in session.execute(nav_pairs_q).all()}
        df = df[~df.grp.isin(nav_exclude)]

        # ----------------------------------------------------------
        # 6) done --------------------------------------------------
        # ----------------------------------------------------------
        return (
            df[["num_transp", "num_scope", "grp", "period"]]
            if not df.empty
            else pd.DataFrame(columns=["num_transp", "num_scope", "grp", "period"])
        )

    finally:
        session.close()
