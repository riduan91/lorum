      , CASE WHEN ISNULL(a.strCpnRateTypeRecv,@dflt_string)=ISNULL(b.strCpnRateTypeRecv,@dflt_string) THEN 0 ELSE 1 END AS valid_strCpnRateTypeRecv
      , CASE WHEN ISNULL(a.numCpnFixedRatePaid,@dflt_float)= ISNULL(b.numCpnFixedRatePaid,@dflt_float) THEN 0 ELSE 1 END AS valid_numCpnFixedRatePaid
      , CASE WHEN ISNULL(a.numCpnFixedRateRecv,@dflt_float)= ISNULL(b.numCpnFixedRateRecv,@dflt_float) THEN 0 ELSE 1 END AS valid_numCpnFixedRateRecv
      , CASE WHEN ISNULL(a.strCpnIndexPaid  ,@dflt_string) = ISNULL(b.strCpnIndexPaid  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strCpnIndexPaid
      , CASE WHEN ISNULL(a.strCpnIndexRecv  ,@dflt_string) = ISNULL(b.strCpnIndexRecv  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strCpnIndexRecv
      , CASE WHEN ISNULL(a.strSwapFreqPaid  ,@dflt_string) = ISNULL(b.strSwapFreqPaid  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strSwapFreqPaid
      , CASE WHEN ISNULL(a.strSwapFreqRecv  ,@dflt_string) = ISNULL(b.strSwapFreqRecv  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strSwapFreqRecv
      , CASE WHEN ISNULL(a.strInstrumentTypeName1,@dflt_string)=ISNULL(b.strInstrumentTypeName1,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeName1
      , CASE WHEN ISNULL(a.strInstrumentTypeIRName1,@dflt_string)=ISNULL(b.strInstrumentTypeIRName1,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeIRName1
      , CASE WHEN ISNULL(a.strInstrumentTypeName3,@dflt_string)=ISNULL(b.strInstrumentTypeName3,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeName3
      , CASE WHEN ISNULL(a.strInstrumentTypeIRName3,@dflt_string)=ISNULL(b.strInstrumentTypeIRName3,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeIRName3
      , CASE WHEN ISNULL(a.strCoreAssetClaLvl1Lbl,@dflt_string)=ISNULL(b.strCoreAssetClaLvl1Lbl,@dflt_string) THEN 0 ELSE 1 END AS valid_strCoreAssetClaLvl1Lbl
      , CASE WHEN ISNULL(a.strCoreAssetClaLvl2Lbl,@dflt_string)=ISNULL(b.strCoreAssetClaLvl2Lbl,@dflt_string) THEN 0 ELSE 1 END AS valid_strCoreAssetClaLvl2Lbl
      , CASE WHEN ISNULL(a.strCoreAssetClaLvl3Lbl,@dflt_string)=ISNULL(b.strCoreAssetClaLvl3Lbl,@dflt_string) THEN 0 ELSE 1 END AS valid_strCoreAssetClaLvl3Lbl
      , CASE WHEN ISNULL(a.strCoreAssetClaLvl4Lbl,@dflt_string)=ISNULL(b.strCoreAssetClaLvl4Lbl,@dflt_string) THEN 0 ELSE 1 END AS valid_strCoreAssetClaLvl4Lbl
      , CASE WHEN ISNULL(a.LocalCurrencyMarketCap,@dflt_float)=ISNULL(b.LocalCurrencyMarketCap,@dflt_float) THEN 0 ELSE 1 END AS valid_LocalCurrencyMarketCap
      , CASE WHEN ISNULL(a.USDMarketCap      ,@dflt_float)    = ISNULL(b.USDMarketCap      ,@dflt_float)    THEN 0 ELSE 1 END AS valid_USDMarketCap
      , CASE WHEN ISNULL(a.EURMarketCap      ,@dflt_float)    = ISNULL(b.EURMarketCap      ,@dflt_float)    THEN 0 ELSE 1 END AS valid_EURMarketCap
      , CASE WHEN ISNULL(a.numInstYieldToMaturity,@dflt_float)=ISNULL(b.numInstYieldToMaturity,@dflt_float) THEN 0 ELSE 1 END AS valid_numInstYieldToMaturity
      , CASE WHEN ISNULL(a.numInstEffDuration,@dflt_float)    = ISNULL(b.numInstEffDuration,@dflt_float)    THEN 0 ELSE 1 END AS valid_numInstEffDuration
      , CASE WHEN ISNULL(a.numInstModifDuration,@dflt_float)  = ISNULL(b.numInstModifDuration,@dflt_float)  THEN 0 ELSE 1 END AS valid_numInstModifDuration
      , CASE WHEN ISNULL(a.numInstSpreadDuration,@dflt_float) = ISNULL(b.numInstSpreadDuration,@dflt_float) THEN 0 ELSE 1 END AS valid_numInstSpreadDuration
      , CASE WHEN ISNULL(a.numInstMCDuration ,@dflt_float)    = ISNULL(b.numInstMCDuration ,@dflt_float)    THEN 0 ELSE 1 END AS valid_numInstMCDuration
      , CASE WHEN ISNULL(a.numInstYield      ,@dflt_float)    = ISNULL(b.numInstYield      ,@dflt_float)    THEN 0 ELSE 1 END AS valid_numInstYield
      , CASE WHEN ISNULL(a.numInstYieldToCall,@dflt_float)    = ISNULL(b.numInstYieldToCall,@dflt_float)    THEN 0 ELSE 1 END AS valid_numInstYieldToCall
      , CASE WHEN ISNULL(a.numInstYieldToMaturityPaid,@dflt_float)=ISNULL(b.numInstYieldToMaturityPaid,@dflt_float) THEN 0 ELSE 1 END AS valid_numInstYieldToMaturityPaid
      , CASE WHEN ISNULL(a.numInstYieldToMaturityRecv,@dflt_float)=ISNULL(b.numInstYieldToMaturityRecv,@dflt_float) THEN 0 ELSE 1 END AS valid_numInstYieldToMaturityRecv
      , CASE WHEN ISNULL(a.InstrSectorBBLevel1,@dflt_string)= ISNULL(b.InstrSectorBBLevel1,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorBBLevel1
      , CASE WHEN ISNULL(a.InstrSectorBBLevel2,@dflt_string)= ISNULL(b.InstrSectorBBLevel2,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorBBLevel2
      , CASE WHEN ISNULL(a.InstrSectorBBLevel3,@dflt_string)= ISNULL(b.InstrSectorBBLevel3,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorBBLevel3
      , CASE WHEN ISNULL(a.InstrSectorBBLevel4,@dflt_string)= ISNULL(b.InstrSectorBBLevel4,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorBBLevel4
      , CASE WHEN ISNULL(a.InstrSectorLHLevel1,@dflt_string)= ISNULL(b.InstrSectorLHLevel1,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorLHLevel1
      , CASE WHEN ISNULL(a.InstrSectorLHLevel2,@dflt_string)= ISNULL(b.InstrSectorLHLevel2,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorLHLevel2
      , CASE WHEN ISNULL(a.InstrSectorLHLevel3,@dflt_string)= ISNULL(b.InstrSectorLHLevel3,@dflt_string)    THEN 0 ELSE 1 END AS valid_InstrSectorLHLevel3
