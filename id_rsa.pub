python -c "from airflow.settings import Session; from airflow.models import DagRun; dag_id='my_dag'; run_id='manual__2025-08-12T00:00:00+00:00'; s=Session(); s.query(DagRun).filter(DagRun.dag_id==dag_id, DagRun.run_id==run_id).update({'run_type': 'scheduled'}); s.commit(); s.close(); print('✅ run_type changed to scheduled')"
