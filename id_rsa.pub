import gc
import pandas as pd

def update_data_constituents(
    path_constituents: str,
    path_data_instruments: str,
    chunk_size: int = 500_000,  # unused in the vectorized path
    use_polars: bool = False,   # set True if you want even more speed (needs polars)
):
    """
    Vectorized rewrite: avoid Python dicts + multiprocessing; use joins/maps instead.
    """
    logger.log.info("Update data constituents (vectorized).")

    # === Load ===
    # If you know the exact columns needed, specify them via columns=[...] to cut IO.
    constituents = load_parquet(path_constituents)  # -> pandas DataFrame
    instruments = load_parquet(path_data_instruments)

    # Build a fast lookup for strInstAladdin -> instrument row (pandas merge)
    # Keep only columns you actually need on the output to reduce memory
    # Example below keeps several typical columns; adjust to your schema.
    cols_keep = [
        "strInstAladdin",
        "numInstTypeId",
        "strInstName",
        "strInstCurrCode",
        # add any other instrument columns you need to attach to constituents
    ]
    inst = instruments.loc[:, [c for c in cols_keep if c in instruments.columns]].copy()

    # Optional: make join keys categorical for memory + speed benefits
    for col in ("strInstAladdin", "strInstCurrCode"):
        if col in inst.columns and col in constituents.columns:
            constituents[col] = constituents[col].astype("category")
            inst[col] = inst[col].astype("category")

    # === (A) Primary join on strInstAladdin ===
    if "strInstAladdin" in constituents.columns and "strInstAladdin" in inst.columns:
        merged = constituents.merge(
            inst, on="strInstAladdin", how="left", suffixes=("", "_inst")
        )
    else:
        logger.log.warning("strInstAladdin not present on both sides; skipping primary merge.")
        merged = constituents.copy()

    # === (B) Optional “hedge index” mapping by currency code ===
    # Build a per-currency lookup among hedged instruments (type 504 + name contains HEDGE / HEDGE INDEX)
    want_hedge = None
    if set(["numInstTypeId", "strInstName", "strInstCurrCode"]).issubset(inst.columns):
        mask = (
            (inst["numInstTypeId"] == 504)
            & inst["strInstName"].notna()
            & (inst["strInstName"].str.contains("HEDGE") | inst["strInstName"].str.contains("HEDGE INDEX"))
        )
        hedge_inst = inst.loc[mask, ["strInstCurrCode", "strInstAladdin"]].copy()

        # If multiple instruments per currency, keep one (define your rule; here first occurrence)
        hedge_inst = hedge_inst.dropna(subset=["strInstCurrCode"]).drop_duplicates("strInstCurrCode")

        # Map currency code on constituents -> hedged instrument Aladdin id
        if "strInstCurrCode" in constituents.columns:
            # This creates a column with the hedged Aladdin id for that currency
            hedge_map = dict(zip(hedge_inst["strInstCurrCode"], hedge_inst["strInstAladdin"]))
            merged["hedge_strInstAladdin"] = constituents["strInstCurrCode"].map(hedge_map)
            want_hedge = True

    # If you need to also bring full hedged-instrument columns, join again on hedge_strInstAladdin
    if want_hedge:
        merged = merged.merge(
            inst.add_prefix("hedge_"),
            left_on="hedge_strInstAladdin",
            right_on="hedge_strInstAladdin",
            how="left",
        )

    # === Save once ===
    path_data_constituents_updated = save_parquet(
        merged,
        child_folder="bench_data_brs",
        name="data_constituents_updated",
    )

    # Free memory
    del constituents, instruments, inst, merged
    gc.collect()

    logger.log.info("Update data constituents is done. Scope size = %s", len(results) if 'results' in locals() else 'n/a')
    return path_data_constituents_updated


