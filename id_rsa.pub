# ---- DEL2 (memory-safe) ---------------------------------------------
print("[DEL2] start", (df_instrument.shape, df_instrument_irtype.shape), get_hardware_info())

# 1) Build the set of Forex/class7 instrument IDs (no join)
if df_instrument_irtype.empty:
    df_instrument_irtype = pd.DataFrame(
        columns=["numInstrTypeID","strReportingType","strInstrumentTypeIRName"]
    )
ir_filter = (df_instrument_irtype["strReportingType"] == "class7") & \
            (df_instrument_irtype["strInstrumentTypeIRName"] == "Forex")
forex_type_ids = df_instrument_irtype.loc[ir_filter, "numInstrTypeID"].dropna().unique()
forex_inst_ids = (
    df_instrument.loc[df_instrument["numInstTypeId"].isin(forex_type_ids), "numInstID"]
    .dropna()
    .drop_duplicates()
)
# Use a Python set for O(1) membership and low overhead
forex_set = set(forex_inst_ids.tolist())
print("[DEL2] forex_inst_ids", len(forex_set), get_hardware_info())

# 2) Early filter to zero-rows ONLY (NumPy ops to avoid pandas temporaries)
qty = pd.to_numeric(df_updated["numWeightedQtqInReportPortf"], errors="coerce").to_numpy()
amt = pd.to_numeric(df_updated["numWeightedAmtInReportPortf"], errors="coerce").to_numpy()
zero_idx = np.flatnonzero((np.nan_to_num(qty) == 0.0) & (np.nan_to_num(amt) == 0.0))
print("[DEL2] zero candidates", zero_idx.size, get_hardware_info())

if zero_idx.size:
    # 3) Membership test only on the candidate slice (no full-length mask)
    inst_slice = df_updated["numInstID"].to_numpy()[zero_idx]

    # Use fromiter to avoid building an intermediate list
    is_fx_slice = np.fromiter((x in forex_set for x in inst_slice), dtype=bool, count=zero_idx.size)

    # 4) Compute final drop indices and drop in one go
    drop_idx = df_updated.index[zero_idx[is_fx_slice]]
    before2 = df_updated.shape[0]
    df_updated = df_updated.drop(index=drop_idx)
    print(f"[DEL2] {before2 - df_updated.shape[0]} forex rows removed", df_updated.shape, get_hardware_info())
else:
    print("[DEL2] no zero-rows to check", df_updated.shape, get_hardware_info())
