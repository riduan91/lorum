# ----------------------------------------------------------------------
# Helpers for parallel execution (private)
# ----------------------------------------------------------------------

def _with_session(Session, fn, *args, **kwargs):
    """Utility to run `fn(session, *args, **kwargs)` with an ephemeral session."""
    session = Session()
    try:
        return fn(session, *args, **kwargs)
    finally:
        session.close()

def _run_temp3_batch(session, monitoring_temp2_values):
    """Worker for a single monitoring_temp2 batch."""
    subquery_monitoring_temp2 = (
        session.query(
            monitoring_temp2_values.c.strInvestedInPortfID,
            monitoring_temp2_values.c.datmaxAccDate
        )
        .distinct()
        .subquery()
    )

    rows = (
        session.query(
            DMIRDMCHolding.strPortfGPSCode,
            DMIRDMCHolding.datACCDATE,
            DMIRDMCHolding.strInstAladdin,
            DMIRDMCHolding.numInstrFKey,
            DMIRDMCHolding.numHoldCrossCur,
            DMIRDMCHolding.numHoldValuInPortfCur,
            DMIRDMCHolding.numHoldQuantity,
            DMIRDMCHolding.numHoldPrice,
            DMIRDMCHolding.numHoldAccruedIntInstr,
            DMIRDMCHolding.numHoldAccruedIntPortf,
            DMIRDMCHolding.numInstrFKey.label("numInstID"),
            DMIRDMCHolding.numHoldAvrgCostInPortfCur,
            DMIRDMCHolding.strUnderlSecCode,
        )
        .join(
            subquery_monitoring_temp2,
            and_(
                DMIRDMCHolding.strPortfGPSCode == subquery_monitoring_temp2.c.strInvestedInPortfID,
                DMIRDMCHolding.datACCDATE    == subquery_monitoring_temp2.c.datmaxAccDate,
            ),
        )
        .all()
    )
    return [dict(r._mapping) for r in rows]

def _run_prev_step_internal_for_temp2(session, monitoring_temp2, path_monitoring_temp3, p_step: int):
    """Worker for one temp2 batch; iterates temp3 batches locally."""
    results = []

    src_upper_step = (
        session.query(
            DMIRMonitoringLTWrk.datReportDate,
            DMIRMonitoringLTWrk.strReportPeriod,
            DMIRMonitoringLTWrk.strReportPortfHoldSrc,
            DMIRMonitoringLTWrk.numReportPortfGroupID,
            DMIRMonitoringLTWrk.strReportPortfGPSCode,
            DMIRMonitoringLTWrk.strInvestedInPortfID,
            DMIRMonitoringLTWrk.strInvestedInPortfName,
            DMIRMonitoringLTWrk.numInvestedInPortfAUM,
            DMIRMonitoringLTWrk.strInvestedInPortfISOCur,
            DMIRMonitoringLTWrk.numWeightInReportPortfAUM,
            DMIRMonitoringLTWrk.strPortfLevelID,
            DMIRMonitoringLTWrk.datPeriodLastDay,
            DMIRMonitoringLTWrk.strSrcUndrlygHoldData,
            DMIRMonitoringLTWrk.datLastNAVDate,
            monitoring_temp2.c.datmaxAccDate,
            DMIRMonitoringLTWrk.strLevel1IsinCode,
            DMIRMonitoringLTWrk.strReportPortfISOCur,
        )
        .join(
            monitoring_temp2,
            and_(
                DMIRMonitoringLTWrk.datLastNAVDate == monitoring_temp2.c.datLastNAVDate,
                DMIRMonitoringLTWrk.strInvestedInPortfID == monitoring_temp2.c.strInvestedInPortfID,
            ),
        )
        .filter(
            DMIRMonitoringLTWrk.numPortfLevel == p_step - 1,
            DMIRMonitoringLTWrk.numUndrlygLTflag == 1,
            DMIRMonitoringLTWrk.numPresUndrlygHoldData == 1,
            DMIRMonitoringLTWrk.strSrcUndrlygHoldData == "INTERNAL",
        )
        .cte("src_upper_step")
    )

    for monitoring_temp3 in cte_data_monitoring_temp3(path_monitoring_temp3=path_monitoring_temp3):
        rows = (
            session.query(
                src_upper_step.c.datReportDate,
                src_upper_step.c.strReportPeriod,
                src_upper_step.c.strReportPortfHoldSrc,
                src_upper_step.c.numReportPortfGroupID,
                src_upper_step.c.strReportPortfGPSCode,
                src_upper_step.c.strInvestedInPortfID.label("strPortfID"),
                src_upper_step.c.strInvestedInPortfName.label("strPortfName"),
                src_upper_step.c.numInvestedInPortfAUM.label("numPortfAUM"),
                src_upper_step.c.strInvestedInPortfISOCur.label("strPortfISOCur"),
                monitoring_temp3.c.strInstAladdin.label("strInvestedInInstrID"),
                monitoring_temp3.c.numHoldCrossCur,
                monitoring_temp3.c.numHoldValuInPortfCur.label("numHoldValueInPortfCur"),
                monitoring_temp3.c.numHoldQuantity,
                monitoring_temp3.c.datACCDATE.label("datHoldDate"),
                monitoring_temp3.c.numHoldPrice,
                monitoring_temp3.c.numHoldAccruedIntInstr,
                monitoring_temp3.c.numHoldAccruedIntPortf,
                src_upper_step.c.numWeightInReportPortfAUM,
                func.concat(
                    src_upper_step.c.strPortfLevelID,
                    ".",
                    src_upper_step.c.strInvestedInPortfID,
                ).label("strPortfLevelID"),
                src_upper_step.c.datPeriodLastDay,
                src_upper_step.c.strSrcUndrlygHoldData,
                monitoring_temp3.c.strInstAladdin,
                monitoring_temp3.c.numInstrFKey.label("numInstID"),
                monitoring_temp3.c.numHoldAvrgCostInPortfCur,
                src_upper_step.c.strLevel1IsinCode,
                src_upper_step.c.strReportPortfISOCur,
            )
            .join(
                src_upper_step,
                and_(
                    src_upper_step.c.strInvestedInPortfID == monitoring_temp3.c.strPortfGPSCode,
                    src_upper_step.c.datmaxAccDate   == monitoring_temp3.c.datACCDATE,
                ),
            )
            .all()
        )
        results.extend(dict(r._mapping) for r in rows)

    return results

def _run_prev_step_internal_2_batch(session, monitoring_internal_values):
    """Worker for one monitoring_previous_step_internal batch."""
    instruments = (
        session.query(
            DMIRBRSInstrument.strInstAladdin,
            func.convert(
                sqlalchemy.text("varchar(255)"), DMIRBRSInstrument.numInstID
            ).label("numInstID"),
            func.coalesce(
                DMIRPortfolio.strPortfGPSCode, DMIRBRSInstrument.strInstISINCode
            ).label("strInvestedInPortfID"),
            func.coalesce(DMIRPortfolio.strPtfName, DMIRBRSInstrument.strInstName).label(
                "strInvestedInPortfName"
            ),
            DMIRInstrumentIRType.strInstrumentTypeIRName,
            DMIRPortfolio.strPortfGPSCode.label("strPortfGPSCode"),
            DMIRBRSInstrument.strInstISINCode,
        )
        .outerjoin(
            DMIRShare,
            and_(
                DMIRBRSInstrument.strInstISINCode == DMIRShare.strShISINCode,
                DMIRShare.strShStatusLabel == "Launched",
            ),
        )
        .outerjoin(
            DMIRPortfolio, DMIRPortfolio.strPortfGPSCode == DMIRShare.strPortfGpsCode
        )
        .join(
            DMIRInstrumentIRType,
            and_(
                DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                DMIRInstrumentIRType.strReportingType == "class2",
                func.lower(DMIRInstrumentIRType.strInstrumentTypeIRName).in_(
                    ("mutual funds", "index", "monetary funds")
                ),
            ),
        )
        .distinct()
        .subquery()
    )

    rows = (
        session.query(
            monitoring_internal_values.c.datReportDate,
            monitoring_internal_values.c.strReportPeriod,
            monitoring_internal_values.c.strReportPortfHoldSrc,
            monitoring_internal_values.c.numReportPortfGroupID,
            monitoring_internal_values.c.strReportPortfGPSCode,
            monitoring_internal_values.c.strPortfID,
            monitoring_internal_values.c.strPortfName,
            monitoring_internal_values.c.numPortfAUM,
            monitoring_internal_values.c.strPortfISOCur,
            monitoring_internal_values.c.strInvestedInInstrID,
            monitoring_internal_values.c.numHoldCrossCur,
            monitoring_internal_values.c.numHoldValueInPortfCur,
            monitoring_internal_values.c.numHoldQuantity,
            monitoring_internal_values.c.datHoldDate,
            monitoring_internal_values.c.numHoldPrice,
            monitoring_internal_values.c.numHoldAccruedIntInstr,
            monitoring_internal_values.c.numHoldAccruedIntPortf,
            monitoring_internal_values.c.numWeightInReportPortfAUM,
            monitoring_internal_values.c.strPortfLevelID,
            monitoring_internal_values.c.datPeriodLastDay,
            case(
                [
                    (DMIRSpecialFunds.strSPISINCode.isnot(None), "SPECIAL"),
                    (instruments.c.strPortfGPSCode.isnot(None), "INTERNAL"),
                ],
                else_="EXTERNAL",
            ).label("strSrcUndrlygHoldData"),
            monitoring_internal_values.c.strInstAladdin,
            monitoring_internal_values.c.numInstID,
            monitoring_internal_values.c.numHoldAvrgCostInPortfCur,
            instruments.c.strInvestedInPortfID,
            instruments.c.strInvestedInPortfName,
            instruments.c.strInstISINCode,
            instruments.c.strInstrumentTypeIRName,
            monitoring_internal_values.c.strLevel1IsinCode,
            monitoring_internal_values.c.strReportPortfISOCur,
        )
        .join(
            instruments,
            monitoring_internal_values.c.strInvestedInInstrID == instruments.c.strInstAladdin,
        )
        .outerjoin(
            DMIRSpecialFunds,
            and_(
                DMIRSpecialFunds.strSPISINCode == instruments.c.strInstISINCode,
                DMIRSpecialFunds.strPortfLevelID == monitoring_internal_values.c.strPortfLevelID,
                DMIRSpecialFunds.datValidBegin <= monitoring_internal_values.c.datHoldDate,
                func.coalesce(
                    DMIRSpecialFunds.datValidEnd, monitoring_internal_values.c.datHoldDate
                )
                <= monitoring_internal_values.c.datHoldDate,
            ),
        )
        .all()
    )

    return [dict(r._mapping) for r in rows]

# ----------------------------------------------------------------------
# Parallelized functions (names preserved)
# ----------------------------------------------------------------------

def data_monitoring_temp3(Session: sqlalchemy.orm.Session, path_monitoring_temp2: str):
    """Parallelize over the batches yielded by cte_data_monitoring_temp2."""
    logger.log.info("Get data monitoring temp3 (parallel).")

    try:
        monitoring_data = []
        futures = []
        # Tune max_workers to your DB capacity (connections/pool). 4-8 is a safe start.
        with ThreadPoolExecutor(max_workers=8) as ex:
            for idx, monitoring_temp2 in enumerate(
                cte_data_monitoring_temp2(path_monitoring_temp2=path_monitoring_temp2)
            ):
                logger.log.info(f"cte_data_monitoring_temp2 idx = {idx}")
                futures.append(
                    ex.submit(_with_session, Session, _run_temp3_batch, monitoring_temp2)
                )

            for f in as_completed(futures):
                # Will raise and bubble up on error, preserving original try/except behavior
                monitoring_data.extend(f.result())

        path_monitoring = dataprocess.save_json(
            data=monitoring_data,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_temp3",
        )

        logger.log.info(f"Get data monitoring temp3 is done. Scope size = {len(monitoring_data)}")
        return path_monitoring

    except SQLAlchemyError as e:
        logger.log.error(f"Error occurred when data_monitoring_temp3: {str(e)}.")
        raise
    except Exception as e:
        logger.log.error(f"Unhandled error in data_monitoring_temp3: {str(e)}.")
        raise


def data_monitoring_previous_step_internal(
    Session: sqlalchemy.orm.Session,
    path_monitoring_temp2: str,
    path_monitoring_temp3: str,
    p_step: int,
):
    """Parallelize across monitoring_temp2 batches; each worker iterates temp3 locally."""
    logger.log.info("Get data monitoring previous step internal (parallel).")

    try:
        all_results = []
        futures = []
        with ThreadPoolExecutor(max_workers=8) as ex:
            for idx, monitoring_temp2 in enumerate(
                cte_data_monitoring_temp2(path_monitoring_temp2=path_monitoring_temp2)
            ):
                logger.log.info(f"cte_data_monitoring_temp2 idx = {idx}")
                futures.append(
                    ex.submit(
                        _with_session,
                        Session,
                        _run_prev_step_internal_for_temp2,
                        monitoring_temp2,
                        path_monitoring_temp3,
                        p_step,
                    )
                )

            for f in as_completed(futures):
                all_results.extend(f.result())

        path_monitoring_previous_step_internal = dataprocess.save_json(
            data=all_results,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_previous_step_internal",
        )

        logger.log.info(
            f"Get data monitoring previous step internal is done. Scope size = {len(all_results)}"
        )
        return path_monitoring_previous_step_internal

    except SQLAlchemyError as e:
        logger.log.error(f"Error occurred when data_monitoring_previous_step_internal: {str(e)}.")
        raise
    except Exception as e:
        logger.log.error(f"Unhandled error in data_monitoring_previous_step_internal: {str(e)}.")
        raise


def data_monitoring_previous_step_internal_2(
    Session: sqlalchemy.orm.Session, path_monitoring_previous_step_internal: str
):
    """Parallelize over batches yielded by cte_data_monitoring_previous_step_internal."""
    logger.log.info("Get data monitoring previous step internal 2 (parallel).")

    try:
        monitoring_data = []
        futures = []
        with ThreadPoolExecutor(max_workers=8) as ex:
            for idx, monitoring_internal in enumerate(
                cte_data_monitoring_previous_step_internal(
                    path_monitoring_previous_step_internal=path_monitoring_previous_step_internal
                )
            ):
                logger.log.info(
                    f"cte_data_monitoring_previous_step_internal idx = {idx}"
                )
                futures.append(
                    ex.submit(
                        _with_session,
                        Session,
                        _run_prev_step_internal_2_batch,
                        monitoring_internal,
                    )
                )

            for f in as_completed(futures):
                monitoring_data.extend(f.result())

        path_monitoring_previous_step_internal_2 = dataprocess.save_json(
            data=monitoring_data,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_previous_step_internal_2",
        )

        logger.log.info(
            f"Get data monitoring previous step internal 2 is done. Scope size = {len(monitoring_data)}"
        )
        return path_monitoring_previous_step_internal_2

    except SQLAlchemyError as e:
        logger.log.error(f"Error occurred when data_monitoring_previous_step_internal_2: {str(e)}.")
        raise
    except Exception as e:
        logger.log.error(f"Unhandled error in data_monitoring_previous_step_internal_2: {str(e)}.")
        raise
