import gc
from typing import List, Dict, Any
import numpy as np
import pandas as pd

# -------------------------
# Bulk fetch into dfs
# -------------------------
def _build_df_inst(session, inst_alds, period_ends, rpt_codes, grp_ids):
    print(f"Build df_inst: {len(inst_alds)} instruments, {len(period_ends)} dates")
    get_hardware_info()

    # --- Instruments ---
    instruments = []
    for chunk_inst_alds in chunker(list(inst_alds), 2000):
        instruments.extend(
            session.query(DMIRBRSInstrument)
            .filter(DMIRBRSInstrument.strInstAladdin.in_(chunk_inst_alds))
            .all()
        )
    df_i = pd.DataFrame([
        dict(
            strInstAladdin=i.strInstAladdin,
            strInstCurrCode=i.strInstCurrCode,
            strInstName=i.strInstName,
            strBloombergCode=i.strBloombergCode,
            strInstISINCode=i.strInstISINCode,
            strInstSedolCode=i.strInstSedolCode,
            strInstCUSIPCode=i.strInstCUSIPCode,
            strInstIssuerName=i.strInstIssuerName,
            strInstExchLocName=i.strInstExchLocName,
            strInstListingCountryLabel=i.strInstListingCountryLabel,
            strInstIssueCountryLabel=i.strInstIssueCountryLabel,
            strInstIssuerCountryLabel=i.strInstIssuerCountryLabel,
            strInstRiskCountryLabel=i.strInstRiskCountryLabel,
            numInstCouponRate=i.numInstCouponRate,
            numInstForwardRate=i.numInstForwardRate,
            datInstMaturityDate=i.datInstMaturityDate,
            datInstCallDate=i.datInstCallDate,
            datInstNextCouponDate=i.datInstNextCouponDate,
            strInstPriceType=i.strInstPriceType,
            strInstRateType=i.strInstRateType,
            numInstSpotRate=i.numInstSpotRate,
            datInstStartDate=i.datInstStartDate,
            numInstUndrlygQty=i.numInstUndrlygQty,
            strInstUndrlygISINCode=i.strInstUndrlygISINCode,
            datInstIssueDate=i.datInstIssueDate,
            numInstNominalMt=i.numInstNominalMt,
            datInstContractEnd=i.datInstContractEnd,
            strInstContractName=i.strInstContractName,
            strInstLegTyp1=i.strInstLegTyp1,
            strInstLegTyp2=i.strInstLegTyp2,
            strInstLegType=i.strInstLegType,
            strCpnRateTypPaid=i.strCpnRateTypPaid,
            strCpnRateTypeRecv=i.strCpnRateTypeRecv,
            numCpnFixedRatePaid=i.numCpnFixedRatePaid,
            numCpnFixedRateRecv=i.numCpnFixedRateRecv,
            strCpnIndexPaid=i.strCpnIndexPaid,
            strCpnIndexRecv=i.strCpnIndexRecv,
            strSwapFreqPaid=i.strSwapFreqPaid,
            strSwapFreqRecv=i.strSwapFreqRecv,
            strinstrmttypcd=i.strinstrmttypcd,
            numInstTypeId=i.numInstTypeId,
        ) for i in instruments
    ])

    # --- Analytics (per inst/date) ---
    analytics_rows = []
    for chunk_inst_alds in chunker(list(inst_alds), 2000):
        analytics_rows.extend(
            session.query(DMIRBRSInstAnalytic)
            .filter(
                DMIRBRSInstAnalytic.strInstAladdin.in_(chunk_inst_alds),
                DMIRBRSInstAnalytic.datInstQuotationDate.in_(list(period_ends)),
            )
            .all()
        )
    df_a = pd.DataFrame([
        dict(
            strInstAladdin=a.strInstAladdin,
            datInstQuotationDate=a.datInstQuotationDate,
            nummktcap=a.nummktcap,
            numInstYieldToMaturity=a.numInstYieldToMaturity,
            numInstEffDuration=a.numInstEffDuration,
            numInstModifDuration=a.numInstModifDuration,
            numInstSpreadDuration=a.numInstSpreadDuration,
            numInstMCDuration=a.numInstMCDuration,
            numInstYield=a.numInstYield,
            numInstYieldToCall=a.numInstYieldToCall,
            numInstYieldToMaturityPaid=a.numInstYieldToMaturityPaid,
            numInstYieldToMaturityRecv=a.numInstYieldToMaturityRecv,
            numInstOptionAdjSpread=a.numInstOptionAdjSpread,
        ) for a in analytics_rows
    ])

    # --- Currency quotes (per currency/date) ---
    curr_codes = set(df_i["strInstCurrCode"].dropna().tolist())
    quotes_rows = []
    for chunk_curr in chunker(list(curr_codes), 2000):
        quotes_rows.extend(
            session.query(DMIRBRSCurrencyQuote)
            .filter(
                DMIRBRSCurrencyQuote.strCurrCode.in_(chunk_curr),
                DMIRBRSCurrencyQuote.datccyqDate.in_(list(period_ends)),
            )
            .all()
        )
    df_q = pd.DataFrame([
        dict(
            strCurrCode=q.strCurrCode,
            datccyqDate=q.datccyqDate,
            numccyqrateInv=q.numccyqrateInv,
        ) for q in quotes_rows
    ])

    # --- IT classes (by type id) ---
    type_ids = set(df_i["numInstTypeId"].dropna().tolist())
    def _it_df(model, cls_label):
        rows = (
            session.query(model)
            .filter(model.numInstrTypeID.in_(list(type_ids)),
                    model.strReportingType == f"class{cls_label}")
            .all()
        )
        return pd.DataFrame([
            dict(
                numInstrTypeID=r.numInstrTypeID,
                **{
                    f"InstrumentTypeNameClass{cls_label}": r.strInstrumentTypeName,
                    f"InstrumentTypeIRNameClass{cls_label}": r.strInstrumentTypeIRName,
                }
            ) for r in rows
        ])

    df_it1 = _it_df(IT1, "1")
    df_it3 = _it_df(IT3, "3")
    df_it8 = _it_df(IT8, "8")
    df_it9 = _it_df(IT9, "9")

    # --- Sectors ---
    def _sb_df(model, key):
        rows = (
            session.query(model)
            .filter(model.strInstAladdin.in_(list(inst_alds)))
            .all()
        )
        return pd.DataFrame([
            dict(
                strInstAladdin=r.strInstAladdin,
                **{
                    f"{key}1": getattr(r, "strInstSectorL1", None) or getattr(r, "strIssSector1Label", None),
                    f"{key}2": getattr(r, "strInstSectorL2", None) or getattr(r, "strIssSector2Label", None),
                    f"{key}3": getattr(r, "strInstSectorL3", None) or getattr(r, "strIssSector3Label", None),
                }
            ) for r in rows
        ])

    df_sb_bb   = _sb_df(SB_BB,   "InstrSectorBBLevel")
    df_sb_lh   = _sb_df(SB_LH,   "InstrSectorBarclaysLevel")
    df_sb_msci = _sb_df(SB_MSCI, "InstrSectorMSCILevel")
    df_sb_icb  = _sb_df(SB_ICB,  "InstrSectorICBLevel")

    # --- Portfolio / Link / AUM ---
    ports = session.query(DMIRPortfolio)\
        .filter(DMIRPortfolio.strPortfGPSCode.in_(list(rpt_codes))).all()
    df_p = pd.DataFrame([
        dict(
            strPortfGPSCode=p.strPortfGPSCode,
            strPtfName=p.strPtfName,
            strPtfCurrCode=p.strPtfCurrCode,
        ) for p in ports
    ])

    lnks = session.query(
        DMIRPortfolioLnk.strPortfGroupDECALOGCode,
        DMIRPortfolioLnk.numPortfGroupSkey,
        DMIRPortfolioLnk.strPortfGroupType
    ).filter(DMIRPortfolioLnk.numPortfGroupSkey.in_(list(map(int, grp_ids))),
             DMIRPortfolioLnk.strPortfGroupType.in_(["A","G"])).all()
    df_lnk = pd.DataFrame([
        dict(
            numReportPortfGroupID=l.numPortfGroupSkey,
            strPortfGroupDECALOGCode=l.strPortfGroupDECALOGCode,
        ) for l in lnks
    ]).drop_duplicates("numReportPortfGroupID")

    aums = session.query(
        DMIRBRSDMCPortfIndicators.strPortfGPSCode,
        DMIRBRSDMCPortfIndicators.datPeriodLastDay,
        DMIRBRSDMCPortfIndicators.numFundAUM
    ).filter(DMIRBRSDMCPortfIndicators.strPortfGPSCode.in_(list(rpt_codes)),
             DMIRBRSDMCPortfIndicators.datPeriodLastDay.in_(list(period_ends))).all()
    df_aum = pd.DataFrame([
        dict(
            strPortfGPSCode=r.strPortfGPSCode,
            datPeriodLastDay=r.datPeriodLastDay,
            numFundAUM=r.numFundAUM,
        ) for r in aums
    ]).sort_values("numFundAUM", ascending=False)\
     .drop_duplicates(["strPortfGPSCode","datPeriodLastDay"])

    # --- Compose df_inst (wide, per instrument) ---
    df_inst = df_i.copy()
    for dfit in (df_it1, df_it3, df_it8, df_it9):
        if not dfit.empty:
            df_inst = df_inst.merge(
                dfit, left_on="numInstTypeId", right_on="numInstrTypeID", how="left"
            ).drop(columns=["numInstrTypeID"], errors="ignore")
    for dfsb in (df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb):
        if not dfsb.empty:
            df_inst = df_inst.merge(dfsb, on="strInstAladdin", how="left")

    print("df_inst built")
    get_hardware_info()
    return df_inst, df_a, df_q, df_p, df_lnk, df_aum


# ---------------------------------------------------
# Vectorized serial processing (no parallelization)
# ---------------------------------------------------
def process_dmc_records_vectorized(
    df_lt: pd.DataFrame,
    df_scope_dmc: pd.DataFrame,  # (strReportPortfGPSCode, datPeriodLastDay)
    df_lt_ind: pd.DataFrame,     # tblDMIRBRSLTPortfInstrIndicators
    num_audit_id: int,
) -> pd.DataFrame:
    """
    Serial + vectorized version that keeps the original business logic.
    """

    # 0) Scope-filter & audit flag
    df_lt = df_lt.assign(numAuditId=num_audit_id).merge(
        df_scope_dmc,
        left_on=["strReportPortfGPSCode", "datPeriodLastDay"],
        right_on=["ReportPortfGPSCode", "datPeriodLastDay"],
        how="inner",
    )

    # 1) Keys for bulk fetch
    get_hardware_info()
    print("Preparing unique keys for bulk fetch")
    inst_alds   = set(df_lt["strInstAladdin"].dropna().unique().tolist())
    period_ends = set(df_lt["datPeriodLastDay"].dropna().unique().tolist())
    rpt_codes   = set(df_lt["strReportPortfGPSCode"].dropna().unique().tolist())
    grp_ids     = set(df_lt["numReportPortfGroupID"].dropna().unique().tolist())

    session = get_session()
    try:
        df_inst, df_a, df_q, df_p, df_lnk, df_aum = _build_df_inst(
            session, inst_alds, period_ends, rpt_codes, grp_ids
        )
    finally:
        session.close()

    # 2) Aggregations on df_lt (per key + instrument)
    print("Aggregating df_lt")
    get_hardware_info()

    group_cols = [
        "strReportPortfGPSCode", "datPeriodLastDay",
        "numReportPortfGroupID", "numAuditId",
        "strInstAladdin", "numInstID"
    ]
    agg_spec = {
        "numHoldPrice": "mean",
        "numHoldAccruedIntPortf": "sum",
        "numWeightedAmtInReportPortf": "sum",
        "numHoldCrossCur": "mean",
        "numWeightedQtqInReportPortf": "sum",
        "numHoldAvrgCostInReportPortf": "sum",
    }
    df_lt_agg = df_lt.groupby(group_cols, as_index=False).agg(agg_spec)

    # signOfLeg / nrLegs via your helper once per group
    def _sign_nr(g):
        return pd.Series(get_sign_leg_and_nr_leg(g))
    sign_nr = df_lt.groupby(group_cols).apply(_sign_nr).reset_index(drop=True)
    df_lt_agg = pd.concat([df_lt_agg, sign_nr], axis=1)

    # 3) Merges
    print("Merging instrument, analytics, quotes, portfolio, aum, link, indicators")
    get_hardware_info()

    # instrument details
    df_m = df_lt_agg.merge(df_inst, on="strInstAladdin", how="left")

    # analytics per (inst, date)
    if not df_a.empty:
        df_m = df_m.merge(
            df_a, left_on=["strInstAladdin", "datPeriodLastDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"], how="left"
        ).drop(columns=["datInstQuotationDate"], errors="ignore")

    # quotes per (currency, date)
    if not df_q.empty:
        df_m = df_m.merge(
            df_q, left_on=["strInstCurrCode", "datPeriodLastDay"],
            right_on=["strCurrCode", "datccyqDate"], how="left"
        ).drop(columns=["strCurrCode", "datccyqDate"], errors="ignore")

    # portfolio info
    if not df_p.empty:
        df_m = df_m.merge(df_p, left_on="strReportPortfGPSCode", right_on="strPortfGPSCode", how="left")\
                   .drop(columns=["strPortfGPSCode"], errors="ignore")

    # link by group
    if not df_lnk.empty:
        df_m = df_m.merge(df_lnk, on="numReportPortfGroupID", how="left")

    # AUM by (portfolio, date)
    if not df_aum.empty:
        df_m = df_m.merge(df_aum, on=["strPortfGPSCode", "datPeriodLastDay"], how="left")

    # indicators per (portfolio, date, inst)
    df_m = df_m.merge(
        df_lt_ind,
        left_on=["strReportPortfGPSCode", "datPeriodLastDay", "strInstAladdin"],
        right_on=["strPortfGPSCode", "datPeriodLastDay", "strInstAladdin"],
        how="left",
        suffixes=("", "_ind"),
    ).drop(columns=["strPortfGPSCode_ind"], errors="ignore")

    # 4) Vectorized enrichment

    # Constants
    df_m["strSource"] = "DMC-LT"
    df_m["AccountingDate"] = pd.to_datetime(df_m["datPeriodLastDay"]).dt.normalize()
    df_m["InstrumentDWHID"] = df_m["numInstID"]
    df_m["PortfolioDWHID"] = df_m["strReportPortfGPSCode"]
    df_m["PortfolioDWHGroupID"] = None
    df_m["PortfolioName"] = df_m.get("strPtfName")
    df_m["PortfolioCurrency"] = df_m.get("strPtfCurrCode")
    df_m["InstrUnitCostInstrCur"] = None
    df_m["InstrAvrgCostPortfCur"] = None
    df_m["InstrLastPriceDate"] = df_m["numHoldPrice"]
    df_m["InstrProfitLossPortfCur"] = None
    df_m["InstrQuantity"] = df_m["numWeightedQtqInReportPortf"]
    df_m["InstrLastPrice"] = df_m["numHoldPrice"]
    df_m["HoldingTypeName"] = None

    # Coupon index truncation
    df_m["InstrCouponIndexPaid"] = df_m["strCpnIndexPaid"].where(df_m["strCpnIndexPaid"].notna(), None)\
                                .astype("object").str.slice(0, 10)
    df_m["InstrCouponIndexReceived"] = df_m["strCpnIndexRecv"].where(df_m["strCpnIndexRecv"].notna(), None)\
                                      .astype("object").str.slice(0, 10)

    # Exchange rate
    df_m["InstrExchangeRate"] = df_m["numccyqrateInv"]

    # Market Cap EUR
    df_m["InstrMktCapEur"] = np.where(
        df_m["nummktcap"].notna() & df_m["numccyqrateInv"].notna(),
        df_m["nummktcap"] * df_m["numccyqrateInv"],
        np.nan
    )

    # Zero contributions when (nrLegs == 2) & (signOfLeg < 0)
    neg_leg_mask = (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0)
    for c in ["numEffectDurationContrib","numMCDurationContrib","numModifDurationContrib","numSpreadDurationContrib"]:
        out_col = {
            "numEffectDurationContrib": "InstrEffectiveDurationContribution",
            "numMCDurationContrib": "InstrMCDurationContribution",
            "numModifDurationContrib": "InstrModifiedDurationContribution",
            "numSpreadDurationContrib": "InstrSpreadDurationContribution",
        }[c]
        df_m[out_col] = np.where(neg_leg_mask, 0, df_m[c])

    # Duration exposure (cur & weight)
    qty_zero_mask = (df_m["nrLegs"] == 2) & (df_m["InstrQuantity"] == 0)
    df_m["InstrDurExposureInPortfCur"] = np.select(
        [
            qty_zero_mask,
            (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0)
        ],
        [
            df_m["numWeightedAmtInReportPortf"],
            0
        ],
        default=df_m["numDurExposureInPortfCur"]
    )
    df_m["InstrDurExposureWeight"] = np.select(
        [
            qty_zero_mask & df_m["numFundAUM"].notna(),
            (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0)
        ],
        [
            df_m["numWeightedAmtInReportPortf"] / df_m["numFundAUM"],
            0
        ],
        default=df_m["numDurExposureWeight"]
    )

    # FX family flag from IT class 3 IR name
    fx_family = df_m["InstrumentTypeIRNameClass3"].astype("string").str.upper().isin(
        ["CURRENCY SPOT","CURRENCY FORWARD","CURRENCY SWAP","FOREX POSITIONS"]
    )

    # Currency exposure (cur & weight)
    zero_qty_forward_mask = (df_m["InstrQuantity"] == 0) & (df_m["numHoldAvrgCostInReportPortf"] > 0)
    fx_flip_mask = fx_family & ( (df_m["signOfLeg"] < 0) | zero_qty_forward_mask )

    # Cur exposure
    df_m["InstrCurExposureInPortfCur"] = np.select(
        [
            fx_flip_mask,                                     # flip + add PL portion
            (~fx_family) & (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0)  # zero out
        ],
        [
            (-df_m["numCurExposureInPortfCur"]).where(df_m["numCurExposureInPortfCur"].notna(), np.nan)
            + np.where(df_m["numFundAUM"].notna() & df_m["numInstrWeight"].notna(),
                       df_m["numInstrWeight"] * df_m["numFundAUM"], 0),
            0
        ],
        default=df_m["numCurExposureInPortfCur"]
    )

    # Weight exposure
    df_m["InstrCurExposureWeight"] = np.select(
        [
            fx_flip_mask,                                     # flip + add weight
            (~fx_family) & (df_m["nrLegs"] == 2) & (df_m["signOfLeg"] < 0),  # zero out
            df_m["numCurExposureWeight"].isna() & df_m["numFundAUM"].notna() # compute from amt/aum
        ],
        [
            (-df_m["numCurExposureWeight"]).where(df_m["numCurExposureWeight"].notna(), np.nan)
            + df_m["numInstrWeight"],
            0,
            df_m["numWeightedAmtInReportPortf"] / df_m["numFundAUM"]
        ],
        default=df_m["numCurExposureWeight"]
    )

    # Instrument weight
    df_m["InstrWeight"] = np.where(
        df_m["numFundAUM"].notna() & (df_m["numFundAUM"] != 0),
        df_m["numWeightedAmtInReportPortf"] / df_m["numFundAUM"],
        np.nan
    )

    # Market-cap tier
    bins = [-np.inf, 3e8, 2.5e9, 1e10, np.inf]
    labels = [
        "CR_DATA_MKTCAP1_4_0-300M",
        "CR_DATA_MKTCAP1_3_300M-2.5B",
        "CR_DATA_MKTCAP1_2_2.5B-10B",
        "CR_DATA_MKTCAP1_1_10B-MAX",
    ]
    df_m["InstrMktCapEurTr1"] = pd.cut(df_m["InstrMktCapEur"], bins=bins, labels=labels)
    df_m["InstrMktCapEurTr1"] = df_m["InstrMktCapEurTr1"].astype("object")
    df_m.loc[df_m["InstrMktCapEur"].isna(), "InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_OTHER"

    # dateEOM (exact end-of-month)
    df_m["dateEOM"] = pd.to_datetime(df_m["datPeriodLastDay"]) + pd.offsets.MonthEnd(0)

    # Map/rename instrument details to final names (already aligned above)
    # Sectors are already attached with names: InstrSectorBBLevel1..3, etc.

    # Final column ordering: keep everything you produced originally; here we return all.
    print(f"Vectorized build complete, rows: {len(df_m)}")
    get_hardware_info()

    if df_m.empty:
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

    # Optional: downcast floats to reduce memory without losing logic
    # df_m = df_m.apply(lambda s: pd.to_numeric(s, downcast="float") if s.dtype == "float64" else s)

    df_out = df_m.copy()
    del df_m, df_lt_agg
    gc.collect()
    return df_out
