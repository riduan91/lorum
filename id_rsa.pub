# --- ProcessPoolExecutor version (this function only) ---
# Helpers for multiprocessing
import pandas as pd
import numpy as np
from concurrent.futures import ProcessPoolExecutor, as_completed
from sqlalchemy import and_, func, cast, String
from sqlalchemy.exc import SQLAlchemyError

# Global inside each worker process (set once via initializer)
_DMPSI2_INSTR_DF = None

def _init_dmpsi2_worker(instr_df: pd.DataFrame):
    """Initializer for worker processes: stash the instruments DataFrame globally."""
    global _DMPSI2_INSTR_DF
    _DMPSI2_INSTR_DF = instr_df

def _process_dmpsi2_batch(batch_df: pd.DataFrame, specials_df: pd.DataFrame) -> pd.DataFrame:
    """
    Worker-side CPU job (pure pandas/numpy; no DB/ORM calls):
    - Merge batch with global instruments DF.
    - Vectorize SPECIAL logic using specials_df.
    - Compute strSrcUndrlygHoldData and return the final projected DataFrame.
    """
    # Ensure datetime dtype
    if "datHoldDate" in batch_df.columns:
        batch_df["datHoldDate"] = pd.to_datetime(batch_df["datHoldDate"], errors="coerce")

    # Vectorized merge with instruments cache (global in this worker)
    merged = batch_df.merge(
        _DMPSI2_INSTR_DF,
        how="left",
        left_on="strInvestedInInstrID",
        right_on="strInstAladdin",
        suffixes=("", "_inst"),
    )

    # Vectorized SPECIAL determination
    if specials_df is not None and not specials_df.empty:
        specials_df = specials_df.copy()
        specials_df["datValidBegin"] = pd.to_datetime(specials_df["datValidBegin"], errors="coerce")
        specials_df["datValidEnd"] = pd.to_datetime(specials_df["datValidEnd"], errors="coerce")

        merged = merged.reset_index().rename(columns={"index": "_row_idx"})
        sp_merge = merged[["_row_idx", "strInstISINCode", "strPortfLevelID", "datHoldDate"]].merge(
            specials_df,
            left_on=["strInstISINCode", "strPortfLevelID"],
            right_on=["strSPISINCode", "strPortfLevelID"],
            how="left",
        )

        cond = (
            (sp_merge["datValidBegin"].isna() | (sp_merge["datValidBegin"] <= sp_merge["datHoldDate"]))
            & (sp_merge["datValidEnd"].isna() | (sp_merge["datValidEnd"] <= sp_merge["datHoldDate"]))
        )

        special_any = cond.groupby(sp_merge["_row_idx"]).any()
        merged = merged.merge(
            special_any.rename("is_special"),
            left_on="_row_idx",
            right_index=True,
            how="left",
        )
        merged["is_special"] = merged["is_special"].fillna(False)
    else:
        merged["is_special"] = False

    # Compute strSrcUndrlygHoldData vectorized
    has_internal = merged["strPortfGPSCode"].notna() if "strPortfGPSCode" in merged else False
    merged["strSrcUndrlygHoldData"] = np.where(
        merged["is_special"],
        "SPECIAL",
        np.where(has_internal, "INTERNAL", "EXTERNAL"),
    )

    # Final projection
    out_cols = [
        "datReportDate",
        "strReportPeriod",
        "strReportPortfHoldSrc",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "strPortfID",
        "strPortfName",
        "numPortfAUM",
        "strPortfISOCur",
        "strInvestedInInstrID",
        "numHoldCrossCur",
        "numHoldValueInPortfCur",
        "numHoldQuantity",
        "datHoldDate",
        "numHoldPrice",
        "numHoldAccruedIntInstr",
        "numHoldAccruedIntPortf",
        "numWeightInReportPortfAUM",
        "strPortfLevelID",
        "datPeriodLastDay",
        "strSrcUndrlygHoldData",
        "strInstAladdin",
        "numInstID",
        "numHoldAvrgCostInPortfCur",
        # enriched fields from instruments cache:
        "strInvestedInPortfID",
        "strInvestedInPortfName",
        "strInstISINCode",
        "strInstrumentTypeIRName",
        "strLevel1IsinCode",
        "strReportPortfISOCur",
    ]
    for c in out_cols:
        if c not in merged.columns:
            merged[c] = pd.Series([None] * len(merged))

    return merged[out_cols]


def data_monitoring_previous_step_internal_2(
    Session: sqlalchemy.orm.Session, path_monitoring_previous_step_internal: str
):
    """
    Parallel (multiprocessing) vectorized version:
      - Build instruments cache DataFrame once in the parent.
      - Stream each batch from cte_data_monitoring_previous_step_internal.
      - For each batch, fetch SPECIALS (ORM, in parent) and submit CPU work to a ProcessPool worker.
      - Collect DataFrames from workers, concatenate once, and save.
    Notes:
      * We DO NOT pass SQLAlchemy Session objects to workers (not picklable).
      * Workers perform only pandas/numpy work using a global instruments DF initialized once.
    """
    logger.log.info("Get data monitoring previous step internal 2 (pandas vectorized + ProcessPool).")

    # ---- Build instruments cache (parent process) ----
    # Expect an existing helper that returns a pandas DataFrame with columns:
    # ['strInstAladdin','numInstID','strInvestedInPortfID','strInvestedInPortfName',
    #  'strInstrumentTypeIRName','strPortfGPSCode','strInstISINCode']
    # If your _ensure_instruments_cache returns None, adapt to fetch the global DF.
    _ensure_instruments_cache(Session)
    instr_df = _INSTRUMENTS_DF.copy()  # make an isolated copy to ship once to each worker

    session = Session()
    try:
        results = []
        futures = []

        # Tune worker count based on CPU and memory
        max_workers = None  # defaults to os.cpu_count()
        with ProcessPoolExecutor(max_workers=max_workers, initializer=_init_dmpsi2_worker, initargs=(instr_df,)) as ex:
            for idx, monitoring_internal in enumerate(
                cte_data_monitoring_previous_step_internal(
                    path_monitoring_previous_step_internal=path_monitoring_previous_step_internal
                )
            ):
                logger.log.info(f"cte_data_monitoring_previous_step_internal idx = {idx}")

                # ---- Load the batch into a DataFrame (parent process, ORM streaming) ----
                q = (
                    session.query(
                        monitoring_internal.c.datReportDate,
                        monitoring_internal.c.strReportPeriod,
                        monitoring_internal.c.strReportPortfHoldSrc,
                        monitoring_internal.c.numReportPortfGroupID,
                        monitoring_internal.c.strReportPortfGPSCode,
                        monitoring_internal.c.strPortfID,
                        monitoring_internal.c.strPortfName,
                        monitoring_internal.c.numPortfAUM,
                        monitoring_internal.c.strPortfISOCur,
                        monitoring_internal.c.strInvestedInInstrID,  # join key to instruments
                        monitoring_internal.c.numHoldCrossCur,
                        monitoring_internal.c.numHoldValueInPortfCur,
                        monitoring_internal.c.numHoldQuantity,
                        monitoring_internal.c.datHoldDate,
                        monitoring_internal.c.numHoldPrice,
                        monitoring_internal.c.numHoldAccruedIntInstr,
                        monitoring_internal.c.numHoldAccruedIntPortf,
                        monitoring_internal.c.numWeightInReportPortfAUM,
                        monitoring_internal.c.strPortfLevelID,
                        monitoring_internal.c.datPeriodLastDay,
                        monitoring_internal.c.strInstAladdin,
                        monitoring_internal.c.numInstID,
                        monitoring_internal.c.numHoldAvrgCostInPortfCur,
                        monitoring_internal.c.strLevel1IsinCode,
                        monitoring_internal.c.strReportPortfISOCur,
                    )
                    .yield_per(5000)
                    .execution_options(stream_results=True)
                )
                rows = [dict(r._mapping) for r in q]
                if not rows:
                    continue

                batch_df = pd.DataFrame.from_records(rows)

                # ---- Fetch SPECIALS for this batch (still in parent process, via ORM) ----
                isin_vals = (
                    batch_df["strInvestedInInstrID"]
                    .map(instr_df.set_index("strInstAladdin")["strInstISINCode"])
                    .dropna()
                    .unique()
                    .tolist()
                    if len(batch_df)
                    else []
                )
                lvl_vals = batch_df["strPortfLevelID"].dropna().unique().tolist() if "strPortfLevelID" in batch_df else []

                specials_df = pd.DataFrame(columns=["strSPISINCode", "strPortfLevelID", "datValidBegin", "datValidEnd"])
                if isin_vals and lvl_vals:
                    specials = (
                        session.query(
                            DMIRSpecialFunds.strSPISINCode,
                            DMIRSpecialFunds.strPortfLevelID,
                            DMIRSpecialFunds.datValidBegin,
                            DMIRSpecialFunds.datValidEnd,
                        )
                        .filter(
                            DMIRSpecialFunds.strSPISINCode.in_(isin_vals),
                            DMIRSpecialFunds.strPortfLevelID.in_(lvl_vals),
                        )
                        .all()
                    )
                    if specials:
                        specials_df = pd.DataFrame.from_records(
                            [
                                {
                                    "strSPISINCode": s.strSPISINCode,
                                    "strPortfLevelID": s.strPortfLevelID,
                                    "datValidBegin": s.datValidBegin,
                                    "datValidEnd": s.datValidEnd,
                                }
                                for s in specials
                            ]
                        )

                # ---- Submit CPU work to a worker process ----
                futures.append(ex.submit(_process_dmpsi2_batch, batch_df, specials_df))

            # ---- Collect results ----
            for f in as_completed(futures):
                results.append(f.result())

        # ---- Save once ----
        if results:
            final_df = pd.concat(results, ignore_index=True)
            monitoring_data = final_df.to_dict(orient="records")
        else:
            monitoring_data = []

        path_out = dataprocess.save_json(
            data=monitoring_data,
            data_folder="data/lt_monitoringwrk_stepn",
            filename="data_monitoring_previous_step_internal_2",
        )

        logger.log.info(
            f"Get data monitoring previous step internal 2 (ProcessPool) done. Scope size = {len(monitoring_data)}"
        )
        return path_out

    except SQLAlchemyError as e:
        session.rollback()
        logger.log.error(
            f"Error occurred when data_monitoring_previous_step_internal_2 (ProcessPool): {str(e)}."
        )
        raise
    finally:
        session.close()
