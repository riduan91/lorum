def single_compute_bench_indicators_bkgn_10(
    i,
    numBenchFBAId,
    strCompositionCd,
    datReportingDay,
    strPeriodTypeFlag,
    strPFCurrencyISOCode,
    group_df,
    retry=3,
):
    """
    Compute one BKGN‑10 group (bench‑level analytics).

    Notes on the rewrite
    --------------------
    • “FI” averages now weight with *numweight* (market‑value weight) rather than
      *numDurExposureWeight* to match the SQL.                 # <-- MODIFIED
    • Instrument‑level columns passed to `weighted_avg` are kept *raw*; the
      function will apply the weight once, preventing double‑weighting.  # <-- MODIFIED
    • Issuer counting and holdings counting use the correct column lists. # <-- MODIFIED
    """
    print(f"Computing bkgn 10 for chunk {i}")
    get_hardware_info()
    final_results = []
    session = None
    try:
        session = get_session()

        instruments = group_df["strInstAladdin"].unique().tolist()
        group_keys = [
            "numBenchFBAId",
            "strCompositionCd",
            "datReportingDay",
            "strPeriodTypeFlag",
            "strPFCurrencyISOCode",
        ]

        # --------------------------  SUBQUERY A  --------------------------
        inst_dfs = []
        for chunk in chunk_list(instruments, 2000):
            query_a = (
                session.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.numInstEffDuration,
                    DMIRBRSInstAnalytic.numInstModifDuration,
                    DMIRBRSInstAnalytic.numInstMCDuration,
                    DMIRBRSInstAnalytic.numInstYieldToMaturity,
                    DMIRBRSInstAnalytic.numInstConvexity,
                    DMIRBRSInstAnalytic.numInstSpreadDuration,
                    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
                    DMIRBRSInstAnalytic.numyldtoworst,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.strInstIssuerCode,
                    DMIRBRSInstrument.numInstCouponRate,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.datInstCallDate,
                    DMIRBRSInstrument.numInstTypeId,
                )
                .select_from(DMIRBRSInstrument)
                .outerjoin(
                    DMIRBRSInstAnalytic,
                    DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                )
                .filter(
                    DMIRBRSInstAnalytic.datInstQuotationDate == datReportingDay,
                    DMIRBRSInstAnalytic.strInstAladdin.in_(chunk),
                )
            )
            inst_dfs.append(get_all_as_df(query_a))
        df_inst = pd.concat(inst_dfs, ignore_index=True)

        if df_inst.empty:
            df_inst = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "numInstEffDuration",
                    "numInstModifDuration",
                    "numInstMCDuration",
                    "numInstYieldToMaturity",
                    "numInstConvexity",
                    "numInstSpreadDuration",
                    "numyldtoworst",
                    "numInstOptionAdjSpread",
                    "datInstQuotationDate",
                    "strInstIssuerCode",
                    "numInstCouponRate",
                    "datInstMaturityDate",
                    "datInstCallDate",
                    "numInstTypeId",
                ]
            )

        df_inst["datInstQuotationDate"] = pd.to_datetime(df_inst["datInstQuotationDate"])

        df_a = pd.merge(
            group_df,
            df_inst,
            how="left",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            suffixes=("", "_a"),
        )

        # Aggregated benchmark‑level totals ────────────────────────────────
        df_a["curExposureBench"] = df_a["numCurExposureInBenchCur"]
        df_a["durExposureBench"] = df_a["numDurExposureInBenchCur"]
        df_a["effectDurationBench"] = df_a["numInstEffDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["modifDurationBench"] = df_a["numInstModifDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["MCDurationBench"] = df_a["numInstMCDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["benchAvgCoupon"] = df_a["numInstCouponRate"].astype(float) * df_a["numweight"].astype(
            float
        )
        df_a["benchAvgYTM"] = df_a["numInstYieldToMaturity"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["benchAvgConvexity"] = df_a["numInstConvexity"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["spreadDurationBench"] = df_a["numInstSpreadDuration"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)
        df_a["benchAvgOas"] = df_a["numInstOptionAdjSpread"].astype(float).fillna(0) * df_a[
            "numDurExposureWeight"
        ].astype(float).fillna(0)
        df_a["benchAvgDts"] = (
            df_a["numInstOptionAdjSpread"].astype(float).fillna(0)
            * df_a["numInstSpreadDuration"].astype(float).fillna(0)
            * df_a["numDurExposureWeight"].astype(float).fillna(0)
        )
        df_a["benchAvgYTMDurWeighted"] = df_a["numInstYieldToMaturity"].astype(float) * df_a[
            "numModifDurationContribWeight"
        ].astype(float)
        df_a["benchAvgYieldWorst"] = df_a["numyldtoworst"].astype(float) * df_a[
            "numDurExposureWeight"
        ].astype(float)

        df_a["maturity_diff"] = df_a.apply(
            lambda row: calc_maturity_diff(row) * row["numweight"], axis=1
        )

        agg_dict_a = {
            "curExposureBench": "sum",
            "durExposureBench": "sum",
            "effectDurationBench": "sum",
            "modifDurationBench": "sum",
            "MCDurationBench": "sum",
            "benchAvgCoupon": "sum",
            "benchAvgYTM": "sum",
            "benchAvgConvexity": "sum",
            "spreadDurationBench": "sum",
            "benchAvgOas": "sum",
            "benchAvgDts": "sum",
            "benchAvgYTMDurWeighted": "sum",
            "benchAvgYieldWorst": "sum",
            "maturity_diff": "sum",
            "strInstIssuerCode": pd.Series.nunique,
        }
        df_a_grouped = df_a.groupby(group_keys).agg(agg_dict_a).reset_index()
        df_a_grouped["datBenchAvgMaturityLife"] = (
            pd.to_datetime(df_a_grouped["datReportingDay"])
            + pd.to_timedelta(df_a_grouped["maturity_diff"], unit="days")
            if df_a_grouped["maturity_diff"].sum() > 0
            else pd.NaT
        )
        df_a_grouped.drop(columns=["maturity_diff"], inplace=True)
        df_a_grouped.rename(columns={"strInstIssuerCode": "numNumberOfIssuers"}, inplace=True)
        group_a = df_a_grouped.iloc[0].to_dict() if not df_a_grouped.empty else {}

        # --------------------------  SUBQUERY B  --------------------------
        inst_dfs_B = []
        for chunk in chunk_list(instruments, 2000):
            query_b = (
                session.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.numInstEffDuration,
                    DMIRBRSInstAnalytic.numInstModifDuration,
                    DMIRBRSInstAnalytic.numInstMCDuration,
                    DMIRBRSInstAnalytic.numInstYieldToMaturity,
                    DMIRBRSInstAnalytic.numInstConvexity,
                    DMIRBRSInstAnalytic.numInstSpreadDuration,
                    DMIRBRSInstAnalytic.numyldtoworst,
                    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.strInstIssuerCode,
                )
                .select_from(DMIRBRSInstrument)
                .outerjoin(
                    DMIRBRSInstAnalytic,
                    DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                )
                .outerjoin(
                    DMIRInstrumentIRType,
                    DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                )
                .filter(
                    DMIRBRSInstAnalytic.datInstQuotationDate == datReportingDay,
                    DMIRBRSInstAnalytic.strInstAladdin.in_(chunk),
                    DMIRInstrumentIRType.strReportingType == "class4",
                    DMIRInstrumentIRType.strInstrumentTypeIRName.in_(
                        ["Derivatives - Fixed Income", "Fixed Income", "MF - Fixed Income"]
                    ),
                )
            )
            inst_dfs_B.append(get_all_as_df(query_b))
        df_inst_B = pd.concat(inst_dfs_B, ignore_index=True)
        if df_inst_B.empty:
            df_inst_B = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "numInstEffDuration",
                    "numInstModifDuration",
                    "numInstMCDuration",
                    "numInstYieldToMaturity",
                    "numInstConvexity",
                    "numInstSpreadDuration",
                    "numyldtoworst",
                    "numInstOptionAdjSpread",
                    "datInstQuotationDate",
                    "strInstIssuerCode",
                ]
            )

        df_inst_B["datInstQuotationDate"] = pd.to_datetime(df_inst_B["datInstQuotationDate"])
        df_b = pd.merge(
            group_df,
            df_inst_B,
            how="left",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            suffixes=("", "_b"),
        )

        # ---- FI instrument‑level RAW values (weight applied later) ------
        df_b["effDurationBenchFI"] = df_b["numInstEffDuration"].astype(float)            # <-- MODIFIED
        df_b["modifDurationBenchFI"] = df_b["numInstModifDuration"].astype(float)        # <-- MODIFIED
        df_b["MCDurationBenchFI"]  = df_b["numInstMCDuration"].astype(float)             # <-- MODIFIED
        df_b["benchAvgYTMFI"]      = df_b["numInstYieldToMaturity"].astype(float)        # <-- MODIFIED
        df_b["benchAvgConvexityFI"]= df_b["numInstConvexity"].astype(float)              # <-- MODIFIED
        df_b["spreadDurationBenchFI"]= df_b["numInstSpreadDuration"].astype(float)       # <-- MODIFIED
        df_b["benchAvgYTMDurWeightedFI"] = (
            df_b["numInstYieldToMaturity"].astype(float)
            * df_b["numModifDurationContribWeight"].astype(float)
        )                                                                                # <-- MODIFIED
        df_b["benchAvgYieldWorstFI"]= df_b["numyldtoworst"].astype(float)                # <-- MODIFIED
        df_b["benchAvgOasFI"]      = df_b["numInstOptionAdjSpread"].astype(float).fillna(0) # <-- MODIFIED
        df_b["benchAvgDtsFI"]      = (
            df_b["numInstOptionAdjSpread"].astype(float).fillna(0)
            * df_b["numInstSpreadDuration"].astype(float).fillna(0)
        )                                                                                # <-- MODIFIED

        # ---- Group and compute weighted averages ----------------------
        df_b_grouped = (
            df_b.groupby(group_keys)
            .apply(
                lambda g: pd.Series(
                    {
                        "numEffectDurationBenchFI":       weighted_avg(g, "effDurationBenchFI"),
                        "numModifDurationBenchFI":        weighted_avg(g, "modifDurationBenchFI"),
                        "numMCDurationBenchFI":           weighted_avg(g, "MCDurationBenchFI"),
                        "numBenchAvgYTMFI":               weighted_avg(g, "benchAvgYTMFI"),
                        "numBenchAvgConvexityFI":         weighted_avg(g, "benchAvgConvexityFI"),
                        "numSpreadDurationBenchFI":       weighted_avg(g, "spreadDurationBenchFI"),
                        "numBenchAvgYTMDurWeightedFI":    weighted_avg(g, "benchAvgYTMDurWeightedFI"),
                        "numBenchAvgYieldWorstFI":        weighted_avg(g, "benchAvgYieldWorstFI"),
                        "numBenchAvgOasFI":               weighted_avg(g, "benchAvgOasFI"),
                        "numBenchAvgDtsFI":               weighted_avg(g, "benchAvgDtsFI"),
                        "numNumberOfIssuersFI":           g["strInstIssuerCode"].nunique(),   # <-- MODIFIED
                    }
                )
            )
            .reset_index(drop=True)
        )
        group_b = df_b_grouped.iloc[0].to_dict() if not df_b_grouped.empty else {}

        # --------------------------  SUBQUERY C  --------------------------
        inst_dfs_c = []
        for chunk in chunk_list(instruments, 2000):
            query_c = (
                session.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.numInstID,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.numInstCouponRate,
                    DMIRBRSInstrument.blncall,
                    DMIRBRSInstrument.datInstCallDate,
                )
                .select_from(DMIRBRSInstrument)
                .outerjoin(
                    DMIRBRSInstAnalytic,
                    DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                )
                .outerjoin(
                    DMIRInstrumentIRType,
                    DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                )
                .filter(
                    DMIRBRSInstAnalytic.datInstQuotationDate == datReportingDay,
                    DMIRBRSInstAnalytic.strInstAladdin.in_(chunk),
                    DMIRInstrumentIRType.strReportingType == "class4",
                    DMIRInstrumentIRType.strInstrumentTypeIRName == "Fixed Income",
                    DMIRBRSInstrument.numInstTypeId != 506,
                )
            )
            inst_dfs_c.append(get_all_as_df(query_c))

        df_inst_c = pd.concat(inst_dfs_c, ignore_index=True)
        if df_inst_c.empty:
            df_inst_c = pd.DataFrame(
                columns=[
                    "strInstAladdin",
                    "datInstQuotationDate",
                    "numInstID",
                    "datInstMaturityDate",
                    "numInstCouponRate",
                    "blncall",
                    "datInstCallDate",
                ]
            )

        df_inst_c["datInstQuotationDate"] = pd.to_datetime(df_inst_c["datInstQuotationDate"])

        df_c = pd.merge(
            group_df,
            df_inst_c,
            how="left",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
            suffixes=("", "_c"),
        )

        df_c["benchAvgCouponFI_weighted"] = (
            df_c["numInstCouponRate"].astype(float) * df_c["numweight"].astype(float)
        )                                                               # <-- MODIFIED (weight)
        df_c["maturity_diff_c"] = df_c.apply(
            lambda row: calc_maturity_diff_c(row) * row["numweight"], axis=1
        )                                                               # <-- MODIFIED (weight)

        df_c_grouped = (
            df_c.groupby(group_keys)
            .apply(
                lambda g: pd.Series(
                    {
                        "numBenchAvgCouponFI": (
                            g["benchAvgCouponFI_weighted"].sum() / g["numweight"].sum()
                            if g["numweight"].sum() != 0
                            else np.nan
                        ),
                        "datBenchAvgMaturityLifeFI": (
                            (
                                pd.to_datetime(g["datReportingDay"].iloc[0])
                                + pd.to_timedelta(
                                    g["maturity_diff_c"].sum() / g["numweight"].sum(),
                                    unit="days",
                                )
                            )
                            if g["numweight"].sum() != 0 and g["maturity_diff_c"].sum() > 0
                            else pd.NaT
                        ),
                    }
                )
            )
            .reset_index(drop=True)
        )
        group_c = df_c_grouped.iloc[0].to_dict() if not df_c_grouped.empty else {}

        # --------------------------  SUBQUERY D  --------------------------
        query_d = (
            session.query(DMIRBRSInstrument.strInstAladdin)
            .select_from(DMIRBRSInstrument)
            .outerjoin(
                DMIRInstrumentIRType,
                DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
            )
            .filter(
                DMIRBRSInstrument.strInstAladdin.in_(instruments),            # <-- MODIFIED
                DMIRInstrumentIRType.strReportingType == "class4",
                DMIRInstrumentIRType.strInstrumentTypeIRName != "Cash",
            )
        )
        df_inst_d = get_all_as_df(query_d)
        if df_inst_d.empty:
            df_inst_d = pd.DataFrame(columns=["strInstAladdin"])

        group_d = {"numHoldingsNumber": df_inst_d["strInstAladdin"].nunique()}

        # --------------------------  FINAL ASSEMBLY -----------------------
        group_result = {}
        group_result.update(group_a)
        group_result.update(group_b)
        group_result.update(group_c)
        group_result.update(group_d)

        group_result["numBenchFBAId"] = numBenchFBAId
        group_result["strCompositionCd"] = strCompositionCd
        group_result["datReportingDay"] = datReportingDay
        group_result["strPeriodTypeFlag"] = strPeriodTypeFlag
        group_result["strPFCurrencyISOCode"] = strPFCurrencyISOCode

        final_results.append(group_result)
        return pd.DataFrame(final_results)

    except Exception as e:
        print(e)
        safe_close(session)
        if retry > 0:
            return single_compute_bench_indicators_bkgn_10(
                i,
                numBenchFBAId,
                strCompositionCd,
                datReportingDay,
                strPeriodTypeFlag,
                strPFCurrencyISOCode,
                group_df,
                retry=retry - 1,
            )
    finally:
        safe_close(session)
