SELECT  DATA_TYPE,
        CHARACTER_MAXIMUM_LENGTH,     -- for varchar, nvarchar …
        NUMERIC_PRECISION,            -- for decimal, numeric …
        NUMERIC_SCALE
FROM    INFORMATION_SCHEMA.COLUMNS
WHERE   TABLE_SCHEMA = 'dbo'
  AND   TABLE_NAME   = 'YourTable'
  AND   COLUMN_NAME  = 'YourColumn';
