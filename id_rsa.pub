# --- FAST aggregation with Polars ---
import polars as pl

print("Aggregating df_lt with Polars")
get_hardware_info()

group_cols = [
    "strReportPortfGPSCode", "datPeriodLastDay",
    "numReportPortfGroupID", "numAuditId",
    "strInstAladdin", "numInstID"
]

# map your agg_spec to Polars expressions
agg_exprs = [
    pl.col("numHoldPrice").mean().alias("numHoldPrice"),
    pl.col("numHoldAccruedIntPortf").sum().alias("numHoldAccruedIntPortf"),
    pl.col("numWeightedAmtInReportPortf").sum().alias("numWeightedAmtInReportPortf"),
    pl.col("numHoldCrossCur").mean().alias("numHoldCrossCur"),
    pl.col("numWeightedQtqInReportPortf").sum().alias("numWeightedQtqInReportPortf"),
    pl.col("numHoldAvrgCostInReportPortf").sum().alias("numHoldAvrgCostInReportPortf"),
]

# Convert pandas -> polars
# (Polars will infer types; ensure datPeriodLastDay is datetime/date)
pl_df = pl.from_pandas(df_lt)

# If needed: enforce date type for consistent grouping (optional)
# pl_df = pl_df.with_columns(pl.col("datPeriodLastDay").cast(pl.Date))

# Groupby + agg in Polars (multi-threaded by default)
pl_agg = (
    pl_df.groupby(group_cols, maintain_order=False)
         .agg(agg_exprs)
)

# Back to pandas (same column names as pandas agg would produce)
df_lt_agg = pl_agg.to_pandas(use_pyarrow_extension_array=True)

print("Polars aggregation complete")
get_hardware_info()
