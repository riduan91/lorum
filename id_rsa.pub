.
SELECT
    wt.session_id        AS blocked_session_id,
    wt.blocking_session_id,
    DB_NAME(er.database_id) AS database_name,
    wt.wait_type,
    wt.wait_duration_ms,
    r.command            AS blocked_command,
    t1.text             AS blocked_sql_text,
    t2.text             AS blocking_sql_text
FROM sys.dm_os_waiting_tasks AS wt
JOIN sys.dm_exec_requests AS er
    ON wt.session_id = er.session_id
CROSS APPLY sys.dm_exec_sql_text(er.sql_handle) AS t1
-- blocking SQL:
OUTER APPLY (
    SELECT text
    FROM sys.dm_exec_requests AS bre
    CROSS APPLY sys.dm_exec_sql_text(bre.sql_handle)
    WHERE bre.session_id = wt.blocking_session_id
) AS t2
WHERE wt.blocking_session_id IS NOT NULL;
