import itertools
from concurrent.futures import ThreadPoolExecutor, as_completed

from sqlalchemy import select, values as sa_values, text, tuple_
from sqlalchemy.orm import Session

# --- helper -------------------------------------------------------------

def _one_chunk(
    engine,
    chunk_records: list[dict],
    lookup_table,           # SQLAlchemy Table or ORM model you join against
    param_cols: list[str],
    extra_cols=None,
    transform=None,
    return_rejected=False,
):
    """
    Worker that does ONE batched join and returns (enriched, rejected).
    Run inside its own thread so it can own its Session.
    """
    if extra_cols is None:
        extra_cols = []

    enriched, rejected = [], []

    with Session(engine) as session:
        # 1. Build VALUES (...) inline table for the parameters we want to match on
        vals = [
            tuple(row[c] for c in param_cols)
            for row in chunk_records
        ]
        # SQLAlchemy 1.4+: sa_values() produces an aliasable "table"
        v_alias = sa_values(
            # list of column objects
            *[tuple_(*param_cols).type] if len(param_cols) > 1 else [lookup_table.c[param_cols[0]].type]
        ).data(vals).alias("v")

        # Make sure the alias columns are named the same as actual columns
        for c, name in zip(v_alias.c, param_cols):
            c.key = name

        # 2. Build the SELECT ... FROM lookup_table JOIN v_alias ...
        stmt = (
            select(
                *[lookup_table.c[col] for col in lookup_table.c.keys()],
                *[v_alias.c[col] for col in param_cols],   # keep keys so we can merge
                *extra_cols
            )
            .select_from(lookup_table.join(
                v_alias,
                # composite join condition
                tuple_(*(lookup_table.c[c] for c in param_cols))
                == tuple_(*(v_alias.c[c] for c in param_cols))
            ))
        )

        db_rows = session.execute(stmt).mappings().all()

    # 3. Index DB result(s) by the join-key so we can merge back
    by_key = {}
    for r in db_rows:
        key = tuple(r[c] for c in param_cols)
        by_key[key] = r  # keep last; if 1-to-many you’ll need list append

    # 4. Merge & optional transform
    for row in chunk_records:
        key = tuple(row[c] for c in param_cols)
        hit = by_key.get(key)
        if hit:
            merged = row | hit  # Python 3.9+ dict union
            if transform:
                merged = transform(merged)
            enriched.append(merged)
        else:
            rejected.append(row)

    return (enriched, rejected) if return_rejected else (enriched, None)


# --- public API ---------------------------------------------------------

def join_with_db_parallel(
    engine,
    records: list[dict],
    lookup_table,
    param_cols: list[str],
    *,
    transform=None,
    return_rejected=False,
    chunk_size=1_000,
    max_workers=4,
):
    """
    Batch-joins *records* with *lookup_table* on *param_cols*.
    Runs chunks concurrently so DB trips overlap.

    Parameters
    ----------
    engine          : SQLAlchemy Engine or Connection
    records         : list[dict]   – input rows
    lookup_table    : Table | ORM  – table/model to join with
    param_cols      : list[str]    – columns that form the join key
    transform       : callable(dict)->dict  – optional row post-processor
    return_rejected : bool         – return list of unmatched rows?
    chunk_size      : int          – how many rows per batch query
    max_workers     : int          – ThreadPool size
    """
    if not records:
        return ([], []) if return_rejected else []

    # 1. Split the work into chunks
    chunks = [
        records[i : i + chunk_size] for i in range(0, len(records), chunk_size)
    ]

    enriched_all, rejected_all = [], []

    # 2. Kick-off workers
    with ThreadPoolExecutor(max_workers=max_workers) as pool:
        futures = [
            pool.submit(
                _one_chunk,
                engine,
                chunk,
                lookup_table,
                param_cols,
                transform=transform,
                return_rejected=return_rejected,
            )
            for chunk in chunks
        ]

        # 3. Gather results as they finish
        for fut in as_completed(futures):
            enriched, rejected = fut.result()
            enriched_all.extend(enriched)
            if return_rejected and rejected:
                rejected_all.extend(rejected)

    return (enriched_all, rejected_all) if return_rejected else enriched_all
