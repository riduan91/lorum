def process_step_4_1(df_tblDMIRTransparizLTWrk: pd.DataFrame,
                     inventory_level: int,
                     audit_id=None) -> pd.DataFrame:
    """
    Python port of stpDMIRLTTranspariz_Step4_1_sourcePython – Step 4.1.
    Only the UPDATE part is reproduced (no inserts).
    """

    now = pd.Timestamp.utcnow()

    # ------------------------------------------------------------------
    # MASTER  (filter on the inventory level)
    # ------------------------------------------------------------------
    df_master = df_tblDMIRTransparizLTWrk[
        df_tblDMIRTransparizLTWrk["numInventoryLevel"] == inventory_level
    ].copy()

    # ------------------------------------------------------------------
    # LKP – rank 1 by numPortfAUMInRptPtfCur over the exact partition cols
    # ------------------------------------------------------------------
    part_cols = [
        "strReportPortfHoldSrc",
        "strReportPeriod",
        "strReportPortfGPSCode",
        "numReportPortfGroupID",
        "strPortfID",
        "strPortfLevelID",
        "datHoldDate",
    ]

    df_lookup = df_tblDMIRTransparizLTWrk.copy()
    df_lookup["rank_"] = (
        df_lookup.groupby(part_cols)["numPortfAUMInRptPtfCur"]
        .rank(method="first", ascending=False)
    )
    df_lookup = df_lookup[df_lookup["rank_"] == 1].copy()
    df_lookup.drop(columns=["rank_"], inplace=True)

    # ------------------------------------------------------------------
    # Build join key = strPortfLevelID + '.' + strInvestedInPortfID
    # to match SQL:  M.strPortfLevelID + '.' + M.strInvestedInPortfID = L.strPortfLevelID
    # ------------------------------------------------------------------
    df_master["join_key"] = (
        df_master["strPortfLevelID"].astype(str) + "." + df_master["strInvestedInPortfID"].astype(str)
    )

    # ------------------------------------------------------------------
    # LEFT JOIN MASTER ↔ LKP   (exactly like SQL)
    # ------------------------------------------------------------------
    left_on = [
        "strReportPortfHoldSrc",
        "strReportPeriod",
        "strReportPortfGPSCode",
        "numReportPortfGroupID",
        "strInvestedInPortfID",
        "datLastNAVDate",
        "join_key",
    ]
    right_on = [
        "strReportPortfHoldSrc",
        "strReportPeriod",
        "strReportPortfGPSCode",
        "numReportPortfGroupID",
        "strPortfID",
        "datHoldDate",
        "strPortfLevelID",
    ]

    df_joined = pd.merge(
        df_master,
        df_lookup[right_on + ["numPortfAUMInRptPtfCur"]],  # keep only needed right cols
        how="left",
        left_on=left_on,
        right_on=right_on,
        suffixes=("", "_lkp"),
    )

    # ------------------------------------------------------------------
    # Compute the SQL-derived columns
    # numHoldValueInReportPortfCur  = numHoldValueInPortfCur * numPortfExRateInRptPtfCur
    # numPctReportPortfInUndrlyg    = ... / L.numPortfAUMInRptPtfCur
    # numWeightedAmtInReportPortf   = "
    # numWeightedQtqInReportPortf   = numHoldQuantity
    # ------------------------------------------------------------------
    df_joined["numHoldValueInReportPortfCur_new"] = (
        df_joined["numHoldValueInPortfCur"] * df_joined["numPortfExRateInRptPtfCur"]
    )

    denom = df_joined["numPortfAUMInRptPtfCur"]  # from LKP (we only pulled that from right side)
    df_joined["numPctReportPortfInUndrlyg_new"] = np.where(
        denom.notna() & (denom != 0),
        df_joined["numHoldValueInReportPortfCur_new"] / denom,
        np.nan,
    )

    df_joined["numWeightedAmtInReportPortf_new"] = df_joined["numHoldValueInReportPortfCur_new"]
    df_joined["numWeightedQtqInReportPortf_new"] = df_joined["numHoldQuantity"]

    # ------------------------------------------------------------------
    # Prepare UPDATE key (must match the SQL UPDATE ON clause)
    # M.strReportPeriod,
    # M.numInventoryLevel,
    # M.strPortfLevelID,
    # M.strInvestedInInstrID,
    # M.strInvestedInPortfISOCur,
    # M.datHoldDate
    # ------------------------------------------------------------------
    key_cols = [
        "strReportPeriod",
        "numInventoryLevel",
        "strPortfLevelID",
        "strInvestedInInstrID",
        "strInvestedInPortfISOCur",
        "datHoldDate",
    ]

    def make_key(df, cols):
        return df[cols].astype(str).agg("|".join, axis=1)

    if not df_joined.empty:
        df_joined["update_key"] = make_key(df_joined, key_cols)
    else:
        df_joined["update_key"] = pd.Series(dtype=str)

    df_target = df_tblDMIRTransparizLTWrk.copy()
    if not df_target.empty:
        df_target["update_key"] = make_key(df_target, key_cols)
    else:
        df_target["update_key"] = pd.Series(dtype=str)

    # keep only the rows we can actually update
    df_updates = df_joined[
        [
            "update_key",
            "numHoldValueInReportPortfCur_new",
            "numPctReportPortfInUndrlyg_new",
            "numWeightedAmtInReportPortf_new",
            "numWeightedQtqInReportPortf_new",
        ]
    ]

    df_target = df_target.merge(df_updates, on="update_key", how="left")

    # ------------------------------------------------------------------
    # Apply the UPDATE with the SQL ISNULL(…,0) <> ISNULL(…,0) semantics
    # ------------------------------------------------------------------
    def _needs_update(src, new):
        return (src.fillna(0) != new.fillna(0))

    mask = (
        _needs_update(df_target["numHoldValueInReportPortfCur"], df_target["numHoldValueInReportPortfCur_new"])
        | _needs_update(df_target["numPctReportPortfInUndrlyg"], df_target["numPctReportPortfInUndrlyg_new"])
        | _needs_update(df_target["numWeightedAmtInReportPortf"], df_target["numWeightedAmtInReportPortf_new"])
        | _needs_update(df_target["numWeightedQtqInReportPortf"], df_target["numWeightedQtqInReportPortf_new"])
    )

    for tgt, src in [
        ("numHoldValueInReportPortfCur", "numHoldValueInReportPortfCur_new"),
        ("numPctReportPortfInUndrlyg",   "numPctReportPortfInUndrlyg_new"),
        ("numWeightedAmtInReportPortf",  "numWeightedAmtInReportPortf_new"),
        ("numWeightedQtqInReportPortf",  "numWeightedQtqInReportPortf_new"),
    ]:
        df_target.loc[mask, tgt] = df_target.loc[mask, src]

    # datLastModifDate = GETDATE() for changed rows (SQL behaviour)
    df_target.loc[mask, "datLastModifDate"] = now

    # clean up
    df_target.drop(
        columns=[
            "update_key",
            "numHoldValueInReportPortfCur_new",
            "numPctReportPortfInUndrlyg_new",
            "numWeightedAmtInReportPortf_new",
            "numWeightedQtqInReportPortf_new",
        ],
        inplace=True,
        errors="ignore",
    )

    # Ensure we keep the original column order (optional)
    df_target = df_target[df_tblDMIRTransparizLTWrk.columns]

    return df_target
