import os
import uuid
import shutil
import tempfile
from concurrent.futures import ProcessPoolExecutor, as_completed

def process_dmc_records(
    df_lt: pd.DataFrame,
    df_scope_dmc: pd.DataFrame,  # #scopes_dmc  (strReportPortfGPSCode, datPeriodLastDay)
    df_lt_ind: pd.DataFrame,     # tblDMIRBRSLTPortfInstrIndicators
    num_audit_id: int,
) -> pd.DataFrame:
    """
    Exact Python analogue of the DMC-LT insert logic.
    Builds and returns a DataFrame that can be bulk-inserted into
    DMIR.tblDMIRAPILTHolding (but does **no write** itself).

    Memory-reduced version:
    - Do not accumulate all rows in memory.
    - Persist each batch to Parquet and concat at the end.
    - Clean up spilled files afterward.
    """

    # 0)  scope-filter & audit flag
    df_lt = df_lt.assign(numAuditId=num_audit_id).merge(
        df_scope_dmc,
        left_on=["strReportPortfGPSCode", "datPeriodLastDay"],
        right_on=["ReportPortfGPSCode", "datPeriodLastDay"],
        how="inner",
    )

    key_cols = [
        "strReportPortfGPSCode",
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "numAuditId",
    ]

    get_hardware_info()
    print("Groupby for df_lt")
    df_lt_groups = df_lt.groupby(key_cols)
    get_hardware_info()
    print("Groupby for df_lt")
    df_lt_ind_groups = df_lt_ind.groupby(["strPortfGPSCode", "datPeriodLastDay"])
    get_hardware_info()

    # Spill directory for batch results
    # Cleanup is handled automatically by TemporaryDirectory context
    with tempfile.TemporaryDirectory(prefix="dmc_batches_") as tmp_dir:
        future_to_batch = {}
        batch_paths = []
        any_written = False

        # Tune workers if needed; keeping your current default of 24
        with ProcessPoolExecutor(max_workers=24) as executor:
            for idx, (key, chunk) in enumerate(df_lt_groups):
                try:
                    ind_slice = df_lt_ind_groups.get_group((key[0], key[1]))
                except KeyError as ke:
                    print(
                        f"Warning: {(key[0], key[1])} is not in instrIndicators. Error message: {ke}."
                    )
                    ind_slice = pd.DataFrame(columns=df_lt_ind.columns)

                future = executor.submit(
                    single_process_dmc_records,
                    idx,
                    key,
                    chunk,
                    ind_slice,
                )
                future_to_batch[future] = idx

            for future in as_completed(future_to_batch):
                batch_idx = future_to_batch[future]
                try:
                    # Each worker returns List[Dict[str, Any]]
                    batch_rows = future.result()

                    # If a worker returns nothing, skip writing a file
                    if not batch_rows:
                        print(f"Batch {batch_idx} produced 0 rows.")
                        continue

                    df_batch = pd.DataFrame.from_records(batch_rows)

                    # Write this batch to a unique Parquet file
                    batch_path = os.path.join(tmp_dir, f"{uuid.uuid4().hex}.parquet")
                    df_batch.to_parquet(batch_path, index=False)
                    batch_paths.append(batch_path)
                    any_written = True

                    print(f"Batch {batch_idx} wrote {len(df_batch)} rows to {batch_path}")

                    # Encourage GC of the large temporary objects
                    del df_batch, batch_rows

                except Exception as exc:
                    print(f"Batch {batch_idx} generated an exception: {exc}")
                    # Let the exception propagate after logging (same behavior as before)
                    raise

        # Assemble final DataFrame (or return empty with expected schema)
        if not any_written:
            print("No batches wrote data; returning empty DataFrame with target schema.")
            return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

        # Stream-read each Parquet to keep memory low during concat
        final_df_iter = (pd.read_parquet(p) for p in batch_paths)
        final_df = pd.concat(final_df_iter, ignore_index=True, copy=False)

        # tmp_dir is automatically removed here by TemporaryDirectory

        return final_df
