import decimal
import time
from concurrent.futures import ProcessPoolExecutor, as_completed
from datetime import timedelta

import numpy as np
import pandas as pd
from sqlalchemy import case, func, and_
from sqlalchemy.orm import Session, aliased

from dags.common.dmir_connections import get_session
from dags.common.models import DMIRScopeLT  # For parallel run
from dags.common.models import (
    DMIRBRSInstAnalytic,
    DMIRBRSInstRating,
    DMIRBRSInstrument,
    DMIRBRSIssuerRating,
    DMIRBRSLTPortfInstrIndicators,
    DMIRInstrumentIRType,
    DMIRPortfolioLnk,
    DWGNInvestmentPositions,
)
from dags.common.utils import (
    chunker,
    get_all_as_df,
    get_date_from_audit_id,
    get_hardware_info,
    normalize_type,
)


# ---------------------------------------------------------------------
# 1) FETCH INSTRUMENT METADATA  (unchanged)
# ---------------------------------------------------------------------
def fetch_instrument_metadata(idx, inst_ids: list[int]):
    print(f"Fetching instruments for chunk {idx}")
    session = get_session()
    try:
        a = aliased(DMIRBRSInstAnalytic)
        i = aliased(DMIRBRSInstrument)
        it = aliased(DMIRInstrumentIRType)
        u = aliased(DMIRBRSInstrument)

        query = (
            session.query(
                a.numInstID,
                a.datInstQuotationDate,
                a.numInstEffDuration,
                a.numInstModifDuration,
                a.numInstConvexity,
                a.numInstMCDuration,
                a.numInstSpreadDuration,
                a.numInstUndrlygPrice,
                a.numInstDelta,
                i.strInstAladdin,
                i.numInstID.label("i_numInstID"),
                i.numInstUndrlygQty,
                i.strCpnRateTypPaid,
                i.strCpnRateTypeRecv,
                i.strInstLegType,
                i.strInstPriceType,
                i.strInstISINCode,
                i.numInstTypeId,
                i.strInstUnderlygAladdin,
                it.strInstrumentTypeIRName,
                u.numInstUndrlygQty.label("UnumInstUndrlygQty"),
                u.strInstPriceType.label("ustrInstPriceType"),
            )
            .join(i, a.numInstID == i.numInstID)
            .outerjoin(
                it, (i.numInstTypeId == it.numInstrTypeID) & (it.strReportingType == "class7")
            )
            .outerjoin(u, i.strInstUnderlygAladdin == u.strInstAladdin)
            .filter(a.numInstID.in_(inst_ids))
        )

        df_instr = get_all_as_df(query)
        return df_instr
    finally:
        session.close()


# ---------------------------------------------------------------------
# 2) BUILD TMP TRANSPARIZ DATA  (#tmpTransparizLTWrk)
# ---------------------------------------------------------------------
def build_transpariz_data(df_tblDMIRTransparizLTWrk: pd.DataFrame, max_workers=24):
    """
    Replicates Task 2:
    - Aggregate DMIR.tblDMIRScopeLT
    - Inner-join to df_tblDMIRTransparizLTWrk (flagged rows)
    - Left-join analytics, instrument metadata, type, underlying
    """
    session = get_session()
    # 1. Fetch and aggregate scope
    query = session.query(
        DMIRScopeLT.datPeriodLastDay,
        DMIRScopeLT.numReportPortfGroupID,
        DMIRScopeLT.strReportPortfGPSCode,
        func.max(DMIRScopeLT.datHoldDate).label("datHoldDate"),
        DMIRScopeLT.strReportPortfISOCur,
        DMIRScopeLT.numReportPortfAUM,
    ).group_by(
        DMIRScopeLT.datPeriodLastDay,
        DMIRScopeLT.numReportPortfGroupID,
        DMIRScopeLT.strReportPortfGPSCode,
        DMIRScopeLT.strReportPortfISOCur,
        DMIRScopeLT.numReportPortfAUM,
    )
    df_s = get_all_as_df(query)

    session.close()

    # 2. Merge scope + transpariz
    df_joined = df_s.merge(
        df_tblDMIRTransparizLTWrk[df_tblDMIRTransparizLTWrk["numLowestInventoryflag"] == 1],
        on=["datPeriodLastDay", "numReportPortfGroupID", "strReportPortfGPSCode"],
        how="inner",
        suffixes=("", "_dup"),
    )

    # 3. Join analytics, instrument
    inst_ids = df_joined["numInstID"].dropna().unique().tolist()
    print("inst_ids", inst_ids)
    instr_dfs = []

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(fetch_instrument_metadata, i, chunk): i
            for i, chunk in enumerate(list(chunker(inst_ids, 1000)))
        }
        for future in as_completed(futures):
            instrs = future.result()
            instr_dfs.append(instrs)
            print(f"Chunk inserted {len(instrs)} rows")

    if len(instr_dfs) > 0:
        df_instr = pd.concat(instr_dfs, ignore_index=True)
    else:
        df_instr = pd.DataFrame(columns=["numInstID", "datInstQuotationDate"])
        normalize_type(df_instr)

    print(df_joined)
    print(df_instr)
    df = df_joined.merge(
        df_instr,
        how="left",
        left_on=["numInstID", "datHoldDate"],
        right_on=["numInstID", "datInstQuotationDate"],
        suffixes=("", "_inst"),
    )

    # numHoldCrossCur: null or 0 → 1
    df["numHoldCrossCur"] = np.where(
        df["numHoldCrossCur"].isna() | (df["numHoldCrossCur"] == 0), 1, df["numHoldCrossCur"]
    )

    # initial delta & original qty
    df["numDeltaAdjustedSpread"] = df["numWeightedAmtInReportPortf"]
    df["OriginalQty"] = df["numWeightedAmtInReportPortf"]

    # forex qty
    df["numWeightedQtyForex"] = np.where(
        df["numWeightedQtqInReportPortf"] > 0, df["numWeightedQtqInReportPortf"], 0
    )

    # string length
    df["numLength"] = df["strPortfID"].astype(str).str.len()

    # extract numeric part (SQL: len != 12, no '_', source ALP)
    mask = (
        df["strPortfID"].notna()
        & (df["numLength"] != 12)
        & ~df["strPortfID"].astype(str).str.contains("_", na=False)
        & (df["strReportPortfHoldSrc"] == "ALP")
    )
    df["strPortfIDNumPart"] = pd.NA
    df.loc[mask, "strPortfIDNumPart"] = (
        df.loc[mask, "strPortfID"].astype(str).str.extract(r"(\d+)")[0].astype("Int64")
    )

    # 4. Set to 0 as in SQL
    df["numDeltaAdjustedSpread"] = 0.0
    df["OriginalQty"] = 0.0

    final_cols = [
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "datHoldDate",
        "strReportPortfISOCur",
        "numReportPortfAUM",
        "numWeightedAmtInReportPortf",
        "numWeightedQtqInReportPortf",
        "numHoldCrossCur",
        "numHoldAvrgCostInReportPortf",
        "strInstAladdin",
        "numInstID",
        "numPortfExRateInRptPtfCur",
        "numHoldQuantity",
        "numHoldPrice",
        "datInstQuotationDate",
        "numInstEffDuration",
        "numInstModifDuration",
        "numInstConvexity",
        "numInstMCDuration",
        "numInstSpreadDuration",
        "numInstUndrlygPrice",
        "numInstDelta",
        "numInstUndrlygQty",
        "strInstrumentTypeIRName",
        "strCpnRateTypPaid",
        "strCpnRateTypeRecv",
        "strInstLegType",
        "strInstPriceType",
        "UnumInstUndrlygQty",
        "ustrInstPriceType",
        "strInstISINCode",
        "numDeltaAdjustedSpread",
        "OriginalQty",
        "strPortfID",
        "numLength",
        "numWeightedQtyForex",
        "strPortfIDNumPart",
    ]

    if df.empty:
        return pd.DataFrame(columns=final_cols)
    return df[final_cols]


# ---------------------------------------------------------------------
# 3) #ScopePortf
# ---------------------------------------------------------------------
def build_portf_scope(df_transpariz: pd.DataFrame):
    df_scope = (
        df_transpariz[["numReportPortfGroupID", "strPortfID", "datPeriodLastDay"]]
        .drop_duplicates()
        .rename(
            columns={
                "numReportPortfGroupID": "numPortfGroupFkey",
                "strPortfID": "strPortfGPSCode",
            }
        )
        .reset_index(drop=True)
    )
    return df_scope


# ---------------------------------------------------------------------
# 4) #investmentpos_sq
# ---------------------------------------------------------------------
def extract_derivative_positions(df_scope: pd.DataFrame):
    session = get_session()
    scope_pairs = (
        df_scope[["datPeriodLastDay", "strPortfGPSCode"]]
        .drop_duplicates()
        .to_dict(orient="records")
    )
    results = []

    instrument_types = [
        "FUTURE_INDEX",
        "OPTION_EQUITY",
        "OPTION_FUTURE",
        "OPTION_CUROTC",
        "FUTURE_FIN",
        "SWAP_TRSWAP",
        "SWAP_SWAP",
    ]

    for i, pair in enumerate(scope_pairs):
        print(f"Processing row {i+1}/{len(scope_pairs)}")
        dat = pair["datPeriodLastDay"]
        if isinstance(dat, pd.Timestamp):
            dat = dat.to_pydatetime().date()
        code = pair["strPortfGPSCode"]

        q = (
            session.query(
                DWGNInvestmentPositions.strInstrmtCd,
                DWGNInvestmentPositions.strProdCd,
                func.max(DWGNInvestmentPositions.datPosDt).label("posDt"),
            )
            .filter(
                DWGNInvestmentPositions.strProdCd == code,
                DWGNInvestmentPositions.datPosDt <= dat,
                DWGNInvestmentPositions.datPosDt > dat - timedelta(days=7),
                DWGNInvestmentPositions.strInstrmtTypCd.in_(instrument_types),
            )
            .group_by(DWGNInvestmentPositions.strInstrmtCd, DWGNInvestmentPositions.strProdCd)
        )

        df_chunk = get_all_as_df(q)
        if df_chunk.empty:
            continue

        df_chunk["datPeriodLastDay"] = dat
        df_chunk["strPortfGPSCode"] = code
        results.append(df_chunk)

    if results:
        df_investmentpos_sq = pd.concat(results, ignore_index=True)
    else:
        df_investmentpos_sq = pd.DataFrame(
            columns=[
                "strInstrmtCd",
                "strProdCd",
                "posDt",
                "datPeriodLastDay",
                "strPortfGPSCode",
            ]
        )
    return df_investmentpos_sq


# ---------------------------------------------------------------------
# 5) #DeltaAdjustedNotionalvalue - DMC
# ---------------------------------------------------------------------
def _compute_delta_dmc_single(row_idx, row, excluded_pocs):
    session = get_session()
    try:
        print(f"Processing compute_delta_dmc for row {row_idx}...")
        instr = row["strInstrmtCd"]
        code = row["strPortfGPSCode"]
        posDt = row["posDt"]
        rptDay = row["datPeriodLastDay"]

        q = session.query(
            func.sum(DWGNInvestmentPositions.numDeltaAdjedNotionalValu).label(
                "numDeltaAdjedNotionalValu"
            ),
            func.sum(
                case(
                    [
                        (
                            DWGNInvestmentPositions.strPosQtySign == "-",
                            -DWGNInvestmentPositions.numPosQty,
                        )
                    ],
                    else_=DWGNInvestmentPositions.numPosQty,
                )
            ).label("numPosQty"),
        ).filter(
            DWGNInvestmentPositions.strInstrmtCd == instr,
            DWGNInvestmentPositions.strProdCd == code,
            DWGNInvestmentPositions.datPosDt == posDt,
            ~DWGNInvestmentPositions.strPocCd.in_(excluded_pocs),
        )

        delta_val, qty_val = q.one()
        return {
            "strInstrmtCd": instr,
            "strProdCd": code,
            "numPortfGroupFkey": -1,  # align to SQL schema
            "numPtfFkey": -1,         # align to SQL schema
            "datPeriodLastDay": rptDay,
            "numDeltaAdjedNotionalValu": float(delta_val or 0.0),
            "numPosQty": float(qty_val or 0.0),
        }
    finally:
        session.close()


def compute_delta_dmc(df_investmentpos_sq: pd.DataFrame, max_workers=24):
    excluded_pocs = {
        "139_17",
        "14781_12",
        "15282_9",
        "15444_9",
        "190_4",
        "2903_9",
        "43270_2",
        "43585_24",
        "44370_2",
        "44407_1",
        "44408_1",
        "44414_2",
        "44420_4",
        "44479_1",
        "44494_2",
        "44548_1",
        "44591_2",
        "44355_1",
    }

    results = []
    keys_df = df_investmentpos_sq[
        ["strInstrmtCd", "strPortfGPSCode", "posDt", "datPeriodLastDay"]
    ].drop_duplicates()

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_compute_delta_dmc_single, row_idx, row, excluded_pocs): row_idx
            for row_idx, row in keys_df.iterrows()
        }
        for future in as_completed(futures):
            res = future.result()
            results.append(res)
            print(f"Chunk inserted {len(results)} rows")

    if results:
        df_delta = pd.DataFrame(results)
    else:
        df_delta = pd.DataFrame(
            columns=[
                "strInstrmtCd",
                "strProdCd",
                "numPortfGroupFkey",
                "numPtfFkey",
                "datPeriodLastDay",
                "numDeltaAdjedNotionalValu",
                "numPosQty",
            ]
        )

    return df_delta


# ---------------------------------------------------------------------
# 6) #DeltaAdjustedNotionalvalue - ALPHA
# ---------------------------------------------------------------------
def build_sq1_loop(session: Session, df_scope: pd.DataFrame):
    instr_types = [
        "FUTURE_INDEX",
        "OPTION_EQUITY",
        "OPTION_FUTURE",
        "OPTION_CUROTC",
        "FUTURE_FIN",
        "SWAP_TRSWAP",
        "SWAP_SWAP",
        "SWAP_CDSWAP",
        "SYNTH_FLOOR",
        "SYNTH_OTC",
        "xxxxSYNTH_SWAPTION",
    ]
    records = []
    scope_pairs = df_scope[["datPeriodLastDay", "numPortfGroupFkey"]].drop_duplicates()
    for idx, row in scope_pairs.iterrows():
        print(f"Processing row {idx+1}/{len(scope_pairs)}.")
        rpt_day = row["datPeriodLastDay"]
        group_fk = row["numPortfGroupFkey"]

        q = (
            session.query(
                DWGNInvestmentPositions.strInstrmtCd.label("strInstrmtCd"),
                DWGNInvestmentPositions.numPtfFkey.label("numPtfFkey"),
                func.max(DWGNInvestmentPositions.datPosDt).label("posDt"),
            )
            .join(
                DMIRPortfolioLnk,
                DMIRPortfolioLnk.numPortfSkey == DWGNInvestmentPositions.numPtfFkey,
            )
            .filter(
                DMIRPortfolioLnk.numPortfGroupSkey == group_fk,
                DWGNInvestmentPositions.strInstrmtTypCd.in_(instr_types),
                DWGNInvestmentPositions.datPosDt <= rpt_day,
                DWGNInvestmentPositions.datPosDt > rpt_day - timedelta(days=7),
            )
            .group_by(DWGNInvestmentPositions.strInstrmtCd, DWGNInvestmentPositions.numPtfFkey)
        )

        df_chunk = get_all_as_df(q)
        if df_chunk.empty:
            continue

        df_chunk["datPeriodLastDay"] = rpt_day
        df_chunk["numPortfGroupFkey"] = group_fk
        records.append(df_chunk)

    if records:
        return pd.concat(records, ignore_index=True)
    else:
        return pd.DataFrame(
            columns=["strInstrmtCd", "numPtfFkey", "posDt", "datPeriodLastDay", "numPortfGroupFkey"]
        )


def _compute_delta_alpha_single(row_idx, row, excluded_pocs):
    session = get_session()
    try:
        print(f"Processing compute_delta_alpha for row {row_idx}...")

        instr = row["strInstrmtCd"]
        pfk = row["numPortfGroupFkey"]
        ptfk = row["numPtfFkey"]
        posdt = row["posDt"]
        rpt = row["datPeriodLastDay"]

        q = session.query(
            func.sum(DWGNInvestmentPositions.numDeltaAdjedNotionalValu).label(
                "numDeltaAdjedNotionalValu"
            ),
            func.sum(
                case(
                    [
                        (
                            DWGNInvestmentPositions.strPosQtySign == "-",
                            -DWGNInvestmentPositions.numPosQty,
                        )
                    ],
                    else_=DWGNInvestmentPositions.numPosQty,
                )
            ).label("numPosQty"),
        ).filter(
            DWGNInvestmentPositions.strInstrmtCd == instr,
            DWGNInvestmentPositions.numPtfFkey == ptfk,
            DWGNInvestmentPositions.datPosDt == posdt,
            ~DWGNInvestmentPositions.strPocCd.in_(excluded_pocs),
        )

        delta_val, qty_val = q.one()
        return {
            "strInstrmtCd": instr,
            "strProdCd": "-1",  # keep schema identical
            "numPortfGroupFkey": pfk,
            "numPtfFkey": ptfk,
            "datPeriodLastDay": rpt,
            "numDeltaAdjedNotionalValu": float(delta_val or 0.0),
            "numPosQty": float(qty_val or 0.0),
        }
    finally:
        session.close()


def compute_delta_alpha(df_scope: pd.DataFrame, max_workers=24):
    session = get_session()
    df_sq1 = build_sq1_loop(session, df_scope)
    session.close()

    excluded_pocs = {
        "139_17",
        "14781_12",
        "15282_9",
        "15444_9",
        "190_4",
        "2903_9",
        "43270_2",
        "43585_24",
        "44370_2",
        "44407_1",
        "44408_1",
        "44414_2",
        "44420_4",
        "44479_1",
        "44494_2",
        "44548_1",
        "44591_2",
        "44355_1",
    }
    records = []

    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_compute_delta_alpha_single, row_idx, row, excluded_pocs): row_idx
            for row_idx, row in df_sq1.iterrows()
        }
        for future in as_completed(futures):
            res = future.result()
            records.append(res)
            print(f"Chunk inserted {len(records)} rows")

    if records:
        return pd.DataFrame(records)
    else:
        return pd.DataFrame(
            columns=[
                "strInstrmtCd",
                "strProdCd",
                "numPortfGroupFkey",
                "numPtfFkey",
                "datPeriodLastDay",
                "numDeltaAdjedNotionalValu",
                "numPosQty",
            ]
        )


# ---------------------------------------------------------------------
# 7) APPLY DELTA ADJUSTMENTS (two SQL UPDATEs)
# ---------------------------------------------------------------------
def _apply_delta_adjustments_instruments_single(chunk_idx, chunk):
    session = get_session()
    try:
        print(f"apply_delta_adjustments_instruments for chunk {chunk_idx}.")
        df_chunk = get_all_as_df(
            session.query(
                DMIRBRSInstrument.strInstAladdin, DMIRInstrumentIRType.strInstrumentTypeIRName
            )
            .outerjoin(
                DMIRInstrumentIRType,
                DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
            )
            .filter(
                DMIRBRSInstrument.strInstAladdin.in_(chunk),
                DMIRInstrumentIRType.strReportingType == "class2",
                func.upper(DMIRInstrumentIRType.strInstrumentTypeIRName) != "FUTURES ON CURRENCIES",
            )
        )
        return df_chunk
    finally:
        session.close()


def apply_delta_adjustments(df_tmp: pd.DataFrame, df_delta: pd.DataFrame, max_workers=24):
    columns = df_tmp.columns  # make sure defined even if no chunks

    # 1. Chunked load of instrument→type mapping
    inst_codes = df_tmp["strInstAladdin"].dropna().unique().tolist()
    chunks = [inst_codes[i : i + 1000] for i in range(0, len(inst_codes), 1000)]

    dfs_instr = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futures = {
            exe.submit(_apply_delta_adjustments_instruments_single, chunk_idx, chunk): chunk_idx
            for chunk_idx, chunk in enumerate(chunks)
        }
        for future in as_completed(futures):
            res = future.result()
            dfs_instr.append(res)
            print(f"Chunk inserted {len(dfs_instr)} rows")

    if len(dfs_instr) > 0:
        df_instr = pd.concat(dfs_instr, ignore_index=True)
        df_tmp = df_tmp.merge(df_instr, on="strInstAladdin", how="left", suffixes=("", "_instr"))

        # Build pandas lookup indices on df_delta
        have_alpha_cols = {"strInstrmtCd", "datPeriodLastDay", "numPortfGroupFkey", "numPtfFkey"}
        have_dmc_cols = {"strInstrmtCd", "datPeriodLastDay", "strProdCd"}

        if have_alpha_cols.issubset(df_delta.columns):
            alpha_idx = df_delta.set_index(
                ["strInstrmtCd", "datPeriodLastDay", "numPortfGroupFkey", "numPtfFkey"]
            )
        else:
            alpha_idx = pd.DataFrame().set_index(
                ["strInstrmtCd", "datPeriodLastDay", "numPortfGroupFkey", "numPtfFkey"]
            )

        if have_dmc_cols.issubset(df_delta.columns):
            dmc_idx = df_delta.set_index(["strInstrmtCd", "datPeriodLastDay", "strProdCd"])
        else:
            dmc_idx = pd.DataFrame().set_index(["strInstrmtCd", "datPeriodLastDay", "strProdCd"])

        # Loop and apply
        inst_tuples_df = df_tmp[
            [
                "strInstAladdin",
                "datPeriodLastDay",
                "numReportPortfGroupID",
                "strPortfIDNumPart",
                "strPortfID",
                "numHoldQuantity",
            ]
        ].drop_duplicates()

        print(f"Found {len(inst_tuples_df)} tuples.")
        for tup in inst_tuples_df.itertuples(index=False):
            (
                instr,
                day,
                grp,
                ptf_part,
                pid,
                hold_qty,
            ) = tup
            # Alpha first
            try:
                ptf = int(ptf_part) if pd.notna(ptf_part) else -2
                x = alpha_idx.loc[(instr, day, grp, ptf)]
                delta_not = float(x["numDeltaAdjedNotionalValu"])
                pos_qty = float(x["numPosQty"]) or 0.0

                mask = (
                    (df_tmp.strInstAladdin == instr)
                    & (df_tmp.datPeriodLastDay == day)
                    & (df_tmp.numReportPortfGroupID == grp)
                    & (df_tmp.strPortfIDNumPart.fillna(-2) == ptf)
                )
                factor = (delta_not / pos_qty * hold_qty) if pos_qty != 0 else 0.0
                df_tmp.loc[mask, "numDeltaAdjustedSpread"] = factor
                df_tmp.loc[mask, "OriginalQty"] = pos_qty
                continue
            except KeyError:
                pass

            # DMC
            try:
                y = dmc_idx.loc[(instr, day, pid)]
                mask = (
                    (df_tmp.strInstAladdin == instr)
                    & (df_tmp.datPeriodLastDay == day)
                    & (df_tmp.strPortfID == pid)
                )
                df_tmp.loc[mask, "numDeltaAdjustedSpread"] = float(
                    y["numDeltaAdjedNotionalValu"]
                )
                df_tmp.loc[mask, "OriginalQty"] = float(y["numPosQty"])
            except KeyError:
                pass
    else:
        df_tmp = pd.DataFrame(columns=columns)

    return df_tmp


# ---------------------------------------------------------------------
# 8) AGGREGATE INDICATORS (#tmpPortfInstrumentIndicators)
# ---------------------------------------------------------------------
def aggregate_indicators(df: pd.DataFrame) -> pd.DataFrame:
    # Prepare “effective” durations (Swaps → abs(value))
    swaps_mask = df["strInstrumentTypeIRName"].fillna("").str.casefold().eq("swaps")
    df["effInstModifDuration"] = np.where(swaps_mask, df["numInstModifDuration"].abs(), df["numInstModifDuration"])
    df["effInstMCDuration"] = np.where(swaps_mask, df["numInstMCDuration"].abs(), df["numInstMCDuration"])
    df["effInstEffDuration"] = np.where(swaps_mask, df["numInstEffDuration"].abs(), df["numInstEffDuration"])
    df["effInstSpreadDuration"] = np.where(swaps_mask, df["numInstSpreadDuration"].abs(), df["numInstSpreadDuration"])
    # Convexity needs abs() regardless of type
    df["effInstConvexity"] = df["numInstConvexity"].abs()

    # 1) Vectorised per-row exposures
    mask_dur = (df["numDeltaAdjustedSpread"] != 0) & (df["numHoldQuantity"] != 0)
    df["durExp"] = df["numWeightedAmtInReportPortf"]
    df.loc[mask_dur, "durExp"] = (
        df.loc[mask_dur, "numWeightedQtqInReportPortf"]
        .abs()
        .div(df.loc[mask_dur, "numHoldQuantity"].abs())
        .mul(df.loc[mask_dur, "numDeltaAdjustedSpread"])
    )

    mask_fx = (
        (df["strInstrumentTypeIRName"] == "Forex")
        & df["strInstISINCode"].notna()
        & ~df["strInstISINCode"].str.startswith("FWD")
        & (df["numLength"] < 12)
    )
    fx_val = (
        df["numWeightedQtyForex"]
        .div(df["numHoldCrossCur"])
        .mul(df["numPortfExRateInRptPtfCur"])
        .where(df["numHoldCrossCur"].fillna(0) != 0, 0)
    )
    df["curExp"] = np.where(mask_fx.fillna(False), fx_val, df["numWeightedAmtInReportPortf"])

    # 2) Group-by aggregation: include ISIN to mirror SQL grouping
    keys = [
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "strReportPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "strInstISINCode",
    ]

    agg = (
        df.groupby(keys, sort=False)
        .agg(
            datPeriodLastNav=("datHoldDate", "max"),
            strCurrencyISOCode=("strReportPortfISOCur", "max"),
            maxAUM=("numReportPortfAUM", "max"),
            sumAmt=("numWeightedAmtInReportPortf", "sum"),
            sumDurExp=("durExp", "sum"),
            sumCurExp=("curExp", "sum"),
            maxConvexity=("effInstConvexity", "max"),
            maxModifDuration=("effInstModifDuration", "max"),
            maxMCDuration=("effInstMCDuration", "max"),
            maxEffDuration=("effInstEffDuration", "max"),
            maxSpreadDuration=("effInstSpreadDuration", "max"),
            sumDelta=("numDeltaAdjustedSpread", "sum"),
        )
        .reset_index()
    )

    # 3) Vector maths (weights, contributions)
    agg = agg.assign(
        numInstrWeight=agg["sumAmt"].div(agg["maxAUM"]).fillna(0),
        numDurExposureInPortfCur=agg["sumDurExp"],
        numCurExposureInPortfCur=agg["sumCurExp"],
        numDurExposureWeight=agg["sumDurExp"].div(agg["maxAUM"]).fillna(0),
        numCurExposureWeight=agg["sumCurExp"].div(agg["maxAUM"]).fillna(0),
    )

    for label, col in [
        ("Convexity", "maxConvexity"),
        ("ModifDuration", "maxModifDuration"),
        ("MCDuration", "maxMCDuration"),
        ("EffectDuration", "maxEffDuration"),
        ("SpreadDuration", "maxSpreadDuration"),
    ]:
        agg[f"num{label}Contrib"] = agg["numDurExposureWeight"] * agg[col].astype(float)

    # 4) Renames & helpers
    agg = agg.rename(
        columns={
            "numReportPortfGroupID": "numPortfGroupFKey",
            "strReportPortfGPSCode": "strPortfGPSCode",
        }
    )
    agg["strPortfGroupFkey"] = agg["numPortfGroupFKey"].astype(str)
    agg["numDeltaAdjustedSpread"] = agg["sumDelta"].astype(float)

    # 5) Portfolio-level sums then contribution weights
    contrib_cols = [
        "numConvexityContrib",
        "numModifDurationContrib",
        "numMCDurationContrib",
        "numEffectDurationContrib",
        "numSpreadDurationContrib",
    ]
    sum_cols = {c: "sum" + c for c in contrib_cols}

    sums = (
        agg.groupby(
            ["datPeriodLastDay", "numPortfGroupFKey", "strPortfGPSCode"],
            sort=False,
        )[contrib_cols]
        .sum()
        .rename(columns=sum_cols)
        .reset_index()
    )

    df_final = agg.merge(
        sums,
        on=["datPeriodLastDay", "numPortfGroupFKey", "strPortfGPSCode"],
        how="left",
    )

    for base in ["Convexity", "ModifDuration", "MCDuration", "EffectDuration", "SpreadDuration"]:
        num = f"num{base}Contrib"
        denom = f"sum{num}"
        wcol = f"num{base}ContribWeight"
        df_final[wcol] = df_final[num].div(df_final[denom]).fillna(0)

    final_cols = [
        "datPeriodLastDay",
        "numPortfGroupFKey",
        "strPortfGPSCode",
        "strInstAladdin",
        "numInstID",
        "datPeriodLastNav",
        "strCurrencyISOCode",
        "numInstrWeight",
        "numDurExposureInPortfCur",
        "numCurExposureInPortfCur",
        "numDurExposureWeight",
        "numCurExposureWeight",
        "numConvexityContrib",
        "numModifDurationContrib",
        "numMCDurationContrib",
        "numEffectDurationContrib",
        "numSpreadDurationContrib",
        "numConvexityContribWeight",
        "numModifDurationContribWeight",
        "numMCDurationContribWeight",
        "numEffectDurationContribWeight",
        "numSpreadDurationContribWeight",
        "numDeltaAdjustedSpread",
        "strPortfGroupFkey",
    ]
    return df_final[final_cols]


# ---------------------------------------------------------------------
# 9) ESG SCOPE + RATINGS
#     (Note: this still fetches CREDIT RATINGS; if you need the real ESG
#      table from stpDMIRESGData, you must port or call that SP.)
# ---------------------------------------------------------------------
def _build_instruments_for_esg_scope_single(batch_idx, batch):
    session = get_session()
    try:
        print(f"Building instrument scope for {batch_idx}")
        query = session.query(
            DMIRBRSInstrument.numInstID,
            DMIRBRSInstrument.strInstIssuerCode,
            DMIRBRSInstrument.strinstrmttypcd,
        ).filter(DMIRBRSInstrument.numInstID.in_(batch))
        df_part = get_all_as_df(query)
        return df_part
    finally:
        session.close()


def build_esg_scope(df_tmp_indicators: pd.DataFrame):
    df_scope = df_tmp_indicators[
        [
            "numPortfGroupFKey",
            "datPeriodLastDay",
            "strPortfGPSCode",
            "strInstAladdin",
            "numInstID",
            "numInstrWeight",
        ]
    ].drop_duplicates()

    df_scope["myKey"] = df_scope.apply(
        lambda row: row["strPortfGPSCode"] if row["numPortfGroupFKey"] == -1 else str(row["numPortfGroupFKey"]),
        axis=1,
    )

    inst_ids = df_scope["numInstID"].dropna().unique().tolist()
    batches = [inst_ids[i : i + 1000] for i in range(0, len(inst_ids), 1000)]

    df_instruments = pd.DataFrame(columns=["numInstID", "strInstIssuerCode", "strinstrmttypcd"])

    with ProcessPoolExecutor(max_workers=128) as executor:
        futures = {
            executor.submit(_build_instruments_for_esg_scope_single, batch_idx, batch)
            for batch_idx, batch in enumerate(batches)
        }
        for future in as_completed(futures):
            df_part = future.result()
            df_instruments = pd.concat([df_instruments, df_part], ignore_index=True)

    df_esg_scope = df_scope.merge(df_instruments, on="numInstID", how="left")

    df_esg_scope = df_esg_scope[
        [
            "myKey",
            "datPeriodLastDay",
            "strInstAladdin",
            "numInstID",
            "strInstIssuerCode",
            "strinstrmttypcd",
            "numInstrWeight",
        ]
    ].rename(columns={"datPeriodLastDay": "datReportingDay"})

    return df_esg_scope


def _fetch_esg_ratings_single(chunk_id, reporting_day, inst_aladdins):
    session = get_session()
    try:
        print(f"ESG/Credit rating for chunk {chunk_id}")
        query = (
            session.query(
                DMIRBRSInstRating.strInstAladdin.label("strInstAladdin"),
                DMIRBRSInstRating.datInstRtgDate.label("datReportingDay"),
                DMIRBRSInstRating.strInstRtgSPStandardized,
                DMIRBRSInstRating.strInstRtgMDStandardized,
                DMIRBRSInstRating.strInstRtgFHStandardized,
                DMIRBRSInstRating.strInstRtgCustom1,
                DMIRBRSInstRating.strInstRtgCustom2,
                DMIRBRSInstRating.strInstRtgCustom3,
                DMIRBRSInstRating.strInstRtgCustom4,
                DMIRBRSInstRating.strInstRtgCustom5,
                DMIRBRSInstRating.strInstRtgCustom6,
                DMIRBRSInstRating.strInstRtgCustom7,
                DMIRBRSInstRating.strInstRtgCustom8,
                DMIRBRSInstRating.strInstRtgCustom9,
                DMIRBRSInstRating.strInstRtgCustom10,
                DMIRBRSInstRating.strInstRtgCustom11,
                DMIRBRSInstRating.strInstRtgCustom12,
                DMIRBRSInstRating.strInstRtgCustom13,
                DMIRBRSIssuerRating.strIssuerRtgSPStandardized,
                DMIRBRSIssuerRating.strIssuerRtgMDStandardized,
                DMIRBRSIssuerRating.strIssuerRtgFHStandardized,
                DMIRBRSIssuerRating.strIssuerRtgCustom1,
                DMIRBRSIssuerRating.strIssuerRtgCustom2,
                DMIRBRSIssuerRating.strIssuerRtgCustom3,
                DMIRBRSIssuerRating.strIssuerRtgCustom4,
                DMIRBRSIssuerRating.strIssuerRtgCustom5,
                DMIRBRSIssuerRating.strIssuerRtgCustom6,
                DMIRBRSIssuerRating.strIssuerRtgCustom7,
                DMIRBRSIssuerRating.strIssuerRtgCustom8,
                DMIRBRSIssuerRating.strIssuerRtgCustom9,
                DMIRBRSIssuerRating.strIssuerRtgCustom10,
                DMIRBRSIssuerRating.strIssuerRtgCustom11,
                DMIRBRSIssuerRating.strIssuerRtgCustom12,
                DMIRBRSIssuerRating.strIssuerRtgCustom13,
            )
            .select_from(DMIRBRSInstrument)
            .outerjoin(
                DMIRBRSInstRating,
                and_(
                    DMIRBRSInstRating.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                    DMIRBRSInstRating.datInstRtgDate == reporting_day,
                    DMIRBRSInstRating.strInstRtgVision == "M",
                ),
            )
            .outerjoin(
                DMIRBRSIssuerRating,
                and_(
                    DMIRBRSInstrument.strInstIssuerCode == DMIRBRSIssuerRating.strInstIssuerCode,
                    DMIRBRSIssuerRating.datIssuerRtgDate == reporting_day,
                    DMIRBRSIssuerRating.strIssuerRtgVision == "M",
                ),
            )
            .filter(DMIRBRSInstrument.strInstAladdin.in_(inst_aladdins))
        )

        return get_all_as_df(query)
    finally:
        session.close()


def fetch_esg_ratings(
    df_ind: pd.DataFrame, df_esg: pd.DataFrame, scope: str, audit_id, max_workers=48
):
    # NOTE: this still returns CREDIT ratings; the SQL uses a separate SP to populate ESG KPIs.
    df_esg = df_esg.dropna(subset=["strInstAladdin", "datReportingDay"])
    df_esg["datReportingDay"] = pd.to_datetime(df_esg["datReportingDay"])

    df_esg["myKey"] = df_esg["myKey"].astype(str)

    df_esg = df_ind.merge(
        df_esg,
        how="left",
        left_on=[
            "strPortfGPSCode" if scope == "DMC" else "strPortfGroupFkey",
            "strInstAladdin",
            "datPeriodLastDay",
        ],
        right_on=["myKey", "strInstAladdin", "datReportingDay"],
        suffixes=("", "_dup"),
    )

    if df_esg.empty:
        # keep schema wide
        return pd.DataFrame(columns=list(set(df_esg.columns) | set(df_ind.columns)))

    print("numPortfGroupFKey unique", df_esg["numPortfGroupFKey"].unique())
    if scope == "DMC":
        df_esg = df_esg[df_esg["numPortfGroupFKey"] == -1]
    elif scope == "ALP":
        df_esg = df_esg[df_esg["numPortfGroupFKey"] != -1]

    dfs = []
    for (reporting_day,), partition in df_esg.groupby(["datReportingDay"]):
        print(f"Retrieving esg/ratings for {reporting_day}")
        inst_aladdins = partition["strInstAladdin"].dropna().unique().tolist()
        print(f"Number of instruments : {len(inst_aladdins)}")
        with ProcessPoolExecutor(max_workers=max_workers) as executor:
            futures = {
                executor.submit(_fetch_esg_ratings_single, chunk_idx, reporting_day, chunk)
                for chunk_idx, chunk in enumerate(chunker(inst_aladdins, 2000))
            }
            for future in as_completed(futures):
                res = future.result()
                dfs.append(res)

    rating_col_suffixes = ["SPStandardized", "MDStandardized", "FHStandardized"] + [
        f"Custom{i}" for i in range(1, 14)
    ]

    if len(dfs) > 0:
        df_result = pd.concat(dfs, ignore_index=True)
        for col in rating_col_suffixes:
            inst_col = f"strInstRtg{col}"
            iss_col = f"strIssuerRtg{col}"
            # choose instrument rating unless NR, else issuer rating
            df_result[inst_col] = df_result.apply(
                lambda r: (r[inst_col] if (r[inst_col] if not pd.isna(r[inst_col]) else "NR") != "NR" else r[iss_col]),
                axis=1,
            )
        df_result = df_result[
            ["datReportingDay", "strInstAladdin"]
            + [f"strInstRtg{col}" for col in rating_col_suffixes]
        ]
    else:
        df_result = pd.DataFrame(
            columns=["datReportingDay", "strInstAladdin"]
            + [f"strInstRtg{col}" for col in rating_col_suffixes]
        )

    # placeholders for the unused fields to keep same shape as SQL final insert
    for col in [
        "numInstPriceEarning",
        "numInstYldToWorst",
        "numInstBondFloor",
        "numInstContribActivRisk",
        "numInstContribTrackingError",
        "numInstRiskFactor",
        "numInstStressTestFactor",
    ]:
        df_result[col] = None

    df_result["datReportingDay"] = pd.to_datetime(df_result["datReportingDay"])

    df_final = df_esg.merge(
        df_result,
        how="left",
        left_on=["strInstAladdin", "datReportingDay"],
        right_on=["strInstAladdin", "datReportingDay"],
        suffixes=("", "_dup"),
    )
    df_final["numAuditId"] = audit_id
    df_final["datModificationDate"] = get_date_from_audit_id(audit_id)

    return df_final


# ---------------------------------------------------------------------
# 10) FINAL UPSERT (DELSERT)
# ---------------------------------------------------------------------
def _upsert_group_single(i, key_tuple, df_group, audit_id, retry=10):
    """
    Deletes existing rows for the key_tuple, then inserts all rows in df_group.
    key_tuple is (datPeriodLastDay, numPortfGroupFKey, strPortfGPSCode)
    """
    session = get_session()
    print(f"Processing tuple {i} -> {key_tuple}")
    try:
        dt, grp_fk, gps = key_tuple

        # 1) Delete existing rows for this key
        session.query(DMIRBRSLTPortfInstrIndicators).filter_by(
            datPeriodLastDay=dt,
            numPortfGroupFKey=int(grp_fk) if not pd.isna(grp_fk) else -1,
            strPortfGPSCode=gps,
        ).delete(synchronize_session=False)

        # 2) Insert rows
        mappings = []
        existed = {}
        for rec in df_group.to_dict(orient="records"):
            rec["numAuditId"] = audit_id
            for k, v in rec.items():
                if k == "numPortfGroupFKey" and (v is None or (isinstance(v, float) and np.isnan(v))):
                    rec[k] = -1
                if isinstance(v, decimal.Decimal):
                    rec[k] = float(v)
                if v == "" or v == " " or (isinstance(v, float) and np.isnan(v)):
                    rec[k] = None
            # Avoid duplicate inst per key (defensive)
            if rec["strInstAladdin"] not in existed:
                mappings.append(rec)
                existed[rec["strInstAladdin"]] = 1

        if mappings:
            session.bulk_insert_mappings(DMIRBRSLTPortfInstrIndicators, mappings)

        get_hardware_info()
        session.commit()
    except Exception:
        if retry > 0:
            time.sleep(10)
            session.rollback()
            return _upsert_group_single(i, key_tuple, df_group, audit_id, retry=retry - 1)
        else:
            raise
    finally:
        session.close()


def final_upsert_instr_indicators(df_final, num_audit_id, max_workers=32):
    """
    Delete+insert on (datPeriodLastDay, numPortfGroupFKey, strPortfGPSCode)
    """
    key_cols = ["datPeriodLastDay", "numPortfGroupFKey", "strPortfGPSCode"]
    groups = list(df_final.groupby(key_cols))

    with ProcessPoolExecutor(max_workers=128) as executor:
        futures = {
            executor.submit(_upsert_group_single, i, key, group_df, num_audit_id)
            for i, (key, group_df) in enumerate(groups)
        }
        for future in as_completed(futures):
            future.result()
    return True
