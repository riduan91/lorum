import gc
import pandas as pd

def single_process_dmc_records(idx, key, chunk, ind_chunk):
    session = None
    try:
        print(f"Processing chunk {idx}")
        (
            rpt_code,
            period_end,
            grp_id,
            audit,
        ) = key

        df_partition = chunk.groupby(["strInstAladdin", "numInstID"])

        # ---------- 1. numeric aggregations (same as inner SELECT) ------
        # Build a LIST instead of dict for lower overhead
        aggs = []
        for (inst_ald, inst_id), subchunk in df_partition:
            row = {
                "strReportPortfGPSCode": rpt_code,
                "datPeriodLastDay": period_end,
                "numReportPortfGroupID": grp_id,
                "strInstAladdin": inst_ald,
                "numInstID": inst_id,
                "numAuditId": audit,
                "numHoldPrice": subchunk["numHoldPrice"].mean(),
                "numHoldAccruedIntPortf": subchunk["numHoldAccruedIntPortf"].sum(),
                "numWeightedAmtInReportPortf": subchunk["numWeightedAmtInReportPortf"].sum(),
                "numHoldCrossCur": subchunk["numHoldCrossCur"].mean(),
                "numWeightedQtqInReportPortf": subchunk["numWeightedQtqInReportPortf"].sum(),
                "numHoldAvrgCostInReportPortf": subchunk["numHoldAvrgCostInReportPortf"].sum(),
                **get_sign_leg_and_nr_leg(subchunk),
            }
            aggs.append(row)

        list_inst_alds = chunk["strInstAladdin"].unique().tolist()

        # ---------- ORM session ----------------------------------------
        session = get_session()
        try:
            instruments = {}
            analytics = {}
            for chunk_inst_alds in chunker(list_inst_alds, 2000):
                instruments.update(
                    {
                        record.strInstAladdin: record
                        for record in session.query(DMIRBRSInstrument)
                        .filter(DMIRBRSInstrument.strInstAladdin.in_(chunk_inst_alds))
                        .all()
                    }
                )
                analytics.update(
                    {
                        record.strInstAladdin: record
                        for record in session.query(DMIRBRSInstAnalytic)
                        .filter(
                            DMIRBRSInstAnalytic.strInstAladdin.in_(chunk_inst_alds),
                            DMIRBRSInstAnalytic.datInstQuotationDate == period_end,
                        )
                        .all()
                    }
                )

            list_curr_codes = list(
                {instrument.strInstCurrCode for instrument in instruments.values()}
            )
            list_inst_type_ids = list(
                {instrument.numInstTypeId for instrument in instruments.values()}
            )
            quotes = {}
            for chunk_curr_codes in chunker(list_curr_codes, 2000):
                quotes.update(
                    {
                        record.strCurrCode: record
                        for record in session.query(DMIRBRSCurrencyQuote)
                        .filter(
                            DMIRBRSCurrencyQuote.strCurrCode.in_(list_curr_codes),
                            DMIRBRSCurrencyQuote.datccyqDate == period_end,
                        )
                        .all()
                    }
                )

            p = session.query(DMIRPortfolio).filter_by(strPortfGPSCode=rpt_code).first()

            lnk = (
                session.query(DMIRPortfolioLnk.strPortfGroupDECALOGCode)
                .filter(
                    DMIRPortfolioLnk.numPortfGroupSkey == int(grp_id),
                    DMIRPortfolioLnk.strPortfGroupType.in_(["A", "G"]),
                )
                .first()
            )

            fund_aum_row = (
                session.query(DMIRBRSDMCPortfIndicators.numFundAUM)
                .filter_by(strPortfGPSCode=rpt_code, datPeriodLastDay=period_end)
                .order_by(DMIRBRSDMCPortfIndicators.numFundAUM.desc())
                .first()
            )
            fund_aum = fund_aum_row.numFundAUM if fund_aum_row else None

            #  aliases
            it = {
                type_id: {
                    "1": (
                        session.query(IT1)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class1")
                        .first()
                    ),
                    "3": (
                        session.query(IT3)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class3")
                        .first()
                    ),
                    "8": (
                        session.query(IT8)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class8")
                        .first()
                    ),
                    "9": (
                        session.query(IT9)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class9")
                        .first()
                    ),
                }
                for type_id in list_inst_type_ids
            }
            sb = {
                inst_ald: {
                    "BB": session.query(SB_BB)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="BNPP_BICS")
                    .first(),
                    "LH": session.query(SB_LH)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="LH")
                    .first(),
                    "MSCI": session.query(SB_MSCI)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="MSCI")
                    .first(),
                    "ICB": session.query(SB_ICB)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="ICB")
                    .first(),
                }
                for inst_ald in list_inst_alds
            }
        finally:
            session.close()

        # ---------- constants & basic fields ---------------------------
        for agg in aggs:
            inst_ald = agg["strInstAladdin"]
            inst_id = agg["numInstID"]

            agg["strSource"] = "DMC-LT"
            agg["AccountingDate"] = pd.to_datetime(period_end).normalize()
            agg["InstrumentDWHID"] = inst_id
            agg["PortfolioDWHID"] = rpt_code
            agg["PortfolioDWHGroupID"] = None
            agg["PortfolioName"] = p.strPtfName if p else None
            agg["PortfolioCurrency"] = p.strPtfCurrCode if p else None
            agg["InstrUnitCostInstrCur"] = None
            agg["InstrAvrgCostPortfCur"] = None
            agg["InstrLastPriceDate"] = agg["numHoldPrice"]
            agg["InstrProfitLossPortfCur"] = None
            agg["InstrQuantity"] = agg["numWeightedQtqInReportPortf"]
            agg["InstrLastPrice"] = agg["numHoldPrice"]
            agg["HoldingTypeName"] = None

            # ---------- instrument details ----------------------------------
            i = instruments.get(inst_ald)
            if i:
                agg.update(
                    dict(
                        instrISOCur=i.strInstCurrCode,
                        InstrumentName=i.strInstName,
                        BloombergCode=i.strBloombergCode,
                        InstrISINCode=i.strInstISINCode,
                        InstSedolCode=i.strInstSedolCode,
                        InstCusipCode=i.strInstCUSIPCode,
                        InstrIssuerName=i.strInstIssuerName,
                        InstrExchangeLocationName=i.strInstExchLocName,
                        InstrListingCotationCountryLabel=i.strInstListingCountryLabel,
                        InstrIssueCountryLabel=i.strInstIssueCountryLabel,
                        InstrIssuerCountryLabel=i.strInstIssuerCountryLabel,
                        InstrRiskCountryLabel=i.strInstRiskCountryLabel,
                        InstrCouponRate=i.numInstCouponRate,
                        InstrForwardRate=i.numInstForwardRate,
                        InstrMaturityDate=i.datInstMaturityDate,
                        InstrCallDate=i.datInstCallDate,
                        InstrNextCouponDate=i.datInstNextCouponDate,
                        strInstPriceType=i.strInstPriceType,
                        InstrRateType=i.strInstRateType,
                        InstrSpotRate=i.numInstSpotRate,
                        InstrStartDate=i.datInstStartDate,
                        InstrUnderlyingQuantity=i.numInstUndrlygQty,
                        InstrUnderlyingISINCode=i.strInstUndrlygISINCode,
                        InstrIssueDate=i.datInstIssueDate,
                        InstrNominalAmount=i.numInstNominalMt,
                        InstrRiskCurrency=i.strInstCurrCode,
                        InstrContractEndDate=i.datInstContractEnd,
                        InstrContractName=i.strInstContractName,
                        InstrLegType1=i.strInstLegTyp1,
                        InstrLegType2=i.strInstLegTyp2,
                        InstrLegType=i.strInstLegType,
                        InstrCouponTypePaid=i.strCpnRateTypPaid,
                        InstrCouponTypeReceived=i.strCpnRateTypeRecv,
                        InstrCouponFixedInterestRatePaid=i.numCpnFixedRatePaid,
                        InstrCouponFixedInterestRateReceived=i.numCpnFixedRateRecv,
                        InstrCouponIndexPaid=i.strCpnIndexPaid[:10] if i.strCpnIndexPaid else None,
                        InstrCouponIndexReceived=(
                            i.strCpnIndexRecv[:10] if i.strCpnIndexRecv else None
                        ),
                        SwapPaidFrequency=i.strSwapFreqPaid,
                        SwapReceivedFrequency=i.strSwapFreqRecv,
                        instrTypCd=i.strinstrmttypcd,
                    )
                )

            # ---------- analytics (a) ----------------------------------------
            a = analytics.get(inst_ald)
            q = quotes.get(i.strInstCurrCode) if i else None
            if a and q:
                mkt_eur = a.nummktcap * q.numccyqrateInv if not pd.isna(a.nummktcap) else None
                agg["InstrMktCapEur"] = mkt_eur
            else:
                mkt_eur = None

            if a:
                agg.update(
                    dict(
                        InstrYieldToMaturity=a.numInstYieldToMaturity,
                        InstrEffectiveDuration=a.numInstEffDuration,
                        InstrModifiedDuration=a.numInstModifDuration,
                        InstrSpreadDuration=a.numInstSpreadDuration,
                        InstrMCDuration=a.numInstMCDuration,
                        InstrYield=a.numInstYield,
                        InstrYieldCalculatedToMaturity=a.numInstYieldToCall,
                        InstrYieldToMaturityPaid=a.numInstYieldToMaturityPaid,
                        InstrYieldToMaturityReceived=a.numInstYieldToMaturityRecv,
                        InstrOAS=a.numInstOptionAdjSpread,
                    )
                )

            # ---------- FX quote --------------------------------------------
            if q:
                agg["InstrExchangeRate"] = q.numccyqrateInv

            # ---------- Instrument type names -------------------------------
            if i:
                for cls in ("1", "3", "8", "9"):
                    itm = it[i.numInstTypeId][cls]
                    if itm:
                        agg[f"InstrumentTypeNameClass{cls}"] = itm.strInstrumentTypeName
                        agg[f"InstrumentTypeIRNameClass{cls}"] = itm.strInstrumentTypeIRName

            # ---------- Sectors ---------------------------------------------
            if sb.get(inst_ald) and sb[inst_ald]["BB"]:
                bb = sb[inst_ald]["BB"]
                agg["InstrSectorBBLevel1"] = bb.strInstSectorL1 or bb.strIssSector1Label
                agg["InstrSectorBBLevel2"] = bb.strInstSectorL2 or bb.strIssSector2Label
                agg["InstrSectorBBLevel3"] = bb.strInstSectorL3 or bb.strIssSector3Label
            if sb.get(inst_ald) and sb[inst_ald]["LH"]:
                lh = sb[inst_ald]["LH"]
                agg["InstrSectorBarclaysLevel1"] = lh.strInstSectorL1 or lh.strIssSector1Label
                agg["InstrSectorBarclaysLevel2"] = lh.strInstSectorL2 or lh.strIssSector2Label
                agg["InstrSectorBarclaysLevel3"] = lh.strInstSectorL3 or lh.strIssSector3Label
            if sb.get(inst_ald) and sb[inst_ald]["MSCI"]:
                ms = sb[inst_ald]["MSCI"]
                agg["InstrSectorMSCILevel1"] = ms.strInstSectorL1 or ms.strIssSector1Label
                agg["InstrSectorMSCILevel2"] = ms.strInstSectorL2 or ms.strIssSector2Label
                agg["InstrSectorMSCILevel3"] = ms.strInstSectorL3 or ms.strIssSector3Label
            if sb.get(inst_ald) and sb[inst_ald]["ICB"]:
                ic = sb[inst_ald]["ICB"]
                agg["InstrSectorICBLevel1"] = ic.strInstSectorL1 or ic.strIssSector1Label
                agg["InstrSectorICBLevel2"] = ic.strInstSectorL2 or ic.strIssSector2Label
                agg["InstrSectorICBLevel3"] = ic.strInstSectorL3 or ic.strIssSector3Label

            # ---------- Aladdin group code ----------------------------------
            if lnk:
                agg["AladdinGroupCode"] = lnk.strPortfGroupDECALOGCode

            ind_row = ind_chunk[ind_chunk["strInstAladdin"] == inst_ald]
            if not ind_row.empty:
                ind = ind_row.iloc[0]
            else:
                ind = None

            # ---------- Duration & currency exposure CASE logic -------------
            if ind is not None and not ind.empty:
                agg.update(
                    dict(
                        InstRtgSPStandardized=ind["strInstRtgSPStandardized"],
                        InstRtgMDStandardized=ind["strInstRtgMDStandardized"],
                        InstRtgFHStandardized=ind["strInstRtgFHStandardized"],
                        InstrESGGlbScore=ind["numESGGlbScore"],
                        InstrESGGlbScoreCov=ind["numESGGlbScoreCov"],
                        InstrCO2IntensEVEval=ind["numCO2IntensEVEval"],
                        InstrCO2IntensEVEvalCov=ind["numCO2IntensEVEvalCov"],
                    )
                )
                for k in range(1, 14):
                    agg[f"InstrCustomRating{k}"] = ind.get(f"strInstRtgCustom{k}", None)
                base_dur_cur = ind["numDurExposureInPortfCur"]
                base_cur_cur = ind["numCurExposureInPortfCur"]
                base_cur_w = ind["numCurExposureWeight"]
                base_dur_w = ind["numDurExposureWeight"]
                agg["InstrEffectiveDurationContribution"] = ind["numEffectDurationContrib"]
                agg["InstrMCDurationContribution"] = ind["numMCDurationContrib"]
                agg["InstrModifiedDurationContribution"] = ind["numModifDurationContrib"]
                agg["InstrSpreadDurationContribution"] = ind["numSpreadDurationContrib"]
            else:
                base_dur_cur = base_cur_cur = base_cur_w = base_dur_w = None
                agg["InstrEffectiveDurationContribution"] = agg["InstrMCDurationContribution"] = None
                agg["InstrModifiedDurationContribution"] = agg["InstrSpreadDurationContribution"] = None

            nr_legs, sign_leg = agg["nrLegs"], agg["signOfLeg"]
            if nr_legs == 2 and sign_leg < 0:
                agg.update(
                    InstrEffectiveDurationContribution=0,
                    InstrMCDurationContribution=0,
                    InstrModifiedDurationContribution=0,
                    InstrSpreadDurationContribution=0,
                )

            # Duration exposure in portf cur / weight
            if nr_legs == 2 and agg["numWeightedQtqInReportPortf"] == 0:
                agg["InstrDurExposureInPortfCur"] = agg["numWeightedAmtInReportPortf"]
                agg["InstrDurExposureWeight"] = (
                    agg["numWeightedAmtInReportPortf"] / fund_aum if fund_aum else None
                )
            elif nr_legs == 2 and sign_leg < 0:
                agg["InstrDurExposureInPortfCur"] = 0
                agg["InstrDurExposureWeight"] = 0
            else:
                agg["InstrDurExposureInPortfCur"] = base_dur_cur
                agg["InstrDurExposureWeight"] = base_dur_w

            # Currency exposure (cur / weight)
            def _fx_family(it3_obj):
                if not it3_obj:
                    return False
                name = it3_obj.strInstrumentTypeIRName.upper()
                return name in (
                    "CURRENCY SPOT",
                    "CURRENCY FORWARD",
                    "CURRENCY SWAP",
                    "FOREX POSITIONS",
                )

            if i and _fx_family(it[i.numInstTypeId]["3"]):
                if sign_leg < 0 or (
                    agg["numWeightedQtqInReportPortf"] == 0
                    and agg["numHoldAvrgCostInReportPortf"] > 0
                ):
                    flip_cur = -base_cur_cur if base_cur_cur is not None else None
                    agg["InstrCurExposureInPortfCur"] = (
                        flip_cur
                        + (ind["numInstrWeight"] * fund_aum if ind is not None and fund_aum else 0)
                        if ind is not None
                        else None
                    )
                    flip_w = -base_cur_w if base_cur_w is not None else None
                    agg["InstrCurExposureWeight"] = (
                        flip_w + ind["numInstrWeight"] if ind is not None else None
                    )
                else:
                    agg["InstrCurExposureInPortfCur"] = base_cur_cur
                    agg["InstrCurExposureWeight"] = base_cur_w
            else:
                if nr_legs == 2 and sign_leg < 0:
                    agg["InstrCurExposureInPortfCur"] = 0
                    agg["InstrCurExposureWeight"] = 0
                else:
                    agg["InstrCurExposureInPortfCur"] = base_cur_cur
                    if base_cur_w is not None:
                        agg["InstrCurExposureWeight"] = base_cur_w
                    elif fund_aum:
                        agg["InstrCurExposureWeight"] = (
                            agg["numWeightedAmtInReportPortf"] / fund_aum
                        )
                    else:
                        agg["InstrCurExposureWeight"] = None

            # ---------- Weight & market-cap tier -----------------------------
            if fund_aum and fund_aum != 0:
                agg["InstrWeight"] = agg["numWeightedAmtInReportPortf"] / fund_aum
            else:
                agg["InstrWeight"] = None

            tier = (
                "CR_DATA_MKTCAP1_OTHER"
                if mkt_eur is None or pd.isna(mkt_eur)
                else (
                    "CR_DATA_MKTCAP1_4_0-300M"
                    if mkt_eur <= 3e8
                    else (
                        "CR_DATA_MKTCAP1_3_300M-2.5B"
                        if mkt_eur <= 2.5e9
                        else (
                            "CR_DATA_MKTCAP1_2_2.5B-10B"
                            if mkt_eur <= 1e10
                            else "CR_DATA_MKTCAP1_1_10B-MAX"
                        )
                    )
                )
            )
            agg["InstrMktCapEurTr1"] = tier

            # ---------- dateEOM ---------------------------------------------
            first_next = pd.to_datetime(period_end) + pd.offsets.MonthBegin(1)
            agg["dateEOM"] = first_next - pd.Timedelta(days=first_next.day)

        # Free big temporaries early
        del instruments, analytics, quotes, it, sb, df_partition
        gc.collect()

        get_hardware_info()
        return aggs
    finally:
        if session:
            session.close()


---


from typing import List, Dict, Any
import pandas as pd
from concurrent.futures import ThreadPoolExecutor, as_completed
import gc

def process_dmc_records(
    df_lt: pd.DataFrame,
    df_scope_dmc: pd.DataFrame,  # #scopes_dmc  (strReportPortfGPSCode, datPeriodLastDay)
    df_lt_ind: pd.DataFrame,     # tblDMIRBRSLTPortfInstrIndicators
    num_audit_id: int,
) -> pd.DataFrame:
    """
    Exact Python analogue of the DMC-LT insert logic.
    Builds and returns a DataFrame that can be bulk-inserted into
    DMIR.tblDMIRAPILTHolding (but does **no write** itself).
    """

    # Optional: categorize repeated strings to cut memory while grouping
    def _categorize(df, cols):
        for c in cols:
            if c in df.columns and df[c].dtype == "object":
                df[c] = df[c].astype("category")

    _categorize(df_lt, ["strReportPortfGPSCode", "strInstAladdin"])
    _categorize(df_scope_dmc, ["ReportPortfGPSCode"])
    _categorize(df_lt_ind, ["strPortfGPSCode", "strInstAladdin"])

    # 0)  scope-filter & audit flag
    df_lt = df_lt.assign(numAuditId=num_audit_id).merge(
        df_scope_dmc,
        left_on=["strReportPortfGPSCode", "datPeriodLastDay"],
        right_on=["ReportPortfGPSCode", "datPeriodLastDay"],
        how="inner",
    )

    key_cols = [
        "strReportPortfGPSCode",
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "numAuditId",
    ]

    results: List[Dict[str, Any]] = []
    future_to_batch = {}

    get_hardware_info()
    print("Groupby for df_lt")
    df_lt_groups = df_lt.groupby(key_cols)
    get_hardware_info()
    print("Groupby for df_lt")
    df_lt_ind_groups = df_lt_ind.groupby(["strPortfGPSCode", "datPeriodLastDay"])
    get_hardware_info()

    future_to_batch = {}
    # Use threads to avoid pickling whole chunks to child processes
    with ThreadPoolExecutor(max_workers=24) as executor:  # same prints, same hardware calls
        for idx, (key, chunk) in enumerate(df_lt_groups):
            try:
                ind_grp = df_lt_ind_groups.get_group((key[0], key[1]))
            except KeyError as ke:
                print(
                    f"Warning: {(key[0], key[1])} is not in instrIndicators. Error message: {ke}."
                )
                ind_grp = pd.DataFrame(columns=df_lt_ind.columns)

            future = executor.submit(
                single_process_dmc_records,
                idx,
                key,
                chunk,
                ind_grp,
            )
            future_to_batch[future] = idx

        for future in as_completed(future_to_batch):
            try:
                result = future.result()
                results.extend(result)
                print(f"Total count {len(results)} ")
            except Exception as exc:
                batch_idx = future_to_batch[future]
                print(f"Batch {batch_idx} generated an exception: {exc}")
                raise

    get_hardware_info()
    if len(results) == 0:
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))

    df = pd.DataFrame(results)
    del results
    gc.collect()
    return df
