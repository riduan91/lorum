# ---------------------------------------------------------------------
# helper ‑ chunk a list ------------------------------------------------
# ---------------------------------------------------------------------
def chunk_list(seq, size):
    for i in range(0, len(seq), size):
        yield seq[i : i + size]


# ---------------------------------------------------------------------
# ❶ fetch *allowed* instrument codes (runs in workers) -----------------
# ---------------------------------------------------------------------
def _fetch_allowed_instr_single(chunk_id: int, aladdins: list[str]) -> pd.DataFrame:
    """
    Return the strInstAladdin codes in *aladdins* that are **not** Cash
    (class4) nor Forex (class7).  Only the column `strInstAladdin` is
    returned.
    """
    session = get_session()
    try:
        IT = DMIRInstrumentIRType
        Ins = DMIRBRSInstrument

        q = (
            session.query(Ins.strInstAladdin)
            .outerjoin(
                IT,
                Ins.numInstTypeId == IT.numInstrTypeID,
            )
            .filter(
                Ins.strInstAladdin.in_(aladdins),
                ~(
                    (IT.strReportingType == "class4") & (IT.strInstrumentTypeIRName == "Cash")
                ),
                ~(
                    (IT.strReportingType == "class7") & (IT.strInstrumentTypeIRName == "Forex")
                ),
            )
        )

        return get_all_as_df(q)   # one col: strInstAladdin
    finally:
        session.close()


# ---------------------------------------------------------------------
# ❷ main routine -------------------------------------------------------
# ---------------------------------------------------------------------
def compute_holdings_number(df_wrk: pd.DataFrame,
                             df_tmp: pd.DataFrame,
                             max_workers: int = 48) -> pd.DataFrame:
    """
    Re‑implements the SQL block that sets  numHoldingsNumber  (RG22).

    Parameters
    ----------
    df_wrk : dataframe with all rows from DMIR.tblDMIRBRSLTPortfInstrIndicatorsWrk
             (must contain at least strInstAladdin + the three key columns)
    df_tmp : staging dataframe that already contains the columns from
             #tmpPortfIndicatorsWrk.  It will receive / overwrite the
             column *numHoldingsNumber*.
    """
    # ------------------------------------------------------------------
    # A. Pull instrument *filter* (parallel, DB)
    # ------------------------------------------------------------------
    inst_codes = df_wrk["strInstAladdin"].dropna().unique().tolist()
    allowed_codes = []

    with ProcessPoolExecutor(max_workers=max_workers) as pool:
        futures = {
            pool.submit(_fetch_allowed_instr_single, idx, chunk): idx
            for idx, chunk in enumerate(chunk_list(inst_codes, 2_000))
        }
        for fut in as_completed(futures):
            allowed_codes.append(fut.result())

    if allowed_codes:
        df_allowed = pd.concat(allowed_codes, ignore_index=True)
        allowed_set = set(df_allowed["strInstAladdin"])
    else:
        # nothing survives the filter ⇒ no holdings will be counted
        allowed_set = set()

    # ------------------------------------------------------------------
    # B. Compute the DISTINCT count per (day, code, fkey)
    # ------------------------------------------------------------------
    mask = df_wrk["strInstAladdin"].isin(allowed_set)
    grp_cols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]

    df_nr = (
        df_wrk.loc[mask, grp_cols + ["strInstAladdin"]]
        .drop_duplicates()
        .groupby(grp_cols, observed=True)["strInstAladdin"]
        .nunique()
        .reset_index(name="numHoldingsNumber")        # <-- “nr” in SQL
    )

    # ------------------------------------------------------------------
    # C. Merge into tmp and overwrite  numHoldingsNumber
    # ------------------------------------------------------------------
    df_out = df_tmp.merge(
        df_nr,
        on=grp_cols,
        how="left",
        suffixes=("", "_nr"),
    )

    if "numHoldingsNumber_nr" in df_out.columns:
        df_out["numHoldingsNumber"] = df_out["numHoldingsNumber_nr"]
        df_out.drop(columns="numHoldingsNumber_nr", inplace=True)

    return df_out
