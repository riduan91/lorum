'''lt_monitoring_pipeline.py

Combined External & Internal branches of DMIR LT‑Monitoring rewritten for pandas + SQLAlchemy 1.x (no CTEs, no pd.read_sql).

Public entry‑points
-------------------
run_external_branch(p_step, folder="data/lt_monitoringwrk_stepn")
    → returns enriched external‑aggregation DataFrame

run_internal_branch(p_step, folder="data/lt_monitoringwrk_stepn")
    → returns enriched internal‑aggregation DataFrame

Both helpers dump the intermediate JSON artefacts under *folder* to keep downstream
tasks unchanged.
'''

from typing import Tuple, List
from concurrent.futures import ProcessPoolExecutor, as_completed
from multiprocessing import cpu_count

import pandas as pd
import numpy as np
from sqlalchemy import text
from airflow.utils.log.logging_mixin import LoggingMixin

from dags.common.connect import get_session
from dags.common.utils import dataprocess

logger = LoggingMixin()

MAX_PROCESSES = min(24, cpu_count())

# ---------------------------------------------------------------------------
#  Generic helpers (shared by both branches)                                  
# ---------------------------------------------------------------------------

def df_from_sql(session, sql_txt: str, params=None) -> pd.DataFrame:
    """SQLAlchemy‑1.x‑friendly DataFrame loader (no pd.read_sql)."""
    res = session.execute(text(sql_txt), params or {})
    rows = res.fetchall()
    return pd.DataFrame(rows, columns=res.keys())


def group_max(df: pd.DataFrame, by_cols: list, date_col: str) -> pd.DataFrame:
    idx = df.groupby(by_cols, sort=False)[date_col].idxmax()
    return df.loc[idx].reset_index(drop=True)


def parallel_group_max(df: pd.DataFrame, by_cols: list, date_col: str,
                       workers: int = MAX_PROCESSES) -> pd.DataFrame:
    pieces = [g for _, g in df.groupby(by_cols[0])]
    with ProcessPoolExecutor(workers) as pool:
        futs = [pool.submit(group_max, g, by_cols, date_col) for g in pieces]
        return pd.concat([f.result() for f in as_completed(futs)], ignore_index=True)

# ---------------------------------------------------------------------------
#  EXTERNAL branch                                                           
# ---------------------------------------------------------------------------

def data_mon_prev_step_external(Session, p_step: int,
                                folder="data/lt_monitoringwrk_stepn") -> Tuple[pd.DataFrame, str]:
    """Fetch previous‑step external detail rows (Block‑A in legacy SQL)."""
    ses = Session()
    try:
        sql_upper = """
          SELECT datReportDate,strReportPeriod,strReportPortfHoldSrc,
                 numReportPortfGroupID,strReportPortfGPSCode,
                 strInvestedInPortfID AS strPortfID,
                 strInvestedInPortfName AS strPortfName,
                 numInvestedInPortfAUM AS numPortfAUM,
                 strInvestedInPortfISOCur AS strPortfISOCur,
                 strSrcUndrlygHoldData,
                 strInvestedInPortfID, datLastNAVDate
          FROM DMIR.tblDMIRMonitoringLTWrk
          WHERE numPortfLevel = :lvl
            AND numUndrlygLTflag = 1
            AND numPresUndrlygHoldData = 1
            AND strSrcUndrlygHoldData IN ('SPECIAL','EXTERNAL')
        """
        upper = df_from_sql(ses, sql_upper, {"lvl": p_step - 1})

        holding_sql = """
          SELECT strPortfISINCode, datHoldDate, strInstAladdin,
                 numHoldCrossCur,numHoldValuInPortfCur,numHoldQuantity,
                 numHoldPrice,numHoldAccruedIntInstr,numHoldAccruedIntPortf,
                 numInstID
          FROM DMIR.tblDMIRExternalSpecialHolding
        """
        hld = df_from_sql(ses, holding_sql)

        merged = (
            upper.merge(hld, left_on="strPortfID", right_on="strPortfISINCode")
                 .query("datHoldDate <= datLastNAVDate")
        )
        merged = parallel_group_max(merged, ["strPortfID", "datLastNAVDate"], "datHoldDate")

        path = dataprocess.save_json(merged.to_dict("records"), folder,
                                     "data_monitoring_previous_step_external")
        return merged, path
    finally:
        ses.close()


def external_add(path_ext: str, df_int2: pd.DataFrame,
                 folder="data/lt_monitoringwrk_stepn") -> str:
    ext_rows = dataprocess.read_json(path_ext) or []
    ext_rows.extend(df_int2.loc[df_int2["strSrcUndrlygHoldData"].isin(["EXTERNAL", "SPECIAL"])]
                         .to_dict("records"))
    return dataprocess.save_json(ext_rows, folder,
                                 "data_monitoring_previous_step_external_add")


def external_agg(df_ext: pd.DataFrame,
                 folder="data/lt_monitoringwrk_stepn") -> Tuple[pd.DataFrame, str]:
    agg = (df_ext.groupby(["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
                          as_index=False)
                 .agg(numHoldQuantity=("numHoldQuantity", "sum"),
                      numHoldValueInPortfCur=("numHoldValuInPortfCur", "sum"),
                      numHoldPrice=("numHoldPrice", "mean"),
                      numHoldAccruedIntInstr=("numHoldAccruedIntInstr", "sum"),
                      numHoldAccruedIntPortf=("numHoldAccruedIntPortf", "sum")))

    firsts = df_ext.drop_duplicates(["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"])
    out = firsts.merge(agg, on=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"])
    out["numWeightInReportPortfAUM"] = (
        out["numHoldValueInPortfCur"] * out["numWeightInReportPortfAUM"] /
        out["numPortfAUM"].replace(0, np.nan))
    path = dataprocess.save_json(out.to_dict("records"), folder,
                                 "data_monitoring_previous_step_external_agg")
    return out, path


def enrich_external_agg(Session, df_ext_agg: pd.DataFrame,
                        folder="data/lt_monitoringwrk_stepn") -> Tuple[pd.DataFrame, str]:
    if df_ext_agg.empty:
        path = dataprocess.save_json([], folder, "update_monitoring_previous_step_external_agg")
        return df_ext_agg, path

    ses = Session()
    try:
        scope = df_from_sql(ses, "SELECT * FROM DMIR.tblDMIRScopeLT WHERE datHoldDate IS NOT NULL")
        ccy   = df_from_sql(ses, """
            SELECT strCurrCode AS iso, numccyqrateInv,
                   CAST(datccyqDate AS varchar) AS d
            FROM   DMIR.vieDMIRBRSCurrencyQuote""")
    finally:
        ses.close()

    merged = (df_ext_agg
              .merge(scope, on=["numReportPortfGroupID", "strReportPortfGPSCode",
                                 "strReportPeriod"], how="left", suffixes=("", "_sc"))
              .merge(ccy, left_on=["strPortfISOCur", "datHoldDate"], right_on=["iso", "d"], how="left")
              .merge(ccy.add_suffix("_rep"),
                     left_on=["strReportPortfISOCur_sc", "datHoldDate"],
                     right_on=["iso_rep", "d_rep"], how="left"))

    merged["numPortfExRateInRptPtfCur"] = merged["numccyqrateInv"] / merged["numccyqrateInv_rep"]
    merged["numPortfAUMInRptPtfCur"] = merged["numPortfExRateInRptPtfCur"] * merged["numPortfAUM"]
    merged["numLTThreshold"] = merged["numLTThreshold"]

    path = dataprocess.save_json(merged.to_dict("records"), folder,
                                 "update_monitoring_previous_step_external_agg")
    return merged, path


# ---------------------------------------------------------------------------
#  INTERNAL branch (temp1/2/3, detail, detail‑2, aggregation, enrich)        
# ---------------------------------------------------------------------------

def temp1(session, p_step: int) -> pd.DataFrame:
    sql = """
      SELECT DISTINCT datLastNAVDate, strInvestedInPortfID
      FROM DMIR.tblDMIRMonitoringLTWrk
      WHERE numPortfLevel = :lvl
        AND numUndrlygLTflag = 1
        AND numPresUndrlygHoldData = 1
        AND strSrcUndrlygHoldData = 'INTERNAL'
    """
    return df_from_sql(session, sql, {"lvl": p_step - 1})


def temp2(session, df_t1: pd.DataFrame) -> pd.DataFrame:
    if df_t1.empty:
        return pd.DataFrame(columns=["datLastNAVDate", "strInvestedInPortfID", "datmaxAccDate"])

    nav_min, nav_max = df_t1["datLastNAVDate"].min(), df_t1["datLastNAVDate"].max()
    sql = """
      SELECT strPortfGPSCode, datACCDATE
      FROM   DMIR.tblDMIRDMCHolding
      WHERE  datACCDATE BETWEEN :dmin AND :dmax
    """
    hld = df_from_sql(session, sql, {"dmin": str(nav_min), "dmax": str(nav_max)})

    merged = (df_t1.merge(hld, left_on="strInvestedInPortfID", right_on="strPortfGPSCode")
                    .query("datACCDATE <= datLastNAVDate"))
    best = parallel_group_max(merged,
                              ["datLastNAVDate", "strInvestedInPortfID"],
                              "datACCDATE")
    return best.rename(columns={"datACCDATE": "datmaxAccDate"})


def temp3(session, df_t2: pd.DataFrame) -> pd.DataFrame:
    if df_t2.empty:
        return pd.DataFrame()

    ids = tuple(df_t2["strInvestedInPortfID"].unique())
    sql = """
      SELECT strPortfGPSCode, datACCDATE, strInstAladdin, numInstrFKey,
             numHoldCrossCur, numHoldValuInPortfCur, numHoldQuantity,
             numHoldPrice, numHoldAccruedIntInstr, numHoldAccruedIntPortf,
             numInstrFKey AS numInstID,
             numHoldAvrgCostInPortfCur, strUnderlSecCode
      FROM   DMIR.tblDMIRDMCHolding
      WHERE  strPortfGPSCode IN :ids
    """
    hld = df_from_sql(session, sql, {"ids": ids})
    return df_t2.merge(hld,
                       left_on=["strInvestedInPortfID", "datmaxAccDate"],
                       right_on=["strPortfGPSCode", "datACCDATE"],
                       how="inner")


def detail_internal(session, df_t2, df_t3, p_step: int) -> pd.DataFrame:
    if df_t2.empty or df_t3.empty:
        return pd.DataFrame()

    sql_up = """
      SELECT datReportDate, strReportPeriod, strReportPortfHoldSrc,
             numReportPortfGroupID, strReportPortfGPSCode,
             strInvestedInPortfID, strInvestedInPortfName,
             numInvestedInPortfAUM, strInvestedInPortfISOCur,
             numWeightInReportPortfAUM, strPortfLevelID,
             datPeriodLastDay, strSrcUndrlygHoldData,
             datLastNAVDate, strLevel1IsinCode, strReportPortfISOCur
      FROM   DMIR.tblDMIRMonitoringLTWrk
      WHERE  numPortfLevel = :lvl
        AND  numUndrlygLTflag = 1
        AND  numPresUndrlygHoldData = 1
        AND  strSrcUndrlygHoldData  = 'INTERNAL'
    """
    up = df_from_sql(session, sql_up, {"lvl": p_step - 1})

    df = (up.merge(df_t2, on=["datLastNAVDate", "strInvestedInPortfID"], how="inner")
             .merge(df_t3,
                    left_on=["strInvestedInPortfID", "datmaxAccDate"],
                    right_on=["strPortfGPSCode", "datACCDATE"],
                    how="inner", suffixes=("", "_hld")))

    out = pd.DataFrame({
        "datReportDate": df["datReportDate"],
        "strReportPeriod": df["strReportPeriod"],
        "strReportPortfHoldSrc": df["strReportPortfHoldSrc"],
        "numReportPortfGroupID": df["numReportPortfGroupID"],
        "strReportPortfGPSCode": df["strReportPortfGPSCode"],
        "strPortfID": df["strInvestedInPortfID"],
        "strPortfName": df["strInvestedInPortfName"],
        "numPortfAUM": df["numInvestedInPortfAUM"],
        "strPortfISOCur": df["strInvestedInPortfISOCur"],
        "strInvestedInInstrID": df["strInstAladdin"],
        "numHoldCrossCur": df["numHoldCrossCur"],
        "numHoldValueInPortfCur": df["numHoldValuInPortfCur"],
        "numHoldQuantity": df["numHoldQuantity"],
        "datHoldDate": df["datACCDATE"],
        "numHoldPrice": df["numHoldPrice"],
        "numHoldAccruedIntInstr": df["numHoldAccruedIntInstr"],
        "numHoldAccruedIntPortf": df["numHoldAccruedIntPortf"],
        "numWeightInReportPortfAUM": df["numWeightInReportPortfAUM"],
        "strPortfLevelID": df["strPortfLevelID"] + "." + df["strInvestedInPortfID"],
        "datPeriodLastDay": df["datPeriodLastDay"],
        "strSrcUndrlygHoldData": df["strSrcUndrlygHoldData"],
        "strInstAladdin": df["strInstAladdin"],
        "numInstID": df["numInstID"],
        "numHoldAvrgCostInPortfCur": df["numHoldAvrgCostInPortfCur"],
        "strLevel1IsinCode": df["strLevel1IsinCode"],
        "strReportPortfISOCur": df["strReportPortfISOCur"],
    })
    return out


# --- enrichment with instrument / SPECIAL flags (function reused) ---------
from lt_monitoring_external import data_monitoring_previous_step_internal_2 as enrich_internal_detail  # noqa: E402


def internal_agg(df_int2: pd.DataFrame) -> pd.DataFrame:
    if df_int2.empty:
        return pd.DataFrame()

    agg = (df_int2.groupby(["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"],
                            as_index=False)
                 .agg(numHoldQuantity=("numHoldQuantity", "sum"),
                      numHoldValueInPortfCur=("numHoldValueInPortfCur", "sum"),
                      numHoldAvrgCostInPortfCur=("numHoldAvrgCostInPortfCur", "sum"),
                      numHoldPrice=("numHoldPrice", "mean"),
                      numHoldAccruedIntInstr=("numHoldAccruedIntInstr", "sum"),
                      numHoldAccruedIntPortf=("numHoldAccruedIntPortf", "sum")))

    firsts = df_int2.drop_duplicates(["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"])
    out = firsts.merge(agg, on=["strReportPeriod", "strPortfLevelID", "strInvestedInInstrID"])
    out["numWeightInReportPortfAUM"] = (
        out["numHoldValueInPortfCur"] * out["numWeightInReportPortfAUM"] /
        out["numPortfAUM"].replace(0, np.nan))
    return out


def enrich_internal_agg(Session, df_int_agg: pd.DataFrame) -> pd.DataFrame:
    if df_int_agg.empty:
        return df_int_agg.copy()

    ses = Session()
    try:
        scope = df_from_sql(ses, "SELECT * FROM DMIR.tblDMIRScopeLT WHERE datHoldDate IS NOT NULL")
        ccy   = df_from_sql(ses, """
            SELECT strCurrCode AS iso, numccyqrateInv,
                   CAST(datccyqDate AS varchar) AS d
            FROM   DMIR.vieDMIRBRSCurrencyQuote""")
    finally:
        ses.close()

    merged = (df_int_agg
              .merge(scope,
                     on=["numReportPortfGroupID", "strReportPortfGPSCode", "strReportPeriod"],
                     how="left", suffixes=("", "_sc"))
              .merge(ccy,
                     left_on=["strPortfISOCur", "datHoldDate"],
                     right_on=["iso", "d"], how="left")
              .merge(ccy.add_suffix("_rep"),
                     left_on=["strReportPortfISOCur_sc", "datHoldDate"],
                     right_on=["iso_rep", "d_rep"], how="left"))

    merged["numPortfExRateInRptPtfCur"] = merged["numccyqrateInv"] / merged["numccyqrateInv_rep"]
    merged["numPortfAUMInRptPtfCur"]   = merged["numPortfExRateInRptPtfCur"] * merged["numPortfAUM"]
    merged["numHoldAvrgCostInPortfCur"] = merged["numPortfExRateInRptPtfCur"] * merged["numHoldAvrgCostInPortfCur"]
    merged["numLTThreshold"] = merged["numLTThreshold"]
    return merged


# ---------------------------------------------------------------------------


def _insert_dataframe(session, df: pd.DataFrame, model_cls, *, chunk_size: int = 100_000):
    if df.empty:
        return 0
    dict_rows = df.to_dict("records")
    total = len(dict_rows)
    for chunk in chunkify(dict_rows, chunk_size):
        session.execute(model_cls.__table__.insert(), chunk)
    return total


def insert_branches(p_step: int, df_ext_enrich: pd.DataFrame, df_int_enrich: pd.DataFrame,
                    num_audit_id: int, var_current_date: str,
                    chunk_size: int = 100_000):
    """Convert enriched DataFrames to the DMIRMonitoringLTWrk schema & bulk‑insert."""
    Session = get_session()
    ses = Session()
    try:
        # ----------------------------  EXTERNAL rows
        if not df_ext_enrich.empty:
            df_out = _map_external_to_output(df_ext_enrich, p_step,
                                             num_audit_id, var_current_date)
            cnt_ext = _insert_dataframe(ses, df_out, DMIRMonitoringLTWrk,
                                        chunk_size=chunk_size)
        else:
            cnt_ext = 0

        # ----------------------------  INTERNAL rows
        if not df_int_enrich.empty:
            df_out_i = _map_internal_to_output(df_int_enrich, p_step,
                                               num_audit_id, var_current_date)
            cnt_int = _insert_dataframe(ses, df_out_i, DMIRMonitoringLTWrk,
                                        chunk_size=chunk_size)
        else:
            cnt_int = 0
        ses.commit()
        logger.log.info("Inserted %d external + %d internal rows into DMIRMonitoringLTWrk", cnt_ext, cnt_int)
    except Exception:
        ses.rollback()
        raise
    finally:
        ses.close()


# --- mapping helpers ------------------------------------------------------

_EXT_COLS = [
    # straight‑copy columns from df_ext_enrich (same name)
    "datReportDate", "strReportPeriod", "strReportPortfHoldSrc",
    "numReportPortfGroupID", "strReportPortfGPSCode", "strPortfID",
    "strPortfName", "strPortfLevelID", "numPortfAUM", "strPortfISOCur",
    "numPortfExRateInRptPtfCur", "numPortfAUMInRptPtfCur",
    "strInvestedInPortfID", "strInvestedInPortfName", "strInstISINCode",
    "strInvestedInPortfISOCur", "numHoldCrossCur", "numHoldValueInPortfCur",
    "numWeightInReportPortfAUM", "numHoldQuantity", "datHoldDate",
    "strSrcUndrlygHoldData", "datPeriodLastDay", "strInstAladdin",
    "numInstID", "numHoldPrice", "numHoldAccruedIntInstr",
    "numHoldAccruedIntPortf", "strLevel1IsinCode", "strReportPortfISOCur",
]


def _map_external_to_output(df: pd.DataFrame, p_step: int, aid: int, now: str) -> pd.DataFrame:
    out = df[_EXT_COLS].copy()
    out.insert(2, "numPortfLevel", p_step)
    out["strInvestedInInstrID"] = df["strInvestedInInstrID"].fillna("-1")

    # nav‑lookup columns come from earlier pandas stage → already merged
    out["numInvestedInPortfAUM"] = df["numAUMInPortfCur"].values
    out["datLastNAVDate"] = df["datAccDate"].values
    out["datLastModifDate"] = now
    out["numPresUndrlygHoldData"] = (df["numAUMInPortfCur"].notna()).astype(int)

    out["numUndrlygLTflag"] = np.where(
        (df["numWeightInReportPortfAUM"].fillna(0) < df["numLTThreshold"]) |
        df["numWeightInReportPortfAUM"].isna() |
        df.apply(lambda r: f".{r['strInvestedInPortfID']}." in r["strPortfLevelID"], axis=1),
        0, 1)

    out["numHoldAvrgCostInReportPortf"] = None
    out["numAuditId"] = aid
    return out


_INT_COLS = [
    # columns copied from df_int_enrich
    "datReportDate", "strReportPeriod", "strReportPortfHoldSrc",
    "numReportPortfGroupID", "strReportPortfGPSCode", "strPortfID",
    "strPortfName", "numPortfAUM", "strPortfISOCur",
    "numPortfExRateInRptPtfCur", "numPortfAUMInRptPtfCur",
    "strInvestedInPortfID", "strInvestedInPortfName", "strInstISINCode",
    "strInvestedInPortfISOCur", "numHoldCrossCur", "numHoldValueInPortfCur",
    "numWeightInReportPortfAUM", "numHoldQuantity", "datHoldDate",
    "strSrcUndrlygHoldData", "datPeriodLastDay", "strInstAladdin", "numInstID",
    "numHoldAvrgCostInPortfCur", "numHoldPrice",
    "numHoldAccruedIntInstr", "numHoldAccruedIntPortf", "strLevel1IsinCode",
    "strReportPortfISOCur",
]


def _map_internal_to_output(df: pd.DataFrame, p_step: int, aid: int, now: str) -> pd.DataFrame:
    out = df[_INT_COLS].copy()
    out.insert(2, "numPortfLevel", p_step)
    out["strPortfLevelID"] = df["strPortfLevelID"].fillna("XX")
    out["strInvestedInInstrID"] = df["strInvestedInInstrID"].fillna("XX")

    out["numInvestedInPortfAUM"] = df["numActifNetTotalOpcvm"].values
    out["datLastNAVDate"] = df["datACCDate"].values
    out["datLastModifDate"] = now
    out["numPresUndrlygHoldData"] = (df["numActifNetTotalOpcvm"].notna()).astype(int)

    out["numUndrlygLTflag"] = np.where(
        (df["numWeightInReportPortfAUM"].fillna(0) < df["numLTThreshold"]) |
        df["numWeightInReportPortfAUM"].isna() |
        df.apply(lambda r: f".{r['strInvestedInPortfID']}." in r["strPortfLevelID"], axis=1),
        0, 1)

    out["strHedgedShClass"] = "U"  # will be overwritten later for H‑shares
    out["numHedgedFactor"] = 1
    out.rename(columns={"numHoldAvrgCostInPortfCur": "numHoldAvrgCostInReportPortf"},
               inplace=True)
    out["numAuditId"] = aid
    return out

# ---------------------------------------------------------------------------
#  G · POST‑PROCESSING UPDATES  (hedged share / hedging value / LT‑exclude)   |
# ---------------------------------------------------------------------------

def update_hedged_share_flag(Session, p_step: int):
    """Equivalent of the temp‑table #temp4 + UPDATE strHedgedShClass = 'H'."""
    ses = Session()
    try:
        sql = (
            "UPDATE dm SET dm.strHedgedShClass = 'H'\n"
            "FROM DMIR.tblDMIRMonitoringLTWrk dm\n"
            "JOIN DMIR.tblDMIRDMCHolding h\n"
            "     ON dm.strInvestedInPortfID = h.strPortfGPSCode\n"
            "    AND dm.datLastNAVDate      = h.datACCDATE\n"
            "    AND dm.strInstISINCode     = h.strUnderlSecCode\n"
            "JOIN DMIR.tblDMIRBRSInstrument i ON i.strInstAladdin = h.strInstAladdin\n"
            "JOIN DMIR.tblDMIRInstrumentIRType irt ON irt.numInstrTypeID = i.numInstTypeId\n"
            "WHERE dm.numPortfLevel = :lvl\n"
            "  AND dm.strSrcUndrlygHoldData = 'INTERNAL'\n"
            "  AND irt.strReportingType = 'class7'\n"
            "  AND irt.strInstrumentTypeIRName = 'Forex'" )
        ses.execute(text(sql), {"lvl": p_step})
        ses.commit()
    finally:
        ses.close()


def update_hedged_factor(Session, p_step: int):
    """SQL rewrite of #ttt temp + UPDATE numHedgedFactor."""
    ses = Session()
    try:
        sql = (
            "UPDATE dm SET dm.numHedgedFactor =\n"
            " (ROUND(v.numActifNetTypePartConcerne / v.numTxchangedevvldevref,0)\n"
            "  / v.numActifNetTotalOpcVm)\n"
            "FROM DMIR.tblDMIRMonitoringLTWrk dm\n"
            "JOIN DMIR.tblDMIRDMCVALO v\n"
            "  ON v.strPortfGPSCode  = dm.strInvestedInPortfID\n"
            " AND v.datDateVL       = dm.datLastNAVDate\n"
            " AND v.strShareISINCode= dm.strInstISINCode\n"
            "WHERE dm.strHedgedShClass = 'H' AND dm.numPortfLevel = :lvl" )
        ses.execute(text(sql), {"lvl": p_step})
        ses.commit()
    finally:
        ses.close()


def update_aum_for_hedging(Session, p_step: int):
    """Combine #all_hedging + #relv_hedging logic in one go."""
    ses = Session()
    try:
        # 1) subtract all hedging
        sql1 = (
            "UPDATE dm SET dm.numInvestedInPortfAUM = dm.numInvestedInPortfAUM - agg.sumVal\n"
            "FROM DMIR.tblDMIRMonitoringLTWrk dm\n"
            "JOIN (\n"
            "  SELECT strPortfLevelID,strReportPeriod,datLastNAVDate,strInvestedInPortfID,\n"
            "         SUM(numHoldValuInPortfCur) AS sumVal\n"
            "  FROM DMIR.tblDMIRDMCHolding h\n"
            "  JOIN DMIR.tblDMIRBRSInstrument i ON i.strInstAladdin = h.strInstAladdin\n"
            "  JOIN DMIR.tblDMIRInstrumentIRType irt ON irt.numInstrTypeID = i.numInstTypeId\n"
            "  WHERE irt.strReportingType = 'class7' AND irt.strInstrumentTypeIRName='Forex'\n"
            "  GROUP BY strPortfLevelID,strReportPeriod,datLastNAVDate,strInvestedInPortfID) agg\n"
            "  ON agg.strPortfLevelID = dm.strPortfLevelID\n"
            " AND agg.strReportPeriod = dm.strReportPeriod\n"
            " AND agg.datLastNAVDate  = dm.datLastNAVDate\n"
            " AND agg.strInvestedInPortfID = dm.strInvestedInPortfID\n"
            "WHERE dm.numPortfLevel = :lvl AND dm.strHedgedShClass IN ('U','H')" )

        # 2) add back relevant hedging for H shares
        sql2 = (
            "UPDATE dm SET dm.numInvestedInPortfAUM = dm.numInvestedInPortfAUM + agg.relVal\n"
            "FROM DMIR.tblDMIRMonitoringLTWrk dm\n"
            "JOIN (\n"
            "  SELECT strPortfLevelID,strReportPeriod,datLastNAVDate,strInvestedInPortfID,\n"
            "         SUM(numHoldValuInPortfCur)/NULLIF(numHedgedFactor,0) AS relVal\n"
            "  FROM DMIR.tblDMIRDMCHolding h\n"
            "  JOIN DMIR.tblDMIRBRSInstrument i ON i.strInstAladdin = h.strInstAladdin\n"
            "  JOIN DMIR.tblDMIRInstrumentIRType irt ON irt.numInstrTypeID = i.numInstTypeId\n"
            "  WHERE irt.strReportingType = 'class7' AND irt.strInstrumentTypeIRName='Forex'\n"
            "  GROUP BY strPortfLevelID,strReportPeriod,datLastNAVDate,strInvestedInPortfID,numHedgedFactor) agg\n"
            "  ON agg.strPortfLevelID = dm.strPortfLevelID\n"
            " AND agg.strReportPeriod = dm.strReportPeriod\n"
            " AND agg.datLastNAVDate  = dm.datLastNAVDate\n"
            " AND agg.strInvestedInPortfID = dm.strInvestedInPortfID\n"
            "WHERE dm.numPortfLevel = :lvl AND dm.strHedgedShClass='H'" )

        ses.execute(text(sql1), {"lvl": p_step})
        ses.execute(text(sql2), {"lvl": p_step})
        ses.commit()
    finally:
        ses.close()


def update_lt_exclude(Session, p_step: int):
    ses = Session()
    try:
        sql = (
            "UPDATE dm SET dm.numUndrlygLTflag=0, dm.numUndrlygUserLTflag=0\n"
            "FROM DMIR.tblDMIRMonitoringLTWrk dm\n"
            "JOIN DMIR.tblDMIRLTExclude ex\n"
            "  ON ex.strPortfLevelID      = dm.strPortfLevelID\n"
            " AND ex.strInvestedInPortfID = dm.strInvestedInPortfID\n"
            "WHERE dm.numPortfLevel = :lvl" )
        ses.execute(text(sql), {"lvl": p_step})
        ses.commit()
    finally:
        ses.close()


def post_processing_updates(p_step: int):
    """Run the four post‑insert update steps in sequence."""
    Session = get_session()
    update_hedged_share_flag(Session, p_step)
    update_hedged_factor(Session, p_step)
    update_aum_for_hedging(Session, p_step)
    update_lt_exclude(Session, p_step)
    logger.log.info("Post‑processing updates finished for level %d", p_step)

# ---------------------------------------------------------------------------
#  Driver helpers                                                            |
# ---------------------------------------------------------------------------

def run_external_branch(p_step: int, folder="data/lt_monitoringwrk_stepn") -> pd.DataFrame:
    Session = get_session()
    df_ext0, path_ext0 = data_mon_prev_step_external(Session, p_step, folder)
    # the internal detail‑2 DataFrame is passed in later, so expose df_ext0
    return df_ext0


def run_internal_branch(p_step: int, folder="data/lt_monitoringwrk_stepn") -> pd.DataFrame:
    Session = get_session()
    ses = Session()
    try:
        df_t1 = temp1(ses, p_step)
        df_t2 = temp2(ses, df_t1)
        df_t3 = temp3(ses, df_t2)
        df_int1 = detail_internal(ses, df_t2, df_t3, p_step)
    finally:
        ses.close()
    df_int2 = enrich_internal_detail(Session, df_int1)[0]
    df_agg  = internal_agg(df_int2)
    df_enrich = enrich_internal_agg(Session, df_agg)
    return df_enrich

