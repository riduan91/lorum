import polars as pl

def show_examples(df: pl.DataFrame, context, df_name: str, sample=None, filters=None):
    print(f"Columns of {df_name}: {df.columns}")

    if not sample:
        sample = min(500, df.height)

    df_head = df

    if filters:
        for k, v in filters.items():
            if k in df.columns:
                df_head = df_head.filter(pl.col(k) == v)
            else:
                print(f"Ignoring filter {k} since {k} is not a column of the dataframe.")

        df_head = df_head.head(sample)
    else:
        df_head = df.head(sample)

    # Convert to JSON via Pandas for XCom compatibility
    sample_json = df_head.to_pandas().to_json(orient="records", date_format="iso")

    context["ti"].xcom_push(key=f"{df_name}.samples", value=sample_json)
    context["ti"].xcom_push(key=f"{df_name}.sample_size", value=df_head.height)
    context["ti"].xcom_push(key=f"{df_name}.size", value=df.height)
