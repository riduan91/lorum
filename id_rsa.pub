import polars as pl

def normalize_type(df: pl.DataFrame, force_float_cols: list[str] = []) -> pl.DataFrame:
    # Step 1: Detect columns by prefix
    dat_cols = [col for col in df.columns if col is not None and col.startswith("dat")]
    str_cols = [col for col in df.columns if col is not None and col.startswith("str")]

    # Step 2: Convert date columns
    for col in dat_cols:
        try:
            df = df.with_columns(
                pl.col(col).str.strptime(pl.Datetime, fmt="%Y-%m-%d", strict=False).alias(col)
            )
        except Exception:
            pass  # In case the format doesn't match, fallback

    # Step 3: Convert string columns
    for col in str_cols:
        df = df.with_columns(pl.col(col).cast(pl.Utf8))

    # Step 4: Force float columns
    for col in force_float_cols:
        if col in df.columns:
            df = df.with_columns(pl.col(col).cast(pl.Float64))

    return df
