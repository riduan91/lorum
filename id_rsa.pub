DECLARE
    @fba_id        INT        = 202069,       -- random selected from fba
    @market_date   DATE       = '2025-06-27',
    @flag          VARCHAR(1) = 'W',
    @dflt_date      DATE        = '',         -- sentinel for dates
    @dflt_float     FLOAT       = 0.0,        -- sentinel zero for floats
    @dflt_int       INT         = 0,          -- sentinel zero for ints
    @dflt_string    VARCHAR(1)  = '',         -- sentinel empty for strings
    @tol            FLOAT       = 1e-6;       -- tolerance = 10e-7

SELECT
    a.datMarketDate      AS datMarketDate,
    a.strPeriodTypeFlag  AS strPeriodTypeFlag,
    a.datPeriodLastDay   AS datPeriodLastDay,
    a.numBenchFBAId      AS numBenchFBAId,

    /* exact (string/date/int) comparisons */
    CASE WHEN ISNULL(a.strPeriodTypeFlag    , @dflt_string) = ISNULL(b.strPeriodTypeFlag    , @dflt_string) THEN 0 ELSE 1 END AS valid_strPeriodTypeFlag,
    CASE WHEN ISNULL(a.datPeriodLastDay     , @dflt_date  ) = ISNULL(b.datPeriodLastDay     , @dflt_date  ) THEN 0 ELSE 1 END AS valid_datPeriodLastDay,
    CASE WHEN ISNULL(a.datMarketDate        , @dflt_date  ) = ISNULL(b.datMarketDate        , @dflt_date  ) THEN 0 ELSE 1 END AS valid_datMarketDate,
    CASE WHEN ISNULL(a.numBenchFBAId        , @dflt_int   ) = ISNULL(b.numBenchFBAId        , @dflt_int   ) THEN 0 ELSE 1 END AS valid_numBenchFBAId,
    CASE WHEN ISNULL(a.strPFCurrencyISOCode , @dflt_string) = ISNULL(b.strPFCurrencyISOCode , @dflt_string) THEN 0 ELSE 1 END AS valid_strPFCurrencyISOCode,

    /* floats comparison with tolerance */
    CASE WHEN ABS(ISNULL(a.numDurExposureBench     , @dflt_float) - ISNULL(b.numDurExposureBench     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numDurExposureBench,
    CASE WHEN ABS(ISNULL(a.numCurExposureBench     , @dflt_float) - ISNULL(b.numCurExposureBench     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCurExposureBench,
    CASE WHEN ISNULL(a.datBenchAvgMaturityLife     , @dflt_date )    = ISNULL(b.datBenchAvgMaturityLife     , @dflt_date ) THEN 0 ELSE 1 END AS valid_datBenchAvgMaturityLife,
    CASE WHEN ABS(ISNULL(a.numEffectDurationBench  , @dflt_float) - ISNULL(b.numEffectDurationBench  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numEffectDurationBench,
    CASE WHEN ABS(ISNULL(a.numModifDurationBench   , @dflt_float) - ISNULL(b.numModifDurationBench   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numModifDurationBench,
    CASE WHEN ABS(ISNULL(a.numMCDurationBench      , @dflt_float) - ISNULL(b.numMCDurationBench      , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numMCDurationBench,
    CASE WHEN ABS(ISNULL(a.numSpreadDurationBench  , @dflt_float) - ISNULL(b.numSpreadDurationBench  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numSpreadDurationBench,
    CASE WHEN ABS(ISNULL(a.numBenchAvgCoupon       , @dflt_float) - ISNULL(b.numBenchAvgCoupon       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgCoupon,
    CASE WHEN ABS(ISNULL(a.numBenchAvgYTM          , @dflt_float) - ISNULL(b.numBenchAvgYTM          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgYTM,
    CASE WHEN ABS(ISNULL(a.numBenchAvgConvexity    , @dflt_float) - ISNULL(b.numBenchAvgConvexity    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgConvexity,
    CASE WHEN ABS(ISNULL(a.numHoldingsNumber       , @dflt_float) - ISNULL(b.numHoldingsNumber       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numHoldingsNumber,
    CASE WHEN ABS(ISNULL(a.numBenchPriceEarnRatio  , @dflt_float) - ISNULL(b.numBenchPriceEarnRatio  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchPriceEarnRatio,
    CASE WHEN ABS(ISNULL(a.numBenchPriceToBook     , @dflt_float) - ISNULL(b.numBenchPriceToBook     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchPriceToBook,
    CASE WHEN ABS(ISNULL(a.numBenchDivYld          , @dflt_float) - ISNULL(b.numBenchDivYld          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchDivYld,
    CASE WHEN ABS(ISNULL(a.numBenchPriceCash       , @dflt_float) - ISNULL(b.numBenchPriceCash       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchPriceCash,
    CASE WHEN ABS(ISNULL(a.numBench35YrForecastEarnGrowth, @dflt_float) 
                  - ISNULL(b.numBench35YrForecastEarnGrowth, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBench35YrForecastEarnGrowth,
    CASE WHEN ABS(ISNULL(a.numBenchROE             , @dflt_float) - ISNULL(b.numBenchROE             , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchROE,
    CASE WHEN ABS(ISNULL(a.numBenchEvEbit          , @dflt_float) - ISNULL(b.numBenchEvEbit          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchEvEbit,
    CASE WHEN ABS(ISNULL(a.numBenchEvSales         , @dflt_float) - ISNULL(b.numBenchEvSales         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchEvSales,
    CASE WHEN ABS(ISNULL(a.numBenchEvEbitda        , @dflt_float) - ISNULL(b.numBenchEvEbitda        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchEvEbitda,
    CASE WHEN ABS(ISNULL(a.numBenchTotalExpenseRatio, @dflt_float) - ISNULL(b.numBenchTotalExpenseRatio, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchTotalExpenseRatio,

    /* exact strings */
    CASE WHEN ISNULL(a.strBenchAvgRtgSP      , @dflt_string) = ISNULL(b.strBenchAvgRtgSP      , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgSP,
    CASE WHEN ISNULL(a.strBenchAvgRtgMD      , @dflt_string) = ISNULL(b.strBenchAvgRtgMD      , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgMD,
    CASE WHEN ISNULL(a.strBenchAvgRtgFH      , @dflt_string) = ISNULL(b.strBenchAvgRtgFH      , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgFH,

    /* more customs… */
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom1 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom1 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom1,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom2 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom2 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom2,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom3 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom3 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom3,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom4 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom4 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom4,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom5 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom5 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom5,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom6 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom6 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom6,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom7 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom7 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom7,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom8 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom8 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom8,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom9 , @dflt_string) = ISNULL(b.strBenchAvgRtgCustom9 , @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom9,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom10, @dflt_string) = ISNULL(b.strBenchAvgRtgCustom10, @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom10,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom11, @dflt_string) = ISNULL(b.strBenchAvgRtgCustom11, @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom11,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom12, @dflt_string) = ISNULL(b.strBenchAvgRtgCustom12, @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom12,
    CASE WHEN ISNULL(a.strBenchAvgRtgCustom13, @dflt_string) = ISNULL(b.strBenchAvgRtgCustom13, @dflt_string) THEN 0 ELSE 1 END AS valid_strBenchAvgRtgCustom13,

    /* continue floats with tolerance */
    CASE WHEN ABS(ISNULL(a.numBenchWAL           , @dflt_float) - ISNULL(b.numBenchWAL           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchWAL,
    CASE WHEN ABS(ISNULL(a.numBenchWAM           , @dflt_float) - ISNULL(b.numBenchWAM           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchWAM,
    CASE WHEN ABS(ISNULL(a.numBenchInflSens      , @dflt_float) - ISNULL(b.numBenchInflSens      , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchInflSens,
    CASE WHEN ABS(ISNULL(a.numBenchDebtEq        , @dflt_float) - ISNULL(b.numBenchDebtEq        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchDebtEq,
    CASE WHEN ABS(ISNULL(a.numBenchWAMarketCap   , @dflt_float) - ISNULL(b.numBenchWAMarketCap   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchWAMarketCap,
    CASE WHEN ABS(ISNULL(a.numEffectDurationBenchFI, @dflt_float) - ISNULL(b.numEffectDurationBenchFI, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numEffectDurationBenchFI,
    CASE WHEN ABS(ISNULL(a.numModifDurationBenchFI , @dflt_float) - ISNULL(b.numModifDurationBenchFI , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numModifDurationBenchFI,
    CASE WHEN ABS(ISNULL(a.numMCDurationBenchFI    , @dflt_float) - ISNULL(b.numMCDurationBenchFI    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numMCDurationBenchFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgCouponFI     , @dflt_float) - ISNULL(b.numBenchAvgCouponFI     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgCouponFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgYTMFI        , @dflt_float) - ISNULL(b.numBenchAvgYTMFI        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgYTMFI,
    CASE WHEN ISNULL(a.datBenchAvgMaturityLifeFI  , @dflt_date )    = ISNULL(b.datBenchAvgMaturityLifeFI  , @dflt_date ) THEN 0 ELSE 1 END AS valid_datBenchAvgMaturityLifeFI,
    CASE WHEN ABS(ISNULL(a.numSpreadDurationBenchFI, @dflt_float) - ISNULL(b.numSpreadDurationBenchFI, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numSpreadDurationBenchFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgMarketCap    , @dflt_float) - ISNULL(b.numBenchAvgMarketCap    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgMarketCap,
    CASE WHEN ABS(ISNULL(a.numBenchMedMarketCap    , @dflt_float) - ISNULL(b.numBenchMedMarketCap    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchMedMarketCap,
    CASE WHEN ABS(ISNULL(a.numBenchAvgYTMDurWeighted, @dflt_float) - ISNULL(b.numBenchAvgYTMDurWeighted, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgYTMDurWeighted,
    CASE WHEN ABS(ISNULL(a.numBenchAvgYTMDurWeightedFI, @dflt_float) - ISNULL(b.numBenchAvgYTMDurWeightedFI, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgYTMDurWeightedFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgYieldWorst    , @dflt_float) - ISNULL(b.numBenchAvgYieldWorst    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgYieldWorst,
    CASE WHEN ABS(ISNULL(a.numBenchAvgYieldWorstFI  , @dflt_float) - ISNULL(b.numBenchAvgYieldWorstFI  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgYieldWorstFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgOas           , @dflt_float) - ISNULL(b.numBenchAvgOas           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgOas,
    CASE WHEN ABS(ISNULL(a.numBenchAvgOasFI         , @dflt_float) - ISNULL(b.numBenchAvgOasFI         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgOasFI,
    CASE WHEN ABS(ISNULL(a.numNumberOfIssuers       , @dflt_float) - ISNULL(b.numNumberOfIssuers       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numNumberOfIssuers,
    CASE WHEN ABS(ISNULL(a.numNumberOfIssuersFI     , @dflt_float) - ISNULL(b.numNumberOfIssuersFI     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numNumberOfIssuersFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgDtsFI         , @dflt_float) - ISNULL(b.numBenchAvgDtsFI         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgDtsFI,
    CASE WHEN ABS(ISNULL(a.numBenchAvgPrice         , @dflt_float) - ISNULL(b.numBenchAvgPrice         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgPrice,
    CASE WHEN ABS(ISNULL(a.numESGGlbScore           , @dflt_float) - ISNULL(b.numESGGlbScore           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGlbScore,
    CASE WHEN ABS(ISNULL(a.numESGGlbCovWeight       , @dflt_float) - ISNULL(b.numESGGlbCovWeight       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGlbCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGGlbScoreCov        , @dflt_float) - ISNULL(b.numESGGlbScoreCov        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGlbScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGEnvScore           , @dflt_float) - ISNULL(b.numESGEnvScore           , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGEnvScore,
    CASE WHEN ABS(ISNULL(a.numESGEnvCovWeight       , @dflt_float) - ISNULL(b.numESGEnvCovWeight       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGEnvCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGEnvScoreCov        , @dflt_float) - ISNULL(b.numESGEnvScoreCov        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGEnvScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGSocialScore        , @dflt_float) - ISNULL(b.numESGSocialScore        , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGSocialScore,
    CASE WHEN ABS(ISNULL(a.numESGSocialCovWeight    , @dflt_float) - ISNULL(b.numESGSocialCovWeight    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGSocialCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGSocialScoreCov     , @dflt_float) - ISNULL(b.numESGSocialScoreCov     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGSocialScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGGovernanceScore    , @dflt_float) - ISNULL(b.numESGGovernanceScore    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGovernanceScore,
    CASE WHEN ABS(ISNULL(a.numESGGovCovWeight       , @dflt_float) - ISNULL(b.numESGGovCovWeight       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGovCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGGovernanceScoreCov , @dflt_float) - ISNULL(b.numESGGovernanceScoreCov , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGovernanceScoreCov,
    CASE WHEN ABS(ISNULL(a.numESGDecile             , @dflt_float) - ISNULL(b.numESGDecile             , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGDecile,
    CASE WHEN ABS(ISNULL(a.numESGDecileCovWeight    , @dflt_float) - ISNULL(b.numESGDecileCovWeight    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGDecileCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGDecileCov          , @dflt_float) - ISNULL(b.numESGDecileCov          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGDecileCov,
    CASE WHEN ABS(ISNULL(a.numESGGlbPotentialScoreCov, @dflt_float) - ISNULL(b.numESGGlbPotentialScoreCov, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGlbPotentialScoreCov,
    CASE WHEN ABS(ISNULL(a.numCO2IntensRevEval      , @dflt_float) - ISNULL(b.numCO2IntensRevEval      , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensRevEval,
    CASE WHEN ABS(ISNULL(a.numCO2IntensRevEvalCovWeight, @dflt_float) - ISNULL(b.numCO2IntensRevEvalCovWeight, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensRevEvalCovWeight,
    CASE WHEN ABS(ISNULL(a.numCO2IntensRevEvalCov    , @dflt_float) - ISNULL(b.numCO2IntensRevEvalCov    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensRevEvalCov,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEval       , @dflt_float) - ISNULL(b.numCO2IntensEVEval       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensEVEval,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEvalCovWeight, @dflt_float) - ISNULL(b.numCO2IntensEVEvalCovWeight, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensEVEvalCovWeight,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEvalCov     , @dflt_float) - ISNULL(b.numCO2IntensEVEvalCov     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensEVEvalCov,
    CASE WHEN ABS(ISNULL(a.numCO2EmmisionsScope12   , @dflt_float) - ISNULL(b.numCO2EmmisionsScope12   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2EmmisionsScope12,
    CASE WHEN ABS(ISNULL(a.numCO2EmmissionCovWeight , @dflt_float) - ISNULL(b.numCO2EmmissionCovWeight , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2EmmissionCovWeight,
    CASE WHEN ABS(ISNULL(a.numCO2EmmisionsCov       , @dflt_float) - ISNULL(b.numCO2EmmisionsCov       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2EmmisionsCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDiversityValu, @dflt_float) - ISNULL(b.numESGKPIGenderDiversityValu, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIGenderDiversityValu,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDivCovWeight , @dflt_float) - ISNULL(b.numESGKPIGenderDivCovWeight , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIGenderDivCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDivValuCov   , @dflt_float) - ISNULL(b.numESGKPIGenderDivValuCov   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIGenderDivValuCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsValu    , @dflt_float) - ISNULL(b.numESGKPIHumanRightsValu    , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsValu,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsCovWeight, @dflt_float) - ISNULL(b.numESGKPIHumanRightsCovWeight, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsValuCov  , @dflt_float) - ISNULL(b.numESGKPIHumanRightsValuCov  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsValuCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIExposureControvESG  , @dflt_float) - ISNULL(b.numESGKPIExposureControvESG  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExposureControvESG,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvESGCovWeight, @dflt_float) - ISNULL(b.numESGKPIExpControvESGCovWeight, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExpControvESGCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvESGCov   , @dflt_float) - ISNULL(b.numESGKPIExpControvESGCov   , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExpControvESGCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIExposureControvSocial, @dflt_float) - ISNULL(b.numESGKPIExposureControvSocial, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExposureControvSocial,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvSocCovWeight, @dflt_float) - ISNULL(b.numESGKPIExpControvSocCovWeight, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExpControvSocCovWeight,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvSocCov , @dflt_float) - ISNULL(b.numESGKPIExpControvSocCov , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExpControvSocCov,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtEnv         , @dflt_float) - ISNULL(b.numESGKPIEngmtEnv         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIEngmtEnv,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtSocial      , @dflt_float) - ISNULL(b.numESGKPIEngmtSocial      , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIEngmtSocial,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtGov         , @dflt_float) - ISNULL(b.numESGKPIEngmtGov         , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIEngmtGov,
    CASE WHEN ABS(ISNULL(a.numESGKPIEngmtNumMeetings , @dflt_float) - ISNULL(b.numESGKPIEngmtNumMeetings , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIEngmtNumMeetings,
    CASE WHEN ABS(ISNULL(a.numESGKPIAllTypEngmt      , @dflt_float) - ISNULL(b.numESGKPIAllTypEngmt      , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIAllTypEngmt,
    CASE WHEN ABS(ISNULL(a.numGrpPolicyRcoWeight     , @dflt_float) - ISNULL(b.numGrpPolicyRcoWeight     , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numGrpPolicyRcoWeight,
    CASE WHEN ABS(ISNULL(a.numESGGlbCovWeightG       , @dflt_float) - ISNULL(b.numESGGlbCovWeightG       , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGGlbCovWeightG,
    CASE WHEN ABS(ISNULL(a.numCO2IntensEVEvalCovWeightG, @dflt_float) - ISNULL(b.numCO2IntensEVEvalCovWeightG, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numCO2IntensEVEvalCovWeightG,
    CASE WHEN ABS(ISNULL(a.numESGKPIGenderDivCovWeightG, @dflt_float) - ISNULL(b.numESGKPIGenderDivCovWeightG, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIGenderDivCovWeightG,
    CASE WHEN ABS(ISNULL(a.numESGKPIHumanRightsCovWeightG, @dflt_float) - ISNULL(b.numESGKPIHumanRightsCovWeightG, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIHumanRightsCovWeightG,
    CASE WHEN ABS(ISNULL(a.numESGKPIExpControvESGCovWeightG, @dflt_float) - ISNULL(b.numESGKPIExpControvESGCovWeightG, @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numESGKPIExpControvESGCovWeightG,
    CASE WHEN ABS(ISNULL(a.numBenchAvgDts          , @dflt_float) - ISNULL(b.numBenchAvgDts          , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgDts,
    CASE WHEN ABS(ISNULL(a.numBenchAvgConvexityFI  , @dflt_float) - ISNULL(b.numBenchAvgConvexityFI  , @dflt_float)) < @tol THEN 0 ELSE 1 END AS valid_numBenchAvgConvexityFI,

    /* raw values for inspection */
    a.numBenchAvgConvexity       AS numBenchAvgConvexity_a,
    b.numBenchAvgConvexity       AS numBenchAvgConvexity_b,
    a.datBenchAvgMaturityLife    AS datBenchAvgMaturityLife_a,
    b.datBenchAvgMaturityLife    AS datBenchAvgMaturityLife_b,
    a.numCurExposureBench        AS numCurExposureBench_a,
    b.numCurExposureBench        AS numCurExposureBench_b,
    a.numDurExposureBench        AS numDurExposureBench_a,
    b.numDurExposureBench        AS numDurExposureBench_b,
    a.numESGGlbScoreCov          AS numESGGlbScoreCov_a,
    b.numESGGlbScoreCov          AS numESGGlbScoreCov_b,
    a.numEffectDurationBench     AS numEffectDurationBench_a,
    a.numHoldingsNumber          AS numHoldingsNumber_a,
    b.numHoldingsNumber          AS numHoldingsNumber_b,
    a.numNumberOfIssuers         AS numNumberOfIssuers_a,
    b.numNumberOfIssuers         AS numNumberOfIssuers_b,
    a.strPFCurrencyISOCode       AS strPFCurrencyISOCode_a,
    b.strPFCurrencyISOCode       AS strPFCurrencyISOCode_b

FROM DMIR.tblDMIRBRSBenchIndicators AS a
INNER JOIN dbo.tblDMIRBRSBenchIndicators AS b
    ON a.strPeriodTypeFlag = b.strPeriodTypeFlag
   AND a.datPeriodLastDay  = b.datPeriodLastDay
   AND a.numBenchFBAId     = b.numBenchFBAId
WHERE
    a.datPeriodLastDay    = @market_date
    AND a.numBenchFBAId   = @fba_id
    AND a.strPeriodTypeFlag = @flag;
