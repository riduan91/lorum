# -----------------------------------------------------------------------
# 1)  metadata/analytic fetch  (concurrent, but *read‑only*)
# -----------------------------------------------------------------------
def _load_fi_chunks(chunk_idx: int, inst_codes: list[str], qdate) -> pd.DataFrame:
    """Pulls coupon / maturity (Instrument) *and* analytic metrics for one chunk."""
    session = get_session()
    try:
        A = DMIRBRSInstAnalytic
        I = DMIRBRSInstrument
        IT = DMIRInstrumentIRType

        q = (
            session.query(
                I.strInstAladdin,
                I.numInstCouponRate,
                I.datInstMaturityDate,
                I.blncall,
                I.datInstCallDate,
                I.strInstIssuerCode,
                A.numInstYieldToMaturity,
                A.numInstConvexity,
                A.numInstOptionAdjSpread,
                A.numInstSpreadDuration,
                A.numInstEffDuration,
                A.numInstModifDuration,
                A.numInstMCDuration,
            )
            .join(
                A,
                and_(
                    A.strInstAladdin == I.strInstAladdin,
                    A.datInstQuotationDate == qdate,
                ),
            )
            .join(
                IT,
                and_(
                    IT.numInstrTypeID == I.numInstTypeId,
                    IT.strReportingType == "class4",
                    IT.strInstrumentTypeIRName.in_(
                        ["Fixed Income", "Derivatives - Fixed Income", "MF - Fixed Income"]
                    ),
                ),
            )
            .filter(I.strInstAladdin.in_(inst_codes))
        )
        return get_all_as_df(q)
    finally:
        session.close()


def _pull_fi_metadata(df_instr: pd.DataFrame, max_workers: int = 32) -> pd.DataFrame:
    """Parallel fan‑out, fan‑in loader – returns one big dataframe."""
    all_codes = df_instr["strInstAladdin"].dropna().unique().tolist()
    if not all_codes:
        return pd.DataFrame()

    qdate = pd.to_datetime(df_instr["datPeriodLastDay"].iloc[0])  # same for the slice
    chunks = [all_codes[i : i + 1000] for i in range(0, len(all_codes), 1000)]

    dfs = []
    with ProcessPoolExecutor(max_workers=max_workers) as exe:
        futs = {exe.submit(_load_fi_chunks, idx, chunk, qdate): idx for idx, chunk in enumerate(chunks)}
        for f in as_completed(futs):
            dfs.append(f.result())

    return pd.concat(dfs, ignore_index=True) if dfs else pd.DataFrame()


# -----------------------------------------------------------------------
# 2)  vectorised aggregation   (faithful to the SQL SELECT  X   CTE)
# -----------------------------------------------------------------------
def compute_fi_portf_metrics(
    df_instr: pd.DataFrame, df_tmp: pd.DataFrame, max_workers: int = 32
) -> pd.DataFrame:
    """
    Vectorised reproduction of the fixed‑income block in the SQL script.
    df_instr  = staging rows (DMIRBRSLTPortfInstrIndicatorsWrk)
    df_tmp    = #tmpPortfIndicatorsWrk       (we update 11 FI columns in it)
    """
    # ------------------------------------------------------------------
    # pre‑filter: keep rows where Dur‑Exposure exists (SQL clause)
    # ------------------------------------------------------------------
    df_instr = df_instr[df_instr["numDurExposureInPortfCur"].notna()].copy()
    if df_instr.empty:
        return df_tmp  # nothing to update

    # ------------------------------------------------------------------
    # join Instrument + Analytic metadata (concurrent fetch)
    # ------------------------------------------------------------------
    df_meta = _pull_fi_metadata(df_instr, max_workers=max_workers)
    df_join = df_instr.merge(df_meta, on="strInstAladdin", how="inner")

    # helper weights (all already float)
    w_dur      = df_join["numDurExposureWeight"].fillna(0)
    w_dur_mod  = df_join["numModifDurationContribWeight"].fillna(0)
    w_instr    = df_join["numInstrWeight"].fillna(0)

    # ------------------------------------------------------------------
    # vectorised helper columns (one per SUM() term in SQL)
    # ------------------------------------------------------------------
    df_join = df_join.assign(
        w_coupon      = df_join["numInstCouponRate"].fillna(0)          * w_instr,
        w_ytm         = df_join["numInstYieldToMaturity"].fillna(0)     * w_dur,
        w_convexity   = df_join["numInstConvexity"].fillna(0)           * w_dur,
        w_ytm_dur_w   = df_join["numInstYieldToMaturity"].fillna(0)     * w_dur_mod,
        w_oas         = df_join["numInstOptionAdjSpread"].fillna(0)     * w_dur,
        w_dts         = (
            df_join["numInstOptionAdjSpread"].fillna(0)
            * df_join["numInstSpreadDuration"].fillna(0)
            * w_dur
        ),
        w_maturity_days = (
            np.where(
                (df_join["blncall"]) & df_join["datInstCallDate"].notna(),
                (df_join["datInstCallDate"] - df_join["datPeriodLastDay"]).dt.days,
                (df_join["datInstMaturityDate"] - df_join["datPeriodLastDay"]).dt.days,
            )
            * w_instr
        ),
    )

    # ------------------------------------------------------------------
    # group‑by portfolio key & sum
    # ------------------------------------------------------------------
    gcols = ["datPeriodLastDay", "strPortfGPSCode", "numPortfGroupFKey"]
    agg = (
        df_join.groupby(gcols, sort=False, observed=True)
        .agg(
            numEffectDurationPortfFI   = ("numEffectDurationContrib", "sum"),
            numModifDurationPortfFI    = ("numModifDurationContrib", "sum"),
            numMCDurationPortfFI       = ("numMCDurationContrib", "sum"),
            numSpreadDurationPortfFI   = ("numSpreadDurationContrib", "sum"),
            numPtfAvgCouponFI          = ("w_coupon", "sum"),
            numPtfAvgYTMFI             = ("w_ytm", "sum"),
            numPtfAvgConvexityFI       = ("w_convexity", "sum"),
            numPtfAvgYTMDurWeightedFI  = ("w_ytm_dur_w", "sum"),
            numPtfAvgMaturityLife_sum  = ("w_maturity_days", "sum"),
            numPtfAvgOas               = ("w_oas", "sum"),
            numPtfAvgDts               = ("w_dts", "sum"),
            sumNumInstrWeight          = ("numInstrWeight", "sum"),
            numNumberOfIssuersFI       = ("strInstIssuerCode", "nunique"),
        )
        .reset_index()
    )

    # ------------------------------------------------------------------
    # divide by weight where required  +   maturity date
    # ------------------------------------------------------------------
    denom = agg["sumNumInstrWeight"].replace({0: np.nan})

    for col in [
        "numEffectDurationPortfFI",
        "numModifDurationPortfFI",
        "numMCDurationPortfFI",
        "numSpreadDurationPortfFI",
        "numPtfAvgCouponFI",
        "numPtfAvgYTMFI",
        "numPtfAvgConvexityFI",
        "numPtfAvgYTMDurWeightedFI",
        "numPtfAvgOas",
        "numPtfAvgDts",
    ]:
        agg[col] = agg[col] / denom

    # maturity: only if (days / weight) is in a realistic range
    days_adj = agg["numPtfAvgMaturityLife_sum"] / denom
    ok = days_adj.between(-100, 36500)
    agg["datPtfAvgMaturityLifeFI"] = np.where(
        ok,
        agg["datPeriodLastDay"] + pd.to_timedelta(days_adj.round().astype("Int64"), unit="D"),
        pd.NaT,
    )

    # ------------------------------------------------------------------
    # merge back into tmp, overwrite 11 target cols
    # ------------------------------------------------------------------
    df_out = df_tmp.merge(agg.drop(columns="numPtfAvgMaturityLife_sum"), on=gcols, how="left")

    cols_to_patch = [
        "numEffectDurationPortfFI",
        "numModifDurationPortfFI",
        "numMCDurationPortfFI",
        "numSpreadDurationPortfFI",
        "numPtfAvgCouponFI",
        "numPtfAvgYTMFI",
        "numPtfAvgConvexityFI",
        "numPtfAvgYTMDurWeightedFI",
        "datPtfAvgMaturityLifeFI",
        "numPtfAvgOasFI",
        "numNumberOfIssuersFI",
        "numPtfAvgDtsFI",
    ]
    rename_map = {c: f"{c}_y" for c in cols_to_patch}  # pandas merge suffix

    for c in cols_to_patch:
        if f"{c}_y" in df_out.columns:
            df_out[c] = df_out[f"{c}_y"]
            df_out.drop(columns=f"{c}_y", inplace=True)

    return df_out
