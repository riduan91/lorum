def build_ma_reporting_scope(current_date: date):
    """Loads MA reporting data using SQLAlchemy ORM into a pandas DataFrame. Correspond to task 1 and 2 in the analysis file
    Parameters:
        session (Session): A SQLAlchemy ORM session.
        current_date (date): The current date used to filter the report scope.

    Returns:
        pd.DataFrame: The resulting DataFrame matching the original SQL logic.
    """
    session = get_session()

    # Define the computed column (flagCalcDate) using the ORM case() function.
    flagCalcDate = case(
        [
            (
                (DMIRReportParam.strLTcalcMethod == "DELTA")
                & (DMIRReportScope.strReportFrequency.in_(["Monthly", "Quarterly", "Yearly"])),
                1,
            ),
            (DMIRReportParam.strLTcalcMethod == "FULL", 14),
        ],
        else_=None,
    )

    # Build the query by joining the three tables and applying the same filters and grouping.
    query = (
        session.query(
            DMIRReportScope.datReportPostingDate.label("datReportDate"),
            DMIRReportParam.strAccSrc.label("strReportPortfHoldSrc"),
            func.coalesce(DMIRReportParam.numPortfGroupfKey, -1).label("numReportPortfGroupID"),
            DMIRReportParam.strEntityName.label("strReportPortfName"),
            DMIRReportParam.numLTThreshold.label("numLTThreshold"),
            DMIRPortfolioLnk.numPortfSkey.label("str1LevelPortfID"),
            DMIRPortfolioLnk.strptflongname.label("strPortfName"),
            DMIRReportScope.datReportPeriodEndDate.label("datReportPeriodEndDate"),
            flagCalcDate.label("flagCalcDate"),
        )
        .join(DMIRReportScope, DMIRReportParam.strReportId == DMIRReportScope.strReportID)
        .join(
            DMIRPortfolioLnk,
            DMIRReportParam.numPortfGroupfKey == DMIRPortfolioLnk.numPortfGroupSkey,
        )
        .filter(
            DMIRReportParam.numLTflag == 1,
            DMIRReportParam.strAccSrc.in_(["ALP"]),
            DMIRReportScope.strReportFrequency.in_(["Monthly", "Quarterly", "Yearly"]),
            DMIRReportParam.strLTcalcMethod.in_(["FULL", "DELTA"]),
            DMIRReportScope.datReportPostingDate >= current_date,
            DMIRReportScope.datReportPeriodEndDate < current_date,
        )
        .group_by(
            DMIRReportScope.datReportPostingDate,
            DMIRReportParam.strAccSrc,
            DMIRReportParam.numPortfGroupfKey,
            DMIRReportParam.strEntityName,
            DMIRReportParam.numLTThreshold,
            DMIRPortfolioLnk.numPortfSkey,
            DMIRPortfolioLnk.strptflongname,
            DMIRReportScope.datReportPeriodEndDate,
            DMIRReportParam.strLTcalcMethod,
            DMIRReportScope.strReportFrequency,
        )
    )
    df = get_all_as_df(query)
    return df, query


def expand_ma_scope_with_period(task_1_query, current_date: date):
    session = get_session()

    # Use the Task 1 query as a subquery 't'
    subq = task_1_query.subquery("t")
    expanded_query = (
        session.query(
            cast(DWGNPeriod.datPerioddate, String).label("datPeriodLastDay"),
            func.format(DWGNPeriod.datPerioddate, "yyyyMM").label("strReportPeriod"),
            subq.c.datReportDate,
            subq.c.strReportPortfHoldSrc,
            subq.c.numReportPortfGroupID,
            subq.c.strReportPortfName,
            subq.c.numLTThreshold,
            subq.c.str1LevelPortfID,
            subq.c.strPortfName,
            subq.c.datReportPeriodEndDate,
        )
        .select_from(subq, DWGNPeriod)
        .filter(
            DWGNPeriod.datPerioddate.between(
                func.dateadd(
                    text("MONTH"), (1 - subq.c.flagCalcDate), subq.c.datReportPeriodEndDate
                ),
                subq.c.datReportPeriodEndDate,
            ),
            DWGNPeriod.blnIsmonth == 1,
        )
    )
    df = get_all_as_df(expanded_query)
    return df


def load_alpha_esg_scope(last_day_of_month: date, excluded_group_ids: list):
    """
    Loads additional rows for Alpha ESG calculations using the ORM, then returns them as a pandas DataFrame.
    Step 3 in the Analysis

    Parameters:
        session (Session): The SQLAlchemy ORM session.
        last_day (date): The target date (e.g. last day of previous month) to filter the holdings.
        excluded_group_ids (list): A list of group IDs that should be excluded from the results.

    Returns:
        pd.DataFrame: DataFrame containing additional Alpha ESG rows.
    """
    session = get_session()

    # Subquery for DMIRMaccNav to check that the portfolio group exists on the target date.
    macc_nav_subq = (
        session.query(DMIRMaccNav.numPortfGroupFKey)
        .filter(DMIRMaccNav.datNavDate == last_day_of_month)
        .subquery()
    )

    # Build the query joining the three tables
    query = (
        session.query(
            DMIRAlphaHolding.datHoldDATE.label("datPeriodLastDay"),
            # Convert the holding date to a six-character period string by taking the left 6 characters of the converted date.
            func.format(DMIRAlphaHolding.datHoldDATE, "yyyyMM").label("strReportPeriod"),
            func.current_timestamp().label(
                "datReportDate"
            ),  # Alternatively, you can pass a parameter for GETDATE()
            literal("ALP").label("strReportPortfHoldSrc"),
            DMIRPortfolioLnk.numPortfGroupSkey.label("numReportPortfGroupID"),
            DMIRPortfolioLnk.strPortfGroupName.label("strReportPortfName"),
            literal(0.01).label("numLTThreshold"),
            DMIRPortfolioLnk.numPortfSkey.label("str1LevelPortfID"),
            DMIRPortfolioLnk.strptflongname.label("strPortfName"),
            DMIRAlphaHolding.datHoldDATE.label("datReportPeriodEndDate"),
        )
        .join(DMIRBRSInstrument, DMIRAlphaHolding.numInstrFKey == DMIRBRSInstrument.numInstID)
        .join(DMIRPortfolioLnk, DMIRAlphaHolding.numPortfFkey == DMIRPortfolioLnk.numPortfSkey)
        .filter(
            DMIRAlphaHolding.datHoldDATE == last_day_of_month,
            DMIRPortfolioLnk.strPortfGroupType.in_(["G", "A"]),
            DMIRPortfolioLnk.numPortfGroupSkey.in_(macc_nav_subq),
            ~DMIRPortfolioLnk.numPortfGroupSkey.in_(excluded_group_ids),
        )
        .distinct()
    )
    df_alpha_esg = get_all_as_df(query)
    return df_alpha_esg


def calculate_ma_aum_single(row_number, row):
    session = get_session()
    if row_number % 100 == 0:
        print(f"Processing {row_number}")
    report_period, portf_group_id, period_last_day = (
        row["strReportPeriod"],
        row["numReportPortfGroupID"],
        row["datPeriodLastDay"],
    )

    query_alpha = session.query(
        literal(report_period).label("strReportPeriod"),
        literal(portf_group_id).label("numReportPortfGroupID"),
        literal(period_last_day).label("datPeriodLastDay"),
        func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("LT_AUM"),
    ).filter(
        DMIRTransparizLT.numLowestInventoryflag == 1,
        DMIRTransparizLT.strReportPortfHoldSrc == "ALP",
        DMIRTransparizLT.numInstID > 1,
        DMIRTransparizLT.strReportPeriod == report_period,
        DMIRTransparizLT.numReportPortfGroupID == portf_group_id,
        DMIRTransparizLT.datPeriodLastDay == period_last_day,
    )  #
    df = get_all_as_df(query_alpha)
    session.close()
    return df


def calculate_ma_aum(current_date):
    session = get_session()
    query_alpha_keys = (
        session.query(
            DMIRTransparizLT.strReportPeriod.label("strReportPeriod"),
            DMIRTransparizLT.numReportPortfGroupID.label("numReportPortfGroupID"),
            DMIRTransparizLT.datPeriodLastDay.label("datPeriodLastDay"),
        )
        .filter(
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.strReportPortfHoldSrc == "ALP",
            DMIRTransparizLT.datPeriodLastDay >= func.dateadd(text("MONTH"), -4, current_date),
            DMIRTransparizLT.numInstID > 1,
        )
        .distinct()
    )

    keys = get_all_as_df(query_alpha_keys)
    df_res_alpha = run_query_in_parallel(calculate_ma_aum_single, keys)
    # print("keys:", len(keys))
    # print("df_res_alpha:", df_res_alpha)

    if df_res_alpha.empty:
        df_res_alpha = pd.DataFrame(
            columns=["strReportPeriod", "numReportPortfGroupID", "datPeriodLastDay", "LT_AUM"]
        )

    indicator_query = session.query(
        DMIRBRSLTPortfIndicators.numPortfGroupFkey.label("numReportPortfGroupID"),
        DMIRBRSLTPortfIndicators.datPeriodLastDay.label("datPeriodLastDay"),
    ).filter(DMIRBRSLTPortfIndicators.numAuditId == 999)

    df_indicators = get_all_as_df(indicator_query)

    if df_indicators.empty:
        df_indicators = pd.DataFrame(columns=["numReportPortfGroupID", "datPeriodLastDay"])

    df_res_alpha = df_res_alpha.merge(
        df_indicators, on=["numReportPortfGroupID", "datPeriodLastDay"], how="left", indicator=True
    )
    # For rows where a matching indicator exists (_merge == "both"), set LT_AUM to 100.
    df_res_alpha.loc[df_res_alpha["_merge"] == "both", "LT_AUM"] = 100
    print("df_res_alpha", df_res_alpha.shape)

    # Drop the merge indicator column and return the updated DataFrame.
    df_res_alpha.drop(columns=["_merge"], inplace=True)
    return df_res_alpha


def calculate_ma_holdings(current_date):
    session = get_session()
    # Query for holding AUM aggregation (df_res_holding)
    query_holdings = (
        session.query(
            func.sum(DMIRAlphaHolding.numHoldValuInPortfCur).label("holding_Aum"),
            DMIRPortfolioLnk.numPortfGroupSkey.label("numPortfGroupSkey"),
            DMIRAlphaHolding.datHoldDATE.label("datHoldDATE"),
        )
        .join(DMIRPortfolioLnk, DMIRPortfolioLnk.numPortfSkey == DMIRAlphaHolding.numPortfFkey)
        .join(DWGNPeriod, DMIRAlphaHolding.datHoldDATE == DWGNPeriod.datPerioddate)
        .filter(
            DMIRAlphaHolding.datHoldDATE >= func.dateadd(text("MONTH"), -4, current_date),
            DWGNPeriod.blnIsmonth == 1,
        )
        .group_by(DMIRPortfolioLnk.numPortfGroupSkey, DMIRAlphaHolding.datHoldDATE)
    )
    df_res_holding = get_all_as_df(query_holdings)
    return df_res_holding


def compute_scope_alpha_using_aum_single(
    row_id, row, df_res_holding, df_ma_reporting_data, current_date, exclude_ids
):
    logging.info(f"Processing row {row_id}")
    session = get_session()
    try:
        group_id = row["numReportPortfGroupID"]
        period_date = row["datPeriodLastDay"]

        reporting_key = (group_id, str(period_date))

        reporting_exclusions = set(
            tuple(x)
            for x in df_ma_reporting_data[["numReportPortfGroupID", "datReportPeriodEndDate"]]
            .drop_duplicates()
            .values
        )

        if reporting_key in reporting_exclusions:
            return None

        # Query DMIRMaccNav for a matching NAV record.
        lower_bound = current_date - relativedelta(months=6)
        nav_record = (
            session.query(DMIRMaccNav)
            .filter(
                DMIRMaccNav.numPortfGroupFKey == group_id,
                DMIRMaccNav.datNavDate == period_date,
                DMIRMaccNav.datNavDate >= lower_bound,
            )
            .first()
        )

        if nav_record is None:
            return None

        # Lookup corresponding holding record in df_res_holding.
        matching_holdings = df_res_holding[
            (df_res_holding["numPortfGroupSkey"] == group_id)
            & (
                df_res_holding["datHoldDATE"].dt.strftime("%Y-%m-%d")
                == period_date.strftime("%Y-%m-%d")
            )
        ]

        if matching_holdings.empty:
            return None

        holding_record = matching_holdings.iloc[0]

        # Check if AUM difference is greater than 0.2.
        if abs(holding_record["holding_Aum"] - row["LT_AUM"]) <= 0.2:
            return None

        # Query DMIRPortfolioLnk for portfolio record for the group.
        query_portfolio = session.query(
            DMIRPortfolioLnk.numPortfGroupSkey,
            DMIRPortfolioLnk.strPortfGroupName,
            DMIRPortfolioLnk.numPortfSkey,
            DMIRPortfolioLnk.strptflongname,
        ).filter(
            DMIRPortfolioLnk.numPortfGroupSkey == group_id,
            ~DMIRPortfolioLnk.numPortfGroupSkey.in_(exclude_ids),
        )
        df_portfolio_records = get_all_as_df(query_portfolio)

        # Construct new record dictionary.

        new_records = [
            {
                "datPeriodLastDay": period_date,
                "strReportPeriod": row["strReportPeriod"],
                "datReportDate": current_date,
                "strReportPortfHoldSrc": "ALP",
                "numReportPortfGroupID": nav_record.numPortfGroupFKey,  # should equal group_id
                "strReportPortfName": portfolio_record["strPortfGroupName"],
                "numLTThreshold": 0.0001,
                "str1LevelPortfID": portfolio_record["numPortfSkey"],
                "strPortfName": portfolio_record["strptflongname"],
                "datReportPeriodEndDate": period_date,
            }
            for _, portfolio_record in df_portfolio_records.iterrows()
        ]
        return new_records
    finally:
        session.close()


def compute_scope_alpha_using_aum(
    df_res_alpha,
    df_res_holding,
    df_ma_reporting_data,
    current_date: datetime,
    exclude_ids: list = [1536595, 536294, 536271, 538593],
    max_workers: int = 16,
):
    new_records = []
    rows = df_res_alpha.to_dict("records")
    # df_res_holding["datHoldDATE"] = pd.to_datetime(df_res_holding["datHoldDATE"])

    with concurrent.futures.ProcessPoolExecutor() as executor:
        # Submit tasks concurrently.
        futures = {
            executor.submit(
                compute_scope_alpha_using_aum_single,
                i,
                row,
                df_res_holding,
                df_ma_reporting_data,
                current_date,
                exclude_ids,
            )
            for i, row in enumerate(rows)
        }

        for future in concurrent.futures.as_completed(futures):
            results = future.result()
            if results is not None:
                new_records.extend(results)

    df_new_records = pd.DataFrame(
        new_records,
        columns=[
            "datPeriodLastDay",
            "strReportPeriod",
            "datReportDate",
            "strReportPortfHoldSrc",
            "numReportPortfGroupID",
            "strReportPortfName",
            "numLTThreshold",
            "str1LevelPortfID",
            "strPortfName",
            "datReportPeriodEndDate",
        ],
    )

    if not df_new_records.empty:
        df_new_records.sort_values(by=["numReportPortfGroupID", "strReportPeriod"], inplace=True)
    return df_new_records


def enrich_ma_data(df_ma_dedup):
    # Build the enrichment query using ORM.
    # The query returns:
    #   - numPortfSkey,
    #   - datNavDate,
    #   - numTotalAUM,
    #   - strCurrCode,
    #   - numccyqrateInv.
    session = get_session()
    enrichment_query = (
        session.query(
            DMIRPortfolioLnk.numPortfSkey.label("numPortfSkey"),
            DWGNMaccNav.datNavDate.label("datNavDate"),
            DWGNMaccNav.numTotalAUM.label("numTotalAUM"),
            DMIRBRSCurrencyQuote.strCurrCode.label("strCurrCode"),
            DMIRBRSCurrencyQuote.numccyqrateInv.label("numccyqrateInv"),
        )
        .join(DWGNMaccNav, DWGNMaccNav.numPortfGroupFkey == DMIRPortfolioLnk.numPortfGroupSkey)
        .outerjoin(
            DMIRBRSCurrencyQuote,
            (DWGNMaccNav.numCurrencyID == DMIRBRSCurrencyQuote.numCurrencyID)
            & (DWGNMaccNav.datNavDate == DMIRBRSCurrencyQuote.datccyqDate),
        )
        .filter(DMIRPortfolioLnk.strPortfGroupType.in_(["P"]))
    )

    # Execute the query and convert the result into a DataFrame.
    enrichment_results = get_all_as_df(enrichment_query)
    enrichment_columns = [desc["name"] for desc in enrichment_query.column_descriptions]
    df_enrichment = pd.DataFrame(enrichment_results, columns=enrichment_columns)

    if df_enrichment.empty:
        df_enrichment = pd.DataFrame(columns=enrichment_columns)

    df_ma_dedup["datPeriodLastDay"] = pd.to_datetime(df_ma_dedup["datPeriodLastDay"])

    merged_df = df_ma_dedup.merge(
        df_enrichment,
        how="left",
        left_on=["str1LevelPortfID", "datPeriodLastDay"],
        right_on=["numPortfSkey", "datNavDate"],
        suffixes=("", "_enrich"),
    )

    # Update enrichment columns for rows where strReportPortfHoldSrc equals 'MA'.
    mask = merged_df["strReportPortfHoldSrc"] == "MA"
    merged_df.loc[mask, "datHoldDate"] = merged_df.loc[mask, "datNavDate"]
    merged_df.loc[mask, "strPortfISOCur"] = merged_df.loc[mask, "strCurrCode"]
    merged_df.loc[mask, "numPortfAUM"] = merged_df.loc[mask, "numTotalAUM"]
    merged_df.loc[mask, "numCcyqRateInvPtf"] = merged_df.loc[mask, "numccyqrateInv"]

    # Drop the enrichment helper columns as they are no longer needed.
    merged_df.drop(
        columns=["numPortfSkey", "datNavDate", "numTotalAUM", "numccyqrateInv"],
        inplace=True,
    )

    return merged_df


def get_missing_portfolio_jointure(num_row, row):
    logging.info(num_row)
    session = get_session()
    workaround_query = (
        session.query(
            DMIRAlphaHolding.numPortfFkey.label("numPortfFkey"),
            DMIRAlphaHolding.datHoldDATE.label("datNavDate"),
            func.sum(DMIRAlphaHolding.numHoldValuInPortfCur).label("numTotalAUM"),
            DMIRAlphaHolding.strPortfISOCur.label("strCurrencyIsoCode"),
            DMIRBRSCurrencyQuote.numccyqrateInv.label("numccyqrateInv"),
            DMIRPortfolioLnk.numPortfGroupSkey.label("numReportPortfGroupID"),
        )
        .join(DMIRPortfolioLnk, DMIRPortfolioLnk.numPortfSkey == DMIRAlphaHolding.numPortfFkey)
        .outerjoin(
            DMIRBRSCurrencyQuote,
            (DMIRBRSCurrencyQuote.strCurrCode == DMIRAlphaHolding.strPortfISOCur)
            & (DMIRAlphaHolding.datHoldDATE == DMIRBRSCurrencyQuote.datccyqDate),
        )
        .filter(
            DMIRAlphaHolding.datHoldDATE == row["datPeriodLastDay"],
            DMIRAlphaHolding.numPortfFkey == row["str1LevelPortfID"],
            DMIRPortfolioLnk.numPortfGroupSkey == row["numReportPortfGroupID"],
        )
        .group_by(
            DMIRPortfolioLnk.numPortfGroupSkey,
            DMIRAlphaHolding.numPortfFkey,
            DMIRAlphaHolding.datHoldDATE,
            DMIRAlphaHolding.strPortfISOCur,
            DMIRBRSCurrencyQuote.numccyqrateInv,
        )
    )
    df_workaround = get_all_as_df(workaround_query)
    session.close()
    return df_workaround


def apply_missing_portfolio_workaround(df_ma):
    # Ensure date columns are of datetime type.
    # df_ma["datPeriodLastDay"] = pd.to_datetime(df_ma["datPeriodLastDay"], format="mixed")
    dfs = []

    with concurrent.futures.ProcessPoolExecutor() as executor:
        # Submit tasks concurrently.
        futures = {
            executor.submit(get_missing_portfolio_jointure, i, row) for i, row in df_ma.iterrows()
        }

        for future in concurrent.futures.as_completed(futures):
            df_res = future.result()
            if df_res is not None:
                dfs.append(df_res)

    df_workaround = pd.concat(dfs, ignore_index=True)
    df_workaround = df_workaround[
        [
            "numPortfFkey",
            "datNavDate",
            "numTotalAUM",
            "strCurrencyIsoCode",
            "numccyqrateInv",
            "numReportPortfGroupID",
        ]
    ]
    df_workaround["strPortfFkey"] = df_workaround["numPortfFkey"].astype(str)

    # Identify rows in df_ma_enriched with missing datHoldDate and where the source is 'ALP'.

    mask_missing = (df_ma["datHoldDate"].isnull()) & (df_ma["strReportPortfHoldSrc"] == "ALP")
    df_missing = df_ma[mask_missing].copy()
    normalize_type(df_missing)

    df_merged = df_missing.merge(
        df_workaround,
        how="left",
        left_on=["datPeriodLastDay", "str1LevelPortfID", "numReportPortfGroupID"],
        right_on=["datNavDate", "strPortfFkey", "numReportPortfGroupID"],
        suffixes=("", "_workaround"),
    )

    # For rows with enrichment data available, update the missing fields.
    mask_update = df_merged["datNavDate"].notnull()
    df_merged.loc[mask_update, "datHoldDate"] = df_merged.loc[mask_update, "datNavDate"]
    df_merged.loc[mask_update, "numPortfAUM"] = df_merged.loc[mask_update, "numTotalAUM"]
    df_merged.loc[mask_update, "strPortfISOCur"] = df_merged.loc[mask_update, "strCurrencyIsoCode"]
    df_merged.loc[mask_update, "numCcyqRateInvPtf"] = df_merged.loc[mask_update, "numccyqrateInv"]

    # Drop the extra columns from the merge.
    df_merged.drop(
        columns=[
            "datNavDate",
            "numTotalAUM",
            "strCurrencyIsoCode",
            "numccyqrateInv",
            "numPortfFkey",
            "strPortfFkey",
        ],
        inplace=True,
    )

    # Update the original enriched DataFrame with the values from df_merged.
    df_ma_final = df_ma.copy()
    df_ma_final.loc[mask_missing, :] = df_merged
    return df_ma_final


def build_maccnav_jointure_for_rg_04(row_number, row):
    logging.info(row_number)
    session = get_session()
    enrichment_query = (
        session.query(
            DMIRMaccNav.numPortfGroupFKey.label("group_key"),
            DMIRMaccNav.datNavDate.label("datNavDate"),
            DMIRMaccNav.numTotalAUM.label("numTotalAUM"),
            DMIRBRSCurrencyQuote.strCurrCode.label("strCurrCode"),
            DMIRMaccNav.strPerformanceStatus.label("strPerformanceStatus"),
            DMIRBRSCurrencyQuote.numccyqrateInv.label("numccyqrateInv"),
        )
        .join(
            DMIRBRSCurrencyQuote,
            (DMIRMaccNav.numCurrencyID == DMIRBRSCurrencyQuote.numCurrencyID)
            & (DMIRMaccNav.datNavDate == DMIRBRSCurrencyQuote.datccyqDate),
            isouter=True,
        )
        .filter(
            DMIRMaccNav.datNavDate == row["datPeriodLastDay"].strftime("%Y-%m-%d"),
            DMIRMaccNav.numPortfGroupFKey == row["numReportPortfGroupID"],
        )
    )

    # Execute the query and load the results into a DataFrame.
    df_enrichment = get_all_as_df(enrichment_query)

    session.close()
    return df_enrichment.head(1)


def apply_rg_04(df_ma_data):
    df_enrichment = run_query_in_parallel(
        build_maccnav_jointure_for_rg_04,
        df_ma_data,
        columns=[
            "group_key",
            "datNavDate",
            "numTotalAUM",
            "strCurrCode",
            "strPerformanceStatus",
            "numccyqrateInv",
        ],
        max_workers=64,
    )

    if df_enrichment.empty:
        df_enrichment = pd.DataFrame(
            columns=[
                "group_key",
                "datNavDate",
                "numTotalAUM",
                "strCurrCode",
                "strPerformanceStatus",
                "numccyqrateInv",
            ]
        )

    df_enrichment = df_enrichment.drop_duplicates(subset=["group_key", "datNavDate"], keep="first")
    df_updated = pd.merge(
        df_ma_data,
        df_enrichment,
        how="left",
        left_on=["datPeriodLastDay", "numReportPortfGroupID"],
        right_on=["datNavDate", "group_key"],
        suffixes=("", "_enrich"),
    )

    # Update the desired columns where the enrichment data is available.
    mask = df_updated["datNavDate"].notnull()
    df_updated.loc[mask, "numReportPortfAUM"] = df_updated.loc[mask, "numTotalAUM"]
    df_updated.loc[mask, "strReportPortfISOCur"] = df_updated.loc[mask, "strCurrCode_enrich"]
    df_updated.loc[mask, "strStatusHoldData"] = df_updated.loc[mask, "strPerformanceStatus"]
    df_updated.loc[mask, "numCcyqRateInvRepPtf"] = df_updated.loc[mask, "numccyqrateInv"]

    # Drop enrichment helper columns.
    drop_columns = [
        "group_key",
        "datNavDate",
        "numTotalAUM",
        "strPerformanceStatus",
        "numccyqrateInv",
        "strCurrCode_enrich",
    ]
    df_updated.drop(columns=drop_columns, inplace=True, errors="ignore")

    return df_updated


def filter_ma_data_against_report_request(df_ma_final):
    """
    Filters the enriched MA DataFrame to remove records from 'ALP' that are not present
    in the report requests.

    The allowed portfolio groups are determined from DMIRReportRequest joined with
    DMIRPortfolioLnk where:
      - DMIRPortfolioLnk.strPortfGroupType is in ('A', 'G'), and
      - DMIRReportRequest.strSource equals 'ALP-LT'.

    Rows with a reporting source different from 'ALP' are preserved.

    Parameters:
        df_ma_final (pd.DataFrame): The enriched MA DataFrame to be filtered.
        session: A SQLAlchemy ORM session.

    Returns:
        pd.DataFrame: The filtered MA DataFrame.
    """
    session = get_session()
    # Retrieve allowed group identifiers via the ORM.
    allowed_groups_query = (
        session.query(DMIRPortfolioLnk.numPortfGroupSkey.distinct())
        .select_from(DMIRReportRequest)
        .join(
            DMIRPortfolioLnk,
            DMIRReportRequest.strAladdinPtf == DMIRPortfolioLnk.strPortfGroupDECALOGCode,
        )
        .filter(
            DMIRPortfolioLnk.strPortfGroupType.in_(["A", "G"]),
            DMIRReportRequest.strSource == "ALP-LT",
        )
    )

    allowed_groups = [row[0] for row in allowed_groups_query.all()]
    mask_keep = (df_ma_final["strReportPortfHoldSrc"] != "ALP") | (
        df_ma_final["numReportPortfGroupID"].isin(allowed_groups)
    )

    df_filtered = df_ma_final[mask_keep].copy()
    session.close()
    return df_filtered


def finalize_scope_alpha(df_filtered_ma, audit_id: int, current_date):
    """
    Writes the final filtered MA data into the target DataFrame (df_scope_lt).

    This function replicates the insertion logic of the SQL procedure by:
      - Filtering out rows with null or zero values in critical fields (numPortfAUM, strPortfISOCur),
      - Adding any placeholder or computed columns (for example, 'NA' for strReportPortfGPSCode),
      - Updating audit and modification dates, and
      - Concatenating the valid MA branch data into the target DataFrame.

    Parameters:
        df_filtered_ma (pd.DataFrame): The filtered and enriched MA DataFrame (e.g. after Task 9).
        df_scope_lt (pd.DataFrame): The target DataFrame (initially may be empty).
        audit_id (int): The audit ID to assign to the records.
        current_date: The current date used to set the datReportDate and datLastModifDate.

    Returns:
        pd.DataFrame: The updated target DataFrame including the MA branch data.
    """
    # Filter out invalid rows (simulate SQL WHERE clause)
    df_valid = df_filtered_ma[
        df_filtered_ma["numPortfAUM"].notnull()
        & df_filtered_ma["strReportPortfISOCur"].notnull()
        & (df_filtered_ma["numPortfAUM"] != 0)
    ].copy()

    # Add or update columns as per the SQL insertion:
    # - Set a placeholder value for strReportPortfGPSCode.
    df_valid["strReportPortfGPSCode"] = "NA"
    # - Convert str1LevelPortfID to string (simulating CONVERT(VARCHAR, ...)).
    df_valid["str1LevelPortfID"] = df_valid["str1LevelPortfID"].astype(int)
    # - Update modification date columns.
    df_valid["datLastModifDate"] = current_date
    # - Set the audit ID.
    df_valid["numAuditId"] = audit_id

    df_valid["numPortfExRateInRptPtfCur"] = np.where(
        df_valid["numCcyqRateInvRepPtf"] == 0,
        None,
        df_valid["numCcyqRateInvPtf"] / df_valid["numCcyqRateInvRepPtf"],
    )
    df_valid["numPortfAUMInRptPtfCur"] = np.where(
        df_valid["numCcyqRateInvRepPtf"] == 0,
        None,
        df_valid["numPortfAUM"] * df_valid["numCcyqRateInvPtf"] / df_valid["numCcyqRateInvRepPtf"],
    )

    df_valid["strPortfLevelID"] = (
        "MA_"
        + df_valid["numReportPortfGroupID"].astype(int).astype(str)
        + "_"
        + df_valid["str1LevelPortfID"].astype(float).astype(int).astype(str)
    )
    df_valid.drop(
        columns=[
            "datReportPeriodEndDate",
            "numCcyqRateInvPtf",
            "numCcyqRateInvRepPtf",
            "strCurrCode",
        ],
        inplace=True,
    )
    return df_valid


def build_dmc_reporting_scope(current_date: datetime):
    """
    Constructs DMC reporting records by querying DMIR.tblDMIRReportParam (rp),
    DMIR.tblDMIRReportScope (rs) and DMIR.tblDMIRPortfolio (ptf) using the ORM.
    The query applies the following filters:
      - rp.numLTflag = 1,
      - rp.strAccSrc = 'DMC',
      - rp.strEntityType IN ('F', 'P'),
      - rs.strReportFrequency IN ('Monthly', 'Quarterly', 'Yearly'),
      - rp.strLTcalcMethod IN ('FULL','DELTA'),
      - rs.datReportPostingDate >= current_date,
      - rs.datReportPeriodEndDate < current_date,
      - and two complex conditions to handle the DELTA method:
            ( rp.strLTcalcMethod <> 'DELTA'
              OR rs.strReportFrequency <> 'Quarterly'
              OR NOT EXISTS (subquery1) )
        AND ( rp.strLTcalcMethod <> 'DELTA'
              OR rs.strReportFrequency <> 'Yearly'
              OR NOT EXISTS (subquery2) )

    The subqueries check for the existence of matching DMIR.tblDMIRReportParam records
    (joined with DMIR.tblDMIRReportScope) for which:
      - For the first subquery (Quarterly case): rs.strReportFrequency = 'Monthly'
      - For the second subquery (Yearly case): rs.strReportFrequency IN ('Monthly','Quarterly')
    with matching rp.strPortfGPSCode, rp.strShareGpsCode, and rs.datReportPeriodEndDate.

    Returns:
        A pandas DataFrame with columns:
          - datReportDate,
          - strReportPeriod,
          - strReportPortfHoldSrc,
          - strReportPortfGPSCode,
          - strReportPortfName,
          - numLTThreshold,
          - str1LevelPortfID,
          - strPortfName,
          - datReportPeriodEndDate,
          - flagCalcDate.
    """
    session = get_session()

    # Aliases for clarity
    rp = aliased(DMIRReportParam)
    rs = aliased(DMIRReportScope)
    ptf = aliased(DMIRPortfolio)

    # Simplified CASE for flagCalcDate
    flag_calc = case(
        [
            (and_(rp.strLTcalcMethod == "DELTA", rs.strReportFrequency == "Monthly"), 1),
            (and_(rp.strLTcalcMethod == "DELTA", rs.strReportFrequency == "Quarterly"), 3),
            (and_(rp.strLTcalcMethod == "DELTA", rs.strReportFrequency == "Yearly"), 11),
            (rp.strLTcalcMethod == "FULL", 14),
        ],
        else_=None,
    )

    # Condition 1: for Quarterly condition
    subquery1 = (
        session.query(func.count(1))
        .select_from(DMIRReportParam)
        .join(DMIRReportScope, DMIRReportParam.strReportId == DMIRReportScope.strReportID)
        .filter(
            DMIRReportScope.strReportFrequency == "Monthly",
            DMIRReportParam.numLTflag == 1,
            DMIRReportParam.strPortfGPSCode == rp.strPortfGPSCode,
            DMIRReportParam.strShareGpsCode == rp.strShareGpsCode,
            DMIRReportScope.datReportPeriodEndDate == rs.datReportPeriodEndDate,
        )
        .exists()
    )

    # Condition 2: for Yearly condition
    subquery2 = (
        session.query(func.count(1))
        .select_from(DMIRReportParam)
        .join(DMIRReportScope, DMIRReportParam.strReportId == DMIRReportScope.strReportID)
        .filter(
            DMIRReportScope.strReportFrequency.in_(["Monthly", "Quarterly"]),
            DMIRReportParam.strPortfGPSCode == rp.strPortfGPSCode,
            DMIRReportParam.strShareGpsCode == rp.strShareGpsCode,
            DMIRReportScope.datReportPeriodEndDate == rs.datReportPeriodEndDate,
        )
        .exists()
    )

    query = (
        session.query(
            rs.datReportPostingDate.label("datReportDate"),
            rp.strAccSrc.label("strReportPortfHoldSrc"),
            func.coalesce(rp.strPortfGPSCode, "NA").label("strReportPortfGPSCode"),
            rp.strEntityName.label("strReportPortfName"),
            rp.numLTThreshold.label("numLTThreshold"),
            ptf.strPortfGPSCode.label("str1LevelPortfID"),
            ptf.strPtfName.label("strPortfName"),
            rs.datReportPeriodEndDate.label("datReportPeriodEndDate"),
            flag_calc.label("flagCalcDate"),
        )
        .join(rs, rp.strReportId == rs.strReportID)
        .join(ptf, rp.strPortfGPSCode == ptf.strPortfGPSCode)
        .filter(
            rp.numLTflag == 1,
            rp.strAccSrc == "DMC",
            rp.strEntityType.in_(["F", "P"]),
            rs.strReportFrequency.in_(["Monthly", "Quarterly", "Yearly"]),
            rp.strLTcalcMethod.in_(["FULL", "DELTA"]),
            rs.datReportPostingDate >= current_date,
            rs.datReportPeriodEndDate < current_date,
            or_(rp.strLTcalcMethod != "DELTA", rs.strReportFrequency != "Quarterly", ~subquery1),
            or_(rp.strLTcalcMethod != "DELTA", rs.strReportFrequency != "Yearly", ~subquery2),
        )
    )

    df_dmc_reporting = get_all_as_df(query)
    return df_dmc_reporting, query


def expand_dmc_scope_with_period(task_1_query, current_date: date):
    session = get_session()

    # Use the Task 1 query as a subquery 't'
    subq = task_1_query.subquery("t")
    expanded_query = (
        session.query(
            cast(DWGNPeriod.datPerioddate, String).label("datPeriodLastDay"),
            func.format(DWGNPeriod.datPerioddate, "yyyyMM").label("strReportPeriod"),
            subq.c.datReportDate,
            subq.c.strReportPortfHoldSrc,
            subq.c.strReportPortfGPSCode,
            subq.c.strReportPortfName,
            subq.c.numLTThreshold,
            subq.c.str1LevelPortfID,
            subq.c.strPortfName,
            subq.c.datReportPeriodEndDate,
        )
        .select_from(subq, DWGNPeriod)
        .filter(
            # Build the condition: p.datPerioddate BETWEEN DATEADD(mm, (1 - t.flagCalcDate), t.datReportPeriodEndDate) AND t.datReportPeriodEndDate
            DWGNPeriod.datPerioddate.between(
                func.dateadd(
                    text("MONTH"), (1 - subq.c.flagCalcDate), subq.c.datReportPeriodEndDate
                ),
                subq.c.datReportPeriodEndDate,
            ),
            DWGNPeriod.blnIsmonth == 1,
        )
    )
    df = get_all_as_df(expanded_query)
    return df


def build_dmc_data_scope_1(df_dmc_reporting, task_1_query):
    session = get_session()

    # Use the Task 1 query as a subquery 't'
    subq = task_1_query.subquery("t")
    expanded_query = (
        session.query(
            cast(DWGNPeriod.datPerioddate, String).label("datPeriodLastDay"),
            func.format(DWGNPeriod.datPerioddate, "yyyyMM").label("strReportPeriod"),
            subq.c.datReportDate,
            subq.c.strReportPortfHoldSrc,
            subq.c.strReportPortfGPSCode,
            subq.c.strReportPortfName,
            subq.c.numLTThreshold,
            subq.c.str1LevelPortfID,
            subq.c.strPortfName,
            subq.c.datReportPeriodEndDate,
        )
        .select_from(subq, DWGNPeriod)
        .filter(
            # Build the condition: p.datPerioddate BETWEEN DATEADD(mm, (1 - t.flagCalcDate), t.datReportPeriodEndDate) AND t.datReportPeriodEndDate
            DWGNPeriod.datPerioddate.between(
                func.dateadd(
                    text("MONTH"), (1 - subq.c.flagCalcDate), subq.c.datReportPeriodEndDate
                ),
                subq.c.datReportPeriodEndDate,
            ),
            DWGNPeriod.blnIsmonth == 1,
        )
        .distinct()
    )
    df = get_all_as_df(expanded_query)
    return df


def load_dmc_esg_scope(prev_last_day, excluded_group_ids: list):
    """
    Inserts ESG score rows for DMC funds into the DMC data.

    Returns:
        pd.DataFrame: The updated DMC DataFrame with the inserted ESG score rows.
    """
    session = get_session()
    lower_bound = prev_last_day - relativedelta(months=2)
    print("excluded_group_ids:", excluded_group_ids)

    query = (
        session.query(
            literal(prev_last_day).label("datPeriodLastDay"),
            literal(prev_last_day.strftime("%Y%m")).label("strReportPeriod"),
            literal(prev_last_day).label("datReportDate"),
            literal("DMC").label("strReportPortfHoldSrc"),
            DMIRDMCHolding.strPortfGPSCode.label("strReportPortfGPSCode"),
            DMIRPortfolio.strPtfName.label("strReportPortfName"),
            literal(0.001).label("numLTThreshold"),
            DMIRDMCHolding.strPortfGPSCode.label("str1LevelPortfID"),
            DMIRPortfolio.strPtfName.label("strPortfName"),
            literal(prev_last_day).label("datReportPeriodEndDate"),
        )
        .select_from(DMIRDMCHolding)
        .join(DMIRPortfolio, DMIRDMCHolding.strPortfGPSCode == DMIRPortfolio.strPortfGPSCode)
        .filter(
            DMIRDMCHolding.datACCDATE <= prev_last_day,
            DMIRDMCHolding.datACCDATE >= lower_bound,
            DMIRDMCHolding.strPortfGPSCode.not_in(excluded_group_ids),
        )
        .group_by(DMIRDMCHolding.strPortfGPSCode, DMIRPortfolio.strPtfName)
    )

    query_text = query.statement.compile(compile_kwargs={"literal_binds": True})
    result = session.execute(text(str(query_text)))
    df_esg = pd.DataFrame(result.mappings().all())
    normalize_type(df_esg)
    return df_esg


def calculate_dmc_aum_single(chunk_number, chunk):
    session = get_session()
    if chunk_number % 100 == 0:
        print(f"Processing chunk_number {chunk_number}")

    query_dmc = (
        session.query(
            DMIRTransparizLT.strReportPeriod.label("strReportPeriod"),
            DMIRTransparizLT.datPeriodLastDay.label("datPeriodLastDay"),
            DMIRTransparizLT.strReportPortfGPSCode.label("strReportPortfGPSCode"),
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("LT_AUM"),
        )
        .filter(
            or_(
                *[
                    and_(
                        DMIRTransparizLT.numInstID > 1,
                        DMIRTransparizLT.strReportPeriod == row["strReportPeriod"],
                        DMIRTransparizLT.strReportPortfGPSCode == row["strReportPortfGPSCode"],
                        DMIRTransparizLT.datPeriodLastDay == row["datPeriodLastDay"],
                    )
                    for _, row in chunk.iterrows()
                ]
            )
        )
        .group_by(
            DMIRTransparizLT.strReportPeriod,
            DMIRTransparizLT.datPeriodLastDay,
            DMIRTransparizLT.strReportPortfGPSCode,
        )
        .distinct()
    )

    query_text = query_dmc.statement.compile(compile_kwargs={"literal_binds": True})
    result = session.execute(text(str(query_text)))
    df = pd.DataFrame(result.mappings().all())
    normalize_type(df)
    session.close()
    return df


def calculate_dmc_aum(current_date, max_workers=48):
    session = get_session()
    query_dmc_keys = (
        session.query(
            DMIRTransparizLT.strReportPeriod.label("strReportPeriod"),
            DMIRTransparizLT.strReportPortfGPSCode.label("strReportPortfGPSCode"),
            DMIRTransparizLT.datPeriodLastDay.label("datPeriodLastDay"),
        )
        .filter(
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPeriod >= "202412",
            DMIRTransparizLT.numInstID > 1,
        )
        .distinct()
    )

    dmc_keys = get_all_as_df(query_dmc_keys)
    chunks = np.array_split(dmc_keys, max_workers * 20)

    dfs = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=max_workers) as executor:
        # Submit tasks concurrently.
        futures = {
            executor.submit(calculate_dmc_aum_single, i, chunk): i for i, chunk in enumerate(chunks)
        }

        for future in concurrent.futures.as_completed(futures):
            result = future.result()
            if result is not None:
                dfs.append(result)

    if len(dfs) > 0:
        df_res_dmc = pd.concat(dfs, ignore_index=True)
    else:
        df_res_dmc = pd.DataFrame(
            columns=["strReportPeriod", "datPeriodLastDay", "strReportPortfGPSCode", "LT_AUM"]
        )

    indicator_query = session.query(
        DMIRBRSLTPortfIndicators.strPortfGPSCode.label("strReportPortfGPSCode"),
        DMIRBRSLTPortfIndicators.datPeriodLastDay.label("datPeriodLastDay"),
        DMIRBRSLTPortfIndicators.numAuditId.label("numAuditId"),
    ).filter(DMIRBRSLTPortfIndicators.numAuditId == 999)

    df_indicators = get_all_as_df(indicator_query)

    if df_indicators.empty:
        df_indicators = pd.DataFrame(
            columns=["strReportPortfGPSCode", "datPeriodLastDay", "numAuditId"]
        )

    df_res_dmc = pd.merge(
        df_res_dmc, df_indicators, on=["strReportPortfGPSCode", "datPeriodLastDay"], how="left"
    )

    # print(list(df_res_dmc.values))
    df_res_dmc.loc[df_res_dmc["numAuditId"] == 999, "LT_AUM"] = 100
    df_res_dmc.drop(columns=["numAuditId"], inplace=True)
    return df_res_dmc


def compute_scope_dmc_using_aum_single(chunk_number, dmc_chunk, lower_bound, last_day_prev):
    session = get_session()
    try:
        if chunk_number % 100 == 0:
            logging.info(chunk_number)

        reference = {
            (dmc_row["strReportPortfGPSCode"], dmc_row["datPeriodLastDay"]): {
                "LT_AUM": dmc_row["LT_AUM"],
                "strReportPeriod": dmc_row["strReportPeriod"],
            }
            for _, dmc_row in dmc_chunk.iterrows()
        }
        print(reference.keys())

        agg_records = (
            session.query(DMIRBRSDMCPortfIndicators)
            .filter(
                or_(
                    *[
                        and_(
                            DMIRBRSDMCPortfIndicators.strPortfGPSCode
                            == dmc_row["strReportPortfGPSCode"],
                            DMIRBRSDMCPortfIndicators.datPeriodLastDay
                            == dmc_row["datPeriodLastDay"],
                            DMIRBRSDMCPortfIndicators.datPeriodLastDay >= lower_bound,
                        )
                        for _, dmc_row in dmc_chunk.iterrows()
                    ]
                )
            )
            .all()
        )

        new_recs = []
        for agg_record in agg_records:
            # Check absolute difference condition.
            dmc_row = reference.get(
                (agg_record.strPortfGPSCode, pd.to_datetime(agg_record.datPeriodLastDay))
            )
            lt_aum = dmc_row.get("LT_AUM")
            report_period = dmc_row.get("strReportPeriod")
            if lt_aum is not None and abs(lt_aum - agg_record.numFundAUM) <= 0.5:
                continue

            # Query portfolio information from DMIR.tblDMIRPortfolio.
            portfolio_records = (
                session.query(DMIRPortfolio)
                .filter(DMIRPortfolio.strPortfGPSCode == agg_record.strPortfGPSCode)
                .all()
            )

            # Construct new record.
            new_recs.extend(
                [
                    {
                        "datPeriodLastDay": agg_record.datPeriodLastDay,
                        "strReportPeriod": report_period,
                        "datReportDate": last_day_prev,
                        "strReportPortfHoldSrc": "DMC",
                        "strReportPortfGPSCode": agg_record.strPortfGPSCode,
                        "strReportPortfName": portfolio_record.strPtfName,
                        "numLTThreshold": 0.0001,
                        "str1LevelPortfID": agg_record.strPortfGPSCode,
                        "strPortfName": portfolio_record.strPtfName,
                        "datReportPeriodEndDate": last_day_prev,
                    }
                    for portfolio_record in portfolio_records
                ]
            )
        return new_recs
    finally:
        session.close()


def compute_scope_dmc_using_aum(df_res_dmc: pd.DataFrame, current_date: datetime, max_workers=96):
    """
    Constructs new DMC data records by joining aggregated DMC data (df_res_dmc) with
    Returns:
        A DataFrame containing the constructed DMC data records.
    """
    # Compute the last day of previous month.
    last_day_prev = (current_date.replace(day=1) - timedelta(days=1)).date()

    # Initialize list to hold new records.
    new_records = []

    # Define lower bound: 4 months before current_date.
    lower_bound = current_date - relativedelta(months=4)

    dmc_chunks = np.array_split(df_res_dmc, max_workers * 10)

    with concurrent.futures.ProcessPoolExecutor(max_workers=max_workers) as executor:
        # Submit tasks concurrently.
        futures = {
            executor.submit(
                compute_scope_dmc_using_aum_single,
                i,
                dmc_chunk,
                lower_bound,
                last_day_prev,
            )
            for i, dmc_chunk in enumerate(dmc_chunks)
        }

        for future in concurrent.futures.as_completed(futures):
            results = future.result()
            if results is not None:
                new_records.extend(results)

    df_new_records = pd.DataFrame(
        new_records,
        columns=[
            "datPeriodLastDay",
            "strReportPeriod",
            "datReportDate",
            "strReportPortfHoldSrc",
            "strReportPortfGPSCode",
            "strReportPortfName",
            "numLTThreshold",
            "str1LevelPortfID",
            "strPortfName",
            "datReportPeriodEndDate",
        ],
    )

    if not df_new_records.empty:
        df_new_records.sort_values(by=["strReportPeriod", "strReportPortfGPSCode"], inplace=True)
        df_new_records.reset_index(drop=True, inplace=True)

    df_new_records = df_new_records.drop_duplicates()
    return df_new_records


def compute_scope_dmc_using_monitoring(current_date: datetime):
    session = get_session()
    # Compute datReportPeriodEndDate as the last day of the previous month
    datReportPeriodEndDate = (current_date.replace(day=1) - timedelta(days=1)).date()

    # Query DMIR.tblDMIRMonitoringLT with the required conditions.
    query_lt = (
        session.query(
            DMIRMonitoringLT.strReportPortfGPSCode,
            DMIRMonitoringLT.strPortfName,
            DMIRMonitoringLT.datHoldDate,
            DMIRMonitoringLT.strReportPeriod,
        )
        .filter(
            DMIRMonitoringLT.strReportPeriod >= "202112",
            DMIRMonitoringLT.strTrackUndrlygHoldData == "RED",
            DMIRMonitoringLT.strSrcUndrlygHoldData == "INTERNAL",
            DMIRMonitoringLT.strReportPortfGPSCode != "NA",
        )
        .distinct()
    )

    df_lt = get_all_as_df(query_lt)

    # Ensure datHoldDate is datetime.
    # df_lt["datHoldDate"] = pd.to_datetime(df_lt["datHoldDate"])

    new_records = []
    for _, row in df_lt.iterrows():
        # Compute the last day of the month based on datHoldDate.
        period_last_day = last_day_of_month(row["datHoldDate"])
        report_period = row["strReportPeriod"]

        new_record = {
            "datPeriodLastDay": period_last_day,
            "strReportPeriod": report_period,
            "datReportDate": period_last_day,
            "strReportPortfHoldSrc": "DMC",
            "strReportPortfGPSCode": row["strReportPortfGPSCode"],
            "strReportPortfName": row["strPortfName"],
            "numLTThreshold": 0.0001,
            "str1LevelPortfID": row["strReportPortfGPSCode"],
            "strPortfName": row["strPortfName"],
            "datReportPeriodEndDate": datReportPeriodEndDate,
        }
        new_records.append(new_record)

    df_new = pd.DataFrame(new_records)
    if not df_new.empty:
        df_new.sort_values(by=["strReportPeriod", "strReportPortfGPSCode"], inplace=True)
        df_new.reset_index(drop=True, inplace=True)

    df_new = df_new.drop_duplicates()
    session.close()
    return df_new


def compute_scope_dmc_using_external(current_date: datetime):
    session = get_session()
    # Compute datReportPeriodEndDate as the last day of previous month.
    report_period_end = (current_date.replace(day=1) - timedelta(days=1)).date()
    lower_bound = current_date - relativedelta(months=4)

    # Query DMIR.tblDMIRMonitoringLT for external funds.
    query_lt = (
        session.query(
            DMIRMonitoringLT.strReportPortfGPSCode,
            DMIRMonitoringLT.strPortfName,
            DMIRMonitoringLT.datHoldDate,
            DMIRMonitoringLT.strReportPeriod,
            DMIRMonitoringLT.strInstISINCode,
        )
        .join(
            DMIRExternalSpecialHolding,
            DMIRExternalSpecialHolding.strPortfISINCode == DMIRMonitoringLT.strInstISINCode,
        )
        .filter(
            DMIRMonitoringLT.strReportPeriod >= "202112",
            DMIRMonitoringLT.strTrackUndrlygHoldData == "RED",
            DMIRMonitoringLT.strSrcUndrlygHoldData == "EXTERNAL",
            DMIRMonitoringLT.strReportPortfGPSCode != "NA",
            DMIRExternalSpecialHolding.datHoldDate >= lower_bound,
        )
        .distinct()
    )

    df_lt = get_all_as_df(query_lt)
    print("Monitoring LT", df_lt.shape)
    # Ensure lt.datHoldDate is datetime.
    # df_lt["datHoldDate"] = pd.to_datetime(df_lt["datHoldDate"])

    new_records = []
    for _, lt in df_lt.iterrows():
        if _ % 100 == 0:
            print(_)

        period_last_day = last_day_of_month(lt["datHoldDate"])
        exthold = (
            session.query(DMIRExternalSpecialHolding)
            .filter(
                DMIRExternalSpecialHolding.strPortfISINCode == lt["strInstISINCode"],
                DMIRExternalSpecialHolding.datHoldDate <= period_last_day,
                DMIRExternalSpecialHolding.datHoldDate >= lower_bound,
            )
            .first()
        )
        if exthold is None:
            continue

        # Construct new record.
        new_rec = {
            "datPeriodLastDay": period_last_day,
            "strReportPeriod": lt["strReportPeriod"],
            "datReportDate": report_period_end,
            "strReportPortfHoldSrc": "DMC",
            "strReportPortfGPSCode": lt["strReportPortfGPSCode"],
            "strReportPortfName": lt["strPortfName"],
            "numLTThreshold": 0.0001,
            "str1LevelPortfID": lt["strReportPortfGPSCode"],
            "strPortfName": lt["strPortfName"],
            "datReportPeriodEndDate": report_period_end,
        }
        new_records.append(new_rec)

    df_new = pd.DataFrame(new_records)
    if not df_new.empty:
        df_new.sort_values(by=["strReportPeriod", "strReportPortfGPSCode"], inplace=True)
        df_new.reset_index(drop=True, inplace=True)
    return df_new


def load_dmc_holdings(current_date: datetime):
    # Define row_number window function:
    session = get_session()
    row_number_expr = (
        func.row_number()
        .over(
            partition_by=[
                DMIRDMCVALO.strPortfGPSCode,
                func.format(DMIRDMCHolding.datACCDATE, "yyyyMM"),
            ],
            order_by=[
                DMIRDMCVALO.datDateVL.desc(),
                DMIRDMCVALO.numActifNetTotalOpcVm.desc(),
            ],
        )
        .label("rowNr")
    )

    query = (
        session.query(
            DMIRDMCVALO.strPortfGPSCode.label("strPortfGPSCode"),
            DMIRDMCVALO.datDateVL.label("datDateVL"),
            func.format(DMIRDMCHolding.datACCDATE, "yyyyMM").label("strReportPeriod"),
            DMIRDMCHolding.strPortfISOCur.label("strPortfISOCur"),
            DMIRDMCVALO.numActifNetTotalOpcVm.label("numActifNetTotalOpcVm"),
            row_number_expr,
        )
        .join(
            DMIRDMCHolding,
            and_(
                DMIRDMCVALO.strPortfGPSCode == DMIRDMCHolding.strPortfGPSCode,
                DMIRDMCVALO.datDateVL == DMIRDMCHolding.datACCDATE,
                DMIRDMCVALO.numCurrencyId == DMIRDMCHolding.numPortfCurId,
            ),
        )
        .filter(DMIRDMCVALO.datDateVL >= func.dateadd(text("MONTH"), -6, func.getdate()))
    )

    subq = query.subquery()
    final_query = session.query(
        subq.c.strPortfGPSCode,
        subq.c.datDateVL,
        subq.c.strReportPeriod,
        subq.c.strPortfISOCur,
        subq.c.numActifNetTotalOpcVm,
    ).filter(subq.c.rowNr == 1)

    df_holdings = get_all_as_df(final_query)
    if df_holdings.empty:
        df_holdings = pd.DataFrame(
            columns=[
                "strPortfGPSCode",
                "datDateVL",
                "strReportPeriod",
                "strPortfISOCur",
                "numActifNetTotalOpcVm",
            ]
        )
    session.close()
    return df_holdings


def update_dmc_data_with_holdings(df_dmc_data: pd.DataFrame, df_holdings: pd.DataFrame):
    df_merged = pd.merge(
        df_dmc_data,
        df_holdings,
        left_on=["strReportPeriod", "str1LevelPortfID"],
        right_on=["strReportPeriod", "strPortfGPSCode"],
        how="left",
        suffixes=("", "_dup"),
    )
    mask = df_merged["datDateVL"].notnull()
    df_merged.loc[mask, "datHoldDate"] = df_merged.loc[mask, "datDateVL"]
    df_merged.loc[mask, "numPortfAUM"] = df_merged.loc[mask, "numActifNetTotalOpcVm"]
    df_merged.loc[mask, "strReportPortfISOCur"] = df_merged.loc[mask, "strPortfISOCur"]
    df_merged.drop(
        columns=["strPortfGPSCode", "datDateVL", "numActifNetTotalOpcVm"],
        inplace=True,
        errors="ignore",
    )
    return df_merged


def finalize_dmc_scope(
    df_dmc_dedup: pd.DataFrame,
    audit_id: int,
    current_date: datetime,
):
    # Filter out rows with null numPortfAUM.
    df_valid = df_dmc_dedup[df_dmc_dedup["numPortfAUM"].notnull()]

    # Compute the last day of the previous month.
    last_day_prev = (current_date.replace(day=1) - timedelta(days=1)).date()

    # Update fields per requirements.
    df_valid["datReportDate"] = last_day_prev
    df_valid["numReportPortfAUM"] = df_valid["numPortfAUM"]
    df_valid["numReportPortfGroupID"] = -1
    # Set numPortfExRateInRptPtfCur to 1 if strReportPortfISOCur is not null, else leave as NaN.
    df_valid["numPortfExRateInRptPtfCur"] = df_valid["strReportPortfISOCur"].notnull().astype(int)
    df_valid["numPortfAUMInRptPtfCur"] = df_valid["numPortfAUM"]
    # Construct strPortfLevelID by concatenating strReportPortfHoldSrc, strReportPortfGPSCode, and str1LevelPortfID.
    df_valid["strPortfLevelID"] = (
        df_valid["strReportPortfHoldSrc"].astype(str)
        + "_"
        + df_valid["strReportPortfGPSCode"].astype(str)
        + "_"
        + df_valid["str1LevelPortfID"].astype(str)
    )
    # Set strStatusHoldData, datLastModifDate, and numAuditId.
    df_valid["strStatusHoldData"] = "Validated Data"
    df_valid["datLastModifDate"] = current_date
    df_valid["numAuditId"] = int(audit_id)

    # Reorder columns to match final target structure.
    final_columns = [
        "datReportDate",  # from input (reset to last day of previous month)
        "strReportPeriod",  # unchanged
        "strReportPortfHoldSrc",  # unchanged
        "numReportPortfGroupID",  # set to -1
        "strReportPortfGPSCode",  # unchanged
        "strReportPortfName",  # unchanged
        "numPortfAUM",  # unchanged
        "numReportPortfAUM",
        "strReportPortfISOCur",  # unchanged
        "numLTThreshold",  # unchanged
        "str1LevelPortfID",  # unchanged
        "strPortfName",  # unchanged
        "strPortfISOCur",
        "datHoldDate",  # unchanged
        "numPortfExRateInRptPtfCur",  # computed: 1 if strReportPortfISOCur not null
        "numPortfAUMInRptPtfCur",  # computed: equal to numPortfAUM
        "strPortfLevelID",  # computed concatenation
        "strStatusHoldData",  # literal "Validated Data"
        "datLastModifDate",  # set to current_date
        "datPeriodLastDay",  # unchanged
        "numAuditId",  # given audit_id
    ]

    # Select only those columns that exist in df_valid.
    df_final = df_valid[[col for col in final_columns if col in df_valid.columns]]
    df_final.sort_values(by=["numReportPortfGroupID", "strReportPeriod"], inplace=True)
    df_final.reset_index(drop=True, inplace=True)
    return df_final


def insert_scopes_into_final_table(df_final):
    session = get_session()
    df_final = df_final.drop_duplicates(subset=["strReportPeriod", "strPortfLevelID"])
    mappings = df_final.to_dict(orient="records")
    for m in mappings:
        for k, v in m.items():
            if pd.isna(v):
                m[k] = None
    session.query(DMIRScopeLT).delete()
    session.bulk_insert_mappings(DMIRScopeLT, mappings)
    session.commit()


def _within_eu_window(ts: datetime) -> bool:
    """True if  (hour>1 & BD>5)  OR  (hour>10 & BD<=5)."""
    d, h = ts.day, ts.hour
    return (h > 1 and d > 5) or (h > 10 and d <= 5)


def _delete_scope_ma() -> int:
    session = get_session()
    try:
        count = (
            session.query(DMIRScopeLT)
            .filter(DMIRScopeLT.strReportPortfHoldSrc == "MA")
            .delete(synchronize_session=False)
        )
        session.commit()
        return count
    finally:
        session.close()


def _delete_pairs_scope_lt(session: Session, src: str, keycol: str, pairs: list[tuple]) -> int:
    total = 0
    for key, period in pairs:
        print(f"Deleting pair ({src}, {key}, {period})")
        total += (
            session.query(DMIRScopeLT)
            .filter(
                DMIRScopeLT.strReportPortfHoldSrc == src,
                getattr(DMIRScopeLT, keycol) == key,
                DMIRScopeLT.strReportPeriod == period,
            )
            .delete(synchronize_session=False)
        )
    session.commit()
    return total


# ---------------------------------------------------------------------------
# Block 2  - DMC  (#to_remove)
# ---------------------------------------------------------------------------


def _eom_prev_month(d: date) -> date:
    """Return the last calendar day of the previous month."""
    first_of_month = d.replace(day=1)
    return first_of_month - timedelta(days=1)


def _yyyymm(d: date) -> str:
    """Return YYYYMM string for a date."""
    return d.strftime("%Y%m")


def compute_exempt(current_date):
    current_date = current_date or date.today()
    eom_prev = _eom_prev_month(current_date)
    session = get_session()
    try:
        audit_subq = (
            session.query(
                DMIRDMCHolding.strPortfGPSCode.label("gps"),
                func.max(DMIRDMCHolding.numAuditId).label("holdings_audit_id"),
            )
            .join(
                DMIRBRSDMCPortfIndicators,
                and_(
                    DMIRBRSDMCPortfIndicators.strPortfGPSCode == DMIRDMCHolding.strPortfGPSCode,
                    DMIRBRSDMCPortfIndicators.datPeriodLastNav == DMIRDMCHolding.datACCDATE,
                ),
            )
            .filter(DMIRBRSDMCPortfIndicators.datPeriodLastDay == eom_prev)
            .group_by(DMIRDMCHolding.strPortfGPSCode)
            .subquery()
        )

        gps_do_not_delete = get_all_as_df(
            session.query(DMIRTransparizLT.strReportPortfGPSCode)
            .join(
                audit_subq,
                audit_subq.c.gps == DMIRTransparizLT.strPortfID,
            )
            .filter(
                DMIRTransparizLT.datPeriodLastDay == eom_prev,
                DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
                audit_subq.c.holdings_audit_id > DMIRTransparizLT.numAuditId,
            )
            .distinct()
        )["strReportPortfGPSCode"].tolist()

        return gps_do_not_delete
    finally:
        session.close()


def _build_df_to_remove_dmc(gps_do_not_delete, current_date: date | None = None) -> pd.DataFrame:
    """
    Build the set of (GPS, period) pairs that *should* be removed from
    DMIR.tblDMIRScopeLT for the DMC data-source, faithfully reproducing the
    logic in the latest SQL procedure.

    Returns
    -------
    pd.DataFrame
        Columns -> num_transp, num_scope, gps, period
        (empty if nothing qualifies).
    """
    current_date = current_date or date.today()
    eom_prev = _eom_prev_month(current_date)
    prev_report_period = _yyyymm(eom_prev)

    session = get_session()
    try:
        # ----------------------------------------------------------
        # 1)  first cut  - rows where TRANSPARIZ AUM ≈ Scope AUM ----
        # ----------------------------------------------------------
        agg_q = (
            session.query(
                func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
                DMIRScopeLT.numReportPortfAUM.label("num_scope"),
                DMIRScopeLT.strReportPortfGPSCode.label("gps"),
                DMIRScopeLT.strReportPeriod.label("period"),
            )
            .select_from(DMIRScopeLT)
            .join(
                DMIRTransparizLT,
                and_(
                    DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
                    DMIRTransparizLT.strReportPortfGPSCode == DMIRScopeLT.strReportPortfGPSCode,
                ),
            )
            .filter(
                DMIRScopeLT.strReportPortfHoldSrc == "DMC",
                DMIRTransparizLT.numLowestInventoryflag == 1,
                DMIRTransparizLT.numInstID > 1,
            )
            .group_by(
                DMIRScopeLT.numReportPortfAUM,
                DMIRScopeLT.strReportPortfGPSCode,
                DMIRScopeLT.strReportPeriod,
            )
        )

        df = pd.DataFrame(session.execute(agg_q).mappings().all())
        normalize_type(df)

        if df.empty:
            return pd.DataFrame(columns=["num_transp", "num_scope", "gps", "period"])

        # AUM-difference tolerance
        df = df[(df["num_transp"] - df["num_scope"]).abs() <= 0.05]

        # ----------------------------------------------------------
        # 2)  pairs having INST-ID  =  -1  → exclude ----------------
        # ----------------------------------------------------------
        bad_pairs = get_all_as_df(
            session.query(
                DMIRTransparizLT.strReportPortfGPSCode,
                DMIRTransparizLT.strReportPeriod,
            )
            .filter(
                DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
                DMIRTransparizLT.numInstID == -1,
            )
            .distinct()
        )
        exclude_missing_instid = set(bad_pairs.apply(tuple, axis=1))

        if not df.empty:
            df = df[~df.apply(lambda r: (r["gps"], r["period"]) in exclude_missing_instid, axis=1)]

        # ----------------------------------------------------------
        # 3)  do-not-delete list for the *latest* month ------------
        # ----------------------------------------------------------

        if not df.empty:
            df = df[~((df["period"] == prev_report_period) | (df["gps"].isin(gps_do_not_delete)))]

        # ----------------------------------------------------------
        # 4)  external / special data safeguard -------------------
        # ----------------------------------------------------------
        ext_pairs_q = (
            session.query(
                DMIRMonitoringLT.strReportPortfGPSCode.label("gps"),
                DMIRMonitoringLT.strReportPeriod.label("period"),
            )
            .filter(
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_(["EXTERNAL", "SPECIAL"]),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .join(
                DMIRExternalSpecialHolding,
                and_(
                    DMIRExternalSpecialHolding.strPortfISINCode == DMIRMonitoringLT.strInstISINCode,
                    DMIRExternalSpecialHolding.datHoldDate
                    >= func.coalesce(DMIRMonitoringLT.datLastNAVDate, date(2000, 1, 1)),
                    DMIRExternalSpecialHolding.datHoldDate <= DMIRMonitoringLT.datHoldDate,
                    DMIRExternalSpecialHolding.numAuditId > DMIRMonitoringLT.numAuditId,
                ),
            )
            .distinct()
        )

        ext_pairs = set(get_all_as_df(ext_pairs_q).apply(tuple, axis=1))
        df = df[~df.apply(lambda r: (r["gps"], r["period"]) in ext_pairs, axis=1)]

        # ----------------------------------------------------------
        # 5)  done -------------------------------------------------
        # ----------------------------------------------------------
        return (
            df[["num_transp", "num_scope", "gps", "period"]]
            if not df.empty
            else pd.DataFrame(columns=["num_transp", "num_scope", "gps", "period"])
        )

    finally:
        session.close()


def _apply_delete_dmc(df: pd.DataFrame) -> int:
    session = get_session()
    try:
        return _delete_pairs_scope_lt(
            session, "DMC", "strReportPortfGPSCode", df[["gps", "period"]].values.tolist()
        )
    finally:
        session.close()


# ---------------------------------------------------------------------------
# Block 3  - ALP  (#to_remove2)
# ---------------------------------------------------------------------------


def _build_df_to_remove_alp(current_date: date | None = None) -> pd.DataFrame:
    """
    Return the list of ALP Scope-LT rows (numReportPortfGroupID, period)
    that should be deleted, reproducing the full logic of the `#to_remove2`
    temp-table block in the SQL procedure.

    Parameters
    ----------
    current_date : date, optional
        The `@varCurrentDate` value from the SQL.  Defaults to today.

    Returns
    -------
    pd.DataFrame  with columns  [num_transp, num_scope, grp, period]
    """
    current_date = current_date or date.today()
    eom_prev = _eom_prev_month(current_date)
    prev_period = _yyyymm(eom_prev)

    session = get_session()
    try:
        # ----------------------------------------------------------
        # 1) total Scope AUM per (period, group) -------------------
        # ----------------------------------------------------------
        scope_sum = (
            session.query(
                DMIRScopeLT.strReportPeriod.label("period"),
                DMIRScopeLT.numReportPortfGroupID.label("grp"),
                func.sum(DMIRScopeLT.numPortfAUM).label("num_scope"),
            )
            .filter(DMIRScopeLT.strReportPortfHoldSrc == "ALP")
            .group_by(DMIRScopeLT.strReportPeriod, DMIRScopeLT.numReportPortfGroupID)
            .subquery()
        )

        # ----------------------------------------------------------
        # 2) transparized AUM for same (period, group) -------------
        # ----------------------------------------------------------
        agg_q = (
            session.query(
                func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
                scope_sum.c.num_scope,
                scope_sum.c.grp,
                scope_sum.c.period,
            )
            .join(
                scope_sum,
                and_(
                    DMIRTransparizLT.strReportPeriod == scope_sum.c.period,
                    DMIRTransparizLT.numReportPortfGroupID == scope_sum.c.grp,
                ),
            )
            .filter(
                DMIRTransparizLT.numLowestInventoryflag == 1,
                DMIRTransparizLT.numInstID > 1,
            )
            .group_by(scope_sum.c.num_scope, scope_sum.c.grp, scope_sum.c.period)
        )

        df = pd.DataFrame(session.execute(agg_q).mappings().all())
        normalize_type(df)

        if df.empty:
            return pd.DataFrame(columns=["num_transp", "num_scope", "grp", "period"])

        # AUM-difference tolerance
        df = df[(df["num_transp"] - df["num_scope"]).abs() <= 0.05]

        # ----------------------------------------------------------
        # 3) EXTERNAL / SPECIAL underlying-holdings safeguard ------
        # ----------------------------------------------------------
        ext_pairs_q = (
            session.query(
                DMIRMonitoringLT.numReportPortfGroupID.label("grp"),
                DMIRMonitoringLT.strReportPeriod.label("period"),
            )
            .filter(
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_(["EXTERNAL", "SPECIAL"]),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .join(
                DMIRExternalSpecialHolding,
                and_(
                    DMIRExternalSpecialHolding.strPortfISINCode == DMIRMonitoringLT.strInstISINCode,
                    DMIRExternalSpecialHolding.datHoldDate
                    >= func.coalesce(DMIRMonitoringLT.datLastNAVDate, date(2000, 1, 1)),
                    DMIRExternalSpecialHolding.datHoldDate <= DMIRMonitoringLT.datHoldDate,
                    DMIRExternalSpecialHolding.numAuditId > DMIRMonitoringLT.numAuditId,
                ),
            )
            .distinct()
        )
        ext_pairs = set(get_all_as_df(ext_pairs_q).apply(tuple, axis=1))

        if not df.empty:
            df = df[~df.apply(lambda r: (r["grp"], r["period"]) in ext_pairs, axis=1)]

        # ----------------------------------------------------------
        # 4) groups with fresher DMC holdings  → do-not-delete -----
        #    (SQL CTE portfGroupDoNotDelete) -----------------------
        # ----------------------------------------------------------
        # 4a)  holdings-audit id per GPS code (same logic as DMC part)
        audit_subq = (
            session.query(
                DMIRDMCHolding.strPortfGPSCode.label("gps"),
                func.max(DMIRDMCHolding.numAuditId).label("holdings_audit_id"),
            )
            .join(
                DMIRBRSDMCPortfIndicators,
                and_(
                    DMIRBRSDMCPortfIndicators.strPortfGPSCode == DMIRDMCHolding.strPortfGPSCode,
                    DMIRBRSDMCPortfIndicators.datPeriodLastNav == DMIRDMCHolding.datACCDATE,
                ),
            )
            .filter(DMIRBRSDMCPortfIndicators.datPeriodLastDay == eom_prev)
            .group_by(DMIRDMCHolding.strPortfGPSCode)
            .subquery()
        )

        # 4b)  exempt group IDs
        gps_exempt = get_all_as_df(
            session.query(DMIRMonitoringLT.numReportPortfGroupID)
            .join(
                audit_subq,
                audit_subq.c.gps == DMIRMonitoringLT.strInvestedInPortfID,
            )
            .filter(
                DMIRMonitoringLT.datPeriodLastDay == eom_prev,
                DMIRMonitoringLT.strSrcUndrlygHoldData == "INTERNAL",
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.numPortfLevel >= 1,
                audit_subq.c.holdings_audit_id > DMIRMonitoringLT.numAuditId,
            )
            .distinct()
        )["numReportPortfGroupID"].tolist()

        if not df.empty:
            df = df[~((df["period"] == prev_period) & (df["grp"].isin(gps_exempt)))]

        # ----------------------------------------------------------
        # 5) groups with newer MACC-NAV audit-id -------------------
        # ----------------------------------------------------------
        nav_pairs_q = (
            session.query(DMIRMaccNav.numPortfGroupFKey.label("grp"))
            .outerjoin(
                DMIRBRSLTPortfIndicators,
                and_(
                    DMIRBRSLTPortfIndicators.datPeriodLastDay == DMIRMaccNav.datNavDate,
                    DMIRBRSLTPortfIndicators.numPortfGroupFkey == DMIRMaccNav.numPortfGroupFKey,
                ),
            )
            .filter(
                DMIRMaccNav.datNavDate == eom_prev,
                DMIRMaccNav.numAuditId > func.coalesce(DMIRBRSLTPortfIndicators.numAuditId, 0),
                DMIRMaccNav.numTotalAUM != 0,
                DMIRMaccNav.strPerformanceStatus.in_(["Validated Data", "Preliminary Data"]),
            )
            .distinct()
        )
        nav_exclude = {t[0] for t in session.execute(nav_pairs_q).all()}
        if not df.empty:
            df = df[~df["grp"].isin(nav_exclude)]

        # ----------------------------------------------------------
        # 6) done --------------------------------------------------
        # ----------------------------------------------------------
        return (
            df[["num_transp", "num_scope", "grp", "period"]]
            if not df.empty
            else pd.DataFrame(columns=["num_transp", "num_scope", "grp", "period"])
        )

    finally:
        session.close()


def _apply_delete_alp(df: pd.DataFrame) -> int:
    session = get_session()
    try:
        return _delete_pairs_scope_lt(
            session, "ALP", "numReportPortfGroupID", df[["grp", "period"]].values.tolist()
        )
    finally:
        session.close()


# ---------------------------------------------------------------------------
# Block 4  - ESG  (#to_remove3)
# ---------------------------------------------------------------------------


def _build_df_to_remove_esg(gps_do_not_delete) -> pd.DataFrame:
    session = get_session()
    try:
        agg = (
            session.query(
                func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
                DMIRScopeLT.numReportPortfAUM.label("num_scope"),
                DMIRScopeLT.strReportPortfGPSCode.label("gps"),
                DMIRScopeLT.strReportPeriod.label("period"),
            )
            .filter(
                DMIRScopeLT.strReportPortfHoldSrc == "DMC",
                DMIRScopeLT.strReportPortfName == "DMC NAME ESG SCORES",
                DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
                DMIRTransparizLT.strReportPortfGPSCode == DMIRScopeLT.strReportPortfGPSCode,
                DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
                DMIRTransparizLT.numLowestInventoryflag == 1,
                DMIRTransparizLT.numInstID > 1,
            )
            .group_by(
                DMIRScopeLT.numReportPortfAUM,
                DMIRScopeLT.strReportPortfGPSCode,
                DMIRScopeLT.strReportPeriod,
            )
        )
        df = get_all_as_df(agg)
        if df.empty:
            return pd.DataFrame(columns=["num_transp", "num_scope", "gps", "period"])
        df = df[(df["num_transp"] - df["num_scope"]).abs() <= 0.05]

        recent_prefix = (datetime.now() - relativedelta(months=1)).strftime("%Y%m")

        if not df.empty:
            mask_exempt = df["period"].str.startswith(recent_prefix) & df["gps"].isin(
                gps_do_not_delete
            )
            df = df[~mask_exempt]
        if df.empty:
            df = pd.DataFrame(columns=["num_transp", "num_scope", "gps", "period"])
        return df
    finally:
        session.close()


def _apply_delete_esg(df: pd.DataFrame) -> int:
    session = get_session()
    try:
        return _delete_pairs_scope_lt(
            session,
            "DMC",
            "strReportPortfGPSCode",
            df[["gps", "period"]].values.tolist(),
        )
    finally:
        session.close()


# ---------------------------------------------------------------------------
# Block 5  - Threshold harmonisation
# ---------------------------------------------------------------------------


def harmonise_thresholds() -> None:
    """
    Re-apply LT-thresholds to Scope LT, mirroring the three UPDATE blocks in
    the SQL procedure:

      • one for ALP   (match on numReportPortfGroupID)
      • one for DMC   (match on strReportPortfGPSCode)
      • set floor at 1e-8 when 0
      • cap everything above 0.0001
    """
    session = get_session()
    try:
        # ------------------------------------------------------------------
        # 1)  build the #tresh equivalent  ----------------------------------
        # ------------------------------------------------------------------
        tresh = (
            session.query(
                func.min(DMIRReportParam.numLTThreshold).label("thr"),
                DMIRReportParam.strAccSrc.label("acc_src"),
                DMIRReportParam.numPortfGroupfKey.label("grp_key"),
                DMIRReportParam.strPortfGPSCode.label("gps"),
            )
            .filter(DMIRReportParam.numLTflag == 1)
            .group_by(
                DMIRReportParam.strAccSrc,
                DMIRReportParam.numPortfGroupfKey,
                DMIRReportParam.strPortfGPSCode,
            )
        ).subquery()

        # ------------------------------------------------------------------
        # 2)  ALP  ----------------------------------------------------------
        # ------------------------------------------------------------------
        alp_rows = session.execute(
            select(tresh.c.grp_key, tresh.c.thr).where(tresh.c.acc_src == "ALP")
        ).all()

        for grp_key, thr in alp_rows:
            session.query(DMIRScopeLT).filter(
                DMIRScopeLT.strReportPortfHoldSrc == "ALP",
                DMIRScopeLT.numReportPortfGroupID == grp_key,
            ).update({DMIRScopeLT.numLTThreshold: thr}, synchronize_session=False)

        # ------------------------------------------------------------------
        # 3)  DMC  ----------------------------------------------------------
        # ------------------------------------------------------------------
        alp_rows = session.execute(
            select(tresh.c.gps, tresh.c.thr).where(tresh.c.acc_src == "DMC")
        ).all()

        for gps, thr in alp_rows:
            session.query(DMIRScopeLT).filter(
                DMIRScopeLT.strReportPortfHoldSrc == "DMC",
                DMIRScopeLT.strReportPortfGPSCode == gps,
            ).update({DMIRScopeLT.numLTThreshold: thr}, synchronize_session=False)

        # ------------------------------------------------------------------
        # 4)  floor & cap  --------------------------------------------------
        # ------------------------------------------------------------------
        session.query(DMIRScopeLT).filter(DMIRScopeLT.numLTThreshold == 0).update(
            {DMIRScopeLT.numLTThreshold: 1e-8}, synchronize_session=False
        )
        session.query(DMIRScopeLT).filter(DMIRScopeLT.numLTThreshold > 0.0001).update(
            {DMIRScopeLT.numLTThreshold: 0.0001}, synchronize_session=False
        )

        session.commit()
    finally:
        session.close()


def refresh_scope_for_updated_holdings(
    current_date: datetime,
    holdings: pd.DataFrame,
    audit_id: int = 0,
) -> None:
    """
    Re-insert DMC Scope LT rows when holdings (tblDMIRDMCHolding) have a newer
    audit-id than the Monitoring-LT snapshot  - faithful to the SQL temp-table
    block that ends with the INSERT … INTO tblDMIRScopeLT.
    """
    session = get_session()
    try:
        # ------------------------------------------------------------------
        # constants ---------------------------------------------------------
        # ------------------------------------------------------------------
        four_months_back = current_date - relativedelta(months=4)
        last_month_end = (current_date.replace(day=1) - timedelta(days=1)).date()

        # ------------------------------------------------------------------
        # 1)  #dmc   - relevant holdings in the last 4 months ----------------
        # ------------------------------------------------------------------
        dmc_sub = (
            session.query(
                DMIRDMCHolding.strPortfGPSCode.label("gps"),
                DMIRDMCHolding.datACCDATE.label("acc_date"),
                DMIRDMCHolding.numAuditId.label("hold_audit"),
            ).filter(DMIRDMCHolding.datACCDATE >= four_months_back.date())
        ).subquery()

        # ------------------------------------------------------------------
        # 2)  monitoring rows that have an OLDER audit-id than the holding --
        #     and match on Invested-In GPS + NAV date -----------------------
        # ------------------------------------------------------------------
        cand_q = (
            session.query(
                DMIRMonitoringLT.strReportPortfGPSCode.label("report_gps"),
                DMIRMonitoringLT.strPortfName,
                DMIRMonitoringLT.strReportPeriod,
                DMIRMonitoringLT.datHoldDate,
                DMIRMonitoringLT.strPortfISOCur,
                # DMIRMonitoringLT.numPortfAUM,
                DMIRMonitoringLT.strReportPortfGPSCode.label("str1LevelPortfID"),
                dmc_sub.c.hold_audit,
            )
            .join(
                dmc_sub,
                and_(
                    DMIRMonitoringLT.strInvestedInPortfID == dmc_sub.c.gps,
                    DMIRMonitoringLT.datLastNAVDate == dmc_sub.c.acc_date,
                    DMIRMonitoringLT.numAuditId < dmc_sub.c.hold_audit,
                ),
            )
            .filter(
                DMIRMonitoringLT.numPortfLevel == 1,
                DMIRMonitoringLT.strReportPortfGPSCode != "NA",
            )
            .distinct()
            .order_by(DMIRMonitoringLT.strReportPeriod.asc())
        )

        df = get_all_as_df(cand_q)
        if df.empty:
            return

        # ------------------------------------------------------------------
        # 3)  enrich with holdings data (AUM, currency …) -------------------
        # ------------------------------------------------------------------
        if not holdings.empty:
            df = update_dmc_data_with_holdings(df, holdings)
        else:
            df["strPortfISOCur"] = None
            df["numPortfAUM"] = None

        # ------------------------------------------------------------------
        # 4)  remove duplicates already present in Scope LT -----------------
        # ------------------------------------------------------------------
        already = get_all_as_df(
            session.query(
                DMIRScopeLT.strReportPortfGPSCode,
                DMIRScopeLT.strReportPeriod,
            )
            .filter(DMIRScopeLT.strReportPortfHoldSrc == "DMC")
            .distinct()
        )
        already = {
            (r["strReportPortfGPSCode"], r["strReportPeriod"]) for _, r in already.iterrows()
        }

        df = df[~df.apply(lambda r: (r["report_gps"], r["strReportPeriod"]) in already, axis=1)]
        df = df.drop_duplicates(subset=["report_gps", "strReportPeriod"])
        df = df.head(350)

        # ------------------------------------------------------------------
        # 5)  final transform → DMIRScopeLT objects -------------------------
        # ------------------------------------------------------------------
        def end_of_month(d: date) -> date:
            first = d.replace(day=1)
            return first + relativedelta(months=1) - timedelta(days=1)

        rows = []
        for r in df.itertuples(index=False):
            period_end = end_of_month(r.datHoldDate)
            if (str(r.report_gps), str(r.strReportPeriod)) not in already:
                rows.append(
                    DMIRScopeLT(
                        datReportDate=period_end,
                        strReportPeriod=r.strReportPeriod,
                        strReportPortfHoldSrc="DMC",
                        numReportPortfGroupID=-1,
                        strReportPortfGPSCode=r.report_gps,
                        strReportPortfName=r.strPortfName,
                        numReportPortfAUM=r.numPortfAUM,
                        strReportPortfISOCur=r.strPortfISOCur,
                        numLTThreshold=0.0001,  # always 0.0001 after cap
                        str1LevelPortfID=r.str1LevelPortfID,
                        strPortfName=r.strPortfName,
                        strPortfISOCur=r.strPortfISOCur,
                        numPortfAUM=r.numPortfAUM,
                        datHoldDate=r.datHoldDate,
                        numPortfExRateInRptPtfCur=1,
                        numPortfAUMInRptPtfCur=r.numPortfAUM,
                        strPortfLevelID=f"DMC_{r.report_gps}_{r.str1LevelPortfID}",
                        strStatusHoldData="Validated Data",
                        datLastModifDate=current_date,
                        datPeriodLastDay=last_month_end,
                        numAuditId=audit_id,
                    )
                )

        session.bulk_save_objects(rows)
        session.commit()
        logging.info("Inserted %d refreshed DMC scope rows", len(rows))

    finally:
        session.close()


def retrieve_final_scope():
    session = get_session()
    query = session.query(
        DMIRScopeLT.datReportDate,
        DMIRScopeLT.strReportPeriod,
        DMIRScopeLT.strReportPortfHoldSrc,
        DMIRScopeLT.strReportPortfGPSCode,
        DMIRScopeLT.numReportPortfGroupID,
        DMIRScopeLT.strReportPortfName,
        DMIRScopeLT.numReportPortfAUM,
        DMIRScopeLT.strReportPortfISOCur,
        DMIRScopeLT.numLTThreshold,
        DMIRScopeLT.str1LevelPortfID,
        DMIRScopeLT.strPortfName,
        DMIRScopeLT.strPortfISOCur,
        DMIRScopeLT.numPortfAUM,
        DMIRScopeLT.datHoldDate,
        DMIRScopeLT.numPortfExRateInRptPtfCur,
        DMIRScopeLT.numPortfAUMInRptPtfCur,
        DMIRScopeLT.strPortfLevelID,
        DMIRScopeLT.strStatusHoldData,
        DMIRScopeLT.datPeriodLastDay,
    )
    df = get_all_as_df(query)
    session.close()
    return df


def reduce_scope_and_cleanup(df_dmc_holdings, audit_id) -> None:
    # For testing: 0:00:05 AM today
    now = datetime.now().replace(hour=0, minute=0, second=5, microsecond=0)
    
    session = get_session()
    try:
        with session.begin():
            # Only perform major cleanup operations within EU window
            if _within_eu_window(now):
                logging.info("Within EU window - performing full scope cleanup")
                
                print("1. Delete scope MA")
                # MA purge
                _delete_scope_ma()

                print("2. #doNotDelete")
                gps_do_not_delete = compute_exempt(current_date=now)

                # DMC
                print("3. Delete DMC")
                _apply_delete_dmc(
                    _build_df_to_remove_dmc(gps_do_not_delete),
                )

                # ALP
                print("4. Delete ALP")
                _apply_delete_alp(_build_df_to_remove_alp())
            else:
                logging.info("Outside EU window - skipping major cleanup operations")
                gps_do_not_delete = compute_exempt(current_date=now)

            # These operations always happen regardless of EU window
            # ESG
            print("5. Delete ESG")
            _apply_delete_esg(_build_df_to_remove_esg(gps_do_not_delete))

            # thresholds
            print("6. Harmonise threshold")
            harmonise_thresholds()

            print("7. Refresh scope")
            refresh_scope_for_updated_holdings(datetime.now(), df_dmc_holdings, audit_id)

            return retrieve_final_scope()
    finally:
        session.close()
