def extract_derivative_positions(df_scope: pd.DataFrame) -> pd.DataFrame:
    """
    Python port of the #investmentpos_sq block:
      SELECT max(datPosDt) AS posDt, strInstrmtCd, strProdCd, datPeriodLastDay, strPortfGPSCode
      FROM DWGN.tblDWGNInvestmentPositions, #ScopePortf
      WHERE ...
      GROUP BY ...
    """
    if df_scope.empty:
        return pd.DataFrame(
            columns=[
                "posDt",
                "strInstrmtCd",
                "strProdCd",
                "datPeriodLastDay",
                "strPortfGPSCode",
            ]
        )

    session = get_session()
    try:
        # Build an in-line VALUES table for the scope pairs
        scope_pairs = (
            df_scope[["datPeriodLastDay", "strPortfGPSCode"]]
            .drop_duplicates()
            .assign(datPeriodLastDay=lambda d: pd.to_datetime(d["datPeriodLastDay"]).dt.date)
        )

        # SQLAlchemy VALUES constructor
        v = values(
            column("datPeriodLastDay", DWGNInvestmentPositions.datPosDt.type),
            column("strPortfGPSCode", DWGNInvestmentPositions.strProdCd.type),
            name="scope_pairs",
        ).data(list(scope_pairs.itertuples(index=False, name=None))).alias("sp")

        ip = DWGNInvestmentPositions.__table__.alias("ip")

        instrument_types = [
            "FUTURE_INDEX",
            "OPTION_EQUITY",
            "OPTION_FUTURE",
            "OPTION_CUROTC",
            "FUTURE_FIN",
            "OPTION_FUTURE",  # duplicated in the SQL; harmless
            "SWAP_TRSWAP",
            "SWAP_SWAP",
        ]

        stmt = (
            select(
                func.max(ip.c.datPosDt).label("posDt"),
                ip.c.strInstrmtCd,
                ip.c.strProdCd,
                v.c.datPeriodLastDay,
                v.c.strPortfGPSCode,
            )
            .select_from(ip.join(
                v,
                and_(
                    ip.c.strProdCd == v.c.strPortfGPSCode,
                    ip.c.datPosDt <= v.c.datPeriodLastDay,
                    ip.c.datPosDt > v.c.datPeriodLastDay - text("7"),  # 7 days back
                ),
            ))
            .where(ip.c.strInstrmtTypCd.in_(instrument_types))
            .group_by(
                ip.c.strInstrmtCd,
                ip.c.strProdCd,
                v.c.datPeriodLastDay,
                v.c.strPortfGPSCode,
            )
        )

        df_investmentpos_sq = get_all_as_df(session.execute(stmt))
        if df_investmentpos_sq.empty:
            return pd.DataFrame(
                columns=[
                    "posDt",
                    "strInstrmtCd",
                    "strProdCd",
                    "datPeriodLastDay",
                    "strPortfGPSCode",
                ]
            )
        return df_investmentpos_sq

    finally:
        session.close()
