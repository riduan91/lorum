from sqlalchemy import MetaData, Table, and_, column, values, select

def _reflect_table(session: Session, schema: str, name: str) -> Table:
    md = MetaData()
    return Table(name, md, schema=schema, autoload_with=session.bind)

def enrich_external_with_nav(session: Session, df_ext_agg: pd.DataFrame) -> pd.DataFrame:
    """
    SQL parity for:
      - #tempres (max datACCDate <= agg.datHoldDate per (ISIN, period))
      - #tmpInvestedInPortfExternal (bring back row at that max date)
    Produces: numInvestedInPortfAUM, strInvestedInPortfISOCur, datLastNAVDate,
              numPresUndrlygHoldData
    Join keys: (strInstISINCode, strReportPeriod)
    """
    if df_ext_agg.empty:
        return df_ext_agg.copy()

    # Only rows with a hold-date can match the "<= datHoldDate" filter.
    keys = (
        df_ext_agg.loc[df_ext_agg["datHoldDate"].notna(),
                       ["strInstISINCode", "strReportPeriod", "datHoldDate"]]
        .drop_duplicates()
    )
    if keys.empty:
        # No enrich possible; keep shape
        out = df_ext_agg.copy()
        out["numInvestedInPortfAUM"] = np.nan
        out["strInvestedInPortfISOCur"] = np.nan
        out["datLastNAVDate"] = pd.NaT
        out["numPresUndrlygHoldData"] = 0
        return out

    ext_tbl = _reflect_table(session, "DMIR", "tblDMIRExtPortfHolding_temp")

    k = (
        values(
            column("strPortfISINCode", ext_tbl.c.strPortfISINCode.type),
            column("strReportPeriod", String),
            column("datHoldDate", ext_tbl.c.datACCDate.type),
            name="key_list",
        )
        .data(list(keys.itertuples(index=False, name=None)))
        .alias("k")
    )

    # Get max datACCDate per (ISIN, period) with the <= hold-date guard
    tmax = (
        select(
            k.c.strPortfISINCode.label("strPortfISINCode"),
            k.c.strReportPeriod.label("strReportPeriod"),
            func.max(ext_tbl.c.datACCDate).label("datAccDate"),
        )
        .select_from(k)
        .join(
            ext_tbl,
            and_(
                ext_tbl.c.strPortfISINCode == k.c.strPortfISINCode,
                ext_tbl.c.datACCDate <= k.c.datHoldDate,
            ),
        )
        .group_by(k.c.strPortfISINCode, k.c.strReportPeriod)
    ).subquery()

    # Bring back the row at that max date
    enrich_rows = session.execute(
        select(
            tmax.c.strPortfISINCode,
            tmax.c.strReportPeriod,
            tmax.c.datAccDate,
            ext_tbl.c.strPortfISOCur,
            ext_tbl.c.numAUMInPortfCur,
        ).join(
            ext_tbl,
            and_(
                ext_tbl.c.strPortfISINCode == tmax.c.strPortfISINCode,
                ext_tbl.c.datACCDate == tmax.c.datAccDate,
            ),
        )
    ).all()

    enrich = pd.DataFrame(
        enrich_rows,
        columns=[
            "strInstISINCode",       # align to df_ext_agg column name
            "strReportPeriod",
            "datLastNAVDate",        # was datAccDate
            "strInvestedInPortfISOCur",  # was strPortfISOCurH
            "numInvestedInPortfAUM",     # was numAUMInPortfCur
        ],
    )

    # Merge back & set presence flag like SQL (RG06)
    out = df_ext_agg.merge(
        enrich, on=["strInstISINCode", "strReportPeriod"], how="left"
    )
    out["numPresUndrlygHoldData"] = np.where(
        out["numInvestedInPortfAUM"].isna(), 0, 1
    )

    return out


def enrich_internal_with_nav(session: Session, df_int_agg: pd.DataFrame) -> pd.DataFrame:
    """
    SQL parity for:
      - #tmpInvestedInPortfInternal (ROW_NUMBER … ORDER BY datACCDate DESC, numActifNetTotalOpcvm DESC)
    We emulate the same by:
      1) max datACCDate <= agg.datHoldDate per (GPSCode, period)
      2) then take the row at that date (ties are fine—SQL chose the max AUM;
         practically, multiple rows at the same date tend to be identical)
    Produces: numInvestedInPortfAUM, strInvestedInPortfISOCur, datLastNAVDate,
              numPresUndrlygHoldData
    Join keys: (strInvestedInPortfID, strReportPeriod)
    """
    if df_int_agg.empty:
        return df_int_agg.copy()

    keys = (
        df_int_agg.loc[df_int_agg["datHoldDate"].notna(),
                       ["strInvestedInPortfID", "strReportPeriod", "datHoldDate"]]
        .drop_duplicates()
    )
    if keys.empty:
        out = df_int_agg.copy()
        out["numInvestedInPortfAUM"] = np.nan
        out["strInvestedInPortfISOCur"] = np.nan
        out["datLastNAVDate"] = pd.NaT
        out["numPresUndrlygHoldData"] = 0
        return out

    int_tbl = _reflect_table(session, "DMIR", "tblDMIRIntPortfHolding_temp")

    k = (
        values(
            column("strPortfGPSCode", int_tbl.c.strPortfGPSCode.type),
            column("strReportPeriod", String),
            column("datHoldDate", int_tbl.c.datACCDate.type),
            name="key_list",
        )
        .data(list(keys.itertuples(index=False, name=None)))
        .alias("k")
    )

    tmax = (
        select(
            k.c.strPortfGPSCode.label("strPortfGPSCode"),
            k.c.strReportPeriod.label("strReportPeriod"),
            func.max(int_tbl.c.datACCDate).label("datAccDate"),
        )
        .select_from(k)
        .join(
            int_tbl,
            and_(
                int_tbl.c.strPortfGPSCode == k.c.strPortfGPSCode,
                int_tbl.c.datACCDate <= k.c.datHoldDate,
            ),
        )
        .group_by(k.c.strPortfGPSCode, k.c.strReportPeriod)
    ).subquery()

    enrich_rows = session.execute(
        select(
            tmax.c.strPortfGPSCode,
            tmax.c.strReportPeriod,
            tmax.c.datAccDate,
            int_tbl.c.strPortfISOCur,
            int_tbl.c.numActifNetTotalOpcvm,
        ).join(
            int_tbl,
            and_(
                int_tbl.c.strPortfGPSCode == tmax.c.strPortfGPSCode,
                int_tbl.c.datACCDate == tmax.c.datAccDate,
            ),
        )
    ).all()

    enrich = pd.DataFrame(
        enrich_rows,
        columns=[
            "strInvestedInPortfID",
            "strReportPeriod",
            "datLastNAVDate",             # was datAccDate
            "strInvestedInPortfISOCur",   # was strPortfISOCurH
            "numInvestedInPortfAUM",      # was numActifNetTotalOpcvm
        ],
    )

    out = df_int_agg.merge(
        enrich, on=["strInvestedInPortfID", "strReportPeriod"], how="left"
    )
    out["numPresUndrlygHoldData"] = np.where(
        out["numInvestedInPortfAUM"].isna(), 0, 1
    )

    return out

