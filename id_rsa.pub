-- ALP: rows keyed by (period, group), only for ALP
CREATE NONCLUSTERED INDEX IX_TransparizLT_ALP_Period_Group
ON dbo.tblDMIRTransparizLT (strReportPeriod, numReportPortfGroupID)
WHERE strReportPortfHoldSrc = 'ALP'
WITH (FILLFACTOR = 90, DATA_COMPRESSION = PAGE);

-- DMC: rows keyed by (period, GPS code), only for DMC
CREATE NONCLUSTERED INDEX IX_TransparizLT_DMC_Period_GPS
ON dbo.tblDMIRTransparizLT (strReportPeriod, strReportPortfGPSCode)
WHERE strReportPortfHoldSrc = 'DMC'
WITH (FILLFACTOR = 90, DATA_COMPRESSION = PAGE);
