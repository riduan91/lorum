df_int_enrich = df_int_enrich.merge(
    sf_df,
    left_on=["strInstISINCode", "strPortfLevelID"],
    right_on=["strSPISINCode", "strPortfLevelID"],
    how="left"
)
mask_valid_sf = (
    df_int_enrich["datHoldDate"].notna() &
    (df_int_enrich["datValidBegin"] <= df_int_enrich["datHoldDate"]) &
    (df_int_enrich["datValidEnd"].isna() | (df_int_enrich["datValidEnd"] <= df_int_enrich["datHoldDate"]))
)
# Null out SF fields when outside window to mimic SQL ON-filtering
df_int_enrich.loc[~mask_valid_sf, ["strSPISINCode","datValidBegin","datValidEnd"]] = np.nan
