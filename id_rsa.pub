
-- ALP side: (numReportPortfGroupID, strReportPeriod)
CREATE NONCLUSTERED INDEX IX_TransparizLT_ALP_Group_Period
ON dbo.DMIRTransparizLT (numReportPortfGroupID, strReportPeriod)
WHERE strReportPortfHoldSrc = 'ALP';

-- DMC side: (strReportPortfGPSCode, strReportPeriod)
CREATE NONCLUSTERED INDEX IX_TransparizLT_DMC_GPS_Period
ON dbo.DMIRTransparizLT (strReportPortfGPSCode, strReportPeriod)
WHERE strReportPortfHoldSrc = 'DMC';
