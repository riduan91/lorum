print("[DEL2] start", (df_instrument.shape, df_instrument_irtype.shape), get_hardware_info())

# Build the set of instrument IDs that are Forex/class7
if df_instrument_irtype.empty:
    df_instrument_irtype = pd.DataFrame(
        columns=["numInstrTypeID","strReportingType","strInstrumentTypeIRName"]
    )

ir_filter = (df_instrument_irtype["strReportingType"] == "class7") & \
            (df_instrument_irtype["strInstrumentTypeIRName"] == "Forex")

# Keep only the type IDs we care about (dedup to avoid cartesian growth)
forex_type_ids = df_instrument_irtype.loc[ir_filter, "numInstrTypeID"].dropna().unique()
print("[DEL2] forex_type_ids", forex_type_ids.shape, get_hardware_info())

# Map type -> instrument IDs, then dedup to a set/Index
forex_inst_ids = (
    df_instrument.loc[df_instrument["numInstTypeId"].isin(forex_type_ids), "numInstID"]
    .dropna()
    .drop_duplicates()
)
print("[DEL2] forex_inst_ids", forex_inst_ids.shape, get_hardware_info())

# Now filter df_updated by (is forex instrument) AND zeros — no merge, no explosion
before2 = len(df_updated)
mask_forex = (
    df_updated["numInstID"].isin(forex_inst_ids) &
    (df_updated["numWeightedQtqInReportPortf"].fillna(0) == 0.0) &
    (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
)
df_updated = df_updated.loc[~mask_forex].copy()
print(f"[DEL2] {before2 - len(df_updated)} forex rows removed", df_updated.shape, get_hardware_info())
