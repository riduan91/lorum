import numpy as np
import pandas as pd

def compute_bench_indicators_bkgn_9(
    df_tblDMIRBKGN8: pd.DataFrame, df_IRRatingsBetween: pd.DataFrame
) -> pd.DataFrame:
    """
    BKGN 9:
      - single groupby+sum
      - vectorized averages
      - nearest rating mapping done with array masks (no index alignment)
    """
    if df_tblDMIRBKGN8 is None or df_tblDMIRBKGN8.empty:
        return pd.DataFrame()

    # 1) Grouping keys
    group_keys = [
        "numBenchFBAId",
        "strCompositionCd",
        "datReportingDay",
        "strPeriodTypeFlag",
        "strPFCurrencyISOCode",
    ]

    # 2) Columns to sum
    weight_cols = ["numWeightSP", "numWeightMD", "numWeightFT"] + [f"numWeightC{i}" for i in range(1, 14)]
    wgt_rt_cols = ["numRatingWeightSP", "numRatingWeightMD", "numRatingWeightFT"] + [
        f"numRatingWeightC{i}" for i in range(1, 14)
    ]
    sum_cols = weight_cols + wgt_rt_cols

    # Keep only what we need to aggregate
    df = df_tblDMIRBKGN8[group_keys + sum_cols].copy()

    # 3) One-pass aggregation (sums)
    agg = df.groupby(group_keys, as_index=False)[sum_cols].sum()

    # 4) Compute numeric averages (safe division)
    def safe_div(num: pd.Series, den: pd.Series) -> pd.Series:
        den2 = den.replace(0, np.nan)
        out = num / den2
        return out.fillna(0.0)

    agg["numBenchAvgRtgSP"] = safe_div(agg["numRatingWeightSP"], agg["numWeightSP"])
    agg["numBenchAvgRtgMD"] = safe_div(agg["numRatingWeightMD"], agg["numWeightMD"])
    agg["numBenchAvgRtgFT"] = safe_div(agg["numRatingWeightFT"], agg["numWeightFT"])
    for i in range(1, 14):
        agg[f"numBenchAvgRtgC{i}"] = safe_div(agg[f"numRatingWeightC{i}"], agg[f"numWeightC{i}"])

    # 5) Vectorized mapping (mask/array based): numeric avg -> nearest string rating per agency
    def nearest_label_mask(avg_s: pd.Series, agency: str, ref_df: pd.DataFrame) -> pd.Series:
        # Input to array (no reliance on index)
        x = pd.to_numeric(avg_s, errors="coerce").to_numpy()

        ref = (
            ref_df.loc[ref_df["strRatingAgency"] == agency, ["strRating", "numRating"]]
            .drop_duplicates()
            .sort_values("numRating", ascending=True)
        )
        if ref.empty:
            return pd.Series(np.where(np.isnan(x), "NR", "NR"), index=avg_s.index)

        vals = ref["numRating"].to_numpy(dtype=float)    # ladder (ascending)
        labels = ref["strRating"].to_numpy()            # same order as vals

        # For each x, find upper and lower neighbors on the ladder
        idx_upper = np.searchsorted(vals, x, side="left")
        idx_lower = np.clip(idx_upper - 1, 0, len(vals) - 1)
        idx_upper = np.clip(idx_upper,       0, len(vals) - 1)

        lower_diff = np.abs(x - vals[idx_lower])
        upper_diff = np.abs(vals[idx_upper] - x)

        # Choose closer; ties -> lower. NaN -> "NR".
        choose_upper = (upper_diff < lower_diff) & ~np.isnan(x)
        idx_choice = np.where(choose_upper, idx_upper, idx_lower)

        out = labels[idx_choice]
        out = np.where(np.isnan(x), "NR", out)
        return pd.Series(out, index=avg_s.index)

    agg["strBenchAvgRtgSP"] = nearest_label_mask(agg["numBenchAvgRtgSP"], "SP", df_IRRatingsBetween)
    agg["strBenchAvgRtgMD"] = nearest_label_mask(agg["numBenchAvgRtgMD"], "MOODY", df_IRRatingsBetween)
    agg["strBenchAvgRtgFT"] = nearest_label_mask(agg["numBenchAvgRtgFT"], "FITCH", df_IRRatingsBetween)
    agg["strBenchAvgRtgFH"] = agg["strBenchAvgRtgFT"]  # alias

    for i in range(1, 14):
        agg[f"strBenchAvgRtgC{i}"] = nearest_label_mask(agg[f"numBenchAvgRtgC{i}"], "SP", df_IRRatingsBetween)

    # 6) Final column order (existing columns only)
    final_cols = group_keys + [
        "numBenchAvgRtgSP", "strBenchAvgRtgSP",
        "numBenchAvgRtgMD", "strBenchAvgRtgMD",
        "numBenchAvgRtgFT", "strBenchAvgRtgFT",
    ]
    for i in range(1, 14):
        final_cols += [f"numBenchAvgRtgC{i}", f"strBenchAvgRtgC{i}"]

    final = [c for c in final_cols if c in agg.columns]
    return agg[final].reset_index(drop=True)
