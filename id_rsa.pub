/* ============================================================================
   Row-by-row comparison – DMIR.tblDMIRAPIBenchHolding
   NULL is treated as “equal to NULL” everywhere.
   ============================================================================*/
DECLARE @accounting_date DATE        = '2025-06-20';  -- date to test
DECLARE @bench_code     VARCHAR(20)  = 'SAMPLE_BENCH';-- benchmark to test

/* ────────────────  type-appropriate sentinels  ────────────────
   You can alter these if they ever collide with real data.      */
DECLARE @dflt_date      DATE        = '19000101';
DECLARE @dflt_float     FLOAT       = -999999999.0;
DECLARE @dflt_int       INT         = -999999999;
DECLARE @dflt_string    VARCHAR(1)  = '';

/* ========================================================================== */
SELECT
        a.Accountingdate            AS Accountingdate,
        a.BenchCode                 AS BenchCode,
        a.InstrumentDWHID           AS InstrumentDWHID

      /* ───────────  0 / 1 mismatch flags (NULL-safe)  ─────────── */
      , CASE WHEN ISNULL(a.Accountingdate   ,@dflt_date  ) = ISNULL(b.Accountingdate   ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_Accountingdate
      , CASE WHEN ISNULL(a.BKGNCode         ,@dflt_int   ) = ISNULL(b.BKGNCode         ,@dflt_int   ) THEN 0 ELSE 1 END AS valid_BKGNCode
      , CASE WHEN ISNULL(a.BenchCode        ,@dflt_string) = ISNULL(b.BenchCode        ,@dflt_string) THEN 0 ELSE 1 END AS valid_BenchCode
      , CASE WHEN ISNULL(a.BenchName        ,@dflt_string) = ISNULL(b.BenchName        ,@dflt_string) THEN 0 ELSE 1 END AS valid_BenchName
      , CASE WHEN ISNULL(a.BenchCurrency    ,@dflt_string) = ISNULL(b.BenchCurrency    ,@dflt_string) THEN 0 ELSE 1 END AS valid_BenchCurrency
      , CASE WHEN ISNULL(a.InstrumentDWHID  ,@dflt_int   ) = ISNULL(b.InstrumentDWHID  ,@dflt_int   ) THEN 0 ELSE 1 END AS valid_InstrumentDWHID
      , CASE WHEN ISNULL(a.ISINCode         ,@dflt_string) = ISNULL(b.ISINCode         ,@dflt_string) THEN 0 ELSE 1 END AS valid_ISINCode
      , CASE WHEN ISNULL(a.SedolCode        ,@dflt_string) = ISNULL(b.SedolCode        ,@dflt_string) THEN 0 ELSE 1 END AS valid_SedolCode
      , CASE WHEN ISNULL(a.CUSIPCode        ,@dflt_string) = ISNULL(b.CUSIPCode        ,@dflt_string) THEN 0 ELSE 1 END AS valid_CUSIPCode
      , CASE WHEN ISNULL(a.InternalCode     ,@dflt_string) = ISNULL(b.InternalCode     ,@dflt_string) THEN 0 ELSE 1 END AS valid_InternalCode
      , CASE WHEN ISNULL(a.CurrencyID       ,@dflt_string) = ISNULL(b.CurrencyID       ,@dflt_string) THEN 0 ELSE 1 END AS valid_CurrencyID
      , CASE WHEN ISNULL(a.LocalCurrencyPrice,@dflt_float ) = ISNULL(b.LocalCurrencyPrice,@dflt_float ) THEN 0 ELSE 1 END AS valid_LocalCurrencyPrice
      , CASE WHEN ISNULL(a.Quantity         ,@dflt_float ) = ISNULL(b.Quantity         ,@dflt_float ) THEN 0 ELSE 1 END AS valid_Quantity
      , CASE WHEN ISNULL(a.strInstAladdin   ,@dflt_string) = ISNULL(b.strInstAladdin   ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstAladdin
      , CASE WHEN ISNULL(a.strInstName      ,@dflt_string) = ISNULL(b.strInstName      ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstName
      , CASE WHEN ISNULL(a.strBloombergCode ,@dflt_string) = ISNULL(b.strBloombergCode ,@dflt_string) THEN 0 ELSE 1 END AS valid_strBloombergCode
      , CASE WHEN ISNULL(a.strInstISINCode  ,@dflt_string) = ISNULL(b.strInstISINCode  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstISINCode
      , CASE WHEN ISNULL(a.strInstSedolCode ,@dflt_string) = ISNULL(b.strInstSedolCode ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstSedolCode
      , CASE WHEN ISNULL(a.strInstCUSIPCode ,@dflt_string) = ISNULL(b.strInstCUSIPCode ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstCUSIPCode
      , CASE WHEN ISNULL(a.strInstIssuerName,@dflt_string) = ISNULL(b.strInstIssuerName,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstIssuerName
      , CASE WHEN ISNULL(a.strInstExchLocName,@dflt_string) = ISNULL(b.strInstExchLocName,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstExchLocName
      , CASE WHEN ISNULL(a.strInstListingCountryLabel,@dflt_string)=ISNULL(b.strInstListingCountryLabel,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstListingCountryLabel
      , CASE WHEN ISNULL(a.strInstIssueCountryLabel ,@dflt_string)=ISNULL(b.strInstIssueCountryLabel ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstIssueCountryLabel
      , CASE WHEN ISNULL(a.strInstIssuerCountryLabel,@dflt_string)=ISNULL(b.strInstIssuerCountryLabel,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstIssuerCountryLabel
      , CASE WHEN ISNULL(a.numInstCouponRate,@dflt_float) = ISNULL(b.numInstCouponRate,@dflt_float) THEN 0 ELSE 1 END AS valid_numInstCouponRate
      , CASE WHEN ISNULL(a.numInstForwardRate,@dflt_float)= ISNULL(b.numInstForwardRate,@dflt_float) THEN 0 ELSE 1 END AS valid_numInstForwardRate
      , CASE WHEN ISNULL(a.datInstMaturityDate,@dflt_date)= ISNULL(b.datInstMaturityDate,@dflt_date) THEN 0 ELSE 1 END AS valid_datInstMaturityDate
      , CASE WHEN ISNULL(a.RemainLife365    ,@dflt_float ) = ISNULL(b.RemainLife365    ,@dflt_float ) THEN 0 ELSE 1 END AS valid_RemainLife365
      , CASE WHEN ISNULL(a.datInstCallDate  ,@dflt_date  ) = ISNULL(b.datInstCallDate  ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datInstCallDate
      , CASE WHEN ISNULL(a.datInstNextCouponDate,@dflt_date)=ISNULL(b.datInstNextCouponDate,@dflt_date) THEN 0 ELSE 1 END AS valid_datInstNextCouponDate
      , CASE WHEN ISNULL(a.strInstPriceType ,@dflt_string) = ISNULL(b.strInstPriceType ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstPriceType
      , CASE WHEN ISNULL(a.strInstRateType  ,@dflt_string) = ISNULL(b.strInstRateType  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstRateType
      , CASE WHEN ISNULL(a.numInstSpotRate  ,@dflt_float ) = ISNULL(b.numInstSpotRate  ,@dflt_float ) THEN 0 ELSE 1 END AS valid_numInstSpotRate
      , CASE WHEN ISNULL(a.datInstStartDate ,@dflt_date  ) = ISNULL(b.datInstStartDate ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datInstStartDate
      , CASE WHEN ISNULL(a.numInstUndrlygQty,@dflt_float ) = ISNULL(b.numInstUndrlygQty,@dflt_float ) THEN 0 ELSE 1 END AS valid_numInstUndrlygQty
      , CASE WHEN ISNULL(a.strInstUndrlygISINCode,@dflt_string)=ISNULL(b.strInstUndrlygISINCode,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstUndrlygISINCode
      , CASE WHEN ISNULL(a.datInstIssueDate ,@dflt_date  ) = ISNULL(b.datInstIssueDate ,@dflt_date  ) THEN 0 ELSE 1 END AS valid_datInstIssueDate
      , CASE WHEN ISNULL(a.numInstNominalMt,@dflt_float ) = ISNULL(b.numInstNominalMt,@dflt_float ) THEN 0 ELSE 1 END AS valid_numInstNominalMt
      , CASE WHEN ISNULL(a.strInstCurrCode  ,@dflt_string) = ISNULL(b.strInstCurrCode  ,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstCurrCode
      , CASE WHEN ISNULL(a.datInstContractEnd,@dflt_date ) = ISNULL(b.datInstContractEnd,@dflt_date ) THEN 0 ELSE 1 END AS valid_datInstContractEnd
