# ────────────────────────────────────────────────────────────────────────────
# NEW version of combine_all() – drop‑in replacement
# ────────────────────────────────────────────────────────────────────────────
def combine_all(scope_csv: str, audit_id: str, part: int, **kwargs) -> pd.DataFrame:
    """
    Combines all intermediate parquet files into the final ESG output.
    Fixed so that *WeightG columns* keep the **raw (global) weight** and
    *Weight* columns keep the **effective (re‑based) weight**.
    """
    # ------------------------------------------------------------------ 1. load base & intermediates
    scope_df           = load_parquet(scope_csv)
    ti                 = kwargs["ti"]
    data_dir           = DATA_FOLDER
    esg_df             = load_parquet(data_dir / f"esg_{part}.parquet")
    co2_df             = load_parquet(data_dir / f"co2_{part}.parquet")
    diversity_df       = load_parquet(data_dir / f"diversity_{part}.parquet")
    hr_df              = load_parquet(data_dir / f"hr_{part}.parquet")
    controverse_df     = load_parquet(data_dir / f"controverse_{part}.parquet")
    engagement_df      = load_parquet(data_dir / f"engagement_{part}.parquet")
    group_df           = load_parquet(data_dir / f"group_{part}.parquet")
    pot_cov_df         = load_parquet(data_dir / f"potential_coverage_{part}.parquet")
    pot_cov_tot_df     = load_parquet(data_dir / f"potential_coverage_total_{part}.parquet")

    # ------------------------------------------------------------------ 2. start with scope
    df_all = scope_df.merge(
        pot_cov_tot_df,
        on=["myKey", "datReportingDay"],
        how="left",
        suffixes=("", "_tot"),
    )

    # ------------------------------------------------------------------ 3. bring in the other slices
    for df_slice in [
        esg_df,
        co2_df,
        diversity_df,
        hr_df,
        controverse_df,
        engagement_df,
        group_df,
        pot_cov_df,
    ]:
        df_all = df_all.merge(
            df_slice,
            on=["myKey", "datReportingDay", "strInstAladdin", "numInstID", "strInstIssuerCode"],
            how="left",
        )

    # ------------------------------------------------------------------ 4. GLOBAL vs EFFECTIVE coverage weights
    weight_cols = [
        "numESGGlbCovWeight",
        "numESGEnvCovWeight",
        "numESGSocialCovWeight",
        "numESGGovCovWeight",
        "numESGDecileCovWeight",
        "numCO2IntensEVEvalCovWeight",
        "numCO2EmmissionCovWeight",
        "numESGKPIGenderDivCovWeight",
        "numESGKPIHumanRightsCovWeight",
        "numESGKPIExpControvESGCovWeight",
        "numESGKPIExpControvSocCovWeight",
    ]

    # (a)  preserve the *raw* value in “…WeightG”
    for col in weight_cols:
        df_all[col + "G"] = df_all[col]          # raw global weight

    # (b)  compute effective coverage “…Weight”  (re‑based on PotentialCoveragePtf)
    df_all["PotentialCoveragePtf"] = df_all["PotentialCoveragePtf"].fillna(0)
    for col in weight_cols:
        df_all[col + "E"] = divide_or_set_zero(df_all[col], df_all["PotentialCoveragePtf"])

    # ------------------------------------------------------------------ 5. discard the now‑redundant raw columns
    df_all.drop(columns=weight_cols, inplace=True)

    # ------------------------------------------------------------------ 6. (the rest of the function is unchanged)
    # ... build df_summary, compute contribution fields, rename columns, write parquet  …
    # (copy your existing code for steps 6 → end)

    # -- example of the final parquet dump & XCom pushes (keep from original) --
    outfile = DATA_FOLDER / f"esg_results_{audit_id}_{part}.parquet"
    final_df.to_parquet(outfile)
    ti.xcom_push("results",   str(outfile))
    ti.xcom_push("n_rows",    len(final_df))
    ti.xcom_push("examples",  final_df.head(N_ROWS_FOR_EXAMPLES).to_json(orient="records", date_format="iso"))
    ti.xcom_push("summary",   df_summary.head(N_ROWS_FOR_EXAMPLES).to_json(orient="records", date_format="iso"))
    return True
