from __future__ import annotations

"""Scope–shrinking logic for **DMIR.tblDMIRScopeLT** (Python port).

Re‑implements the end of the legacy stored‑procedure
`DMIR.stpDMIRLTScopeAG_sourcePython` without using `tuple_`, so it runs on
SQL Server 2019.  Temp‑table blocks from the T‑SQL are mirrored by helpers
below:

* `#to_remove`   → `_build_df_to_remove_dmc`, `_delete_pairs_scope_lt(DMC)`
* `#to_remove2`  → `_build_df_to_remove_alp`, `_delete_pairs_scope_lt(ALP)`
* `#to_remove3`  → `_build_df_to_remove_esg`, `_delete_pairs_scope_lt(DMC ESG)`
* `#auditIdDMCHoldings` / `#gpsDoNotDelete` → `_recent_dmc_holdings_audit`,
  `_gps_do_not_delete`
"""

import logging
from datetime import datetime, timedelta, date
from typing import List, Set, Tuple

import pandas as pd
from dateutil.relativedelta import relativedelta
from sqlalchemy import and_, func
from sqlalchemy.orm import Session

from dags.common.dmir_connections import get_session
from dags.common.models import (
    DMIRBRSDMCPortfIndicators,
    DMIRDMCHolding,
    DMIRMonitoringLT_Legacy as DMIRMonitoringLT,
    DMIRMaccNav,
    DMIRReportParam,
    DMIRScopeLT,
    DMIRTransparizLT_Legacy as DMIRTransparizLT,
)
from dags.common.utils import get_all_as_df
from dags.lookthrough_transpariz.config import MONTHS_TO_LOOK_PAST_FULL
from dags.lookthrough_transpariz.lt_utils import update_dmc_data_with_holdings

# ---------------------------------------------------------------------------
# General‑purpose helpers ----------------------------------------------------
# ---------------------------------------------------------------------------

def _within_eu_window(ts: datetime) -> bool:
    """Return *True* when we are in the time window where the clean‑up should run."""
    d, h = ts.day, ts.hour
    return (h > 1 and d > 5) or (h > 10 and d <= 5)


def _delete_scope_ma(session: Session) -> int:
    """DELETE FROM DMIRScopeLT WHERE strReportPortfHoldSrc = 'MA'"""
    return (
        session.query(DMIRScopeLT)
        .filter(DMIRScopeLT.strReportPortfHoldSrc == "MA")
        .delete(synchronize_session=False)
    )


# ---------------------------------------------------------------------------
# Block 2 – DMC (#to_remove) -------------------------------------------------
# ---------------------------------------------------------------------------

def _build_df_to_remove_dmc(session: Session) -> pd.DataFrame:
    q = (
        session.query(
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
            DMIRScopeLT.numReportPortfAUM.label("num_scope"),
            DMIRScopeLT.strReportPortfGPSCode.label("gps"),
            DMIRScopeLT.strReportPeriod.label("period"),
        )
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
            DMIRTransparizLT.strReportPortfGPSCode == DMIRScopeLT.strReportPortfGPSCode,
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.numInstID > 1,
        )
        .group_by(
            DMIRScopeLT.numReportPortfAUM,
            DMIRScopeLT.strReportPortfGPSCode,
            DMIRScopeLT.strReportPeriod,
        )
    )
    df = get_all_as_df(q)
    if df.empty:
        return df

    df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

    bad = get_all_as_df(
        session.query(DMIRTransparizLT.strReportPortfGPSCode, DMIRTransparizLT.strReportPeriod)
        .filter(DMIRTransparizLT.strReportPortfHoldSrc == "DMC", DMIRTransparizLT.numInstID == -1)
        .distinct()
    )
    bad_set = set(bad.apply(tuple, axis=1))
    df = df[~df.apply(lambda r: (r.gps, r.period) in bad_set, axis=1)]
    return df


# ---------------------------------------------------------------------------
# Block 3 – ALP (#to_remove2) ------------------------------------------------
# ---------------------------------------------------------------------------

def _build_df_to_remove_alp(session: Session, gps_exempt: Set[str]) -> pd.DataFrame:
    q = (
        session.query(
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
            DMIRScopeLT.numReportPortfAUM.label("num_scope"),
            DMIRScopeLT.numReportPortfGroupID.label("grp"),
            DMIRScopeLT.strReportPeriod.label("period"),
        )
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "ALP",
            DMIRTransparizLT.strReportPortfHoldSrc == "ALP",
            DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
            DMIRTransparizLT.numReportPortfGroupID == DMIRScopeLT.numReportPortfGroupID,
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.numInstID > 1,
        )
        .group_by(
            DMIRScopeLT.numReportPortfAUM, DMIRScopeLT.numReportPortfGroupID, DMIRScopeLT.strReportPeriod
        )
    )
    df = get_all_as_df(q)
    if df.empty:
        return df

    df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

    ext_idx = set(
        get_all_as_df(
            session.query(DMIRMonitoringLT.numReportPortfGroupID, DMIRMonitoringLT.strReportPeriod)
            .filter(
                DMIRMonitoringLT.strReportPortfHoldSrc == "ALP",
                DMIRMonitoringLT.strSrcUndrlygHoldData.in_("EXTERNAL", "SPECIAL"),
                DMIRMonitoringLT.strTrackUndrlygHoldData != "BLANK",
            )
            .distinct()
        ).apply(tuple, axis=1)
    )
    df = df[~df.apply(lambda r: (r.grp, r.period) in ext_idx, axis=1)]
    df = df[~df.grp.isin(gps_exempt)]
    return df


# ---------------------------------------------------------------------------
# Block 4 – auditIdDMCHoldings / gpsDoNotDelete ------------------------------
# ---------------------------------------------------------------------------

def _recent_dmc_holdings_audit(session: Session, month_end: date) -> pd.DataFrame:
    q = (
        session.query(
            DMIRDMCHolding.strPortfGPSCode,
            func.max(DMIRDMCHolding.numAuditId).label("aud_hold"),
        )
        .join(
            DMIRBRSDMCPortfIndicators,
            and_(
                DMIRBRSDMCPortfIndicators.strPortfGPSCode == DMIRDMCHolding.strPortfGPSCode,
                DMIRBRSDMCPortfIndicators.datPeriodLastNav == DMIRDMCHolding.datACCDATE,
                DMIRBRSDMCPortfIndicators.datPeriodLastDay == month_end,
            ),
        )
        .group_by(DMIRDMCHolding.strPortfGPSCode)
    )
    return get_all_as_df(q)


def _gps_do_not_delete(session: Session, month_end: date, df_audit: pd.DataFrame) -> Set[str]:
    if df_audit.empty:
        return set()
    max_audit = df_audit.set_index("strPortfGPSCode").aud_hold.to_dict()

    lt_audit = get_all_as_df(
        session.query(
            DMIRTransparizLT.strReportPortfGPSCode,
            func.max(DMIRTransparizLT.numAuditId).label("aud_lt"),
        )
        .filter(
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.datPeriodLastDay == month_end,
        )
        .group_by(DMIRTransparizLT.strReportPortfGPSCode)
    ).set_index("strReportPortfGPSCode").aud_lt.to_dict()

    return {gps for gps, a_hold in max_audit.items() if a_hold > lt_audit.get(gps, 0)}


# ---------------------------------------------------------------------------
# Block 5 – ESG (#to_remove3) ------------------------------------------------
# ---------------------------------------------------------------------------

def _build_df_to_remove_esg(session: Session, gps_exempt: Set[str]) -> pd.DataFrame:
    q = (
        session.query(
            func.sum(DMIRTransparizLT.numWeightedAmtInReportPortf).label("num_transp"),
            DMIRScopeLT.numReportPortfAUM.label("num_scope"),
            DMIRScopeLT.strReportPortfGPSCode.label("gps"),
            DMIRScopeLT.strReportPeriod.label("period"),
        )
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "DMC",
            DMIRScopeLT.strReportPortfName == "DMC NAME ESG SCORES",
            DMIRTransparizLT.strReportPortfHoldSrc == "DMC",
            DMIRTransparizLT.strReportPortfGPSCode == DMIRScopeLT.strReportPortfGPSCode,
            DMIRTransparizLT.strReportPeriod == DMIRScopeLT.strReportPeriod,
            DMIRTransparizLT.numLowestInventoryflag == 1,
            DMIRTransparizLT.numInstID > 1,
        )
        .group_by(
            DMIRScopeLT.numReportPortfAUM,
            DMIRScopeLT.strReportPortfGPSCode,
            DMIRScopeLT.strReportPeriod,
        )
    )
    df = get_all_as_df(q)
    if df.empty:
        return df

    df = df[(df.num_transp - df.num_scope).abs() <= 0.05]

    # Exempt most-recent month if GPS code is in “do-not-delete”
    recent_prefix = (datetime.now() - relativedelta(months=1)).strftime("%Y%m")
    df = df[
        ~(df.period.str.startswith(recent_prefix) & df.gps.isin(gps_exempt))
    ]
    return df


def _apply_delete_esg(df: pd.DataFrame, session: Session) -> int:
    if df.empty:
        return 0
    total = 0
    for gps, period in df[["gps", "period"]].drop_duplicates().itertuples(index=False):
        total += (
            session.query(DMIRScopeLT)
            .filter(
                DMIRScopeLT.strReportPortfHoldSrc == "DMC",
                DMIRScopeLT.strReportPortfName == "DMC NAME ESG SCORES",
                DMIRScopeLT.strReportPortfGPSCode == gps,
                DMIRScopeLT.strReportPeriod == period,
            )
            .delete(synchronize_session=False)
        )
    return total


# ---------------------------------------------------------------------------
# Block 6 – threshold harmonisation -----------------------------------------
# ---------------------------------------------------------------------------

def harmonise_thresholds(session: Session) -> None:
    subq = (
        session.query(
            func.min(DMIRReportParam.numLTThreshold).label("thr"),
            DMIRReportParam.strAccSrc,
            DMIRReportParam.numPortfGroupfKey,
            DMIRReportParam.strPortfGPSCode,
        )
        .filter(DMIRReportParam.numLTflag == 1)
        .group_by(
            DMIRReportParam.strAccSrc,
            DMIRReportParam.numPortfGroupfKey,
            DMIRReportParam.strPortfGPSCode,
        )
    ).subquery()

    # ALP
    (
        session.query(DMIRScopeLT)
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "ALP",
            DMIRScopeLT.numReportPortfGroupID == subq.c.numPortfGroupfKey,
        )
        .update({DMIRScopeLT.numLTThreshold: subq.c.thr}, synchronize_session=False)
    )

    # DMC
    (
        session.query(DMIRScopeLT)
        .filter(
            DMIRScopeLT.strReportPortfHoldSrc == "DMC",
            DMIRScopeLT.strReportPortfGPSCode == subq.c.strPortfGPSCode,
        )
        .update({DMIRScopeLT.numLTThreshold: subq.c.thr}, synchronize_session=False)
    )

    # floors / caps as in T-SQL
    (
        session.query(DMIRScopeLT)
        .filter(DMIRScopeLT.numLTThreshold == 0)
        .update({DMIRScopeLT.numLTThreshold: 1e-8}, synchronize_session=False)
    )
    (
        session.query(DMIRScopeLT)
        .filter(DMIRScopeLT.numLTThreshold > 0.0001)
        .update({DMIRScopeLT.numLTThreshold: 0.0001}, synchronize_session=False)
    )


# ---------------------------------------------------------------------------
# Orchestrator – runs blocks 1-5 in order, then block 6 ----------------------
# ---------------------------------------------------------------------------

def reduce_scope_and_cleanup(now: datetime | None = None) -> None:
    now = now or datetime.now()
    if not _within_eu_window(now):
        logging.info("Skip scope-cleanup: outside EU window.")
        return

    month_end = (now.replace(day=1) - timedelta(days=1)).date()
    session = get_session()
    try:
        with session.begin():
            # 1. MA purge
            _delete_scope_ma(session)

            # 2. safeguard lists
            df_audit = _recent_dmc_holdings_audit(session, month_end)
            gps_exempt = _gps_do_not_delete(session, month_end, df_audit)

            # 3. DMC
            _apply_delete_dmc(_build_df_to_remove_dmc(session), session)

            # 4. ALP
            _apply_delete_alp(_build_df_to_remove_alp(session, gps_exempt), session)

            # 5. ESG
            _apply_delete_esg(_build_df_to_remove_esg(session, gps_exempt), session)

            # 6. Threshold fixes
            harmonise_thresholds(session)
    finally:
        session.close()


# ---------------------------------------------------------------------------
# Airflow TaskFlow wrappers --------------------------------------------------
# ---------------------------------------------------------------------------

from airflow.decorators import task

@task
def task__reduce_scope_and_cleanup(**_):
    reduce_scope_and_cleanup()
    return "scope_cleaned"


@task
def task__harmonise_thresholds(**_):
    session = get_session()
    try:
        harmonise_thresholds(session)
        session.commit()
    finally:
        session.close()
    return "thresholds_fixed"


@task
def task__refresh_scope_updated_holdings(**context):
    from dags.lookthrough_transpariz.scope_lt_refresh import (
        refresh_scope_for_updated_holdings,
    )

    audit_id = context["params"].get("audit_id", 0)
    refresh_scope_for_updated_holdings(datetime.now(), audit_id=audit_id)
    return "scope_refreshed"
