import polars as pl

# Convert your pandas DataFrame to Polars if needed
# df = pl.from_pandas(df)

# Define the keys and aggregations
keys = ["key1", "key2", ...]  # replace with your actual keys

agg = (
    df
    .groupby(keys)
    .agg([
        pl.col("datHoldDate").max().alias("datPeriodLastNav"),
        pl.col("strReportPortfISOcur").max().alias("strCurrencyISOCode"),
        pl.col("numReportPortfAUM").max().alias("maxAUM"),
        pl.col("numWeightedAmtInReportPortf").sum().alias("sumAmt"),
        pl.col("durExp").sum().alias("sumDurExp"),
        pl.col("curExp").sum().alias("sumCurExp"),
        pl.col("numInstConvexityAdjbps").max().alias("maxConvexity"),
        pl.col("effInstModifDuration").max().alias("maxModifDuration"),
        pl.col("effInstMCDuration").max().alias("maxMCDuration"),
        pl.col("effInstEffDuration").max().alias("maxEffDuration"),
        pl.col("effInstSpreadDuration").max().alias("maxSpreadDuration"),
        pl.col("numDeltaAdjustedSpread").sum().alias("sumDelta"),
    ])
)
