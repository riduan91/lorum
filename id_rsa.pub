def single_process_alpha_records(idx, key, chunk, ind_chunk):
    session = None
    try:
        (
            rpt_code,
            period_end,
            group_id,
            audit,
        ) = key

        # Partition info (kept for logging)
        df_partition = chunk.groupby(["strInstAladdin", "numInstID"])
        print("df_partition", get_hardware_info())

        # ------------------------------------------------------------------#
        # 2 .  aggregate numeric holds  (memory-light: DataFrame, not dicts)
        # ------------------------------------------------------------------#
        gb = chunk.groupby(["strInstAladdin", "numInstID"], observed=True)

        agg_df = gb.agg(
            numHoldPrice=("numHoldPrice", "mean"),
            numHoldAccruedIntPortf=("numHoldAccruedIntPortf", "sum"),
            numWeightedAmtInReportPortf=("numWeightedAmtInReportPortf", "sum"),
            numHoldCrossCur=("numHoldCrossCur", "mean"),
            numWeightedQtqInReportPortf=("numWeightedQtqInReportPortf", "sum"),
            numHoldAvrgCostInReportPortf=("numHoldAvrgCostInReportPortf", "sum"),
        ).reset_index()

        # If get_sign_leg_and_nr_leg(subchunk) must run per group, apply once and merge
        try:
            sign_nr = gb.apply(get_sign_leg_and_nr_leg)
            # normalize to DataFrame with the group keys as columns
            if isinstance(sign_nr, pd.Series) and isinstance(sign_nr.iloc[0], dict):
                sign_nr = sign_nr.apply(pd.Series)
            sign_nr = sign_nr.reset_index()
            agg_df = agg_df.merge(
                sign_nr,
                on=["strInstAladdin", "numInstID"],
                how="left"
            )
        except Exception:
            # If anything goes wrong, keep going without those columns (faithful fallback)
            pass

        # Release groupby objects promptly
        del gb, df_partition
        print("aggs", len(agg_df), get_hardware_info())

        # ------------------------------------------------------------------#
        # 3 .  ORM pulls  (kept as-is)
        # ------------------------------------------------------------------#
        session = get_session()
        try:
            instruments = {}
            analytics = {}
            list_inst_alds = chunk["strInstAladdin"].unique().tolist()
            for chunk_inst_alds in chunker(list_inst_alds, 2000):
                instruments.update(
                    {
                        record.strInstAladdin: record
                        for record in session.query(DMIRBRSInstrument)
                        .filter(DMIRBRSInstrument.strInstAladdin.in_(chunk_inst_alds))
                        .all()
                    }
                )
                analytics.update(
                    {
                        record.strInstAladdin: record
                        for record in session.query(DMIRBRSInstAnalytic)
                        .filter(
                            DMIRBRSInstAnalytic.strInstAladdin.in_(chunk_inst_alds),
                            DMIRBRSInstAnalytic.datInstQuotationDate == period_end,
                        )
                        .all()
                    }
                )

            list_curr_codes = list(
                {instrument.strInstCurrCode for instrument in instruments.values()}
            )
            list_inst_type_ids = list(
                {instrument.numInstTypeId for instrument in instruments.values()}
            )
            quotes = {}
            for chunk_curr_codes in chunker(list_curr_codes, 2000):
                quotes.update(
                    {
                        record.strCurrCode: record
                        for record in session.query(DMIRBRSCurrencyQuote)
                        .filter(
                            DMIRBRSCurrencyQuote.strCurrCode.in_(chunk_curr_codes),
                            DMIRBRSCurrencyQuote.datccyqDate == period_end,
                        )
                        .all()
                    }
                )

            ptf_agg = (
                session.query(DMIRBRSALPHAPortfGroupIndicators.numAUM)
                .filter_by(
                    numPortfGroupFkey=int(group_id),
                    datPeriodLastDay=period_end,
                    strPeriodTypeFlag="M",
                )
                .first()
            )
            lnk = (
                session.query(DMIRPortfolioLnk.strPortfGroupDECALOGCode)
                .filter(
                    DMIRPortfolioLnk.numPortfGroupSkey == int(group_id),
                    DMIRPortfolioLnk.strPortfGroupType.in_(["A", "G"]),
                )
                .first()
            )

            #  aliases
            it = {
                type_id: {
                    "1": (
                        session.query(IT1)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class1")
                        .first()
                    ),
                    "3": (
                        session.query(IT3)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class3")
                        .first()
                    ),
                    "8": (
                        session.query(IT8)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class8")
                        .first()
                    ),
                    "9": (
                        session.query(IT9)
                        .filter_by(numInstrTypeID=type_id, strReportingType="class9")
                        .first()
                    ),
                }
                for type_id in list_inst_type_ids
            }
            sb = {
                inst_ald: {
                    "BB": session.query(SB_BB)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="BNPP_BICS")
                    .first(),
                    "LH": session.query(SB_LH)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="LH")
                    .first(),
                    "MSCI": session.query(SB_MSCI)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="MSCI")
                    .first(),
                    "ICB": session.query(SB_ICB)
                    .filter_by(strInstAladdin=inst_ald, strInstSectorAgy="ICB")
                    .first(),
                }
                for inst_ald in list_inst_alds
            }
        finally:
            session.close()

        # ------------------------------------------------------------------#
        # 4–8, 10 .  enrich in place on the DataFrame (row-wise, faithful logic)
        # ------------------------------------------------------------------#
        # Constants & simple columns (vectorized)
        agg_df["strReportPortfGPSCode"] = rpt_code
        agg_df["datPeriodLastDay"] = period_end
        agg_df["numReportPortfGroupID"] = group_id
        agg_df["numAuditId"] = audit
        agg_df["strSource"] = "ALP-LT"
        agg_df["AccountingDate"] = pd.to_datetime(period_end).normalize()
        agg_df["PortfolioDWHID"] = None
        agg_df["PortfolioDWHGroupID"] = group_id
        agg_df["PortfolioName"] = None
        agg_df["PortfolioCurrency"] = None
        agg_df["InstrumentDWHID"] = agg_df["numInstID"]

        # Per-row enrichments that depend on lookups (kept faithful)
        for idx_row, row in agg_df.iterrows():
            inst_ald = row["strInstAladdin"]
            inst_id = row["numInstID"]

            i = instruments.get(inst_ald)
            if lnk:
                agg_df.at[idx_row, "AladdinGroupCode"] = lnk.strPortfGroupDECALOGCode
            if i:
                agg_df.at[idx_row, "instrISOCur"] = i.strInstCurrCode
                agg_df.at[idx_row, "InstrumentName"] = i.strInstName
                agg_df.at[idx_row, "BloombergCode"] = i.strBloombergCode
                agg_df.at[idx_row, "InstrISINCode"] = i.strInstISINCode
                agg_df.at[idx_row, "InstrCouponRate"] = i.numInstCouponRate
                agg_df.at[idx_row, "InstrMaturityDate"] = i.datInstMaturityDate

                q = quotes.get(i.strInstCurrCode)
                if q:
                    agg_df.at[idx_row, "InstrExchangeRate"] = q.numccyqrateInv

                # 5 . instrumentType names
                if i.numInstTypeId in it:
                    for cls in ("1", "3", "8", "9"):
                        it_cls = it[i.numInstTypeId][cls]
                        if it_cls:
                            agg_df.at[idx_row, f"InstrumentTypeNameClass{cls}"] = it_cls.strInstrumentTypeName
                            agg_df.at[idx_row, f"InstrumentTypeIRNameClass{cls}"] = it_cls.strInstrumentTypeIRName

            # 6 . sectors
            if inst_ald in sb and sb[inst_ald].get("BB"):
                bb = sb[inst_ald]["BB"]
                agg_df.at[idx_row, "InstrSectorBBLevel1"] = bb.strInstSectorL1 or bb.strIssSector1Label
                agg_df.at[idx_row, "InstrSectorBBLevel2"] = bb.strInstSectorL2 or bb.strIssSector2Label
                agg_df.at[idx_row, "InstrSectorBBLevel3"] = bb.strInstSectorL3 or bb.strIssSector3Label

            if inst_ald in sb and sb[inst_ald].get("LH"):
                lh = sb[inst_ald]["LH"]
                agg_df.at[idx_row, "InstrSectorBarclaysLevel1"] = lh.strInstSectorL1 or lh.strIssSector1Label
                agg_df.at[idx_row, "InstrSectorBarclaysLevel2"] = lh.strInstSectorL2 or lh.strIssSector2Label
                agg_df.at[idx_row, "InstrSectorBarclaysLevel3"] = lh.strInstSectorL3 or lh.strIssSector3Label

            if inst_ald in sb and sb[inst_ald].get("MSCI"):
                ms = sb[inst_ald]["MSCI"]
                agg_df.at[idx_row, "InstrSectorMSCILevel1"] = ms.strInstSectorL1 or ms.strIssSector1Label
                agg_df.at[idx_row, "InstrSectorMSCILevel2"] = ms.strInstSectorL2 or ms.strIssSector2Label
                agg_df.at[idx_row, "InstrSectorMSCILevel3"] = ms.strInstSectorL3 or ms.strIssSector3Label

            if inst_ald in sb and sb[inst_ald].get("ICB"):
                ic = sb[inst_ald]["ICB"]
                agg_df.at[idx_row, "InstrSectorICBLevel1"] = ic.strInstSectorL1 or ic.strIssSector1Label
                agg_df.at[idx_row, "InstrSectorICBLevel2"] = ic.strInstSectorL2 or ic.strIssSector2Label
                agg_df.at[idx_row, "InstrSectorICBLevel3"] = ic.strInstSectorL3 or ic.strIssSector3Label

            # 7 . analytics / weight / market-cap tier
            a = analytics.get(inst_ald)
            q = None
            if i:
                q = quotes.get(i.strInstCurrCode)

            if a and q:
                mkt_eur = (a.nummktcap or np.nan) * q.numccyqrateInv
                agg_df.at[idx_row, "InstrMktCapEur"] = mkt_eur
            else:
                mkt_eur = None

            if ptf_agg and ptf_agg.numAUM:
                aum = ptf_agg.numAUM
                agg_df.at[idx_row, "InstrWeight"] = row["numWeightedAmtInReportPortf"] / aum
            else:
                aum = None

            tier = (
                "CR_DATA_MKTCAP1_OTHER"
                if mkt_eur is None or pd.isna(mkt_eur)
                else (
                    "CR_DATA_MKTCAP1_4_0-300M"
                    if mkt_eur <= 3e8
                    else (
                        "CR_DATA_MKTCAP1_3_300M-2.5B"
                        if mkt_eur <= 2.5e9
                        else (
                            "CR_DATA_MKTCAP1_2_2.5B-10B"
                            if mkt_eur <= 1e10
                            else "CR_DATA_MKTCAP1_1_10B-MAX"
                        )
                    )
                )
            )
            agg_df.at[idx_row, "InstrMktCapEurTr1"] = tier

            # --- analytics basic fields
            if a:
                agg_df.at[idx_row, "InstrYieldToMaturity"] = a.numInstYieldToMaturity
                agg_df.at[idx_row, "InstrEffectiveDuration"] = a.numInstEffDuration
                agg_df.at[idx_row, "InstrModifiedDuration"] = a.numInstModifDuration
                agg_df.at[idx_row, "InstrSpreadDuration"] = a.numInstSpreadDuration
                agg_df.at[idx_row, "InstrMCDuration"] = a.numInstMCDuration
                agg_df.at[idx_row, "InstrYield"] = a.numInstYield
                agg_df.at[idx_row, "InstrYieldCalculatedToMaturity"] = a.numInstYieldToCall
                agg_df.at[idx_row, "InstrYieldToMaturityPaid"] = a.numInstYieldToMaturityPaid
                agg_df.at[idx_row, "InstrYieldToMaturityReceived"] = a.numInstYieldToMaturityRecv
                agg_df.at[idx_row, "InstrOAS"] = a.numInstOptionAdjSpread

            # 8 .  look-through indicators (ind) — now from provided ind_chunk
            if not ind_chunk.empty:
                ind_row = ind_chunk[ind_chunk["strInstAladdin"] == inst_ald]
                if not ind_row.empty:
                    ind = ind_row.iloc[0]
                    agg_df.at[idx_row, "InstrEffectiveDurationContribution"] = ind["numEffectDurationContrib"]
                    agg_df.at[idx_row, "InstrMCDurationContribution"] = ind["numMCDurationContrib"]
                    agg_df.at[idx_row, "InstrModifiedDurationContribution"] = ind["numModifDurationContrib"]
                    agg_df.at[idx_row, "InstrSpreadDurationContribution"] = ind["numSpreadDurationContrib"]
                    agg_df.at[idx_row, "InstrDurExposureInPortfCur"] = ind["numDurExposureInPortfCur"]
                    agg_df.at[idx_row, "InstrCurExposureInPortfCur"] = ind["numCurExposureInPortfCur"]
                    agg_df.at[idx_row, "InstrCurExposureWeight"] = ind["numCurExposureWeight"]
                    agg_df.at[idx_row, "InstrDurExposureWeight"] = ind["numDurExposureWeight"]
                    agg_df.at[idx_row, "InstRtgSPStandardized"] = ind["strInstRtgSPStandardized"]
                    agg_df.at[idx_row, "InstRtgMDStandardized"] = ind["strInstRtgMDStandardized"]
                    agg_df.at[idx_row, "InstRtgFHStandardized"] = ind["strInstRtgFHStandardized"]
                    agg_df.at[idx_row, "InstrESGGlbScore"] = ind["numESGGlbScore"]
                    agg_df.at[idx_row, "InstrESGGlbScoreCov"] = ind["numESGGlbScoreCov"]
                    agg_df.at[idx_row, "InstrCO2IntensEVEval"] = ind["numCO2IntensEVEval"]
                    agg_df.at[idx_row, "InstrCO2IntensEVEvalCov"] = ind["numCO2IntensEVEvalCov"]
                    for k in range(1, 14):
                        colk = f"strInstRtgCustom{k}"
                        dstk = f"InstrCustomRating{k}"
                        agg_df.at[idx_row, dstk] = ind.get(colk, None)

            # 10 . dateEOM
            first_next = pd.to_datetime(period_end) + pd.offsets.MonthBegin(1)
            agg_df.at[idx_row, "dateEOM"] = first_next - pd.Timedelta(days=first_next.day)

        get_hardware_info()
        print(f"Finished processing: {len(agg_df)}")
        return agg_df.to_dict("records")
    except Exception as exc:
        print(exc)
    finally:
        if session is not None:
            session.close()


def process_alpha_records(
    df_lt: pd.DataFrame,
    df_scope_alpha: pd.DataFrame,
    df_lt_ind: pd.DataFrame,
    num_audit_id: int,
    max_workers: int = 48,
):
    # ------------------------------------------------------------------#
    # 1 .  scope filter  + audit id
    # ------------------------------------------------------------------#
    df_lt = (
        df_lt.assign(numAuditId=num_audit_id)
        .merge(
            df_scope_alpha,
            left_on=["numReportPortfGroupID", "datPeriodLastDay"],
            right_on=["numPortfGroupFkey", "datPeriodLastDay"],
            how="inner",
        )
        .query(
            "numLowestInventoryflag == 1 and strReportPortfGPSCode == 'NA' and numReportPortfGroupID != -1"
        )
    )

    key_cols = [
        "strReportPortfGPSCode",
        "datPeriodLastDay",
        "numReportPortfGroupID",
        "numAuditId",
    ]

    get_hardware_info()
    print("Groupby for df_lt")
    df_lt_groups = df_lt.groupby(key_cols)
    get_hardware_info()
    print("Groupby for df_lt")

    # Keep a print comparable to original; avoid building and using get_group repeatedly
    # Create a set of available keys in df_lt_ind for visibility
    ind_keys = set(zip(df_lt_ind["numPortfGroupFKey"], df_lt_ind["datPeriodLastDay"]))
    print(ind_keys)

    results: list = []
    future_to_batch = {}

    with ProcessPoolExecutor(max_workers=32) as executor:
        for idx, (key, chunk) in enumerate(df_lt_groups):
            (
                rpt_code,
                period_end,
                group_id,
                audit,
            ) = key

            try:
                # Instead of df_lt_ind_groups.get_group(...), slice once without groupby
                ind_chunk = df_lt_ind[
                    (df_lt_ind["numPortfGroupFKey"] == key[2]) &
                    (df_lt_ind["datPeriodLastDay"] == key[1])
                ]
                if ind_chunk.empty:
                    raise KeyError((key[2], key[1]))

                future_to_batch[
                    executor.submit(
                        single_process_alpha_records,
                        idx,
                        key,
                        chunk,
                        ind_chunk,
                    )
                ] = idx
            except KeyError as ke:
                print(
                    f"Warning: {(key[2], key[1])} is not in instrIndicators. Error message: {ke}."
                )
                future_to_batch[
                    executor.submit(
                        single_process_alpha_records,
                        idx,
                        key,
                        chunk,
                        pd.DataFrame(columns=df_lt_ind.columns),
                    )
                ] = idx

        print("Finished for loop 1.")

        for future in as_completed(future_to_batch):
            try:
                result = future.result()
                if result:
                    results.extend(result)
                    print(f"Total count {len(results)}.")
            except Exception as exc:
                batch_idx = future_to_batch[future]
                print(f"Batch {batch_idx} generated an exception: {exc}")

    if len(results) == 0:
        return pd.DataFrame(columns=list(DMIRAPILTHolding.__table__.columns.keys()))
    return pd.DataFrame(results)

