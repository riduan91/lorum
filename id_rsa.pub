def compute_bench_indicators_bkgn_10(df7: pd.DataFrame) -> pd.DataFrame:
    """
    Vectorized BKGN-10 that matches A/B/C/D logic AND preserves the original
    astype(float)/fillna semantics before multiplications.
    """
    if df7 is None or df7.empty:
        return pd.DataFrame()

    group_keys = [
        "numBenchFBAId",
        "strCompositionCd",
        "datReportingDay",
        "strPeriodTypeFlag",
        "strPFCurrencyISOCode",
    ]
    needed_cols = group_keys + [
        "strInstAladdin",
        "numCurExposureInBenchCur",
        "numDurExposureInBenchCur",
        "numDurExposureWeight",
        "numModifDurationContribWeight",
        "numweight",
    ]
    df7 = df7[needed_cols].copy()
    df7["datReportingDay"] = pd.to_datetime(df7["datReportingDay"])

    out_all_days = []

    for day in df7["datReportingDay"].drop_duplicates().sort_values():
        day_slice = df7[df7["datReportingDay"] == day].copy()

        # ---- pull analytics + instrument + type for the day
        s = get_session()
        try:
            q = (
                s.query(
                    DMIRBRSInstAnalytic.strInstAladdin,
                    DMIRBRSInstAnalytic.numInstEffDuration,
                    DMIRBRSInstAnalytic.numInstModifDuration,
                    DMIRBRSInstAnalytic.numInstMCDuration,
                    DMIRBRSInstAnalytic.numInstYieldToMaturity,
                    DMIRBRSInstAnalytic.numInstConvexity,
                    DMIRBRSInstAnalytic.numInstSpreadDuration,
                    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
                    DMIRBRSInstAnalytic.numyldtoworst,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstrument.strInstIssuerCode,
                    DMIRBRSInstrument.numInstCouponRate,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.datInstCallDate,
                    DMIRBRSInstrument.numInstTypeId,
                    DMIRBRSInstrument.blncall,
                    DMIRInstrumentIRType.strReportingType,
                    DMIRInstrumentIRType.strInstrumentTypeIRName,
                )
                .select_from(DMIRBRSInstAnalytic)
                .outerjoin(
                    DMIRBRSInstrument,
                    DMIRBRSInstAnalytic.strInstAladdin == DMIRBRSInstrument.strInstAladdin,
                )
                .outerjoin(
                    DMIRInstrumentIRType,
                    DMIRBRSInstrument.numInstTypeId == DMIRInstrumentIRType.numInstrTypeID,
                )
                .filter(DMIRBRSInstAnalytic.datInstQuotationDate == day)
            )
            dfA = get_all_as_df(q)
        finally:
            safe_close(s)

        if dfA.empty:
            continue

        dfA["datInstQuotationDate"] = pd.to_datetime(dfA["datInstQuotationDate"])
        dfA["blncall"] = dfA["blncall"].fillna(0).astype("int8", copy=False)

        merged = day_slice.merge(
            dfA,
            how="left",
            left_on=["strInstAladdin", "datReportingDay"],
            right_on=["strInstAladdin", "datInstQuotationDate"],
        ).drop(columns=["datInstQuotationDate"], errors="ignore")

        # helper: exact float casting like the original (and optional fillna(0))
        def f(col, fill0=False):
            s = pd.to_numeric(merged[col], errors="coerce").astype(float)
            return s.fillna(0.0) if fill0 else s

        # ---- maturity (vectorized) with call override; weighted by numweight (casted)
        rep  = merged["datReportingDay"]
        mat  = pd.to_datetime(merged["datInstMaturityDate"])
        call = pd.to_datetime(merged["datInstCallDate"])
        bln  = merged["blncall"].fillna(0).astype("int8")

        after_rep = mat.notna() & (mat > rep)
        call_mask = (bln == 1) & call.notna()
        days_to = np.where(
            call_mask, (call - rep).dt.days.astype(float),
            np.where(after_rep, (mat - rep).dt.days.astype(float), 0.0),
        )
        merged["maturity_weighted"] = days_to * f("numweight", fill0=False)

        # =========================
        # A) ALL INSTRUMENTS (SUMS)
        # =========================
        merged["curExposureBench"]    = f("numCurExposureInBenchCur")
        merged["durExposureBench"]    = f("numDurExposureInBenchCur")

        merged["effectDurationBench"] = f("numInstEffDuration")    * f("numDurExposureWeight")
        merged["modifDurationBench"]  = f("numInstModifDuration")  * f("numDurExposureWeight")
        merged["MCDurationBench"]     = f("numInstMCDuration")     * f("numDurExposureWeight")
        merged["benchAvgCoupon"]      = f("numInstCouponRate")     * f("numweight")
        merged["benchAvgYTM"]         = f("numInstYieldToMaturity")* f("numDurExposureWeight")
        merged["benchAvgConvexity"]   = f("numInstConvexity")      * f("numDurExposureWeight")
        merged["spreadDurationBench"] = f("numInstSpreadDuration") * f("numDurExposureWeight")

        # original had fillna(0) on OAS and DTS multipliers
        merged["benchAvgOas"] = f("numInstOptionAdjSpread").fillna(0.0) * f("numDurExposureWeight").fillna(0.0)
        merged["benchAvgDts"] = (
            f("numInstOptionAdjSpread").fillna(0.0)
            * f("numInstSpreadDuration").fillna(0.0)
            * f("numDurExposureWeight").fillna(0.0)
        )

        merged["benchAvgYTMDurWeighted"] = f("numInstYieldToMaturity") * f("numModifDurationContribWeight")
        merged["benchAvgYieldWorst"]     = f("numyldtoworst")          * f("numDurExposureWeight")

        agg_all = (
            merged.groupby(group_keys, as_index=False)
            .agg(
                curExposureBench=("curExposureBench", "sum"),
                durExposureBench=("durExposureBench", "sum"),
                effectDurationBench=("effectDurationBench", "sum"),
                modifDurationBench=("modifDurationBench", "sum"),
                MCDurationBench=("MCDurationBench", "sum"),
                benchAvgCoupon=("benchAvgCoupon", "sum"),
                benchAvgYTM=("benchAvgYTM", "sum"),
                benchAvgConvexity=("benchAvgConvexity", "sum"),
                spreadDurationBench=("spreadDurationBench", "sum"),
                benchAvgOas=("benchAvgOas", "sum"),
                benchAvgDts=("benchAvgDts", "sum"),
                benchAvgYTMDurWeighted=("benchAvgYTMDurWeighted", "sum"),
                benchAvgYieldWorst=("benchAvgYieldWorst", "sum"),
                maturity_weighted=("maturity_weighted", "sum"),
                numNumberOfIssuers=("strInstIssuerCode", pd.Series.nunique),
            )
        )
        agg_all["datBenchAvgMaturityLife"] = pd.NaT
        mpos = agg_all["maturity_weighted"] > 0
        agg_all.loc[mpos, "datBenchAvgMaturityLife"] = (
            agg_all.loc[mpos, "datReportingDay"]
            + pd.to_timedelta(agg_all.loc[mpos, "maturity_weighted"], unit="D")
        )
        agg_all.drop(columns=["maturity_weighted"], inplace=True)

        # ===========================================
        # B) FI FAMILY (class4 + three FI type names)
        #     -> averages by sum(numweight)
        # ===========================================
        mask_b = (
            (merged["strReportingType"] == "class4")
            & (merged["strInstrumentTypeIRName"].isin(
                ["Derivatives - Fixed Income", "Fixed Income", "MF - Fixed Income"]
            ))
            & merged["strInstAladdin"].notna()
        )
        fi_b = merged.loc[mask_b, [
            *group_keys, "strInstIssuerCode",
            "numweight","numDurExposureWeight","numModifDurationContribWeight",
            "numInstEffDuration","numInstModifDuration","numInstMCDuration",
            "numInstYieldToMaturity","numInstConvexity","numInstSpreadDuration",
            "numInstOptionAdjSpread","numyldtoworst"
        ]].copy()

        if not fi_b.empty:
            # cast on-the-fly like original
            wd = pd.to_numeric(fi_b["numDurExposureWeight"], errors="coerce").astype(float)
            wm = pd.to_numeric(fi_b["numModifDurationContribWeight"], errors="coerce").astype(float)
            w  = pd.to_numeric(fi_b["numweight"], errors="coerce").astype(float)

            fi_b["effDurationBenchFI_sum"]       = pd.to_numeric(fi_b["numInstEffDuration"],    errors="coerce").astype(float) * wd
            fi_b["modifDurationBenchFI_sum"]     = pd.to_numeric(fi_b["numInstModifDuration"],  errors="coerce").astype(float) * wd
            fi_b["MCDurationBenchFI_sum"]        = pd.to_numeric(fi_b["numInstMCDuration"],     errors="coerce").astype(float) * wd
            fi_b["benchAvgYTMFI_sum"]            = pd.to_numeric(fi_b["numInstYieldToMaturity"],errors="coerce").astype(float) * wd
            fi_b["benchAvgConvexityFI_sum"]      = pd.to_numeric(fi_b["numInstConvexity"],      errors="coerce").astype(float) * wd
            fi_b["spreadDurationBenchFI_sum"]    = pd.to_numeric(fi_b["numInstSpreadDuration"], errors="coerce").astype(float) * wd
            fi_b["benchAvgYTMDurWeightedFI_sum"] = pd.to_numeric(fi_b["numInstYieldToMaturity"],errors="coerce").astype(float) * wm
            fi_b["benchAvgYieldWorstFI_sum"]     = pd.to_numeric(fi_b["numyldtoworst"],         errors="coerce").astype(float) * wd
            fi_b["benchAvgOasFI_sum"]            = pd.to_numeric(fi_b["numInstOptionAdjSpread"],errors="coerce").astype(float).fillna(0.0) * wd.fillna(0.0)
            fi_b["benchAvgDtsFI_sum"] = (
                pd.to_numeric(fi_b["numInstOptionAdjSpread"], errors="coerce").astype(float).fillna(0.0)
                * pd.to_numeric(fi_b["numInstSpreadDuration"], errors="coerce").astype(float).fillna(0.0)
                * wd.fillna(0.0)
            )

            agg_b = (
                fi_b.groupby(group_keys, as_index=False)
                .agg(
                    sum_w=("numweight", "sum"),
                    numNumberOfIssuersFI=("strInstIssuerCode", pd.Series.nunique),
                    numEffectDurationBenchFI=("effDurationBenchFI_sum", "sum"),
                    numModifDurationBenchFI=("modifDurationBenchFI_sum", "sum"),
                    numMCDurationBenchFI=("MCDurationBenchFI_sum", "sum"),
                    numBenchAvgYTMFI=("benchAvgYTMFI_sum", "sum"),
                    numBenchAvgConvexityFI=("benchAvgConvexityFI_sum", "sum"),
                    numSpreadDurationBenchFI=("spreadDurationBenchFI_sum", "sum"),
                    numBenchAvgYTMDurWeightedFI=("benchAvgYTMDurWeightedFI_sum", "sum"),
                    numBenchAvgYieldWorstFI=("benchAvgYieldWorstFI_sum", "sum"),
                    numBenchAvgOasFI=("benchAvgOasFI_sum", "sum"),
                    numBenchAvgDtsFI=("benchAvgDtsFI_sum", "sum"),
                )
            )
            for col in [
                "numEffectDurationBenchFI","numModifDurationBenchFI","numMCDurationBenchFI",
                "numBenchAvgYTMFI","numBenchAvgConvexityFI","numSpreadDurationBenchFI",
                "numBenchAvgYTMDurWeightedFI","numBenchAvgYieldWorstFI","numBenchAvgOasFI","numBenchAvgDtsFI",
            ]:
                agg_b[col] = np.where(agg_b["sum_w"] != 0, agg_b[col] / agg_b["sum_w"], np.nan)
            agg_b.drop(columns=["sum_w"], inplace=True)
        else:
            agg_b = pd.DataFrame(columns=group_keys + [
                "numNumberOfIssuersFI","numEffectDurationBenchFI","numModifDurationBenchFI","numMCDurationBenchFI",
                "numBenchAvgYTMFI","numBenchAvgConvexityFI","numSpreadDurationBenchFI",
                "numBenchAvgYTMDurWeightedFI","numBenchAvgYieldWorstFI","numBenchAvgOasFI","numBenchAvgDtsFI",
            ])

        # ===========================================================
        # C) FI-only (class4 + 'Fixed Income' + numInstTypeId != 506)
        #     -> coupon average & FI maturity life (weighted by numweight)
        # ===========================================================
        mask_c = (
            (merged["strReportingType"] == "class4")
            & (merged["strInstrumentTypeIRName"] == "Fixed Income")
            & (merged["numInstTypeId"] != 506)
            & merged["strInstAladdin"].notna()
        )
        fi_c = merged.loc[mask_c, [*group_keys, "numweight", "numInstCouponRate", "maturity_weighted"]].copy()

        if not fi_c.empty:
            w = pd.to_numeric(fi_c["numweight"], errors="coerce").astype(float)
            fi_c["benchAvgCouponFI_weighted"] = pd.to_numeric(fi_c["numInstCouponRate"], errors="coerce").astype(float) * w

            agg_c = (
                fi_c.groupby(group_keys, as_index=False)
                .agg(
                    sum_w=("numweight", "sum"),
                    sum_coupon=("benchAvgCouponFI_weighted", "sum"),
                    sum_maturity_weighted=("maturity_weighted", "sum"),
                    datReportingDay=("datReportingDay", "first"),
                )
            )
            agg_c["numBenchAvgCouponFI"] = np.where(
                agg_c["sum_w"] != 0, agg_c["sum_coupon"] / agg_c["sum_w"], np.nan
            )
            agg_c["datBenchAvgMaturityLifeFI"] = pd.NaT
            mask_pos = (agg_c["sum_w"] != 0) & (agg_c["sum_maturity_weighted"] > 0)
            agg_c.loc[mask_pos, "datBenchAvgMaturityLifeFI"] = (
                agg_c.loc[mask_pos, "datReportingDay"]
                + pd.to_timedelta(
                    agg_c.loc[mask_pos, "sum_maturity_weighted"] / agg_c.loc[mask_pos, "sum_w"],
                    unit="D",
                )
            )
            agg_c = agg_c[group_keys + ["numBenchAvgCouponFI", "datBenchAvgMaturityLifeFI"]]
        else:
            agg_c = pd.DataFrame(columns=group_keys + ["numBenchAvgCouponFI", "datBenchAvgMaturityLifeFI"])

        # ===============================
        # D) Holdings count (exclude Cash)
        # ===============================
        mask_d = (merged["strReportingType"] == "class4") & (merged["strInstrumentTypeIRName"] != "Cash")
        agg_d = (
            merged.loc[mask_d]
            .groupby(group_keys)["strInstAladdin"]
            .nunique()
            .reset_index(name="numHoldingsNumber")
        )

        out_day = (
            agg_all
            .merge(agg_b, on=group_keys, how="left")
            .merge(agg_c, on=group_keys, how="left")
            .merge(agg_d, on=group_keys, how="left")
        )
        out_all_days.append(out_day)

    if not out_all_days:
        return pd.DataFrame()

    df10 = pd.concat(out_all_days, ignore_index=True)

    # final order + renames
    final_columns = [
        "numBenchFBAId","strCompositionCd","datReportingDay","strPeriodTypeFlag","strPFCurrencyISOCode",
        "curExposureBench","durExposureBench","effectDurationBench","modifDurationBench","MCDurationBench",
        "benchAvgCoupon","benchAvgYTM","benchAvgConvexity","datBenchAvgMaturityLife","numHoldingsNumber",
        "spreadDurationBench",
        "numEffectDurationBenchFI","numModifDurationBenchFI","numMCDurationBenchFI","numBenchAvgCouponFI",
        "numBenchAvgYTMFI","numBenchAvgConvexityFI","datBenchAvgMaturityLifeFI","numSpreadDurationBenchFI",
        "benchAvgYTMDurWeighted","numBenchAvgYTMDurWeightedFI","benchAvgYieldWorst","numBenchAvgYieldWorstFI",
        "benchAvgOas","numBenchAvgOasFI","numNumberOfIssuersFI","benchAvgDts","numBenchAvgDtsFI","numNumberOfIssuers",
    ]
    df10 = df10.reindex(columns=[c for c in final_columns if c in df10.columns]).rename(columns={
        "curExposureBench": "numCurExposureBench",
        "durExposureBench": "numDurExposureBench",
        "effectDurationBench": "numEffectDurationBench",
        "modifDurationBench": "numModifDurationBench",
        "MCDurationBench": "numMCDurationBench",
        "benchAvgCoupon": "numBenchAvgCoupon",
        "benchAvgYTM": "numBenchAvgYTM",
        "benchAvgConvexity": "numBenchAvgConvexity",
        "spreadDurationBench": "numSpreadDurationBench",
        "benchAvgYTMDurWeighted": "numBenchAvgYTMDurWeighted",
        "benchAvgYieldWorst": "numBenchAvgYieldWorst",
        "benchAvgOas": "numBenchAvgOas",
        "benchAvgDts": "numBenchAvgDts",
    })

    return df10
