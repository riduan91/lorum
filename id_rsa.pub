import polars as pl
import pandas as pd

def _is_pl(df) -> bool:
    """True if df is a Polars DataFrame (or LazyFrame)."""
    return isinstance(df, (pl.DataFrame, pl.LazyFrame))


def _left_join(df_left, df_right, *, on=None,
               left_on=None, right_on=None, how="left"):
    """
    A very small abstraction so we can call one function
    instead of branching on every merge / join.
    """
    if _is_pl(df_left):
        return df_left.join(
            df_right,
            how=how,
            on=on,
            left_on=left_on,
            right_on=right_on,
        )
    else:  # pandas
        return pd.merge(
            df_left, df_right,
            how=how,
            on=on,
            left_on=left_on,
            right_on=right_on,
            suffixes=("", "_y")
        )


def process_merge_chunk_bkgn_2(i, df_a_chunk, df_inst_subq, df_inst_analytic):
    """Merge a‑chunk with instrument meta & analytics (Pandas or Polars)."""
    print(f"Merging instr analytics for chunk {i}")

    # ------------ 1) join with instrument “sub‑query” ------------
    keep_cols = [
        "strInstAladdin", "numInstID",
        "strInstrumentTypeIRName",
        "numInstUndrlygQty", "strInstPriceType",
    ]
    if _is_pl(df_inst_subq):
        df_inst_subq_cp = df_inst_subq.select(keep_cols) if df_inst_subq.height else \
                          pl.DataFrame(schema=[(c, pl.Null) for c in keep_cols])
    else:
        df_inst_subq_cp = df_inst_subq[keep_cols] if not df_inst_subq.empty else \
                          pd.DataFrame(columns=keep_cols)

    merged = _left_join(df_a_chunk, df_inst_subq_cp, on="strInstAladdin")

    # ------------ 2) join with analytics ------------
    if _is_pl(df_inst_analytic):
        if df_inst_analytic.height == 0:
            df_inst_analytic = pl.DataFrame(
                schema=[
                    ("strInstAladdin", pl.Utf8),
                    ("datInstQuotationDate", pl.Date),
                    ("numInstConvexity", pl.Float64),
                    ("numInstModifDuration", pl.Float64),
                    ("numInstMCDuration", pl.Float64),
                    ("numInstSpreadDuration", pl.Float64),
                    ("numInstEffDuration", pl.Float64),
                ]
            )
    else:
        if df_inst_analytic.empty:
            df_inst_analytic = pd.DataFrame(
                columns=[
                    "strInstAladdin", "datInstQuotationDate",
                    "numInstConvexity", "numInstModifDuration",
                    "numInstMCDuration", "numInstSpreadDuration",
                    "numInstEffDuration",
                ]
            )

    merged = _left_join(
        merged,
        df_inst_analytic,
        left_on=["strInstAladdin", "datReportingDay"],
        right_on=["strInstAladdin", "datInstQuotationDate"],
    )

    # ------------ 3) drop unneeded cols ------------
    drop_cols = [
        "datInstQuotationDate", "numInstID",
        "strExtCode", "numCurrencyId", "numCurrencyID", "datccyqDate",
    ]
    if _is_pl(merged):
        present = [c for c in drop_cols if c in merged.columns]
        merged = merged.drop(present)
    else:
        merged = merged.drop(columns=[c for c in drop_cols if c in merged.columns])

    return merged


def compute_instr_indicators_bkgn_2(df_tblDMIRBKGN):
    """
    Second step – now works with Pandas *or* Polars input.
    Returns the same frame type it received.
    """
    if df_tblDMIRBKGN is None or len(df_tblDMIRBKGN) == 0:
        return pl.DataFrame() if _is_pl(df_tblDMIRBKGN) else pd.DataFrame()

    is_pl = _is_pl(df_tblDMIRBKGN)
    df_a = (
        df_tblDMIRBKGN
        .select if is_pl else df_tblDMIRBKGN.loc[:, :]
    )
    # ---- column subset ----
    sub_cols = [
        "numBenchFBAId", "strCompositionCd", "strPeriodTypeFlag",
        "datReportingDay", "numPFCurrencyRate", "strPFCurrencyISOCode",
        "datval", "strInstAladdin", "numInstId", "codinscurid",
        "numweight", "numinslclcurpri", "numinsqty", "numlclcurmktcap",
        "numusdmktcap", "numeurmktcap",
    ]
    df_a = df_a[sub_cols] if not is_pl else df_a(sub_cols)

    # ---- currency merge ----
    # pandas or polars → same helper
    session = get_local_session()
    currency_query = session.query(
        DMIRTypCurrency.strExtCode, DMIRTypCurrency.numCurrencyId
    ).filter(
        DMIRTypCurrency.strExtCode.in_(
            df_a["codinscurid"].unique().to_list() if is_pl 
            else df_a["codinscurid"].unique().tolist()
        )
    )
    df_typ_currency = get_all_as_df(currency_query)   # pandas
    if is_pl:
        df_typ_currency = pl.from_pandas(df_typ_currency)

    df_a = _left_join(
        df_a, df_typ_currency.select(["strExtCode", "numCurrencyId"]),
        left_on="codinscurid", right_on="strExtCode"
    )

    # ---- currency quotes (parallel) ----
    valid_dates = (
        df_a["datval"].unique().to_list() if is_pl else df_a["datval"].unique().tolist()
    )
    valid_currency_ids = (
        df_typ_currency["numCurrencyId"].drop_nulls().cast(pl.Int64).unique().to_list()
        if is_pl else
        df_typ_currency["numCurrencyId"].dropna().astype(int).unique().tolist()
    )

    quote_results = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=32) as ex:
        fut = {
            ex.submit(get_currency_quotes_for_date, valid_currency_ids, d): d
            for d in valid_dates
        }
        for f in concurrent.futures.as_completed(fut):
            quote_results.extend(f.result())

    df_currency_quote = pd.DataFrame(quote_results)
    df_currency_quote["datccyqDate"] = pd.to_datetime(df_currency_quote["datccyqDate"])
    if is_pl:
        df_currency_quote = pl.from_pandas(df_currency_quote)

    df_a = _left_join(
        df_a,
        df_currency_quote.select(["numCurrencyID", "datccyqDate", "numccyqRate"]),
        left_on=["numCurrencyId", "datval"],
        right_on=["numCurrencyID", "datccyqDate"],
    )

    # ---- instrument & analytics (reuse helpers) ----
    valid_aladdin = (
        df_a["strInstAladdin"].unique().to_list() if is_pl else
        df_a["strInstAladdin"].unique().tolist()
    )
    num_cpus = os.cpu_count() or 4
    chunk_size = max(1, min(2000, len(valid_aladdin) // (num_cpus * 2)))
    chunks = [valid_aladdin[i:i + chunk_size] for i in range(0, len(valid_aladdin), chunk_size)]

    instrument_results, analytics_results = [], []
    with concurrent.futures.ProcessPoolExecutor(max_workers=32) as ex:
        inst_fut = {
            ex.submit(single_compute_instr_indicators_bkgn_2_instruments, i, ch): i
            for i, ch in enumerate(chunks)
        }
        anal_fut = {
            ex.submit(get_analytics_for_instruments, i, ch,
                      df_a["datReportingDay"].unique().tolist() if not is_pl
                      else df_a["datReportingDay"].unique().to_list()): i
            for i, ch in enumerate(chunks)
        }
        for f in concurrent.futures.as_completed(inst_fut):
            instrument_results.extend(f.result())
        for f in concurrent.futures.as_completed(anal_fut):
            analytics_results.extend(f.result())

    df_inst = pd.DataFrame(instrument_results)
    df_inst_analytic = pd.DataFrame(analytics_results)
    if is_pl:
        df_inst = pl.from_pandas(df_inst)
        df_inst_analytic = pl.from_pandas(df_inst_analytic)

    # ---- load IRType, deduplicate to “sub‑query” ----
    ir_rows = [
        {c.name: getattr(r, c.name)
         for c in DMIRInstrumentIRType.__table__.columns
         if c.name != "_sa_instance_state"}
        for r in session.query(DMIRInstrumentIRType)
                .filter(DMIRInstrumentIRType.strReportingType == "class7")
    ]
    df_inst_ir = pl.from_pandas(pd.DataFrame(ir_rows)) if is_pl else pd.DataFrame(ir_rows)

    df_inst_merged = _left_join(
        df_inst, df_inst_ir,
        left_on="numInstTypeId", right_on="numInstrTypeID"
    )

    dedup_cols = [
        "strInstAladdin", "numInstID",
        "strInstrumentTypeIRName", "numInstUndrlygQty", "strInstPriceType"
    ]
    df_inst_subq = (
        df_inst_merged.unique(subset=dedup_cols) if is_pl
        else df_inst_merged.drop_duplicates(subset=dedup_cols)
    )

    # ---- split df_a (just one chunk today) & merge ----
    merged_chunks = []
    for idx, df_chunk in enumerate([df_a] if is_pl else np.array_split(df_a, 1)):
        merged = process_merge_chunk_bkgn_2(
            idx, df_chunk, df_inst_subq, df_inst_analytic
        )
        merged_chunks.append(merged)

    out_df = (
        pl.concat(merged_chunks) if is_pl else
        pd.concat(merged_chunks, ignore_index=True)
    )
    return out_df
