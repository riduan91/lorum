import pandas as pd
import numpy as np
import gc

def process_final_step_3(
    df_DMIRTransparizLTWrk: pd.DataFrame,
    df_instrument: pd.DataFrame,
    df_instrument_irtype: pd.DataFrame,
):
    # --- Schema tightening: dtypes & categories -----------------------
    print("start df_DMIRTransparizLTWrk", df_DMIRTransparizLTWrk.shape, get_hardware_info())

    cat_cols = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID",
        "strInvestedInPortfISOCur","strInvestedInPortfID"
    ]
    for c in cat_cols:
        if c in df_DMIRTransparizLTWrk.columns and df_DMIRTransparizLTWrk[c].dtype == object:
            df_DMIRTransparizLTWrk[c] = df_DMIRTransparizLTWrk[c].astype("category")

    for c in ["numReportLevelID","numInventoryLevel","numInstID","numUndrlygIRLTflag",
              "numPresUndrlygHoldData"]:
        if c in df_DMIRTransparizLTWrk.columns and not pd.api.types.is_integer_dtype(df_DMIRTransparizLTWrk[c]):
            df_DMIRTransparizLTWrk[c] = pd.to_numeric(df_DMIRTransparizLTWrk[c], errors="coerce").astype("Int32")

    for c in ["numWeightedAmtInReportPortf","numWeightedQtqInReportPortf"]:
        if c in df_DMIRTransparizLTWrk.columns and not pd.api.types.is_float_dtype(df_DMIRTransparizLTWrk[c]):
            df_DMIRTransparizLTWrk[c] = pd.to_numeric(df_DMIRTransparizLTWrk[c], errors="coerce").astype("Float32")

    print("after dtype tightening", df_DMIRTransparizLTWrk.shape, get_hardware_info())

    # --- Prep lookup of lowest-level rows -----------------------------
    base_cols = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur","numReportLevelID"
    ]
    df_lkp = (
        df_DMIRTransparizLTWrk.loc[df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 1, base_cols]
        .drop_duplicates()
    )
    print("df_lkp", df_lkp.shape, get_hardware_info())

    # ---------- PART 1  (exact four-key join) -------------------------
    cond_master = (
        (df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 0) &
        (
            df_DMIRTransparizLTWrk["strInvestedInPortfID"].isna()
            | (df_DMIRTransparizLTWrk["numUndrlygIRLTflag"] == 0)
            | (df_DMIRTransparizLTWrk["numPresUndrlygHoldData"] == 0)
        )
    )
    join_keys = [
        "strReportPeriod","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur"
    ]
    part1 = pd.merge(
        df_DMIRTransparizLTWrk.loc[cond_master, join_keys],
        df_lkp[join_keys + ["numReportLevelID"]],
        on=join_keys,
        how="left",
        sort=False,
    ).rename(columns={"numReportLevelID": "numReportLevelID_lkp"})
    print("part1", part1.shape, get_hardware_info())
    gc.collect(); get_hardware_info()

    # ---------- PART 2  (hierarchical LIKE join, prefix-explode) -----
    cond_part2 = (
        (df_DMIRTransparizLTWrk["numLowestInventoryflag"] == 0)
        & df_DMIRTransparizLTWrk["strInvestedInPortfID"].notna()
        & (df_DMIRTransparizLTWrk["numUndrlygIRLTflag"] == 1)
        & (df_DMIRTransparizLTWrk["numPresUndrlygHoldData"] == 1)
    )

    df_part2 = df_DMIRTransparizLTWrk.loc[cond_part2, join_keys + ["strInvestedInPortfID"]].copy()
    print("part2 seed", df_part2.shape, get_hardware_info())

    parent_prefix = (df_part2["strPortfLevelID"].astype(str) + "." + df_part2["strInvestedInPortfID"].astype(str))

    def _ancestors(s: str):
        parts = s.split(".")
        out = []
        cur = []
        for p in parts[:-1]:  # exclude the last element (the child)
            cur.append(p)
            out.append(".".join(cur))
        return out

    df_part2 = df_part2.assign(_anc=parent_prefix.astype(str).map(_ancestors))
    df_part2 = df_part2.explode("_anc", ignore_index=True)
    df_part2 = df_part2[df_part2["_anc"].notna()]
    print("part2 exploded", df_part2.shape, get_hardware_info())

    lkp_like = df_lkp.rename(columns={"strPortfLevelID": "_anc"})  # re-use memory
    prelim_like = pd.merge(
        df_part2,
        lkp_like[["_anc","strReportPeriod","strInvestedInInstrID","strInvestedInPortfISOCur","numReportLevelID"]],
        on=["_anc","strReportPeriod","strInvestedInInstrID","strInvestedInPortfISOCur"],
        how="inner",
        sort=False,
    )
    print("prelim_like", prelim_like.shape, get_hardware_info())

    min_levels = (
        prelim_like.groupby(join_keys, as_index=False)["numReportLevelID"].min()
        .rename(columns={"numReportLevelID": "numReportLevelID_lkp"})
    )
    print("min_levels", min_levels.shape, get_hardware_info())

    del prelim_like, df_part2
    gc.collect(); get_hardware_info()

    part2_final = pd.merge(
        df_DMIRTransparizLTWrk.loc[cond_part2, join_keys],
        min_levels,
        on=join_keys,
        how="left",
        sort=False,
    )
    print("part2_final", part2_final.shape, get_hardware_info())

    # ---------- UNION the two branches -------------------------------
    df_step_final_3 = pd.concat([part1, part2_final], ignore_index=True)
    print("df_step_final_3", df_step_final_3.shape, get_hardware_info())
    del part1, part2_final, min_levels
    gc.collect(); get_hardware_info()

    # ---------- Update main table ------------------------------------
    join_keys_full = [
        "strReportPeriod","numInventoryLevel","strPortfLevelID","strInvestedInInstrID","strInvestedInPortfISOCur",
    ]
    tmp_join = pd.merge(
        df_DMIRTransparizLTWrk[join_keys_full],
        df_step_final_3[join_keys + ["numReportLevelID_lkp"]],
        on=join_keys,
        how="left",
        sort=False,
    )[join_keys_full + ["numReportLevelID_lkp"]]
    print("tmp_join", tmp_join.shape, get_hardware_info())

    df_updated = pd.merge(
        df_DMIRTransparizLTWrk,
        tmp_join,
        on=join_keys_full,
        how="left",
        sort=False,
    )
    print("df_updated (post-join)", df_updated.shape, get_hardware_info())

    del df_step_final_3, tmp_join
    gc.collect(); get_hardware_info()

    changed = df_updated["numReportLevelID_lkp"].notna()
    df_updated["numReportLevelID"] = df_updated["numReportLevelID"].where(~changed, df_updated["numReportLevelID_lkp"])
    df_updated.loc[changed, "datLastModifDate"] = pd.Timestamp.now()
    df_updated.drop(columns="numReportLevelID_lkp", inplace=True)
    print("df_updated (after upsert)", df_updated.shape, get_hardware_info())

    # --- Deletion 1 ---------------------------------------------------
    df_updated = df_updated.loc[
        ~(
            (df_updated["numInstID"].fillna(-1) == -1)
            & (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
        )
    ]
    print("df_updated (after deletion1)", df_updated.shape, get_hardware_info())

    # --- Deletion 2 (Forex class7) -----------------------------------
    if df_instrument_irtype.empty:
        df_instrument_irtype = pd.DataFrame(
            columns=["numInstrTypeID", "strReportingType", "strInstrumentTypeIRName"]
        )

    forex_type_ids = df_instrument_irtype.loc[
        (df_instrument_irtype["strReportingType"] == "class7")
        & (df_instrument_irtype["strInstrumentTypeIRName"] == "Forex"),
        "numInstrTypeID",
    ].unique()

    inst_map = df_instrument.drop_duplicates("numInstID").set_index("numInstID")["numInstTypeId"]
    df_updated["numInstTypeId"] = df_updated["numInstID"].map(inst_map)
    print("df_updated (mapped inst type)", df_updated.shape, get_hardware_info())

    mask_forex = (
        df_updated["numInstTypeId"].isin(forex_type_ids)
        & (df_updated["numWeightedQtqInReportPortf"].fillna(0) == 0.0)
        & (df_updated["numWeightedAmtInReportPortf"].fillna(0) == 0.0)
    )
    df_updated = df_updated.loc[~mask_forex].drop(columns="numInstTypeId")
    print("df_updated (final)", df_updated.shape, get_hardware_info())

    return df_updated
