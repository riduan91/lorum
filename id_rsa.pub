# ───────────────────────────────────────────────────────────────
# 1)  Vectorised lookup of FX quotes
# ───────────────────────────────────────────────────────────────
# quotes_dict:  {(dat, iso_cur) : rate, …}

# helper that turns the two columns into tuple keys and maps directly
def _map_rates(df, date_col, cur_col):
    return pd.Series(
        [quotes_dict.get(k)                           # O(1) dict lookup
         for k in zip(df[date_col].values,
                      df[cur_col].values)],
        index=df.index,                               # keep the original order
        dtype="float64",                              # avoids object column
    )

df["rate_inst"]  = _map_rates(df, "datHoldDate", "strInstISOCur")
df["rate_portf"] = _map_rates(df, "datHoldDate", "strPortfISOCur")

# If the dict is very large and you do this often, create it once as a
# MultiIndex Series and join instead – that’s still fully vectorised and
# avoids the Python‑level for‑loop above.

# ───────────────────────────────────────────────────────────────
# 2)  Boolean mask for rows that need the cross‑currency calc
# ───────────────────────────────────────────────────────────────
cond_cat   = df["strInstCatName"] != "CONTRACT CN CURRENCY"
cond_portf = df["strInvestedInPortfName"].str.startswith("EXTERNAL FUND HEDGING")
cond_rate  = df["rate_portf"].notna() & (df["rate_portf"] != 0)

mask = (cond_cat | cond_portf) & cond_rate

# ───────────────────────────────────────────────────────────────
# 3)  Final vectorised division (with np.where if you want to keep old values)
# ───────────────────────────────────────────────────────────────
df["numHoldCrossCur"] = np.where(
    mask,
    df["rate_inst"].to_numpy(dtype="float64") / df["rate_portf"].to_numpy(dtype="float64"),
    df.get("numHoldCrossCur", np.nan)   # preserve existing values / NaNs
)

print("compute_cross_cur finished.")  # same log line as before
session.close()
return df
