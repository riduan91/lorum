from __future__ import annotations

import re
from concurrent.futures import ProcessPoolExecutor, as_completed
from typing import Callable, Iterable, Any, Tuple

from sqlalchemy import create_engine, text
from sqlalchemy.orm import sessionmaker


# ──────────────────────────────
# Worker executed in each process
# ──────────────────────────────
def _lookup_worker(
    conn_str: str,
    lookup_sql: str,
    row: dict[str, Any],
    param_cols: list[str] | None,
    transform: Callable[[dict], dict] | None,
) -> Tuple[bool, dict[str, Any]]:
    """Return (matched?, row_or_extended_row)."""
    engine = create_engine(conn_str, future=True)
    Session = sessionmaker(bind=engine, future=True)

    if param_cols:
        params = {col: row.get(col) for col in param_cols}
    else:
        used_keys = set(re.findall(r":(\w+)", lookup_sql))
        params = {k: row[k] for k in used_keys} if used_keys else row

    with Session() as session:
        result = session.execute(text(lookup_sql), params).fetchone()

    if result:
        extended = row.copy()
        extended.update(dict(result))
        if transform:
            extended = transform(extended)
        return True, extended

    return False, row


# ──────────────────────────────────────────────────────────────────────────────
# Public API that uses as_completed
# ──────────────────────────────────────────────────────────────────────────────
def join_with_db_per_row_parallel(
    conn_str: str,
    records: Iterable[dict[str, Any]],
    lookup_sql: str,
    param_cols: list[str] | None = None,
    transform: Callable[[dict], dict] | None = None,
    return_rejected: bool = False,
    *,
    max_workers: int | None = None,
) -> list[dict] | tuple[list[dict], list[dict]]:
    """
    Parallel row-by-row enrichment using ProcessPoolExecutor + as_completed.

    The original input order **is preserved**.
    """
    records = list(records)                    # We need indices
    enriched_pairs: list[tuple[int, dict]] = []
    rejected_pairs: list[tuple[int, dict]] = []

    with ProcessPoolExecutor(max_workers=max_workers) as executor:
        future_to_idx = {
            executor.submit(
                _lookup_worker,
                conn_str,
                lookup_sql,
                row,
                param_cols,
                transform,
            ): idx
            for idx, row in enumerate(records)
        }

        for future in as_completed(future_to_idx):
            idx = future_to_idx[future]
            is_match, row_out = future.result()
            target = enriched_pairs if is_match else rejected_pairs
            target.append((idx, row_out))

    # Re-establish stable order
    enriched = [row for idx, row in sorted(enriched_pairs)]
    if return_rejected:
        rejected = [row for idx, row in sorted(rejected_pairs)]
        return enriched, rejected

    return enriched
