import re

def compare_schemas(**kwargs):
    audit_id_cutoff = kwargs["params"].get("audit_id_cutoff")
    session = get_session()
    engine = session.get_bind()

    # Gather per-table sections
    sections = []  # list of dicts: {id, title, summary_html, diffs_html}
    for tbl, pair in PAIRS.items():
        # 1) Summary counts
        df_summary = fetch_group_counts(session, pair, audit_id_cutoff)
        df_summary.to_csv(f"{OUTDIR}/{tbl}_summary.csv", index=False)
        logging.info(f"Written into {OUTDIR}/{tbl}_summary.csv")

        # 2) Column diffs (sampled)
        cols_with_types = get_shared_columns_with_types(engine, pair["legacy"], pair["python"])
        df_col = fetch_column_diffs(session, pair, cols_with_types, df_summary)
        df_col.to_csv(f"{OUTDIR}/{tbl}_column_diffs.csv", index=False)
        logging.info(f"Written into {OUTDIR}/{tbl}_column_diffs.csv")

        # 3) Prepare HTML for this table
        safe_id = re.sub(r'[^a-zA-Z0-9_-]', '_', tbl)
        sections.append({
            "id": safe_id,
            "title": tbl,
            "summary_html": df_summary.to_html(index=False),
            "diffs_html": df_col.head(300).to_html(index=False)
        })

    # Build a tabbed HTML report
    tabs_html = "\n".join(
        f'<li class="tab{" active" if i == 0 else ""}" data-target="{s["id"]}">{s["title"]}</li>'
        for i, s in enumerate(sections)
    )
    panels_html = "\n".join(
        f'''
        <section id="{s["id"]}" class="panel{" active" if i == 0 else ""}">
            <h2>{s["title"]}</h2>
            <h3>Summary</h3>
            {s["summary_html"]}
            <h3>Column Diffs</h3>
            {s["diffs_html"]}
        </section>
        '''
        for i, s in enumerate(sections)
    )

    html = f"""
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>Schema Comparison Report</title>
<style>
  body {{ font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif; margin: 16px; }}
  .tabs {{ list-style: none; padding: 0; display: flex; gap: 8px; border-bottom: 1px solid #ccc; margin-bottom: 12px; flex-wrap: wrap; }}
  .tab {{ padding: 8px 12px; cursor: pointer; border: 1px solid #ccc; border-bottom: none; border-radius: 6px 6px 0 0; background: #f7f7f7; }}
  .tab.active {{ background: white; font-weight: 600; }}
  .panel {{ display: none; }}
  .panel.active {{ display: block; }}
  table {{ border-collapse: collapse; width: 100%; margin-bottom: 24px; }}
  th, td {{ border: 1px solid #e2e2e2; padding: 6px 8px; text-align: left; }}
  th {{ background: #fafafa; position: sticky; top: 0; }}
  h2 {{ margin: 8px 0 6px; }}
  h3 {{ margin: 14px 0 6px; }}
</style>
</head>
<body>
  <h1>Schema Comparison Report</h1>
  <ul class="tabs">
    {tabs_html}
  </ul>
  {panels_html}
<script>
  const tabs = document.querySelectorAll('.tab');
  const panels = document.querySelectorAll('.panel');
  tabs.forEach(tab => {{
    tab.addEventListener('click', () => {{
      const target = tab.getAttribute('data-target');
      tabs.forEach(t => t.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      tab.classList.add('active');
      document.getElementById(target).classList.add('active');
    }});
  }});
</script>
</body>
</html>
"""
    with open(f"{OUTDIR}/report.html", "w", encoding="utf-8") as f:
        f.write(html)
    logging.info(f"Written into {OUTDIR}/report.html.")
    session.close()
