# -- ratings: own → issuer → 1st-level underl. → 2nd-level underl. --
def _apply_rating(src_rating, target):
    """Copy every rating field from src_rating to target dict if missing."""
    if not src_rating:
        return
    for fld in (
        "strInstRtgSPStandardized",
        "strInstRtgMDStandardized",
        "strInstRtgFHStandardized",
        *[f"strInstRtgCustom{i}" for i in range(1, 14)],
    ):
        target[fld] = target.get(fld) or getattr(src_rating, fld, None)


if inst_id in ratings_records:
    _apply_rating(ratings_records[inst_id], record)

if not record.get("strInstRtgSPStandardized"):
    # try own issuer
    _apply_rating(issuer_ratings.get(record.get("strInstIssuerCode")), record)

if not record.get("strInstRtgSPStandardized"):
    # first-level underlying
    ul = instruments.get(instr.numInstUndrlygID) if instr else None
    if ul:
        _apply_rating(ratings_records.get(ul.numInstID), record)
        _apply_rating(issuer_ratings.get(ul.strInstIssuerCode), record)

if not record.get("strInstRtgSPStandardized"):
    # second-level underlying
    ul2 = (
        level2_instruments.get(ul.numInstUndrlygID)
        if ul and ul.numInstUndrlygID
        else None
    )
    if ul2:
        _apply_rating(ratings_records.get(ul2.numInstID), record)
        _apply_rating(issuer_ratings.get(ul2.strInstIssuerCode), record)
