def retrieve_bench_scope_from_constituents():
    """
    Retrieve benchmark scope from constituents using parallel processing.

    Returns:
        DataFrame (Polars or Pandas) containing benchmark scope data
    """
    session = None
    try:
        session = get_local_session()
        agg_query = (
            session.query(
                DMIRBenchScopeAG.strPeriodTypeFlag,
                DMIRBenchScopeAG.datPeriodLastDay,
                DMIRBenchScopeAG.numBenchMarkId,
                func.max(DMIRBenchScopeAG.numPFCurrencyID).label("numPFCurrencyID"),
                func.max(DMIRBenchScopeAG.strPFCurrencyISOCode).label("strPFCurrencyISOCode"),
                func.max(DMIRBenchScopeAG.numPFCurrencyRate).label("numPFCurrencyRate"),
                func.cast(None, Date).label("datStartDate"),
                func.max(DMIRBRSBenchmarkConstituent.datMarketDate).label("datPeriodLastMarketDay"),
            )
            .join(
                DMIRBRSBenchmarkConstituent,
                DMIRBenchScopeAG.numBenchMarkId == DMIRBRSBenchmarkConstituent.numBenchFBAId,
            )
            .filter(
                DMIRBRSBenchmarkConstituent.datMarketDate <= DMIRBenchScopeAG.datPeriodLastDay,
                DMIRBenchScopeAG.numBenchMarkId != -1,
            )
            .group_by(
                DMIRBenchScopeAG.strPeriodTypeFlag,
                DMIRBenchScopeAG.datPeriodLastDay,
                DMIRBenchScopeAG.numBenchMarkId,
            )
        )

        df_bench_scope = get_all_as_df(agg_query, mode="polars")  # ← switch here
    finally:
        safe_close(session)

    if df_bench_scope.is_empty():  # works for Polars and Pandas
        return df_bench_scope.__class__()  # return same type as df

    # Add row index for tracking
    df_bench_scope = df_bench_scope.with_columns(
        pl.Series("row_idx", pl.arange(0, df_bench_scope.height))
    ) if isinstance(df_bench_scope, pl.DataFrame) else (
        df_bench_scope.assign(row_idx=range(len(df_bench_scope)))
    )

    # Split the dataframe into chunks
    num_cpus = os.cpu_count() or 4
    chunk_size = max(1, min(100, len(df_bench_scope) // num_cpus))
    records = df_bench_scope.to_dicts() if isinstance(df_bench_scope, pl.DataFrame) else df_bench_scope.to_dict("records")

    chunks = [
        records[i : i + chunk_size]
        for i in range(0, len(records), chunk_size)
    ]

    # Process chunks in parallel
    results = []
    with concurrent.futures.ProcessPoolExecutor(max_workers=32) as executor:
        future_to_chunk = {
            executor.submit(single_process_composition_codes, i, chunk): i
            for i, chunk in enumerate(chunks)
        }

        for future in concurrent.futures.as_completed(future_to_chunk):
            try:
                chunk_results = future.result()
                results.extend(chunk_results)
            except Exception as exc:
                print(f"Chunk {future_to_chunk[future]} generated an exception: {exc}")

    # Map results back to the dataframe
    composition_dict = {r["row_idx"]: r["strCompositionCd"] for r in results}

    if isinstance(df_bench_scope, pl.DataFrame):
        df_bench_scope = df_bench_scope.with_columns(
            pl.col("row_idx").map_dict(composition_dict).alias("strCompositionCd")
        ).drop("row_idx")
        df_bench_scope = df_bench_scope.filter(
            (pl.col("datStartDate").is_null())
            | (pl.col("datPeriodLastMarketDay") >= pl.col("datStartDate"))
        )
        return df_bench_scope.rename({"datPeriodLastDay": "datReportingDay"})
    else:
        df_bench_scope["strCompositionCd"] = df_bench_scope["row_idx"].map(composition_dict)
        df_bench_scope = df_bench_scope[
            df_bench_scope["datStartDate"].isna()
            | (df_bench_scope["datPeriodLastMarketDay"] >= df_bench_scope["datStartDate"])
        ]
        df_bench_scope = df_bench_scope.drop(columns=["row_idx"])
        df_bench_scope = df_bench_scope.rename(columns={"datPeriodLastDay": "datReportingDay"})
        return df_bench_scope
