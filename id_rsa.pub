@monitor_mem()
def compute_scope_for_api_bench_holding(audit_id=None, calc_hor=1, end_date=None):
    """
    Computes scope for API bench holdings by identifying benchmarks that need updates.

    Args:
        audit_id (int): Current audit ID for the process
        calc_hor (int): Month horizon for lookback (default: 1)
        end_date (datetime): Reference date for calculation (default: current date)

    Returns:
        pd.DataFrame: DataFrame containing benchmark scope
    """
    now, today, today_10h, today_18h = get_date_pivot(audit_id)
    if end_date is None:
        end_date = today

    print(audit_id)

    session = get_session()
    try:
        # Calculate date ranges equivalent to SQL date functions
        last_day_of_month = end_date.replace(day=1) - timedelta(days=1)
        start_date = last_day_of_month + timedelta(days=1) - relativedelta(months=calc_hor)

        print(f"Computing scope for API bench holdings from {start_date} to {last_day_of_month}")

        # === STEP 1: Create Initial Scope ===
        # Query scope_api - get benchmarks already in API holdings
        scope_api_stmt = (
            session.query(
                DMIRAPIBenchHolding.Accountingdate.label("datMarketDate"),
                DMIRAPIBenchHolding.BKGNCode.label("numBenchFBAId"),
                DMIRAPIBenchHolding.numAuditId,
            )
            .where(DMIRAPIBenchHolding.Accountingdate.between(start_date, last_day_of_month))
            .distinct()
        )

        scope_api_df = get_all_as_df(scope_api_stmt)

        # Query scope_aggr - get benchmarks from indicators
        scope_aggr_stmt = (
            session.query(
                DMIRBRSBenchIndicators.datMarketDate,
                DMIRBRSBenchIndicators.numBenchFBAId,
                DMIRBRSBenchIndicators.strPeriodTypeFlag,
                DMIRBRSBenchIndicators.numAuditId,
            )
            .where(
                DMIRBRSBenchIndicators.strPeriodTypeFlag == "M",
                DMIRBRSBenchIndicators.datPeriodLastDay.between(start_date, last_day_of_month),
            )
            .group_by(
                DMIRBRSBenchIndicators.datMarketDate,
                DMIRBRSBenchIndicators.numBenchFBAId,
                DMIRBRSBenchIndicators.strPeriodTypeFlag,
                DMIRBRSBenchIndicators.numAuditId,
            )
        )
        scope_aggr_df = get_all_as_df(scope_aggr_stmt)

        # Merge and filter for more recent audit IDs (LEFT JOIN + WHERE)
        if not scope_aggr_df.empty:
            if not scope_api_df.empty:
                merged_df = pd.merge(
                    scope_aggr_df,
                    scope_api_df,
                    on=["datMarketDate", "numBenchFBAId"],
                    how="left",
                    suffixes=["", "_api"],
                )

                # Filter where aggr audit ID > api audit ID or api doesn't exist
                scope_df = merged_df[
                    merged_df["numAuditId_api"].isna()
                    | (merged_df["numAuditId"] > merged_df["numAuditId_api"])
                ]

                scope_df = scope_df.rename(columns={"strPeriodTypeFlag": "strFrequency"})
                scope_df = scope_df[
                    ["numBenchFBAId", "datMarketDate", "strFrequency", "numAuditId"]
                ]
            else:
                # No existing API records, use all from aggr
                scope_df = scope_aggr_df.rename(columns={"strPeriodTypeFlag": "strFrequency"})
                scope_df = scope_df[
                    ["numBenchFBAId", "datMarketDate", "strFrequency", "numAuditId"]
                ]
        else:
            # Empty scope
            scope_df = pd.DataFrame(
                columns=["numBenchFBAId", "datMarketDate", "strFrequency", "numAuditId"]
            )

        # === STEP 2: Add on-demand benchmarks ===
        # Find on-demand benchmarks not in current scope
        # ------------------------ During parallel run

        on_demand_benchmarks_stmt = select(DMIRSpeedProcsParam).where(
            DMIRSpeedProcsParam.strSource == "BM", DMIRSpeedProcsParam.numBenchFBAId.isnot(None)
        )
        on_demand_results = session.execute(on_demand_benchmarks_stmt).scalars().all()

        # Convert results to DataFrame for easier processing
        if on_demand_results:
            on_demand_df = pd.DataFrame(
                [
                    {
                        "numBenchFBAId": param.numBenchFBAId,
                        "datPeriodLastDay": param.datPeriodLastDay,
                    }
                    for param in on_demand_results
                ]
            )

            # Add these benchmarks if not in scope
            missing_benchmarks = []

            # Calculate last day of month for each market date in scope
            if not scope_df.empty:
                scope_df["datPeriodLastMonth"] = scope_df["datMarketDate"].apply(
                    lambda d: (
                        d.replace(day=1) + relativedelta(months=1) - timedelta(days=1)
                        if d is not None
                        else None
                    )
                )

            # Process each on-demand benchmark
            for _, row in on_demand_df.iterrows():
                # Check if this benchmark/period is already in scope
                is_in_scope = False
                if not scope_df.empty:
                    is_in_scope = any(
                        (scope_df["numBenchFBAId"] == row["numBenchFBAId"])
                        & (scope_df["datPeriodLastMonth"] == row["datPeriodLastDay"])
                    )

                # If not in scope, get benchmark indicators for this benchmark
                if not is_in_scope:
                    avail_indicators_stmt = select(
                        DMIRBRSBenchIndicators.numBenchFBAId,
                        DMIRBRSBenchIndicators.datPeriodLastDay,
                        DMIRBRSBenchIndicators.datMarketDate,
                        DMIRBRSBenchIndicators.strPeriodTypeFlag,
                        DMIRBRSBenchIndicators.numAuditId,
                    ).where(
                        DMIRBRSBenchIndicators.numBenchFBAId == row["numBenchFBAId"],
                        DMIRBRSBenchIndicators.datPeriodLastDay == row["datPeriodLastDay"],
                        DMIRBRSBenchIndicators.strPeriodTypeFlag == "M",
                    )

                    avail_results = session.execute(avail_indicators_stmt).all()

                    # Add to missing benchmarks list
                    for result in avail_results:
                        missing_benchmarks.append(
                            {
                                "numBenchFBAId": result.numBenchFBAId,
                                "datMarketDate": result.datMarketDate,
                                "strFrequency": result.strPeriodTypeFlag,
                                "numAuditId": result.numAuditId,
                            }
                        )

            # Add missing benchmarks to scope
            if missing_benchmarks:
                on_demand_scope_df = pd.DataFrame(missing_benchmarks)
                scope_df = pd.concat([scope_df, on_demand_scope_df], ignore_index=True)

            # Drop temporary column
            if "datPeriodLastMonth" in scope_df.columns:
                scope_df = scope_df.drop(columns=["datPeriodLastMonth"])

        # Clean up speed procs parameters
        parallel_run = True
        schema = "dbo" if parallel_run else "DMIR"
        session.execute(
            text(
                f"DELETE FROM {schema}.tblDMIRSpeedProcsParam WHERE strProcType = 'AGG' AND strSource = 'BM'"
            )
        )
        session.commit()

        print(f"Found {len(scope_df)} benchmarks requiring updates")
        scope_df["datMarketDate"] = pd.to_datetime(scope_df["datMarketDate"])
        return scope_df

    finally:
        safe_close(session)


def _delete_api_bench_holdings_single(idx, batch, retry=3):
    session = None
    try:
        print(f"Deleting for batch {idx}.")
        session = get_session()
        filters = [
            and_(
                DMIRAPIBenchHolding.BKGNCode == bm_id,
                DMIRAPIBenchHolding.Accountingdate == date,
            )
            for bm_id, date in batch
        ]

        if filters:
            deleted = (
                session.query(DMIRAPIBenchHolding)
                .filter(or_(*filters))
                .delete(synchronize_session=False)
            )
            session.commit()
        session.commit()
        return deleted
    except Exception as e:
        print(e)
        if session:
            session.close()
        if retry > 0:
            return _delete_api_bench_holdings_single(idx, batch, retry=retry - 1)
    finally:
        if session:
            session.close()


@monitor_mem()
def delete_api_bench_holdings(scope_df):
    """
    Deletes existing API benchmark holdings based on the scope.

    Args:
        scope_df (pd.DataFrame): DataFrame containing benchmark scope

    Returns:
        int: Number of records deleted
    """
    if scope_df.empty:
        print("No benchmarks to delete, scope is empty")
        return 0

    session = get_session()
    try:
        # Create tuples for the IN conditions
        scope_tuples = list(zip(scope_df["numBenchFBAId"], scope_df["datMarketDate"]))

        # Delete existing records - process in batches
        delete_count = 0
        batch_size = 10

        for idx, i in enumerate(range(0, len(scope_tuples), batch_size)):
            rec = _delete_api_bench_holdings_single(idx, scope_tuples[i : i + batch_size])
            if rec is not None:
                delete_count += rec

        return delete_count
    finally:
        safe_close(session)


def _propagate_sector_country(src, tgt):
    """Copy sector L1-L3 (all taxonomies) + country labels when present."""
    mapping = {
        # Barclays / BB
        "InstrSectorBBLevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorBBLevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorBBLevel3": ("strInstSectorL3", "strIssSector3Label"),
        # LH
        "InstrSectorLHLevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorLHLevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorLHLevel3": ("strInstSectorL3", "strIssSector3Label"),
        # MSCI
        "InstrSectorMSCILevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorMSCILevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorMSCILevel3": ("strInstSectorL3", "strIssSector3Label"),
        # ICB
        "InstrSectorICBLevel1": ("strInstSectorL1", "strIssSector1Label"),
        "InstrSectorICBLevel2": ("strInstSectorL2", "strIssSector2Label"),
        "InstrSectorICBLevel3": ("strInstSectorL3", "strIssSector3Label"),
    }

    for tgt_key, (l_key, ll_key) in mapping.items():
        val = getattr(src, l_key) or getattr(src, ll_key)
        if val:
            tgt[tgt_key] = val

    # country labels
    for k in (
        "strInstIssueCountryLabel",
        "strInstIssuerCountryLabel",
        "strInstRiskCountryLabel",
    ):
        if getattr(src, k):
            tgt[k] = getattr(src, k)


def _apply_rating(src_rating, target):
    """Copy every rating field from src_rating to target dict if missing."""
    if not src_rating:
        return
    for fld in (
        "strInstRtgSPStandardized",
        "strInstRtgMDStandardized", 
        "strInstRtgFHStandardized",
        *[f"strInstRtgCustom{i}" for i in range(1, 14)],
    ):
        # Only set the field if it's currently None or empty in the target (matching COALESCE behavior)
        current_val = target.get(fld)
        if current_val is None or current_val == "" or (isinstance(current_val, str) and current_val.strip() == ""):
            src_val = getattr(src_rating, fld, None)
            if src_val is not None and src_val != "" and not (isinstance(src_val, str) and src_val.strip() == ""):
                target[fld] = src_val


def _process_benchmark_batch(idx, benchmark, audit_id, retry=3):
    print(f"Processing benchmark batch {idx}.")
    session = None
    try:
        session = get_local_session()
        results = []

        bm_id = int(benchmark["numBenchFBAId"])
        accounting_date = pd.to_datetime(benchmark["datMarketDate"])
        period_last_date = accounting_date.normalize() + pd.offsets.MonthEnd(0)
        print("Id and date:", bm_id, period_last_date)

        C = DMIRBRSBenchmarkConstituent  # type: ignore
        INST = DMIRBRSInstrument  # alias for instrument (I)
        B = DWGNBenchmarkCharacteristic  # alias for benchmark characteristics (B)
        IT1 = aliased(DMIRInstrumentIRType)
        IT3 = aliased(DMIRInstrumentIRType)
        IT8 = aliased(DMIRInstrumentIRType)
        IT9 = aliased(DMIRInstrumentIRType)
        SECT_BB = aliased(DMIRBRSInstSector)
        SECT_LH = aliased(DMIRBRSInstSector)
        SECT_ML = aliased(DMIRBRSInstSector)
        SECT_JPM = aliased(DMIRBRSInstSector)
        SECT_MSCI = aliased(DMIRBRSInstSector)
        SECT_ICB = aliased(DMIRBRSInstSector)
        AGG = aliased(DMIRBRSBenchInstrIndicators)

        # Build the query selecting (with labels) all the fields and computed expressions.
        qry = (
            session.query(
                func.EOMONTH(literal(accounting_date)).label("datPeriodLastDay"),
                literal(accounting_date).label("Accountingdate"),
                literal(bm_id).label("BKGNCode"),
                B.strBnchmkTickerCd.label("BenchCode"),
                B.strShrtNdxDesc.label("BenchName"),
                B.strBnchmkCcy.label("BenchCurrency"),
                C.numInstId.label("InstrumentDWHID"),
                C.strInstISINCode.label("ISINCode"),
                C.strInstSedolCode.label("SedolCode"),
                C.strInstCUSIPCode.label("CUSIPCode"),
                C.strtInstInternalCode.label("InternalCode"),
                C.codInstCurId.label("CurrencyID"),
                C.numInstLocalCurPrice.label("LocalCurrencyPrice"),
                C.numInstQty.label("Quantity"),
                INST.strInstAladdin.label("strInstAladdin"),
                INST.strInstName.label("strInstName"),
                INST.strBloombergCode.label("strBloombergCode"),
                INST.strInstISINCode.label("strInstISINCode"),
                INST.strInstSedolCode.label("strInstSedolCode"),
                INST.strInstCUSIPCode.label("strInstCUSIPCode"),
                func.left(INST.strInstIssuerName, 80).label("strInstIssuerName"),
                INST.strInstExchLocName.label("strInstExchLocName"),
                INST.strInstListingCountryLabel.label("strInstListingCountryLabel"),
                INST.strInstIssueCountryLabel.label("strInstIssueCountryLabel"),
                INST.strInstIssuerCountryLabel.label("strInstIssuerCountryLabel"),
                INST.strInstRiskCountryLabel.label("strInstRiskCountryLabel"),
                INST.numInstCouponRate.label("numInstCouponRate"),
                INST.numInstForwardRate.label("numInstForwardRate"),
                INST.datInstMaturityDate.label("datInstMaturityDate"),
                (func.datediff(text("day"), C.datMarketDate, INST.datInstMaturityDate) / 365).label(
                    "RemainLife365"
                ),
                INST.datInstCallDate.label("datInstCallDate"),
                INST.datInstNextCouponDate.label("datInstNextCouponDate"),
                INST.strInstPriceType.label("strInstPriceType"),
                INST.strInstRateType.label("strInstRateType"),
                INST.numInstSpotRate.label("numInstSpotRate"),
                INST.datInstStartDate.label("datInstStartDate"),
                INST.numInstUndrlygQty.label("numInstUndrlygQty"),
                INST.strInstUndrlygISINCode.label("strInstUndrlygISINCode"),
                INST.datInstIssueDate.label("datInstIssueDate"),
                INST.numInstNominalMt.label("numInstNominalMt"),
                INST.strInstCurrCode.label("strInstCurrCode"),
                INST.datInstContractEnd.label("datInstContractEnd"),
                INST.strInstContractName.label("strInstContractName"),
                INST.strInstLegTyp1.label("strInstLegTyp1"),
                INST.strInstLegTyp2.label("strInstLegTyp2"),
                INST.strInstLegType.label("strInstLegType"),
                INST.strCpnRateTypPaid.label("strCpnRateTypPaid"),
                INST.strCpnRateTypeRecv.label("strCpnRateTypeRecv"),
                INST.numCpnFixedRatePaid.label("numCpnFixedRatePaid"),
                INST.numCpnFixedRateRecv.label("numCpnFixedRateRecv"),
                INST.strCpnIndexPaid.label("strCpnIndexPaid"),
                INST.strCpnIndexRecv.label("strCpnIndexRecv"),
                INST.strSwapFreqPaid.label("strSwapFreqPaid"),
                INST.strSwapFreqRecv.label("strSwapFreqRecv"),
                # Instrument type joins (using IT1, IT3, IT8, IT9)
                IT1.strInstrumentTypeName.label("strInstrumentTypeName1"),
                IT1.strInstrumentTypeIRName.label("strInstrumentTypeIRName1"),
                IT3.strInstrumentTypeName.label("strInstrumentTypeName3"),
                IT3.strInstrumentTypeIRName.label("strInstrumentTypeIRName3"),
                IT8.strInstrumentTypeName.label("strInstrumentTypeName8"),
                IT8.strInstrumentTypeIRName.label("strInstrumentTypeIRName8"),
                IT9.strInstrumentTypeName.label("strInstrumentTypeName9"),
                IT9.strInstrumentTypeIRName.label("strInstrumentTypeIRName9"),
                # Core Asset Class Labels
                INST.strCoreAssetClaLvl1Lbl.label("strCoreAssetClaLvl1Lbl"),
                INST.strCoreAssetClaLvl2Lbl.label("strCoreAssetClaLvl2Lbl"),
                INST.strCoreAssetClaLvl3Lbl.label("strCoreAssetClaLvl3Lbl"),
                INST.strCoreAssetClaLvl4Lbl.label("strCoreAssetClaLvl4Lbl"),
                literal(None).label("strCoreAssetClaLvl1LblBbl"),
                literal(None).label("strCoreAssetClaLvl2LblBbl"),
                literal(None).label("strCoreAssetClaLvl3LblBbl"),
                literal(None).label("strCoreAssetClaLvl4LblBbl"),
                # Benchmark Instrument Weight
                C.numBenchInstWeight.label("numInstrWeight"),
                #  (using COALESCE – note the use of func.coalesce)
                func.coalesce(SECT_BB.strInstSectorL1, SECT_BB.strIssSector1Label).label(
                    "InstrSectorBBLevel1"
                ),
                func.coalesce(SECT_BB.strInstSectorL2, SECT_BB.strIssSector2Label).label(
                    "InstrSectorBBLevel2"
                ),
                func.coalesce(SECT_BB.strInstSectorL3, SECT_BB.strIssSector3Label).label(
                    "InstrSectorBBLevel3"
                ),
                func.coalesce(SECT_BB.strInstSectorL4, SECT_BB.strIssSector4Label).label(
                    "InstrSectorBBLevel4"
                ),
                func.coalesce(SECT_LH.strInstSectorL1, SECT_LH.strIssSector1Label).label(
                    "InstrSectorLHLevel1"
                ),
                func.coalesce(SECT_LH.strInstSectorL2, SECT_LH.strIssSector2Label).label(
                    "InstrSectorLHLevel2"
                ),
                func.coalesce(SECT_LH.strInstSectorL3, SECT_LH.strIssSector3Label).label(
                    "InstrSectorLHLevel3"
                ),
                func.coalesce(SECT_LH.strInstSectorL4, SECT_LH.strIssSector4Label).label(
                    "InstrSectorLHLevel4"
                ),
                func.coalesce(SECT_ML.strInstSectorL1, SECT_ML.strIssSector1Label).label(
                    "InstrSectorMLLevel1"
                ),
                func.coalesce(SECT_ML.strInstSectorL2, SECT_ML.strIssSector2Label).label(
                    "InstrSectorMLLevel2"
                ),
                func.coalesce(SECT_ML.strInstSectorL3, SECT_ML.strIssSector3Label).label(
                    "InstrSectorMLLevel3"
                ),
                func.coalesce(SECT_ML.strInstSectorL4, SECT_ML.strIssSector4Label).label(
                    "InstrSectorMLLevel4"
                ),
                func.coalesce(SECT_JPM.strInstSectorL1, SECT_JPM.strIssSector1Label).label(
                    "InstrSectorJPMLevel1"
                ),
                func.coalesce(SECT_JPM.strInstSectorL2, SECT_JPM.strIssSector2Label).label(
                    "InstrSectorJPMLevel2"
                ),
                func.coalesce(SECT_JPM.strInstSectorL3, SECT_JPM.strIssSector3Label).label(
                    "InstrSectorJPMLevel3"
                ),
                func.coalesce(SECT_JPM.strInstSectorL4, SECT_JPM.strIssSector4Label).label(
                    "InstrSectorJPMLevel4"
                ),
                func.coalesce(SECT_MSCI.strInstSectorL1, SECT_MSCI.strIssSector1Label).label(
                    "InstrSectorMSCILevel1"
                ),
                func.coalesce(SECT_MSCI.strInstSectorL2, SECT_MSCI.strIssSector2Label).label(
                    "InstrSectorMSCILevel2"
                ),
                func.coalesce(SECT_MSCI.strInstSectorL3, SECT_MSCI.strIssSector3Label).label(
                    "InstrSectorMSCILevel3"
                ),
                func.coalesce(SECT_MSCI.strInstSectorL4, SECT_MSCI.strIssSector4Label).label(
                    "InstrSectorMSCILevel4"
                ),
                func.coalesce(SECT_ICB.strInstSectorL1, SECT_ICB.strIssSector1Label).label(
                    "InstrSectorICBLevel1"
                ),
                func.coalesce(SECT_ICB.strInstSectorL2, SECT_ICB.strIssSector2Label).label(
                    "InstrSectorICBLevel2"
                ),
                func.coalesce(SECT_ICB.strInstSectorL3, SECT_ICB.strIssSector3Label).label(
                    "InstrSectorICBLevel3"
                ),
                func.coalesce(SECT_ICB.strInstSectorL4, SECT_ICB.strIssSector4Label).label(
                    "InstrSectorICBLevel4"
                ),
                # Lastly, select remaining fields:
                literal(int(audit_id)).label("numAuditId"),
                INST.strinstrmttypcd.label("instrTypCd"),
                # FNFHOrGNMA: A nested CASE expression
                case(
                    [
                        # If core asset level 3 label is not one of the two specified, return NULL.
                        (INST.strCoreAssetClaLvl3Lbl.not_in(["MBS Pass-Through", "TBAs"]), None)
                    ],
                    else_=case(
                        [
                            (
                                (
                                    func.replace(INST.strInstIssuerName, " ", "").like(
                                        "GOVERNMENTNATIONALMORTGAGEASSOCIATION%"
                                    )
                                )
                                | (INST.strInstContractName.like("GNMA%")),
                                "GNMA",
                            ),
                            (
                                (
                                    func.replace(INST.strInstIssuerName, " ", "").like(
                                        "FEDERALNATIONALMORTGAGEASSOCIATION%"
                                    )
                                )
                                | (
                                    func.replace(INST.strInstIssuerName, " ", "").like(
                                        "FEDERALHOMELOANMORTGAGECORPORATION%"
                                    )
                                )
                                | (func.replace(INST.strInstIssuerName, " ", "").like("FANNIEMAE%"))
                                | (
                                    func.replace(INST.strInstIssuerName, " ", "").like(
                                        "FREDDIEMAC%"
                                    )
                                )
                                | (
                                    func.replace(INST.strInstIssuerName, " ", "").like(
                                        "UNIFORMMBS%"
                                    )
                                )
                                | (INST.strInstContractName.like("FNFH%"))
                                | (INST.strInstContractName.like("FGOLD%"))
                                | (INST.strInstContractName.like("FHLMC%"))
                                | (INST.strInstContractName.like("FNMA%"))
                                | (INST.strInstContractName.like("FRUMBS%")),
                                "FN/FH",
                            ),
                        ],
                        else_="other",
                    ),
                ).label("FNFHOrGNMA"),
                AGG.numEffectDurationContrib,
                AGG.numMCDurationContrib,
                AGG.numModifDurationContrib,
                AGG.numSpreadDurationContrib,
                AGG.numDurExposureInBenchCur,
                AGG.numCurExposureInBenchCur,
                AGG.numCurExposureWeight,
                AGG.numDurExposureWeight,
                # Note: Rating fields are NOT included here - they will be populated later via UPDATE logic
                # to match the SQL procedure behavior
                literal(None).label("strInstRtgSPStandardized"),
                literal(None).label("strInstRtgMDStandardized"),
                literal(None).label("strInstRtgFHStandardized"),
                literal(None).label("strInstRtgCustom1"),
                literal(None).label("strInstRtgCustom2"),
                literal(None).label("strInstRtgCustom3"),
                literal(None).label("strInstRtgCustom4"),
                literal(None).label("strInstRtgCustom5"),
                literal(None).label("strInstRtgCustom6"),
                literal(None).label("strInstRtgCustom7"),
                literal(None).label("strInstRtgCustom8"),
                literal(None).label("strInstRtgCustom9"),
                literal(None).label("strInstRtgCustom10"),
                literal(None).label("strInstRtgCustom11"),
                literal(None).label("strInstRtgCustom12"),
                literal(None).label("strInstRtgCustom13"),
                AGG.numESGGlbScore.label("InstrESGGlbScore"),
                AGG.numESGGlbScoreCov.label("InstrESGGlbScoreCov"),
                AGG.numCO2IntensEVEval.label("InstrCO2IntensEVEval"),
                AGG.numCO2IntensEVEvalCov.label("InstrCO2IntensEVEvalCov"),
                # Store AGG rating data for later UPDATE logic
                AGG.strInstRtgSPStandardized.label("AGG_strInstRtgSPStandardized"),
                AGG.strInstRtgMDStandardized.label("AGG_strInstRtgMDStandardized"),
                AGG.strInstRtgFHStandardized.label("AGG_strInstRtgFHStandardized"),
                AGG.strInstRtgCustom1.label("AGG_strInstRtgCustom1"),
                AGG.strInstRtgCustom2.label("AGG_strInstRtgCustom2"),
                AGG.strInstRtgCustom3.label("AGG_strInstRtgCustom3"),
                AGG.strInstRtgCustom4.label("AGG_strInstRtgCustom4"),
                AGG.strInstRtgCustom5.label("AGG_strInstRtgCustom5"),
                AGG.strInstRtgCustom6.label("AGG_strInstRtgCustom6"),
                AGG.strInstRtgCustom7.label("AGG_strInstRtgCustom7"),
                AGG.strInstRtgCustom8.label("AGG_strInstRtgCustom8"),
                AGG.strInstRtgCustom9.label("AGG_strInstRtgCustom9"),
                AGG.strInstRtgCustom10.label("AGG_strInstRtgCustom10"),
                AGG.strInstRtgCustom11.label("AGG_strInstRtgCustom11"),
                AGG.strInstRtgCustom12.label("AGG_strInstRtgCustom12"),
                AGG.strInstRtgCustom13.label("AGG_strInstRtgCustom13"),
            )
            .select_from(C)
            .outerjoin(INST, C.numInstId == INST.numInstID)
            .outerjoin(B, B.strBnchmkCd == cast(C.numBenchFBAId, String(10)))
            .outerjoin(
                IT1,
                (INST.numInstTypeId == IT1.numInstrTypeID) & (IT1.strReportingType == "class1"),
            )
            .outerjoin(
                IT3,
                (INST.numInstTypeId == IT3.numInstrTypeID) & (IT3.strReportingType == "class3"),
            )
            .outerjoin(
                IT8,
                (INST.numInstTypeId == IT8.numInstrTypeID) & (IT8.strReportingType == "class8"),
            )
            .outerjoin(
                IT9,
                (INST.numInstTypeId == IT9.numInstrTypeID) & (IT9.strReportingType == "class9"),
            )
            .outerjoin(
                SECT_BB,
                (INST.numInstID == SECT_BB.numInstID) & (SECT_BB.strInstSectorAgy == "BNPP_BICS"),
            )
            .outerjoin(
                SECT_LH,
                (INST.numInstID == SECT_LH.numInstID) & (SECT_LH.strInstSectorAgy == "LH"),
            )
            .outerjoin(
                SECT_ML,
                (INST.numInstID == SECT_ML.numInstID) & (SECT_ML.strInstSectorAgy == "ML"),
            )
            .outerjoin(
                SECT_JPM,
                (INST.numInstID == SECT_JPM.numInstID) & (SECT_JPM.strInstSectorAgy == "JPM"),
            )
            .outerjoin(
                SECT_MSCI,
                (INST.numInstID == SECT_MSCI.numInstID) & (SECT_MSCI.strInstSectorAgy == "MSCI"),
            )
            .outerjoin(
                SECT_ICB,
                (INST.numInstID == SECT_ICB.numInstID) & (SECT_ICB.strInstSectorAgy == "ICB"),
            )
            .outerjoin(
                AGG,
                and_(
                    AGG.numBenchFBAId == bm_id,
                    AGG.datPeriodLastDay == period_last_date,
                    AGG.numInstID == C.numInstId,
                ),
            )
            .filter(C.datMarketDate == accounting_date, C.numBenchFBAId == bm_id)
        )

        results = get_all_as_df(qry)
        for cls_idx in range(1, 5):
            source_label = f"strCoreAssetClaLvl{cls_idx}Lbl"
            target_label = f"strCoreAssetClaLvl{cls_idx}LblBbl"
            prefix = f"CR_DATA_COREACL{cls_idx}_"
            results[target_label] = np.where(
                results[source_label].notna() & results[source_label].str.strip().ne(""),
                prefix + results[source_label].str.strip().str.upper(),
                np.nan,
            )

        results = results.to_dict(orient="records")
        inst_and_dates = list(
            {
                (record["InstrumentDWHID"], record["Accountingdate"])
                for record in results
                if record["InstrumentDWHID"] is not None
            }
        )

        instrument_ids = list(
            {
                record["InstrumentDWHID"]
                for record in results
                if record["InstrumentDWHID"] is not None
            }
        )

        print(f"{idx}, inst_and_dates: ", len(inst_and_dates))

        if inst_and_dates:
            analytics_records = {}
            CHUNK_SIZE = 1000

            for cid, chunk in enumerate(chunker(instrument_ids, CHUNK_SIZE)):
                analytics_query = session.query(
                    DMIRBRSInstAnalytic.numInstID,
                    DMIRBRSInstAnalytic.datInstQuotationDate,
                    DMIRBRSInstAnalytic.numInstYieldToMaturity,
                    DMIRBRSInstAnalytic.numInstEffDuration,
                    DMIRBRSInstAnalytic.numInstModifDuration,
                    DMIRBRSInstAnalytic.numInstSpreadDuration,
                    DMIRBRSInstAnalytic.numInstMCDuration,
                    DMIRBRSInstAnalytic.numInstYield,
                    DMIRBRSInstAnalytic.numInstYieldToCall,
                    DMIRBRSInstAnalytic.numInstYieldToMaturityPaid,
                    DMIRBRSInstAnalytic.numInstYieldToMaturityRecv,
                    DMIRBRSInstAnalytic.numInstOptionAdjSpread,
                    DMIRBRSInstAnalytic.nummktcap,
                ).filter(
                    DMIRBRSInstAnalytic.numInstID.in_(chunk),
                    DMIRBRSInstAnalytic.datInstQuotationDate == accounting_date,
                )
                for a in analytics_query.all():
                    analytics_records[(a.numInstID, pd.to_datetime(a.datInstQuotationDate))] = a

            # --- 2. Fetch ratings data in bulk (chunked) ---
            ratings_records = {}
            for inst_chunk in chunker(instrument_ids, CHUNK_SIZE):
                ratings_query = session.query(
                    DMIRBRSInstRating.numInstID,
                    DMIRBRSInstRating.strInstRtgSPStandardized,
                    DMIRBRSInstRating.strInstRtgMDStandardized,
                    DMIRBRSInstRating.strInstRtgFHStandardized,
                    DMIRBRSInstRating.strInstRtgCustom1,
                    DMIRBRSInstRating.strInstRtgCustom2,
                    DMIRBRSInstRating.strInstRtgCustom3,
                    DMIRBRSInstRating.strInstRtgCustom4,
                    DMIRBRSInstRating.strInstRtgCustom5,
                    DMIRBRSInstRating.strInstRtgCustom6,
                    DMIRBRSInstRating.strInstRtgCustom7,
                    DMIRBRSInstRating.strInstRtgCustom8,
                    DMIRBRSInstRating.strInstRtgCustom9,
                    DMIRBRSInstRating.strInstRtgCustom10,
                    DMIRBRSInstRating.strInstRtgCustom11,
                    DMIRBRSInstRating.strInstRtgCustom12,
                    DMIRBRSInstRating.strInstRtgCustom13,
                ).filter(
                    DMIRBRSInstRating.numInstID.in_(inst_chunk),
                    DMIRBRSInstRating.datInstRtgDate == period_last_date,
                    DMIRBRSInstRating.strInstRtgVision == "M",
                )
                for rating in ratings_query.all():
                    if rating.numInstID not in ratings_records:
                        ratings_records[rating.numInstID] = rating

            # --- 3. Fetch issuer ratings for fallback (chunked) ---
            issuer_codes = [r["strInstIssuerCode"] for r in results if r.get("strInstIssuerCode")]
            issuer_ratings = {}
            if issuer_codes:
                for code_chunk in chunker(issuer_codes, CHUNK_SIZE):
                    issuer_ratings_query = session.query(
                        DMIRBRSIssuerRating.strInstIssuerCode,
                        DMIRBRSIssuerRating.strInstRtgSPStandardized,
                        DMIRBRSIssuerRating.strInstRtgMDStandardized,
                        DMIRBRSIssuerRating.strInstRtgFHStandardized,
                        DMIRBRSIssuerRating.strInstRtgCustom1,
                        DMIRBRSIssuerRating.strInstRtgCustom2,
                        DMIRBRSIssuerRating.strInstRtgCustom3,
                        DMIRBRSIssuerRating.strInstRtgCustom4,
                        DMIRBRSIssuerRating.strInstRtgCustom5,
                        DMIRBRSIssuerRating.strInstRtgCustom6,
                        DMIRBRSIssuerRating.strInstRtgCustom7,
                        DMIRBRSIssuerRating.strInstRtgCustom8,
                        DMIRBRSIssuerRating.strInstRtgCustom9,
                        DMIRBRSIssuerRating.strInstRtgCustom10,
                        DMIRBRSIssuerRating.strInstRtgCustom11,
                        DMIRBRSIssuerRating.strInstRtgCustom12,
                        DMIRBRSIssuerRating.strInstRtgCustom13,
                    ).filter(
                        DMIRBRSIssuerRating.strInstIssuerCode.in_(code_chunk),
                        DMIRBRSInstRating.datIssuerRtgDate == period_last_date,
                        DMIRBRSIssuerRating.strIssuerRtgVision == "M",
                    )
                    for i_rating in issuer_ratings_query.all():
                        if i_rating.strInstIssuerCode not in issuer_ratings:
                            issuer_ratings[i_rating.strInstIssuerCode] = i_rating

            # --- 4. Fetch currency quotes for market cap calculation (chunked) ---
            tuple_codes = list(
                {(r["CurrencyID"], r["Accountingdate"]) for r in results if r.get("CurrencyID")}
            )
            currency_quotes = {}
            for tuple_code in chunker(tuple_codes, CHUNK_SIZE):
                currency_query = session.query(
                    DMIRBRSCurrencyQuote.strCurrCode,
                    DMIRBRSCurrencyQuote.datccyqDate,
                    DMIRBRSCurrencyQuote.numccyqrateInv.label("numCcyqRateInv"),
                ).filter(
                    or_(
                        *[
                            and_(
                                DMIRBRSCurrencyQuote.strCurrCode == currency_code,
                                DMIRBRSCurrencyQuote.datccyqDate == mkt_date,
                            )
                            for currency_code, mkt_date in tuple_code
                        ]
                    )
                )
                for c in currency_query.all():
                    currency_quotes[(c.strCurrCode, pd.to_datetime(c.datccyqDate))] = c

            # --- 5. Get country of risk overrides (chunked) ---
            country_risk_map = {}
            for inst_chunk in chunker(instrument_ids, CHUNK_SIZE):
                country_risk_query = session.query(
                    DMIRFundCountryOfRisk.numInstID, DMIRFundCountryOfRisk.strRiskCountryLabel
                ).filter(DMIRFundCountryOfRisk.numInstID.in_(inst_chunk))
                for c in country_risk_query.all():
                    country_risk_map[c.numInstID] = c.strRiskCountryLabel

            # 6. For derivatives, get underlying instruments to use their attributes
            derivatives = [
                r
                for r in results
                if r.get("strInstrumentTypeIRName3")
                in [
                    "Future on OPC",
                    "CDS on Corporate",
                    "CDS on Index",
                    "CDS Tranche",
                    "Forward Contracts",
                    "Future on bond",
                    "Future on bond index",
                    "Future on stock",
                    "Future on stock index",
                    "Listed Option on Bond",
                    "Listed Option On Index",
                    "Listed Option on Stock",
                    "Option on Stock derivatives",
                    "OTC Option On Index",
                    "OTC Option On Stock",
                    "Warrant",
                    "Listed Option On Future On Bond",
                    "Listed Option On Future On Index",
                    "Listed Option On Future On Stock",
                    "OTC Option On Future On Bond",
                    "OTC Option On Future On Index",
                    "OTC Option On Future On Stock",
                ]
            ]

            if derivatives:
                # Query to get underlying instruments for derivatives
                underlyings_query = session.query(
                    DMIRBRSInstrument.numInstID,
                    DMIRBRSInstrument.numInstUndrlygID,
                    DMIRBRSInstrument.datInstMaturityDate,
                    DMIRBRSInstrument.strInstIssueCountryLabel,
                    DMIRBRSInstrument.strInstIssuerCountryLabel,
                    DMIRBRSInstrument.strInstRiskCountryLabel,
                ).filter(DMIRBRSInstrument.numInstID.in_(instrument_ids))
                instruments = {i.numInstID: i for i in underlyings_query.all()}

                # Get second-level underlyings (e.g., for options on futures)
                second_level_ids = [
                    i.numInstUndrlygID
                    for i in instruments.values()
                    if i.numInstUndrlygID is not None
                ]
                if second_level_ids:
                    level2_query = session.query(
                        DMIRBRSInstrument.numInstID,
                        DMIRBRSInstrument.numInstUndrlygID,
                        DMIRBRSInstrument.datInstMaturityDate,
                        DMIRBRSInstrument.strInstIssueCountryLabel,
                        DMIRBRSInstrument.strInstIssuerCountryLabel,
                        DMIRBRSInstrument.strInstRiskCountryLabel,
                    ).filter(DMIRBRSInstrument.numInstID.in_(second_level_ids))
                    level2_instruments = {i.numInstID: i for i in level2_query.all()}

                    # Update derivatives with underlying attributes
                    for record in derivatives:
                        instr = instruments.get(record["InstrumentDWHID"])
                        if instr and instr.numInstUndrlygID:
                            if record["strInstrumentTypeIRName3"] == "Future on bond":
                                underlying = instruments.get(instr.numInstUndrlygID)
                                if underlying:
                                    # Update maturity date for futures on bonds
                                    record["datInstMaturityDate"] = underlying.datInstMaturityDate
                            elif (
                                record["strInstrumentTypeIRName3"]
                                == "Listed Option On Future On Bond"
                            ):
                                underlying = instruments.get(instr.numInstUndrlygID)
                                if underlying:
                                    underlying2 = level2_instruments.get(
                                        underlying.numInstUndrlygID
                                    )

                                    if underlying2:
                                        # Update maturity date for futures on bonds
                                        record["datInstMaturityDate"] = (
                                            underlying2.datInstMaturityDate
                                        )

                            if record["strInstrumentTypeIRName3"] in [
                                "Future on OPC",
                                "CDS on Corporate",
                                "CDS on Index",
                                "CDS Tranche",
                                "Forward Contracts",
                                "Future on bond",
                                "Future on bond index",
                                "Future on stock",
                                "Future on stock index",
                                "Listed Option on Bond",
                                "Listed Option On Index",
                                "Listed Option on Stock",
                                "Option on Stock derivatives",
                                "OTC Option On Index",
                                "OTC Option On Stock",
                                "Warrant",
                            ]:
                                underlying = instruments.get(instr.numInstUndrlygID)
                                if underlying:
                                    if underlying.strInstIssueCountryLabel:
                                        record["strInstIssueCountryLabel"] = (
                                            underlying.strInstIssueCountryLabel
                                        )
                                    if underlying.strInstIssuerCountryLabel:
                                        record["strInstIssuerCountryLabel"] = (
                                            underlying.strInstIssuerCountryLabel
                                        )
                                    if underlying.strInstRiskCountryLabel:
                                        record["strInstRiskCountryLabel"] = (
                                            underlying.strInstRiskCountryLabel
                                        )

                            if record["strInstrumentTypeIRName3"] in [
                                "Listed Option On Future On Bond",
                                "Listed Option On Future On Index",
                                "Listed Option On Future On Stock",
                                "OTC Option On Future On Bond",
                                "OTC Option On Future On Index",
                                "OTC Option On Future On Stock",
                            ]:
                                underlying = instruments.get(instr.numInstUndrlygID)
                                if underlying:
                                    underlying2 = level2_instruments.get(
                                        underlying.numInstUndrlygID
                                    )
                                    if underlying2:
                                        if underlying2.strInstIssueCountryLabel:
                                            record["strInstIssueCountryLabel"] = (
                                                underlying2.strInstIssueCountryLabel
                                            )
                                        if underlying2.strInstIssuerCountryLabel:
                                            record["strInstIssuerCountryLabel"] = (
                                                underlying2.strInstIssuerCountryLabel
                                            )
                                        if underlying2.strInstRiskCountryLabel:
                                            record["strInstRiskCountryLabel"] = (
                                                underlying2.strInstRiskCountryLabel
                                            )

            # 7. Update all records with the enriched data
            second_level_types = {
                "Listed Option On Future On Bond",
                "Listed Option On Future On Index",
                "Listed Option On Future On Stock",
                "OTC Option On Future On Bond",
                "OTC Option On Future On Index",
                "OTC Option On Future On Stock",
            }

            for record in results:
                if record.get("strInstrumentTypeIRName3") in second_level_types:
                    inst = instruments.get(record["InstrumentDWHID"])
                    if inst and inst.numInstUndrlygID:
                        lvl1 = instruments.get(inst.numInstUndrlygID)
                        lvl2 = (
                            level2_instruments.get(lvl1.numInstUndrlygID)
                            if lvl1 and lvl1.numInstUndrlygID
                            else None
                        )
                        if lvl2:
                            _propagate_sector_country(lvl2, record)

            # 7. Update all records with the enriched data
            for record in results:
                inst_id = record["InstrumentDWHID"]
                accounting_date = record["Accountingdate"]

                # STEP 1: Apply AGG rating data (matching SQL UPDATE statement)
                for field in ["strInstRtgSPStandardized", "strInstRtgMDStandardized", "strInstRtgFHStandardized"] + [f"strInstRtgCustom{i}" for i in range(1, 14)]:
                    agg_field = f"AGG_{field}"
                    if agg_field in record and record[agg_field] is not None:
                        record[field] = record[agg_field]
                    # Clean up the temporary AGG field
                    record.pop(agg_field, None)

                # Update with analytics data
                analytics_key = (inst_id, accounting_date)

                if analytics_key in analytics_records:
                    analytics = analytics_records[analytics_key]
                    record.update(
                        {
                            "numInstYieldToMaturity": analytics.numInstYieldToMaturity,
                            "numInstEffDuration": analytics.numInstEffDuration,
                            "numInstModifDuration": analytics.numInstModifDuration,
                            "numInstSpreadDuration": analytics.numInstSpreadDuration,
                            "numInstMCDuration": None,  # analytics.numInstMCDuration,
                            "numInstYield": analytics.numInstYield,
                            "numInstYieldToCall": analytics.numInstYieldToCall,
                            "numInstYieldToMaturityPaid": analytics.numInstYieldToMaturityPaid,
                            "numInstYieldToMaturityRecv": analytics.numInstYieldToMaturityRecv,
                            "InstrOAS": analytics.numInstOptionAdjSpread,
                        }
                    )

                    # Calculate EUR market cap
                    if record.get("CurrencyID"):
                        curr_key = (record["CurrencyID"], accounting_date)
                        if curr_key in currency_quotes:
                            eur_rate_inv = currency_quotes[curr_key].numCcyqRateInv
                            if analytics.nummktcap:
                                record["InstrMktCapEur"] = analytics.nummktcap * eur_rate_inv
                            else:
                                record["InstrMktCapEur"] = None

                            # Set market cap tranche
                            mktcap_eur = record["InstrMktCapEur"]
                            if mktcap_eur is not None:
                                if mktcap_eur <= 300000000 and mktcap_eur > 0:
                                    record["InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_4_0-300M"
                                elif mktcap_eur <= 2500000000 and mktcap_eur > 300000000:
                                    record["InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_3_300M-2.5B"
                                elif mktcap_eur <= 10000000000 and mktcap_eur > 2500000000:
                                    record["InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_2_2.5B-10B"
                                elif mktcap_eur > 10000000000:
                                    record["InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_1_10B-MAX"
                                else:
                                    record["InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_OTHER"
                            else:
                                record["InstrMktCapEurTr1"] = "CR_DATA_MKTCAP1_OTHER"

                # STEP 2: Apply derivative-specific rating logic (matching SQL UPDATE statements)
                # Apply rating logic ONLY to specific derivative types (matching SQL logic exactly)
                # This matches the first UPDATE statement in the SQL procedure
                if record.get("strInstrumentTypeIRName3") in {
                    'CDS on Corporate', 'Future on bond', 'Listed Option on Bond', 'CDS on Index'
                }:
                    # Apply rating hierarchy: current -> instrument rating -> issuer rating
                    # where ratings come from underlying instruments (like in SQL)
                    instr = instruments.get(record["InstrumentDWHID"]) if 'instruments' in locals() else None
                    if instr and instr.numInstUndrlygID:
                        # Get underlying instrument ratings (matching SQL logic)
                        ul_inst_rating = ratings_records.get(instr.numInstUndrlygID)
                        ul_issuer_code = instruments.get(instr.numInstUndrlygID)
                        ul_issuer_rating = issuer_ratings.get(ul_issuer_code.strInstIssuerCode) if ul_issuer_code else None
                        
                        # Apply SQL COALESCE logic: h.field, instRat.field, issrRat.field
                        for field in ["strInstRtgSPStandardized", "strInstRtgMDStandardized", "strInstRtgFHStandardized"] + [f"strInstRtgCustom{i}" for i in range(1, 14)]:
                            # Start with current value (h.field)
                            current_val = record.get(field)
                            if not current_val:
                                # Try underlying instrument rating (instRat.field)
                                if ul_inst_rating:
                                    underlying_val = getattr(ul_inst_rating, field, None)
                                    if underlying_val:
                                        record[field] = underlying_val
                                        continue
                                # Try underlying issuer rating (issrRat.field)
                                if ul_issuer_rating:
                                    issuer_field = field.replace("strInstRtg", "strIssuerRtg") if "Standardized" in field else field.replace("strInstRtg", "strIssuerRtg")
                                    issuer_val = getattr(ul_issuer_rating, issuer_field, None)
                                    if issuer_val:
                                        record[field] = issuer_val

                # Apply second-level rating logic for complex derivatives (matching second SQL UPDATE)
                elif record.get("strInstrumentTypeIRName3") in {
                    "Listed Option On Future On Bond", "Listed Option On Future On Index", 
                    "Listed Option On Future On Stock", "OTC Option On Future On Bond",
                    "OTC Option On Future On Index", "OTC Option On Future On Stock"
                }:
                    instr = instruments.get(record["InstrumentDWHID"]) if 'instruments' in locals() else None
                    if instr and instr.numInstUndrlygID:
                        # Get first-level underlying
                        ul1 = instruments.get(instr.numInstUndrlygID)
                        if ul1 and ul1.numInstUndrlygID:
                            # Get second-level underlying
                            ul2 = level2_instruments.get(ul1.numInstUndrlygID) if 'level2_instruments' in locals() else None
                            
                            # Apply extended COALESCE logic with second-level underlyings
                            ul1_inst_rating = ratings_records.get(ul1.numInstID)
                            ul1_issuer_rating = issuer_ratings.get(ul1.strInstIssuerCode)
                            ul2_inst_rating = ratings_records.get(ul2.numInstID) if ul2 else None
                            ul2_issuer_rating = issuer_ratings.get(ul2.strInstIssuerCode) if ul2 else None
                            
                            for field in ["strInstRtgSPStandardized", "strInstRtgMDStandardized", "strInstRtgFHStandardized"] + [f"strInstRtgCustom{i}" for i in range(1, 14)]:
                                current_val = record.get(field)
                                if not current_val:
                                    # Try level-1 instrument rating
                                    if ul1_inst_rating:
                                        val = getattr(ul1_inst_rating, field, None)
                                        if val:
                                            record[field] = val
                                            continue
                                    # Try level-1 issuer rating
                                    if ul1_issuer_rating:
                                        issuer_field = field.replace("strInstRtg", "strIssuerRtg") if "Standardized" in field else field.replace("strInstRtg", "strIssuerRtg")
                                        val = getattr(ul1_issuer_rating, issuer_field, None)
                                        if val:
                                            record[field] = val
                                            continue
                                    # Try level-2 instrument rating
                                    if ul2_inst_rating:
                                        val = getattr(ul2_inst_rating, field, None)
                                        if val:
                                            record[field] = val
                                            continue
                                    # Try level-2 issuer rating
                                    if ul2_issuer_rating:
                                        issuer_field = field.replace("strInstRtg", "strIssuerRtg") if "Standardized" in field else field.replace("strInstRtg", "strIssuerRtg")
                                        val = getattr(ul2_issuer_rating, issuer_field, None)
                                        if val:
                                            record[field] = val

                # Update country of risk if override exists
                if inst_id in country_risk_map:
                    record["strInstRiskCountryLabel"] = country_risk_map[inst_id]

                # Special case for derivatives - update sector classifications
                if (
                    (upper_name_9 := (record.get("strInstrumentTypeIRName9", "") or "").upper())
                    == "CASH"
                    or "DERIVATIVES" in upper_name_9
                    or upper_name_9 == "IRS"
                ):
                    conditions_met = (
                        record.get("strInstrumentTypeIRName3")
                        and "BOND"
                        not in (
                            upper_name_3 := (
                                record.get("strInstrumentTypeIRName3", "") or ""
                            ).upper()
                        )
                        and "STOCK" not in upper_name_3
                        and "WARRANT" not in upper_name_3
                        and "CDS" not in upper_name_3
                        and "CORPORATE" not in upper_name_3
                    )

                    if conditions_met:
                        sector_value = "Cash" if upper_name_9 == "CASH" else "Derivatives"
                        record.update(
                            {
                                "InstrSectorBBLevel1": sector_value,
                                "InstrSectorBBLevel2": sector_value,
                                "InstrSectorBBLevel3": sector_value,
                                "InstrSectorLHLevel1": sector_value,
                                "InstrSectorLHLevel2": sector_value,
                                "InstrSectorLHLevel3": sector_value,
                                "InstrSectorMSCILevel1": sector_value,
                                "InstrSectorMSCILevel2": sector_value,
                                "InstrSectorMSCILevel3": sector_value,
                                "InstrSectorICBLevel1": sector_value,
                                "InstrSectorICBLevel2": sector_value,
                                "InstrSectorICBLevel3": sector_value,
                            }
                        )

                for k, v in record.items():
                    if isinstance(v, decimal.Decimal):
                        record[k] = float(v)
                    if (isinstance(v, str) and v.strip() == "") or pd.isna(v):
                        record[k] = None
        print(f"Inserting records forbatch {idx} ({bm_id}, {accounting_date})")
        session.bulk_insert_mappings(DMIRAPIBenchHolding, results)

        session.commit()
        return len(results)

    except Exception as e:
        print(f"Error processing batch: {str(e)}")
        if retry > 0:
            return _process_benchmark_batch(idx, benchmark, audit_id, retry=retry - 1)
    finally:
        safe_close(session)


@monitor_mem()
def process_api_bench_holding(scope_df, audit_id):
    if scope_df.empty:
        print("No benchmarks to process, scope is empty")
        count = 0
    else:

        benchmark_groups = scope_df.groupby(["numBenchFBAId", "datMarketDate"])
        benchmarks = [
            {"numBenchFBAId": bm_id, "datMarketDate": accounting_date}
            for (bm_id, accounting_date), _ in benchmark_groups
        ]

        session = get_session()

        # Process batches in parallel
        count = 0

        with concurrent.futures.ProcessPoolExecutor(max_workers=48) as executor:
            future_to_batch = {
                executor.submit(
                    _process_benchmark_batch,
                    i,
                    benchmark,
                    audit_id,
                ): i
                for i, benchmark in enumerate(benchmarks)
            }

            for future in concurrent.futures.as_completed(future_to_batch):
                try:
                    row_count_for_batch = future.result()

                    if row_count_for_batch is not None:
                        count += row_count_for_batch

                        print(
                            f"Batch {future_to_batch[future]} returns {row_count_for_batch} records. Total count {count} "
                        )
                        print(
                            f"Completed batch {future_to_batch[future]} with {row_count_for_batch} records. Total: {count}"
                        )
                except Exception as exc:
                    batch_idx = future_to_batch[future]
                    print(f"Batch {batch_idx} generated an exception: {exc}")

    # Clean up old records
    old_date = datetime.now() - relativedelta(months=36)
    try:
        session = get_session()
        result = (
            session.query(DMIRAPIBenchHolding)
            .filter(DMIRAPIBenchHolding.Accountingdate < old_date)
            .delete(synchronize_session=False)
        )
        print(f"Cleaned up {result} old records")
        session.commit()
    finally:
        safe_close(session)

    return pd.DataFrame([count], columns=["count"])
