# Preload hold values into a dict
hold_value_by_key = {
    (
        row.datLastNAVDate,
        row.strInvestedInPortfID,
        row.strPortfLevelID,
        row.strReportPeriod,
    ): row.numHoldValuInPortfCur
    for row in session.query(all_hedging).all()
}


for row in update_monitoring_all_hedging:
    key = (
        row.datLastNAVDate,
        row.strInvestedInPortfID,
        row.strPortfLevelID,
        row.strReportPeriod,
    )
    if key in hold_value_by_key:
        row.numInvestedInPortfAUM = hold_value_by_key[key]

session.commit()
