from concurrent.futures import ProcessPoolExecutor, as_completed
import pandas as pd

# Map model labels -> classes (so workers can re-import safely)
MODEL_MAP = {
    "SB_BB": SB_BB,
    "SB_LH": SB_LH,
    "SB_MSCI": SB_MSCI,
    "SB_ICB": SB_ICB,
}

# ---- worker (top-level) ----
def _fetch_sector_worker(model_label: str, key_prefix: str, inst_alds_chunk):
    # model_label: "SB_BB" | "SB_LH" | "SB_MSCI" | "SB_ICB"
    # key_prefix:  e.g. "InstrSectorBBLevel" (will produce ...1, ...2, ...3)
    print(f"[worker] {model_label}: fetching {len(inst_alds_chunk)} instruments")
    session = get_session()
    try:
        Model = MODEL_MAP[model_label]
        rows = (
            session.query(Model)
            .filter(Model.strInstAladdin.in_(list(inst_alds_chunk)))
            .all()
        )
        out = []
        for r in rows:
            out.append({
                "strInstAladdin": r.strInstAladdin,
                f"{key_prefix}1": getattr(r, "strInstSectorL1", None) or getattr(r, "strIssSector1Label", None),
                f"{key_prefix}2": getattr(r, "strInstSectorL2", None) or getattr(r, "strIssSector2Label", None),
                f"{key_prefix}3": getattr(r, "strInstSectorL3", None) or getattr(r, "strIssSector3Label", None),
            })
        print(f"[worker] {model_label}: done {len(out)} rows")
        return model_label, out
    finally:
        session.close()

# ---- launcher ----
def fetch_sectors_parallel(inst_alds, chunk_size=2000, max_workers=8):
    """
    Parallel fetch for sector tables (BB/LH/MSCI/ICB).
    Returns four DataFrames: df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb
    """
    model_jobs = [
        ("SB_BB",   "InstrSectorBBLevel"),
        ("SB_LH",   "InstrSectorBarclaysLevel"),
        ("SB_MSCI", "InstrSectorMSCILevel"),
        ("SB_ICB",  "InstrSectorICBLevel"),
    ]

    print(f"Launching sector fetch in parallel for {len(inst_alds)} instruments")
    get_hardware_info()

    # submit all (model x chunk) jobs
    futures = []
    with ProcessPoolExecutor(max_workers=max_workers) as ex:
        for model_label, key_prefix in model_jobs:
            for inst_alds_chunk in chunker(list(inst_alds), chunk_size):
                futures.append(ex.submit(_fetch_sector_worker, model_label, key_prefix, inst_alds_chunk))

        # collect
        buckets = {m[0]: [] for m in model_jobs}
        for fut in as_completed(futures):
            model_label, rows = fut.result()   # raise on error
            buckets[model_label].extend(rows)
            total = sum(len(v) for v in buckets.values())
            print(f"Sectors fetched so far: {total}")
            get_hardware_info()

    # build DataFrames
    df_sb_bb   = pd.DataFrame(buckets["SB_BB"])   if buckets["SB_BB"]   else pd.DataFrame(columns=["strInstAladdin","InstrSectorBBLevel1","InstrSectorBBLevel2","InstrSectorBBLevel3"])
    df_sb_lh   = pd.DataFrame(buckets["SB_LH"])   if buckets["SB_LH"]   else pd.DataFrame(columns=["strInstAladdin","InstrSectorBarclaysLevel1","InstrSectorBarclaysLevel2","InstrSectorBarclaysLevel3"])
    df_sb_msci = pd.DataFrame(buckets["SB_MSCI"]) if buckets["SB_MSCI"] else pd.DataFrame(columns=["strInstAladdin","InstrSectorMSCILevel1","InstrSectorMSCILevel2","InstrSectorMSCILevel3"])
    df_sb_icb  = pd.DataFrame(buckets["SB_ICB"])  if buckets["SB_ICB"]  else pd.DataFrame(columns=["strInstAladdin","InstrSectorICBLevel1","InstrSectorICBLevel2","InstrSectorICBLevel3"])

    print("Sector parallel fetch complete")
    get_hardware_info()
    return df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb


# Old:
# df_sb_bb   = _sb_df(SB_BB,   "InstrSectorBBLevel")
# df_sb_lh   = _sb_df(SB_LH,   "InstrSectorBarclaysLevel")
# df_sb_msci = _sb_df(SB_MSCI, "InstrSectorMSCILevel")
# df_sb_icb  = _sb_df(SB_ICB,  "InstrSectorICBLevel")

# New:
df_sb_bb, df_sb_lh, df_sb_msci, df_sb_icb = fetch_sectors_parallel(inst_alds, chunk_size=2000, max_workers=8)
