      , CASE WHEN ISNULL(a.strCoreAssetClaLvl3LblBbl,@dflt_string)=ISNULL(b.strCoreAssetClaLvl3LblBbl,@dflt_string) THEN 0 ELSE 1 END AS valid_strCoreAssetClaLvl3LblBbl
      , CASE WHEN ISNULL(a.strCoreAssetClaLvl4LblBbl,@dflt_string)=ISNULL(b.strCoreAssetClaLvl4LblBbl,@dflt_string) THEN 0 ELSE 1 END AS valid_strCoreAssetClaLvl4LblBbl
      , CASE WHEN ISNULL(a.InstrMktCapEur    ,@dflt_float) = ISNULL(b.InstrMktCapEur    ,@dflt_float)      THEN 0 ELSE 1 END AS valid_InstrMktCapEur
      , CASE WHEN ISNULL(a.InstrMktCapEurTr1 ,@dflt_string)= ISNULL(b.InstrMktCapEurTr1 ,@dflt_string)     THEN 0 ELSE 1 END AS valid_InstrMktCapEurTr1
      , CASE WHEN ISNULL(a.strInstRiskCountryLabel,@dflt_string)=ISNULL(b.strInstRiskCountryLabel,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstRiskCountryLabel
      , CASE WHEN ISNULL(a.InstrOAS          ,@dflt_float) = ISNULL(b.InstrOAS          ,@dflt_float)      THEN 0 ELSE 1 END AS valid_InstrOAS
      , CASE WHEN ISNULL(a.instrTypCd        ,@dflt_string)= ISNULL(b.instrTypCd        ,@dflt_string)     THEN 0 ELSE 1 END AS valid_instrTypCd
      , CASE WHEN ISNULL(a.FNFHOrGNMA        ,@dflt_string)= ISNULL(b.FNFHOrGNMA        ,@dflt_string)     THEN 0 ELSE 1 END AS valid_FNFHOrGNMA
      , CASE WHEN ISNULL(a.strInstrumentTypeName8,@dflt_string)=ISNULL(b.strInstrumentTypeName8,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeName8
      , CASE WHEN ISNULL(a.strInstrumentTypeIRName8,@dflt_string)=ISNULL(b.strInstrumentTypeIRName8,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeIRName8
      , CASE WHEN ISNULL(a.strInstrumentTypeName9,@dflt_string)=ISNULL(b.strInstrumentTypeName9,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeName9
      , CASE WHEN ISNULL(a.strInstrumentTypeIRName9,@dflt_string)=ISNULL(b.strInstrumentTypeIRName9,@dflt_string) THEN 0 ELSE 1 END AS valid_strInstrumentTypeIRName9
/* ───────────────────────────────────────────────────────────────
   NOTE: The table contains many columns; all remaining columns
   follow the same ISNULL-wrapped pattern.  For brevity the rest
   of the list is omitted here, but continue in the same style.
   ─────────────────────────────────────────────────────────────── */

FROM   DMIR.tblDMIRAPIBenchHolding a
JOIN   DMIR.tblDMIRAPIBenchHolding b
       ON  ISNULL(a.Accountingdate   ,@dflt_date ) = ISNULL(b.Accountingdate   ,@dflt_date )
       AND ISNULL(a.BenchCode        ,@dflt_string) = ISNULL(b.BenchCode        ,@dflt_string)
       AND ISNULL(a.InstrumentDWHID  ,@dflt_int  ) = ISNULL(b.InstrumentDWHID  ,@dflt_int  )

WHERE  a.Accountingdate = @accounting_date
  AND  a.BenchCode      = @bench_code;
